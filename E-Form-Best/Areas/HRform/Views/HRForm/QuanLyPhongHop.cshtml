@{
    ViewData["Title"] = "Quản lý Phòng Họp";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";
}

@* Token bảo mật để gửi kèm các yêu cầu POST *@
@Html.AntiForgeryToken()

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap');

    body {
        background-color: #f1f5f9;
    }

    .stat-card {
        transition: 0.3s;
        cursor: pointer;
        border: none;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
        }

    .nav-tabs {
        border-bottom: 2px solid #e2e8f0;
    }

        .nav-tabs .nav-link {
            border: none;
            color: #64748b;
            font-weight: 700;
            padding: 14px 24px;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            transition: 0.3s;
        }

            .nav-tabs .nav-link.active {
                color: #1e40af;
                background: transparent;
                border-bottom: 3px solid #1e40af;
            }

    /* Table Desktop Style */
    .table-modern {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-modern thead th {
            background: #f8fafc;
            color: #475569;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            padding: 15px 20px;
            border-bottom: 2px solid #e2e8f0;
            white-space: nowrap;
        }

        .table-modern tbody td {
            padding: 15px 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            background: #fff;
        }

    .sub-badge {
        font-size: 10px;
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 800;
        border: 1.5px solid;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    /* Phân trang */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* Style Bộ Lọc Nâng Cao */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
    }

        .filter-input:focus {
            border-color: #1e40af;
            box-shadow: 0 0 0 2px rgba(30, 64, 175, 0.1);
        }

    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* ==========================================
               RESPONSIVE & CHỐNG VỠ FORM
               ========================================== */
    .container-fluid-custom {
        max-width: 1600px;
        margin: 0 auto;
        padding: 25px;
        font-family: 'Inter', sans-serif;
    }

    @@media (max-width: 1024px) {
        #quickSearch {
            width: 200px !important;
        }
    }

    @@media (max-width: 768px) {
        .mobile-top-bar {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 20px !important;
        }

        .mobile-controls {
            flex-direction: column !important;
            width: 100% !important;
        }

        .mobile-search-box {
            width: 100% !important;
        }

            .mobile-search-box input {
                width: 100% !important;
            }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }

        .mobile-stat-grid {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }

        .stat-card {
            padding: 15px !important;
        }

        .card-value {
            font-size: 22px !important;
        }

        .nav-tabs .nav-link {
            padding: 12px 15px;
            font-size: 11px;
        }
        /* Biến bảng thành dạng Card trên Mobile */
        .table-modern thead {
            display: none;
        }

        .table-modern, .table-modern tbody, .table-modern tr, .table-modern td {
            display: block;
            width: 100%;
        }

            .table-modern tr {
                margin-bottom: 15px;
                border: 1px solid #e2e8f0 !important;
                border-radius: 15px;
                overflow: hidden;
                background: #fff;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            }

            .table-modern td {
                text-align: right !important;
                padding: 12px 15px !important;
                border-bottom: 1px dashed #f1f5f9;
                position: relative;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                .table-modern td:last-child {
                    border-bottom: none;
                    background: #f8fafc;
                    justify-content: center;
                    padding: 15px !important;
                }
                /* Hiển thị label từ thuộc tính data-label */
                .table-modern td::before {
                    content: attr(data-label);
                    float: left;
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                }

        .mobile-val-container {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            max-width: 65%;
            text-align: right;
        }

        .pagination-container {
            flex-direction: column !important;
            gap: 15px;
            text-align: center !important;
        }

        #paginationButtons {
            justify-content: center;
        }
    }
</style>

<div class="container-fluid-custom">

    @* --- HIỂN THỊ THÔNG BÁO --- *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4" style="border-radius: 12px; background: #dcfce7; color: #166534; padding: 15px;">
            <i class="fa fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close float-end" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 12px; background: #fee2e2; color: #991b1b; padding: 15px;">
            <i class="fa fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close float-end" data-bs-dismiss="alert"></button>
        </div>
    }

    @* --- TOP BAR --- *@
    <div class="mobile-top-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 15px;">
        <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 26px; display: flex; align-items: center; gap: 12px;">
            <span style="background: #1e40af; color: white; width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(30, 64, 175, 0.3);">
                <i class="fa fa-building"></i>
            </span>
            PHÒNG HỌP
        </h2>

        <div class="mobile-controls" style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 15px; border-radius: 14px; border: 2px solid #cbd5e1;">
                <span style="font-size: 13px; font-weight: 700; color: #64748b;">Dòng:</span>
                <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #0f172a; cursor: pointer; background: transparent; font-size: 14px;">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
            <div class="mobile-search-box" style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="filterData()" placeholder="Tìm nhanh lịch đặt..."
                       style="padding: 12px 12px 12px 42px; border-radius: 14px; border: 2px solid #cbd5e1; font-size: 14px; width: 280px; outline: none; font-weight: 700; background: white;">
            </div>
            <div style="font-size: 11px; background: #1e40af; padding: 10px 18px; border-radius: 10px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">@ViewBag.UserRole</div>
        </div>
    </div>

    @* --- BỘ LỌC NÂNG CAO --- *@
    <div class="advanced-filter">
        <div class="filter-group">
            <label>Từ ngày</label>
            <input type="date" id="txtFromDate" class="filter-input" onchange="fetchAllData()" />
        </div>
        <div class="filter-group">
            <label>Đến ngày</label>
            <input type="date" id="txtToDate" class="filter-input" onchange="fetchAllData()" />
        </div>
        <div class="filter-group">
            <label>Phòng họp</label>
            <select id="selRoom" class="filter-input" onchange="filterData()">
                <option value="">-- Tất cả --</option>
            </select>
        </div>
        <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
            <button class="btn-clear-filter" onclick="clearAllFilters()">
                <i class="fa fa-refresh"></i> Làm mới
            </button>
        </div>
    </div>

    @* --- STATS ROW --- *@
    <div class="mobile-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
        <div class="stat-card" style="background: white; padding: 25px; border-radius: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; margin-bottom: 8px;">Tổng lượt đặt</div>
            <div id="statTotalBookings" class="card-value" style="font-size: 28px; font-weight: 1000; color: #1e293b;">0</div>
        </div>
        <div class="stat-card" style="background: #ecfdf5; padding: 25px; border-radius: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 2px solid #10b981;">
            <div style="font-size: 11px; font-weight: 900; color: #047857; text-transform: uppercase; margin-bottom: 8px;">Đang sử dụng</div>
            <div id="statRoomsOn" class="card-value" style="font-size: 28px; font-weight: 1000; color: #10b981;">0</div>
        </div>
        <div class="stat-card" style="background: #fef2f2; padding: 25px; border-radius: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 2px solid #ef4444;">
            <div style="font-size: 11px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 8px;">Phòng trống</div>
            <div id="statEmptyRooms" class="card-value" style="font-size: 28px; font-weight: 1000; color: #ef4444;">0</div>
        </div>
        <div class="stat-card" style="background: #eff6ff; padding: 25px; border-radius: 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 2px solid #1e40af;">
            <div style="font-size: 11px; font-weight: 900; color: #1e40af; text-transform: uppercase; margin-bottom: 8px;">Danh mục phòng</div>
            <div id="statTotalRooms" class="card-value" style="font-size: 28px; font-weight: 1000; color: #1e40af;">0</div>
        </div>
    </div>

    @* --- TABS & TABLE AREA --- *@
    <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <div style="padding: 10px 25px 0 25px; border-bottom: 1px solid #f1f5f9; background: #fff;">
            <ul class="nav nav-tabs border-bottom-0" id="roomTab" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">
                        <i class="fa fa-calendar-check-o me-2"></i> Lịch sử đặt phòng
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="category-tab" data-bs-toggle="tab" data-bs-target="#category" type="button" role="tab">
                        <i class="fa fa-list-alt me-2"></i> Danh mục & Cấu hình
                    </button>
                </li>
            </ul>
        </div>

        <div class="tab-content" id="roomTabContent">
            @* --- TAB 1: LỊCH ĐẶT PHÒNG --- *@
            <div class="tab-pane fade show active" id="history" role="tabpanel">
                <div class="table-responsive" style="overflow-x: auto;">
                    <table class="table-modern" id="dataTable">
                        <thead>
                            <tr>
                                <th style="width: 60px; text-align: center;">STT</th>
                                <th>Phòng & Công ty</th>
                                <th>Người đặt / Đối tác</th>
                                <th>Thời gian</th>
                                <th style="text-align: center;">Trạng thái</th>
                                <th style="text-align: right;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="bookingTableBody">
                            <tr><td colspan="6" style="text-align: center; padding: 40px; color: #94a3b8;"><i class="fa fa-spinner fa-spin fa-2x"></i></td></tr>
                        </tbody>
                    </table>
                </div>

                @* PHÂN TRANG *@
                <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; border-top: 1px solid #e2e8f0;">
                    <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
                    <div style="text-align: right; color: #64748b; font-size: 13px; font-weight: 700;">
                        Trang <span id="currentPageNum" style="color: #1e40af;">1</span> / <span id="totalPagesNum">1</span>
                    </div>
                </div>
            </div>

            @* --- TAB 2: DANH MỤC PHÒNG --- *@
            <div class="tab-pane fade" id="category" role="tabpanel" style="padding: 25px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
                    <h6 style="font-weight: 800; color: #475569; margin: 0; text-transform: uppercase; font-size: 13px;">Danh sách phòng họp gốc</h6>
                    <button type="button" class="btn" onclick="openRoomModal(0, '', '')"
                            style="background: #1e40af; color: white; font-weight: 800; border-radius: 12px; font-size: 12px; padding: 10px 24px; min-width: 180px;">
                        <i class="fa fa-plus me-2"></i> THÊM PHÒNG MỚI
                    </button>
                </div>
                <div class="table-responsive" style="overflow-x: auto;">
                    <table class="table-modern" id="categoryTable">
                        <thead>
                            <tr>
                                <th style="width: 80px; text-align: center;">ID</th>
                                <th>Tên Phòng Họp</th>
                                <th>Ghi Chú & Mô tả</th>
                                <th style="text-align: right;">Hành động</th>
                            </tr>
                        </thead>
                        <tbody id="roomTableBody">
                            <tr><td colspan="4" style="text-align: center; padding: 40px; color: #94a3b8;"><i class="fa fa-spinner fa-spin fa-2x"></i></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- MODAL THÊM/SỬA PHÒNG --- *@
<div class="modal fade" id="modalRoom" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/FormHR/LuuPhongHop" method="post" style="width: 100%;">
            @Html.AntiForgeryToken()
            <div class="modal-content" style="border-radius: 24px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
                <div class="modal-header" style="border-bottom: 1px solid #f1f5f9; padding: 25px;">
                    <h5 class="modal-title" id="roomModalTitle" style="font-weight: 1000; color: #1e40af; font-size: 20px;">Thông tin phòng họp</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding: 30px;">
                    <input type="hidden" name="Id" id="room_id" />
                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 800; color: #475569; font-size: 13px; text-transform: uppercase;">Tên phòng họp *</label>
                        <input type="text" name="TenPhongHop" id="room_name" class="form-control" required style="border-radius: 14px; padding: 14px; border: 2px solid #e2e8f0; font-weight: 700;">
                    </div>
                    <div class="mb-2">
                        <label class="form-label" style="font-weight: 800; color: #475569; font-size: 13px; text-transform: uppercase;">Ghi chú / Vị trí</label>
                        <textarea name="GhiChu" id="room_note" class="form-control" rows="3" style="border-radius: 14px; padding: 14px; border: 2px solid #e2e8f0; font-weight: 700; resize: none;"></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="padding: 20px 30px;">
                    <button type="button" class="btn text-secondary fw-bold" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold" style="border-radius: 14px; background: #1e40af; border: none;">LƯU DỮ LIỆU</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let roomModal;
        let masterRooms = [];
        let masterBookings = [];
        let filteredBookings = [];

        let currentPage = 1;
        let rowsPerPage = 20;

        document.addEventListener('DOMContentLoaded', async function() {
        const modalEl = document.getElementById('modalRoom');
        if (modalEl) roomModal = new bootstrap.Modal(modalEl);

        // --- Phục hồi trạng thái bộ lọc ---
        const savedText = sessionStorage.getItem("savedRoomSearchText");
        if (savedText) document.getElementById("quickSearch").value = savedText;

        const savedFrom = sessionStorage.getItem("savedRoomFromDate");
        if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

        const savedTo = sessionStorage.getItem("savedRoomToDate");
        if (savedTo) document.getElementById("txtToDate").value = savedTo;

        await fetchAllData();

        // Phục hồi Combobox Phòng họp sau khi đổ dữ liệu Master
        const savedRoom = sessionStorage.getItem("savedRoomFilter");
        if (savedRoom) document.getElementById("selRoom").value = savedRoom;

        filterData();
        });

        function populateDropdowns() {
        const selRoom = document.getElementById("selRoom");
        const rooms = [...new Set(masterRooms.map(x => x.tenPhongHop))].sort();

        const curVal = selRoom.value;
        selRoom.innerHTML = '<option value="">-- Tất cả --</option>';
        rooms.forEach(r => {
        selRoom.innerHTML += `<option value="${r}">${r}</option>`;
        });
        if (curVal && rooms.includes(curVal)) {
        selRoom.value = curVal;
        }
        }

        async function fetchAllData() {
        // Lấy thời gian để filter Database ngay tại Server
        const fromDate = document.getElementById("txtFromDate").value;
        const toDate = document.getElementById("txtToDate").value;

        sessionStorage.setItem("savedRoomFromDate", fromDate);
        sessionStorage.setItem("savedRoomToDate", toDate);

        const url = `/FormHR/GetPhongHopData?fromDate=${fromDate}&toDate=${toDate}`;

        try {
        const response = await fetch(url);
        const data = await response.json();

        masterRooms = data.danhMucPhong || [];
        masterBookings = data.lichDatPhong || [];

        populateDropdowns();
        updateStats();
        filterData();
        } catch (e) {
        console.error(e);
        }
        }

        function clearAllFilters() {
        document.getElementById("quickSearch").value = "";
        document.getElementById("txtFromDate").value = "";
        document.getElementById("txtToDate").value = "";
        document.getElementById("selRoom").value = "";

        sessionStorage.removeItem("savedRoomSearchText");
        sessionStorage.removeItem("savedRoomFromDate");
        sessionStorage.removeItem("savedRoomToDate");
        sessionStorage.removeItem("savedRoomFilter");

        fetchAllData();
        }

        function updateStats() {
        const total = masterBookings.length;
        const onCount = masterBookings.filter(x => x.trangThaiPhong === 'on').length;

        document.getElementById('statTotalBookings').innerText = total;
        document.getElementById('statRoomsOn').innerText = onCount;
        document.getElementById('statEmptyRooms').innerText = Math.max(0, masterRooms.length - onCount);
        document.getElementById('statTotalRooms').innerText = masterRooms.length;
        }

        function filterData() {
        const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();
        const roomFilter = document.getElementById("selRoom").value;

        sessionStorage.setItem("savedRoomSearchText", searchText);
        sessionStorage.setItem("savedRoomFilter", roomFilter);

        filteredBookings = masterBookings.filter(item => {
        const str = `${item.tenPhongHop} ${item.tenCongTy} ${item.nguoiBook} ${item.tenCongTyKhach}`.toUpperCase();
        const matchText = searchText === "" || str.includes(searchText);
        const matchRoom = roomFilter === "" || item.tenPhongHop === roomFilter;

        return matchText && matchRoom;
        });

        renderRooms(searchText); // Cập nhật lại Bảng Danh Mục
        currentPage = 1;
        paginateBookings();
        }

        function changePageSize() {
        rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
        currentPage = 1;
        paginateBookings();
        }

        function paginateBookings() {
        const totalItems = filteredBookings.length;
        const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
        if (currentPage > totalPages) currentPage = totalPages;

        document.getElementById("currentPageNum").innerText = currentPage;
        document.getElementById("totalPagesNum").innerText = totalPages;

        const startIndex = (currentPage - 1) * rowsPerPage;
        const endIndex = startIndex + rowsPerPage;
        const pageData = filteredBookings.slice(startIndex, endIndex);

        renderBookings(pageData, startIndex);
        renderPaginationButtons(totalPages);
        }

        function renderBookings(pageData, startIndex) {
        const tbody = document.getElementById("bookingTableBody");
        tbody.innerHTML = "";

        if (pageData.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" style="text-align: center; padding: 40px; color: #94a3b8; display: block; width: 100%;">Không tìm thấy lịch đặt nào phù hợp.</td></tr>`;
        return;
        }

        let html = "";
        pageData.forEach((item, index) => {
        let statusHtml = "";
        let actionBtn = "";

        if (item.trangThaiPhong === "on") {
        statusHtml = `<span class="sub-badge" style="background: #ecfdf5; color: #047857; border-color: #10b981;"><i class="fa fa-play-circle"></i> ĐANG SỬ DỤNG</span>`;
        actionBtn = `<button type="button" class="btn btn-sm btn-danger w-100" onclick="updateStatus(${item.id}, 'off')" style="font-weight: 800; font-size: 11px; padding: 7px 15px; border-radius: 8px;">Trả phòng</button>`;
        } else {
        statusHtml = `<span class="sub-badge" style="background: #f8fafc; color: #64748b; border-color: #cbd5e1;"><i class="fa fa-stop-circle"></i> TRỐNG</span>`;
        actionBtn = `<button type="button" class="btn btn-sm btn-success w-100" onclick="updateStatus(${item.id}, 'on')" style="font-weight: 800; font-size: 11px; padding: 7px 15px; border-radius: 8px;">Bật 'ON'</button>`;
        }

        html += `
        <tr>
        <td data-label="STT" style="text-align: center; font-weight: 800; color: #94a3b8;">${startIndex + index + 1}</td>
        <td data-label="Phòng & Công ty">
        <div class="mobile-val-container">
        <div style="font-weight: 1000; color: #1e40af; font-size: 15px;">${item.tenPhongHop}</div>
        <div style="font-size: 11px; color: #64748b; font-weight: 700; text-transform: uppercase;">${item.tenCongTy}</div>
        </div>
        </td>
        <td data-label="Người đặt / Đối tác">
        <div class="mobile-val-container">
        <div style="font-weight: 800; color: #0f172a; font-size: 14px;">${item.nguoiBook}</div>
        <div style="font-size: 11px; color: #64748b; font-weight: 600;">Khách: ${item.tenCongTyKhach}</div>
        </div>
        </td>
        <td data-label="Thời gian">
        <div class="mobile-val-container">
        <div style="font-size: 12px; font-weight: 800; color: #15803d;"><i class="fa fa-sign-in"></i> ${item.thoiGianBatDau}</div>
        <div style="font-size: 12px; font-weight: 800; color: #dc2626;"><i class="fa fa-sign-out"></i> ${item.thoiGianKetThuc}</div>
        </div>
        </td>
        <td data-label="Trạng thái" style="text-align: center;">
        <div class="mobile-val-container">${statusHtml}</div>
        </td>
        <td style="text-align: right;">
        <div style="display: flex; gap: 5px; justify-content: flex-end;">
        ${actionBtn}
        <a href="/FormHR/ChiTiet/${item.idFormHr}" class="btn btn-sm btn-light border" style="padding: 7px 15px; border-radius: 8px;"><i class="fa fa-eye"></i></a>
        </div>
        </td>
        </tr>
        `;
        });
        tbody.innerHTML = html;
        }

        function renderRooms(filter) {
        const tbody = document.getElementById("roomTableBody");
        tbody.innerHTML = "";

        const filteredRooms = masterRooms.filter(x => {
        const str = `${x.tenPhongHop} ${x.ghiChu}`.toUpperCase();
        return str.includes(filter);
        });

        if (filteredRooms.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; padding: 40px; color: #94a3b8; display: block; width: 100%;">Không tìm thấy phòng nào trong danh mục.</td></tr>`;
        return;
        }

        let html = "";
        filteredRooms.forEach(p => {
        html += `
        <tr>
        <td data-label="ID" style="text-align: center; font-weight: 800; color: #94a3b8;">#${p.id}</td>
        <td data-label="Tên Phòng">
        <div class="mobile-val-container" style="font-weight: 1000; color: #1e40af; font-size: 15px;">${p.tenPhongHop}</div>
        </td>
        <td data-label="Ghi chú">
        <div class="mobile-val-container" style="color: #64748b; font-size: 13px; font-weight: 600;">${p.ghiChu}</div>
        </td>
        <td style="text-align: right;">
        <div style="display: flex; gap: 5px; justify-content: flex-end;">
        <button type="button" class="btn btn-sm" onclick="openRoomModal(${p.id}, '${p.tenPhongHop}', '${p.ghiChu}')" style="color: #b45309; background: #fffbeb; border: 1px solid #fed7aa; border-radius: 8px; padding: 7px 15px;"><i class="fa fa-edit"></i></button>
        <button type="button" class="btn btn-sm" onclick="deleteRoom(${p.id})" style="color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 7px 15px;"><i class="fa fa-trash"></i></button>
        </div>
        </td>
        </tr>
        `;
        });
        tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
        const container = document.getElementById("paginationButtons");
        container.innerHTML = "";
        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
        if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
        if (i === 3 || i === totalPages - 2) {
        const dot = document.createElement("span");
        dot.innerText = "...";
        dot.style.padding = "8px"; dot.style.color = "#64748b";
        container.appendChild(dot);
        }
        continue;
        }
        const btn = document.createElement("button");
        btn.innerText = i;
        btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
        btn.onclick = () => {
        currentPage = i;
        paginateBookings();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        };
        container.appendChild(btn);
        }
        }

        function openRoomModal(id, name, note) {
        document.getElementById('room_id').value = id;
        document.getElementById('room_name').value = name;
        document.getElementById('room_note').value = note;
        document.getElementById('roomModalTitle').innerText = id === 0 ? "Thêm phòng họp mới" : "Chỉnh sửa thông tin phòng";
        if (roomModal) roomModal.show();
        }

        function updateStatus(id, status) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        Swal.fire({
        title: 'Xác nhận?',
        text: status === 'on' ? "Kích hoạt ĐANG SỬ DỤNG" : "Trả phòng/Tắt trạng thái ON",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#1e40af',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Đồng ý',
        cancelButtonText: 'Bỏ qua'
        }).then((result) => {
        if (result.isConfirmed) {
        const formData = new FormData();
        formData.append('id', id);
        formData.append('status', status);
        formData.append('__RequestVerificationToken', token);

        fetch('/FormHR/UpdateTrangThaiPhong', { method: 'POST', body: formData })
        .then(response => response.json())
        .then(res => {
        if (res.success) fetchAllData();
        else Swal.fire('Lỗi!', res.message, 'error');
        });
        }
        });
        }

        function deleteRoom(id) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        Swal.fire({
        title: 'Xóa phòng này?',
        text: "Dữ liệu sẽ bị xóa khỏi danh mục gốc!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Xóa ngay',
        cancelButtonText: 'Bỏ qua'
        }).then((result) => {
        if (result.isConfirmed) {
        const formData = new FormData();
        formData.append('id', id);
        formData.append('__RequestVerificationToken', token);

        fetch('/FormHR/XoaPhongHop', { method: 'POST', body: formData })
        .then(response => response.json())
        .then(res => {
        if (res.success) fetchAllData();
        else Swal.fire('Lỗi!', res.message, 'error');
        });
        }
        });
        }

        setInterval(function () {
        const historyTab = document.getElementById('history-tab');
        if(historyTab && historyTab.classList.contains('active')) fetchAllData();
        }, 300000);
    </script>
}