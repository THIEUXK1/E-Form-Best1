@{
    ViewData["Title"] = "HR Logo";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";
}

<div style="
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 85vh;
    background: radial-gradient(circle at top left, #fdfbfb 0%, #ebedee 100%);
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
">
    <div style="
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        padding: 60px 50px;
        border-radius: 40px;
        box-shadow: 20px 20px 60px #d9d9d9, -20px -20px 60px #ffffff;
        text-align: center;
        max-width: 550px;
        border: 1px solid rgba(255, 255, 255, 0.8);
        position: relative;
    ">

        <div style="
            position: absolute;
            top: -15px;
            right: -15px;
            width: 50px;
            height: 50px;
            background: #4facfe;
            border-radius: 50%;
            opacity: 0.1;
        "></div>

        <div style="
            width: 110px;
            height: 110px;
            margin: 0 auto 30px;
            border-radius: 30px;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 42px;
            color: #fff;
            font-weight: 900;
            box-shadow: 0 15px 35px rgba(30, 60, 114, 0.3);
            transform: rotate(-5deg);
        ">
            HR
        </div>

        <div style="letter-spacing: 4px; color: #1e3c72; font-weight: 800; font-size: 0.85rem; margin-bottom: 10px; text-transform: uppercase;">
            Digital Transformation
        </div>

        <h1 style="
            margin: 0;
            font-size: 3rem;
            background: linear-gradient(to right, #1e3c72, #2a5298);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 850;
        ">
            HR FORM
        </h1>

        <div style="
            width: 60px;
            height: 4px;
            background: #4facfe;
            margin: 20px auto;
            border-radius: 2px;
        "></div>

        <p style="
            margin: 0 0 25px;
            font-size: 1.2rem;
            color: #334e68;
            font-weight: 600;
        ">
            Hành Chính – Nhân Sự
        </p>

        <div style="
            background: #f8fafc;
            padding: 25px;
            border-radius: 20px;
            border: 1px solid #e2e8f0;
        ">
            <p style="
                font-size: 1rem;
                color: #627d98;
                line-height: 1.8;
                margin: 0;
                font-style: italic;
            ">
                "Nền tảng quản lý quy trình hành chính nhân sự,
                tiếp nhận – xử lý – theo dõi các yêu cầu nội bộ
                một cách <span style="color:#2a5298; font-weight:bold;">nhanh chóng</span> và <span style="color:#2a5298; font-weight:bold;">minh bạch</span>."
            </p>
        </div>

        <div style="margin-top: 35px; font-size: 0.8rem; color: #bcccdc;">
            &copy; 2025 E-Form Best. All rights reserved.
        </div>
    </div>
</div>