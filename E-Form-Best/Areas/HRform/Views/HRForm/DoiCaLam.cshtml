@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký Đổi ca làm việc";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- CHUYỂN ĐỔI TỪ SESSION SANG COOKIE CLAIMS (CK) ---
    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? ""; // Đảm bảo lúc Login bạn đã lưu Claim tên "PhongBan"
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? ""; // Hoặc ClaimTypes.NameIdentifier tùy cách bạn lưu mã NV
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // Toolkit Style: Tông màu Amber/Orange cho sự thay đổi (Change/Schedule)
    string primaryColor = "#f59e0b"; // Amber 500
    string darkColor = "#92400e";
    string lightBg = "#fffbeb";

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid #fde68a; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: #451a03;";
    string labelStyle = "font-weight: 800; color: #92400e; font-size: 11px; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 1px;";
    string boxStyle = $"background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #fef3c7; margin-bottom: 25px; box-shadow: 0 10px 15px -3px rgba(245, 158, 11, 0.05);";
}

<div style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); padding: 50px 15px; min-height: 100vh; font-family: 'Inter', sans-serif;">

    <form id="doiCaForm" method="post" enctype="multipart/form-data" action="/FormHR/DoiCaLam"
          style="max-width: 850px; margin: 0 auto; background: #ffffff; border-radius: 35px; box-shadow: 0 25px 50px -12px rgba(146, 64, 14, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); padding: 45px 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 20px; right: 30px; font-size: 10px; opacity: 0.8; font-weight: 700; letter-spacing: 2px;">E-FORM HR SERVICES</div>
            <h2 style="margin: 0; font-size: 26px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px;">Đăng ký Đổi ca làm việc</h2>
            <div style="margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; background: rgba(255,255,255,0.2); border-radius: 100px; font-size: 13px; backdrop-filter: blur(4px);">
                <span>📅 Ngày tạo đơn:</span>
                <span style="font-weight: 800;">@ngayHienThi</span>
            </div>
        </div>

        <div style="padding: 40px;">

            @* --- THÔNG TIN NHÂN VIÊN (Lấy từ CK) --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: #92400e; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-id-card" style="font-size: 18px; color: #f59e0b;"></i> Thông tin nhân viên
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                    <div><label style="@labelStyle">Họ tên</label><input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #fffcf0;"></div>
                    <div><label style="@labelStyle">Bộ phận</label><input name="PhanBo" value="@phongBan" readonly style="@inputStyle; background: #fffcf0;"></div>
                    <div><label style="@labelStyle">Mã NV / Email</label><input value="@soNhanVien" readonly style="@inputStyle; background: #fffcf0;"></div>
                </div>
            </div>

            @* --- NỘI DUNG ĐỔI CA & MINH CHỨNG --- *@
            <div style="@boxStyle">
                <h3 style="color: #92400e; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 25px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-calendar-check-o" style="font-size: 18px; color: #f59e0b;"></i> Chi tiết lịch đổi ca
                </h3>

                @* VÙNG DÁN ẢNH: CHỤP LỊCH ĐỔI CA *@
                <div style="margin-bottom: 25px;">
                    <label style="@labelStyle">Ảnh minh chứng: Lịch đổi ca / Tin nhắn xác nhận (Ctrl+V)</label>
                    <div id="paste_AnhDoiCa" tabindex="0" class="paste-zone"
                         style="width: 100%; border: 2.5px dashed #f59e0b; height: 250px; border-radius: 18px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fffbeb; color: #92400e; cursor: pointer; transition: 0.3s; gap: 10px; outline: none;">
                        <i class="fa fa-camera" style="font-size: 35px;"></i>
                        <span style="font-size: 11px; font-weight: 700; text-align:center; padding: 0 20px;">
                            Click vào đây rồi nhấn <b>Ctrl+V</b> để dán ảnh chụp lịch đổi ca hoặc phiếu xác nhận tay
                        </span>
                    </div>
                    @* Khớp với thuộc tính Anh trong CtDoiCaLam8 *@
                    <input type="file" id="Anh" name="Anh" hidden accept="image/*">
                </div>

                @* FILE ĐÍNH KÈM *@
                <div>
                    <label style="@labelStyle">File đính kèm bổ sung (nếu có)</label>
                    <div style="background: #ffffff; border: 2px dashed #e2e8f0; border-radius: 18px; padding: 20px; display: flex; align-items: center; gap: 15px;">
                        <i class="fa fa-paperclip" style="font-size: 24px; color: #f59e0b;"></i>
                        <div style="flex: 1;">
                            <input type="file" name="UploadFile" style="font-size: 13px; color: #475569; width: 100%;">
                        </div>
                    </div>
                </div>
            </div>

            @* --- LƯU Ý --- *@
            <div style="@boxStyle; border-color: #fcd34d; background: #fffcf0; padding: 25px;">
                <h3 style="color: #92400e; font-size: 13px; display: flex; align-items: center; gap: 10px; margin-bottom: 12px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-warning"></i> Lưu ý khi đổi ca
                </h3>
                <ul style="margin: 0; padding-left: 20px; color: #78350f; font-size: 12px; line-height: 1.8; font-weight: 600;">
                    <li>Việc đổi ca phải được sự đồng ý của trưởng bộ phận và người đổi cùng (nếu có).</li>
                    <li>Ảnh minh chứng cần rõ ràng ngày tháng và nội dung các ca thay đổi.</li>
                    <li>Vui lòng gửi đơn ít nhất 24h trước khi ca làm việc bắt đầu.</li>
                </ul>

                <hr style="border: 0; border-top: 1px solid #fde68a; margin: 20px 0;">

                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer;" id="labelCamKet">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; accent-color: #d97706;">
                    <span style="font-size: 13px; color: #92400e; font-weight: 800;">
                        Tôi xác nhận việc đổi ca này đã được sự thống nhất của các bên liên quan.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="guiDonDoiCa()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, #f59e0b, #d97706); color: #fff; border: none; border-radius: 20px; font-weight: 900; font-size: 17px; cursor: pointer; transition: 0.3s; box-shadow: 0 15px 30px -5px rgba(245, 158, 11, 0.4); text-transform: uppercase;">
                    <i class="fa fa-check-square-o" style="margin-right: 10px;"></i> Gửi đăng ký đổi ca
                </button>
            </div>

        </div>
    </form>
</div>

<script>
    // Hàm xử lý dán ảnh từ Clipboard
    function setupPasteImage(zoneId, inputId) {
        const zone = document.getElementById(zoneId);
        const input = document.getElementById(inputId);

        zone.addEventListener('paste', (e) => {
            const items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    const blob = items[i].getAsFile();
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        zone.innerHTML = `<img src="${event.target.result}" style="max-width:100%; max-height:100%; object-fit:contain; border-radius:12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">`;
                        zone.style.background = "#ffffff";
                        zone.style.borderColor = "#d97706";

                        const dataTransfer = new DataTransfer();
                        dataTransfer.items.add(blob);
                        input.files = dataTransfer.files;
                    };
                    reader.readAsDataURL(blob);
                }
            }
        });

        // Thêm click để focus hỗ trợ paste tốt hơn trên một số trình duyệt
        zone.addEventListener('click', () => zone.focus());
    }

    // Khởi tạo
    setupPasteImage("paste_AnhDoiCa", "Anh");

    function guiDonDoiCa() {
        // Kiểm tra ảnh
        const anhInput = document.getElementById("Anh");
        if (anhInput.files.length === 0) {
            alert("⚠️ Vui lòng dán ảnh minh chứng lịch đổi ca trước khi gửi.");
            document.getElementById("paste_AnhDoiCa").focus();
            return;
        }

        // Kiểm tra cam kết
        const chkCamKet = document.getElementById("chkCamKet");
        if (!chkCamKet.checked) {
            alert("⚠️ Bạn phải tích chọn xác nhận đã thống nhất trước khi gửi đơn.");
            return;
        }

        if (confirm("Xác nhận gửi yêu cầu đổi ca làm việc này?")) {
            document.getElementById("doiCaForm").submit();
        }
    }
</script>