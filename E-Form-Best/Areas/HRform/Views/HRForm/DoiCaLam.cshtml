@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký Đổi ca làm việc";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- LẤY THÔNG TIN TỪ CLAIMS ---
    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // Toolkit Style: Tông màu Amber (Vàng Cam)
    string primaryColor = "#f59e0b";
    string darkAmber = "#92400e";
    string lightAmber = "#fffbeb";

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 10px; border: 1.5px solid #fde68a; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {darkAmber};";
    string labelStyle = $"font-weight: 800; color: {darkAmber}; font-size: 11px; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.5px;";
    string pasteZoneStyle = $"width: 100%; border: 2.5px dashed {primaryColor}; height: 180px; border-radius: 15px; display: flex; align-items: center; justify-content: center; background: {lightAmber}; color: {darkAmber}; cursor: pointer; overflow: hidden; font-size: 12px; font-weight: 600; transition: 0.3s; margin-top: 10px; position: relative; outline: none;";
}

<style>
    /* CSS Lớp phủ bảo trì / chưa hoạt động */
    .maintenance-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(8px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }

    .maintenance-content {
        background: white;
        padding: 40px;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(146, 64, 14, 0.2);
        border: 3px solid @primaryColor;
        text-align: center;
        max-width: 80%;
    }

    /* ==========================================
           THÊM MỚI: CSS CHO MOBILE RESPONSIVE
           ========================================== */
    @@media (max-width: 768px) {
        .mobile-wrapper {
            padding: 15px 10px !important;
        }

        .mobile-form {
            border-radius: 20px !important;
        }

        .mobile-header {
            padding: 30px 20px !important;
        }

            .mobile-header h2 {
                font-size: 18px !important;
                margin-top: 10px !important;
            }

        .system-badge {
            position: relative !important;
            top: 0 !important;
            right: 0 !important;
            display: inline-block;
            margin-bottom: 10px;
        }

        .mobile-body {
            padding: 20px 15px !important;
        }
        /* Chuyển các lưới grid về 1 cột */
        .mobile-grid {
            grid-template-columns: 1fr !important;
            gap: 12px !important;
        }

        .mobile-section {
            padding: 15px !important;
        }

        .maintenance-content {
            padding: 25px !important;
            max-width: 90% !important;
        }

            .maintenance-content h2 {
                font-size: 18px !important;
            }

            .maintenance-content p {
                font-size: 14px !important;
            }
    }
</style>

<div class="mobile-wrapper" style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); padding: 40px 15px; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    <form id="hrForm" class="mobile-form" method="post" enctype="multipart/form-data" action="/FormHR/DoiCaLam"
          style="max-width: 900px; margin: 0 auto; background: #ffffff; border-radius: 30px; box-shadow: 0 20px 50px rgba(146, 64, 14, 0.1); overflow: hidden; border: 1px solid rgba(255,255,255,0.8); position: relative;">

        @Html.AntiForgeryToken()

        @* --- LỚP PHỦ THÔNG BÁO CHƯA HOẠT ĐỘNG --- *@
        <div class="maintenance-overlay">
            <div class="maintenance-content">
                <div style="font-size: 60px; margin-bottom: 20px;">⏳</div>
                <h2 style="color: @darkAmber; margin: 0; font-size: 26px; font-weight: 900; text-transform: uppercase;">Chưa chính thức hoạt động</h2>
                <div style="width: 50px; height: 4px; background: @primaryColor; margin: 15px auto;"></div>
                <p style="color: @darkAmber; font-size: 16px; font-weight: 600; line-height: 1.6;">
                    Hệ thống Đăng ký Đổi ca hiện tại chưa được đưa vào sử dụng chính thức.<br />
                    Vui lòng quay lại sau hoặc liên hệ bộ phận Nhân sự để biết thêm chi tiết.
                </p>
                <button type="button" onclick="window.history.back()"
                        style="margin-top: 25px; padding: 12px 30px; background: @darkAmber; color: #fff; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; transition: 0.3s;">
                    QUAY LẠI
                </button>
            </div>
        </div>

        @* --- HEADER --- *@
        <div class="mobile-header" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); padding: 40px; color: #ffffff; text-align: center; position: relative;">
            <div class="system-badge" style="position: absolute; top: 15px; right: 25px; font-size: 11px; opacity: 0.9; font-weight: 700; letter-spacing: 1.5px;">E-FORM HR SERVICES</div>
            <h2 style="margin: 0; font-size: 24px; text-transform: uppercase; font-weight: 900; letter-spacing: 1.5px;">Đăng ký Đổi ca làm việc</h2>
            <div style="margin-top: 12px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; background: rgba(255,255,255,0.2); border-radius: 50px; font-size: 13px; backdrop-filter: blur(4px);">
                📅 Ngày lập đơn: <span style="font-weight: 800; color: #fff;">@ngayHienThi</span>
            </div>
        </div>

        <div class="mobile-body" style="padding: 40px;">
            @* --- PHẦN 1: THÔNG TIN NHÂN SỰ --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: @darkAmber; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @primaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">1</span>
                    Thông tin nhân viên
                </h3>
                <div class="mobile-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px;">
                    <div>
                        <label style="@labelStyle">Họ tên nhân viên</label>
                        <input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #fffcf0; border-color: #fde68a;">
                    </div>
                    <div>
                        <label style="@labelStyle">Phòng ban</label>
                        <input name="BoPhan" value="@phongBan" readonly style="@inputStyle; background: #fffcf0; border-color: #fde68a;">
                    </div>
                    <div>
                        <label style="@labelStyle">Mã nhân viên</label>
                        <input name="SoNhanVien" value="@soNhanVien" readonly style="@inputStyle; background: #fffcf0; border-color: #fde68a;">
                    </div>
                </div>

                <div class="mobile-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label style="@labelStyle">Đơn vị / Công ty</label>
                        <input name="TenCongTy" value="@tenCongTy" readonly style="@inputStyle; background: #fffcf0; border-style: dashed;">
                    </div>
                    <div>
                        <label style="@labelStyle">Danh mục hồ sơ</label>
                        <input name="Danhmuc" value="ĐƠN ĐĂNG KÝ ĐỔI CA" readonly style="@inputStyle; background: #fffcf0; border-style: dashed; color: @primaryColor;">
                    </div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT ĐỔI CA --- *@
            <div class="mobile-section" style="background: #fffdf7; padding: 25px; border-radius: 20px; border: 1.5px solid #fde68a; margin-bottom: 30px; box-shadow: inset 0 2px 4px rgba(245, 158, 11, 0.05);">
                <h3 style="color: @darkAmber; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @darkAmber; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">2</span>
                    Chi tiết lịch đổi ca
                </h3>

                <div class="mobile-grid" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label style="@labelStyle">Ngày cần đổi <span style="color:#dc2626">*</span></label>
                        <input type="date" name="NgayCanDoi" required style="@inputStyle; border-color: @primaryColor;">
                    </div>
                    <div>
                        <label style="@labelStyle">Ca làm việc gốc <span style="color:#dc2626">*</span></label>
                        <input type="text" name="CaGoc" placeholder="Ví dụ: Ca 1..." required style="@inputStyle; border-color: @primaryColor;">
                    </div>
                    <div>
                        <label style="@labelStyle">Ca muốn đổi sang <span style="color:#dc2626">*</span></label>
                        <input type="text" name="CaMuonDoi" placeholder="Ví dụ: Ca 3..." required style="@inputStyle; border-color: @primaryColor;">
                    </div>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Lý do đổi ca <span style="color:#dc2626">*</span></label>
                    <textarea name="LyDoDoiCa" placeholder="Vui lòng nhập lý do cụ thể..." required style="@inputStyle; height: 80px; resize: none; border-color: @primaryColor;"></textarea>
                </div>

                <div class="mobile-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelStyle">Ảnh minh chứng (Ctrl+V)</label>
                        <div id="paste_Anh" class="paste-zone" style="@pasteZoneStyle" tabindex="0">
                            <div style="text-align: center;">
                                <i class="fa fa-camera" style="font-size: 24px; margin-bottom: 8px;"></i><br>
                                Dán ảnh lịch đổi ca tại đây
                            </div>
                        </div>
                        <input type="file" id="Anh" name="Anh" hidden accept="image/*">
                    </div>

                    <div>
                        <label style="@labelStyle">Tài liệu đính kèm</label>
                        <div style="margin-top:10px; background: #ffffff; padding: 15px; border-radius: 12px; border: 2px dashed #fde68a; height: 180px; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;">
                            <input type="file" name="UploadFile" style="font-size: 13px; width: 100%;">
                            <p style="font-size: 11px; color: @darkAmber; margin-top: 15px; line-height: 1.4; opacity: 0.8;">Đính kèm file PDF/Excel nếu có lịch tổng bộ phận.</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CHỌN LOẠI YÊU CẦU HỖ TRỢ --- *@
            <div class="mobile-section" style="background: #ffffff; padding: 25px; border-radius: 20px; border: 1px solid #fde68a; margin-bottom: 30px; box-shadow: 0 4px 6px rgba(245, 158, 11, 0.05);">
                <h3 style="color: @darkAmber; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @primaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">3</span>
                    Chọn loại yêu cầu hỗ trợ
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px;">
                    @if (ViewBag.ListNguoiHoTro != null)
                    {
                        foreach (var item in (List<E_Form_Best.Models.ITForm.HrNguoiHoTro>)ViewBag.ListNguoiHoTro)
                        {
                            foreach (var cv in item.CongViecHrs)
                            {
                                <label style="display: flex; align-items: center; gap: 12px; padding: 15px; border: 1px solid #fef3c7; border-radius: 12px; cursor: pointer; transition: 0.2s; background: #fffdf7;"
                                       onmouseover="this.style.borderColor='@primaryColor'; this.style.background='#fffbeb'; this.style.transform='translateY(-2px)';"
                                       onmouseout="this.style.borderColor='#fef3c7'; this.style.background='#fffdf7'; this.style.transform='translateY(0)';"
                                       title="Phụ trách bởi: @item.Ten">

                                    <input type="checkbox" name="SelectedCongViecIds" value="@cv.Id" style="width: 20px; height: 20px; accent-color: @primaryColor;">

                                    <div style="flex: 1;">
                                        <div style="font-weight: 700; color: @darkAmber; font-size: 14px; display: flex; align-items: center; gap: 8px;">
                                            <span style="font-size: 16px;">🔄</span> @cv.Ten
                                        </div>
                                        <div style="font-size: 11px; color: @darkAmber; opacity: 0.7; margin-top: 2px;">
                                            Tiếp nhận: @item.Ten
                                        </div>
                                    </div>
                                </label>
                            }
                        }
                    }
                    else
                    {
                        <p style="font-size: 12px; color: @darkAmber; font-style: italic; grid-column: 1/-1;">Đang tải danh sách hỗ trợ...</p>
                    }
                </div>
            </div>

            @* --- PHẦN 4: CAM KẾT --- *@
            <div class="mobile-section" style="background: @lightAmber; border: 1.5px solid @primaryColor; border-radius: 20px; padding: 25px; margin-bottom: 30px;">
                <label id="containerCamKet" style="cursor: pointer; display: flex; align-items: flex-start; gap: 12px; background: #ffffff; padding: 15px; border-radius: 12px; border: 2px solid #fde68a; transition: 0.3s;">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; margin-top: 2px; accent-color: @primaryColor; cursor: pointer;">
                    <span style="font-size: 13px; font-weight: 800; color: @darkAmber; line-height: 1.5;">
                        Tôi xác nhận việc đổi ca này đã được sự thống nhất của các bên và cam kết đi làm đúng giờ giấc theo ca đã đăng ký.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="xuLyLuuDon()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, #f59e0b, #d97706); color: #fff; border: none; border-radius: 15px; font-weight: 900; font-size: 18px; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(245, 158, 11, 0.3); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-check-circle" style="margin-right: 10px;"></i> Gửi đăng ký đổi ca
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // Logic Paste ảnh từ Clipboard
    function handlePaste(e, inputId, zoneId) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        let blob = null;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                blob = items[i].getAsFile();
                break;
            }
        }
        if (blob) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const zone = document.getElementById(zoneId);
                zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:10px;">`;
                zone.style.border = "2px solid @primaryColor";
                zone.style.background = "#ffffff";

                const fileInput = document.getElementById(inputId);
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(blob);
                fileInput.files = dataTransfer.files;
            };
            reader.readAsDataURL(blob);
        }
    }

    const zoneEl = document.getElementById("paste_Anh");
    if (zoneEl) {
        zoneEl.addEventListener('paste', (e) => handlePaste(e, "Anh", "paste_Anh"));
        zoneEl.onclick = () => zoneEl.focus();
    }

    // Kiểm tra dữ liệu và Gửi đơn
    function xuLyLuuDon() {
        const ngayDoi = document.querySelector('input[name="NgayCanDoi"]').value;
        const caGoc = document.querySelector('input[name="CaGoc"]').value.trim();
        const caMoi = document.querySelector('input[name="CaMuonDoi"]').value.trim();
        const lyDo = document.querySelector('textarea[name="LyDoDoiCa"]').value.trim();
        const chk = document.getElementById('chkCamKet');
        const selectedHoTro = document.querySelectorAll('input[name="SelectedCongViecIds"]:checked');

        if (!ngayDoi) {
            alert("⚠️ Vui lòng chọn ngày cần đổi ca!");
            return;
        }
        if (!caGoc || !caMoi) {
            alert("⚠️ Vui lòng nhập thông tin ca làm việc!");
            return;
        }
        if (lyDo.length < 5) {
            alert("⚠️ Vui lòng nhập lý do đổi ca cụ thể!");
            return;
        }
        if (selectedHoTro.length === 0) {
            alert("⚠️ Vui lòng chọn ít nhất một loại yêu cầu hỗ trợ!");
            return;
        }
        if (!chk.checked) {
            alert("⚠️ Bạn chưa tích chọn cam kết!");
            return;
        }

        if (confirm("Xác nhận gửi đơn đăng ký đổi ca làm việc?")) {
            document.getElementById("hrForm").submit();
        }
    }
</script>