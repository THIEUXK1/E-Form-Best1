@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@using System.Security.Claims

@{
    ViewData["Title"] = "Quản Lý Xét Duyệt HR - B2";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- 1. LẤY THÔNG TIN ROLE ---
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? User.FindFirst("UserRole")?.Value ?? "Guest";

    // --- 2. LOGIC THỐNG KÊ ---
    var total = Model?.Count() ?? 0;
    var daHuy = Model?.Count(x => (x.TenForm ?? "").Contains("[ĐÃ HỦY]")) ?? 0;
    
    // Logic B2: Đã qua bước QL (IdNguoiDuyet != null) nhưng HR Admin chưa chốt (IdAdmin == null)
    var dangXuLyB2 = Model?.Count(x => x.IdNguoiDuyet != null && x.IdAdmin == null && !(x.TenForm ?? "").Contains("[ĐÃ HỦY]")) ?? 0;
    var hoanTat = Model?.Count(x => x.IdAdmin != null && !(x.TenForm ?? "").Contains("[ĐÃ HỦY]")) ?? 0;
}

<style>
    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }
    .support-avatar {
        width: 28px;
        height: 28px;
        background: #f0f9ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0369a1;
        border: 1px solid #e0f2fe;
    }
    #dataTable tr { transition: 0.2s; }
    .status-pill {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 1000;
        display: inline-block;
        min-width: 90px;
        text-align: center;
        text-transform: uppercase;
    }
</style>

<div style="padding: 20px; background: #f8fafc; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    @* --- TOP BAR --- *@
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 15px;">
        <h2 style="margin: 0; color: #0369a1; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
            <span style="background: #0369a1; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-clipboard-check"></i>
            </span>
            XÉT DUYỆT NHÂN SỰ (B2)
        </h2>

        <div style="display: flex; gap: 10px; align-items: center;">
            <div style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="filterTable()" placeholder="Tìm tên, bộ phận, mã đơn..."
                       style="padding: 10px 12px 10px 38px; border-radius: 12px; border: 2px solid #e2e8f0; font-size: 14px; width: 280px; outline: none; font-weight: 700;">
            </div>

            <div style="font-size: 11px; background: #0369a1; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; letter-spacing: 0.5px;">
                @userRole
            </div>
        </div>
    </div>

    @* --- STATS ROW --- *@
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 25px;">
        @{
            var stats = new[] {
                new { Label = "TỔNG ĐƠN B2", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                new { Label = "B2 ĐANG XỬ LÝ", Value = dangXuLyB2, Color = "#0369a1", Bg = "#f0f9ff", Filter = "B2-ADMIN" },
                new { Label = "HOÀN TẤT", Value = hoanTat, Color = "#10b981", Bg = "#ecfdf5", Filter = "HOÀN TẤT" },
                new { Label = "ĐƠN ĐÃ HỦY", Value = daHuy, Color = "#b91c1c", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
            };
        }
        @foreach (var s in stats)
        {
            <div onclick="filterByStatus('@s.Filter')"
                 style="background: @s.Bg; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.02); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);"
                 onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='@s.Color';"
                 onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(0,0,0,0.02)';">
                <div style="font-size: 11px; font-weight: 900; color: @s.Color; text-transform: uppercase; margin-bottom: 5px; opacity: 0.8;">@s.Label</div>
                <div style="font-size: 26px; font-weight: 1000; color: @s.Color;">@s.Value</div>
            </div>
        }
    </div>

    @* --- TABLE AREA --- *@
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <table id="dataTable" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 3px solid #f1f5f9;">
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nội dung đơn</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin người duyệt B2</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 140px;">Tiến độ</th>
                    <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                    <th style="padding: 18px 20px; text-align: right;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        bool isCancelled = (item.TenForm ?? "").Contains("[ĐÃ HỦY]");
                        bool isFinished = item.IdAdmin != null;

                        string pWidth = "65%"; string pColor = "#0369a1"; string pText = "B2-ADMIN";
                        string bg = "#e0f2fe"; string fg = "#0369a1"; string statusTag = "B2-ADMIN";

                        if (isCancelled)
                        {
                            pWidth = "100%"; pColor = "#ef4444"; pText = "ĐÃ HỦY";
                            bg = "#fee2e2"; fg = "#b91c1c"; statusTag = "ĐÃ HỦY";
                        }
                        else if (isFinished)
                        {
                            pWidth = "100%"; pColor = "#10b981"; pText = "HOÀN TẤT";
                            bg = "#d1fae5"; fg = "#047857"; statusTag = "HOÀN TẤT";
                        }

                        <tr style="border-bottom: 1px solid #f1f5f9;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                            @* 1. Nhân viên *@
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">@item.BoPhan • <span style="color: #0369a1;">MS: @item.SoNhanVien</span></div>
                            </td>

                            @* 2. Nội dung đơn *@
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                    <span>ID: #@item.Id • <i class="fa fa-clock-o"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>
                                    
                                    @if (item.BaoVeHrs != null && item.BaoVeHrs.Any())
                                    {
                                        var bv = item.BaoVeHrs.FirstOrDefault();
                                        <span class="sub-badge" style="color: #64748b; border-color: #cbd5e1; background: #f8fafc;">
                                            <i class="fa fa-shield"></i> BV @(bv?.TrangThai == 1 ? "OK" : "...")
                                        </span>
                                    }
                                </div>
                            </td>

                            @* 3. Thông tin người duyệt B2 (Dữ liệu từ bảng HrQuanLyDuyetB2) *@
                            <td style="padding: 15px 20px;">
                                @if (item.HrNguoiXacNhans != null && item.HrNguoiXacNhans.Any())
                                {
                                    // Lấy người xác nhận B2 có thời gian mới nhất
                                    var xacNhanB2 = item.HrNguoiXacNhans.OrderByDescending(x => x.ThoiGianXacNhan).FirstOrDefault();
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <div class="support-avatar">
                                            <i class="fa fa-user-shield" style="font-size: 12px;"></i>
                                        </div>
                                        <div>
                                            <div style="font-weight: 800; color: #334155; font-size: 13px;">@xacNhanB2?.TenNguoiXacNhan</div>
                                            <div style="font-size: 10px; color: #64748b; font-weight: 600;">
                                                <i class="fa fa-calendar-check-o"></i> @(xacNhanB2?.ThoiGianXacNhan?.ToString("dd/MM HH:mm") ?? "Đang chờ...")
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div style="color: #94a3b8; font-size: 12px; font-style: italic; display: flex; align-items: center; gap: 5px;">
                                        <i class="fa fa-hourglass-half"></i> Hệ thống đang xử lý...
                                    </div>
                                }
                            </td>

                            @* 4. Tiến độ *@
                            <td style="padding: 15px 20px;">
                                <div style="font-size: 9px; font-weight: 1000; color: @pColor; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>@pText</span> <span>@pWidth</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                    <div style="width: @pWidth; height: 100%; background: @pColor; border-radius: 10px;"></div>
                                </div>
                            </td>

                            @* 5. Trạng thái *@
                            <td style="padding: 15px 20px; text-align: center;">
                                <span class="status-pill" style="background:@bg; color:@fg; border: 1.5px solid @fg;">@statusTag</span>
                            </td>

                            @* 6. Hành động *@
                            <td style="padding: 15px 20px; text-align: right;">
                                <a href="/FormHR/ChiTiet/@item.Id"
                                   style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s;
                                   background: @(isFinished || isCancelled ? "#f1f5f9" : "#0369a1");
                                   color: @(isFinished || isCancelled ? "#64748b" : "#ffffff");">
                                    <i class="fa @(isFinished || isCancelled ? "fa-eye" : "fa-edit")"></i> @(isFinished || isCancelled ? "Xem lại" : "Xử lý B2")
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div style="text-align: center; padding: 100px 0; color: #94a3b8;">
            <div style="margin-bottom: 15px;">
                <i class="fa fa-folder-open-o" style="font-size: 64px; opacity: 0.2;"></i>
            </div>
            <p style="font-weight: 700; font-size: 16px; margin: 0;">Không tìm thấy dữ liệu xét duyệt B2</p>
            <p style="font-size: 13px; margin-top: 5px;">Vui lòng kiểm tra lại bộ lọc hoặc quyền truy cập của bạn.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterTable() {
            const input = document.getElementById("quickSearch");
            const filter = input.value.toUpperCase();
            const table = document.getElementById("dataTable");
            const tr = table.getElementsByTagName("tr");

            for (let i = 1; i < tr.length; i++) {
                let rowText = tr[i].innerText.toUpperCase();
                tr[i].style.display = rowText.includes(filter) ? "" : "none";
            }
        }

        function filterByStatus(s) {
            const searchInput = document.getElementById("quickSearch");
            searchInput.value = s;
            filterTable();
            
            // Hiệu ứng phản hồi khi bấm vào box thống kê
            const table = document.getElementById("dataTable");
            table.style.opacity = "0.4";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }
    </script>
}