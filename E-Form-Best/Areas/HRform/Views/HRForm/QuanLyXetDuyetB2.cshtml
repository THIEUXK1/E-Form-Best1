@{
    ViewData["Title"] = "Quản Lý Xét Duyệt HR - B2";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // Vẫn lấy Role từ Claim để hiển thị giao diện góc phải
    var userRole = User.Identity?.Name ?? "Guest";
}

<style>
    body {
        background-color: #f8fafc;
    }

    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 28px;
        height: 28px;
        background: #f0f9ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0369a1;
        border: 1px solid #e0f2fe;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
    }

    .status-pill {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 1000;
        display: inline-block;
        min-width: 95px;
        text-align: center;
        text-transform: uppercase;
    }

    /* Style Bộ lọc nâng cao */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
        height: 38px;
    }

        .filter-input:focus {
            border-color: #0369a1;
            box-shadow: 0 0 0 2px rgba(3, 105, 161, 0.1);
        }

    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
        height: 38px;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* Phân trang JS CSS */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #0369a1;
            color: white;
            border-color: #0369a1;
            box-shadow: 0 4px 6px -1px rgba(3, 105, 161, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* ========================================================
        CSS MỚI: HỆ THỐNG DROPDOWN CHECKBOX (MULTI-SELECT)
        ======================================================== */
    .dropdown-combo-btn {
        text-align: left;
        background-color: #fff;
        border: 1px solid #cbd5e1;
        padding: 8px 28px 8px 12px;
        font-size: 13px;
        font-weight: 600;
        border-radius: 8px;
        color: #1e293b;
        position: relative;
        min-width: 160px;
        height: 38px;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

        .dropdown-combo-btn:after {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
        }

        .dropdown-combo-btn:focus {
            border-color: #0369a1;
            box-shadow: 0 0 0 2px rgba(3,105,161,0.1);
            outline: 0;
        }

    .dropdown-combo-menu {
        min-width: 220px;
        max-height: 280px;
        overflow-y: auto;
        padding: 8px 0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        z-index: 1050;
    }

    .dropdown-combo-item {
        display: flex;
        align-items: center;
        padding: 6px 16px;
        cursor: pointer;
        user-select: none;
        font-size: 13px;
        color: #334155;
        transition: background-color 0.15s ease;
    }

        .dropdown-combo-item:hover {
            background-color: #f1f5f9;
        }

        .dropdown-combo-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #0369a1;
            flex-shrink: 0;
        }

        .dropdown-combo-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    /* ========================================================
        BỔ SUNG CSS CHO MOBILE RESPONSIVE
        ======================================================== */
    @@media (max-width: 768px) {
        .mobile-top-bar {
            flex-direction: column !important;
            align-items: stretch !important;
        }

        .mobile-controls {
            flex-direction: column !important;
            width: 100% !important;
        }

        .mobile-search-input {
            width: 100% !important;
        }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .dropdown-combo-btn {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }

        .mobile-stat-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }

        #dataTable thead {
            display: none;
        }

        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }

            #dataTable tr {
                margin-bottom: 15px;
                border: 1px solid #e2e8f0 !important;
                border-radius: 15px;
                overflow: hidden;
                background: #fff;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            }

            #dataTable td {
                text-align: right !important;
                padding: 12px 15px !important;
                border-bottom: 1px dashed #f1f5f9;
                position: relative;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                #dataTable td:last-child {
                    border-bottom: none;
                    background: #f8fafc;
                    justify-content: center;
                }

                #dataTable td::before {
                    content: attr(data-label);
                    float: left;
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                }

        .mobile-td-val {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .pagination-container {
            flex-direction: column !important;
            gap: 20px;
            text-align: center !important;
        }

        #paginationButtons {
            justify-content: center;
        }
    }
</style>

<div style="padding: 20px; background: #f8fafc; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    @* --- TOP BAR --- *@
    <div class="mobile-top-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 15px;">
        <h2 style="margin: 0; color: #0369a1; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
            <span style="background: #0369a1; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-clipboard-check"></i>
            </span>
            XÉT DUYỆT BỘ PHẬN (B2)
        </h2>

        <div class="mobile-controls" style="display: flex; gap: 10px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #e2e8f0;">
                <span style="font-size: 12px; font-weight: 700; color: #64748b;">Hiển thị:</span>
                <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #0369a1; cursor: pointer; background: transparent; font-size: 14px;">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>

            <div class="mobile-search-input" style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="handleFilterAndPaginate()" placeholder="Tìm tên, bộ phận, mã đơn..."
                       style="padding: 10px 12px 10px 38px; border-radius: 12px; border: 2px solid #e2e8f0; font-size: 14px; outline: none; font-weight: 700; box-sizing: border-box; width: 100%;">
            </div>
            <div style="font-size: 11px; background: #0369a1; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">@userRole</div>
        </div>
    </div>

    @* --- BỘ LỌC NÂNG CAO DROPDOWN MULTI-CHECKBOX --- *@
    <div class="advanced-filter">
        <div class="filter-group">
            <label>Từ ngày</label>
            <input type="date" id="txtFromDate" class="filter-input" onchange="handleFilterAndPaginate()" />
        </div>
        <div class="filter-group">
            <label>Đến ngày</label>
            <input type="date" id="txtToDate" class="filter-input" onchange="handleFilterAndPaginate()" />
        </div>

        <div class="filter-group">
            <label>Bộ phận</label>
            <div class="dropdown">
                <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropBoPhan" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    -- Tất cả --
                </button>
                <div class="dropdown-menu dropdown-combo-menu" id="menuBoPhan" aria-labelledby="btnDropBoPhan">
                </div>
            </div>
        </div>

        <div class="filter-group">
            <label>Người hỗ trợ</label>
            <div class="dropdown">
                <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropStaff" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    -- Tất cả --
                </button>
                <div class="dropdown-menu dropdown-combo-menu" id="menuStaff" aria-labelledby="btnDropStaff">
                </div>
            </div>
        </div>

        <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
            <button class="btn-clear-filter" onclick="clearAllFilters()">
                <i class="fa fa-refresh"></i> Làm mới
            </button>
        </div>
    </div>

    @* --- STATS ROW --- *@
    <div class="mobile-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin-bottom: 25px;">
        <div data-status="" onclick="filterByStatus('')" class="stat-card" style="background: white; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #1e293b; text-transform: uppercase; margin-bottom: 5px; white-space: nowrap;">TỔNG ĐƠN B2</div>
            <div id="stat-total" style="font-size: 22px; font-weight: 1000; color: #1e293b;">0</div>
        </div>
        <div data-status="BP XÁC NHẬN" onclick="filterByStatus('BP XÁC NHẬN')" class="stat-card" style="background: #f0f9ff; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #0369a1; text-transform: uppercase; margin-bottom: 5px; white-space: nowrap;">CHỜ B2 DUYỆT</div>
            <div id="stat-b2" style="font-size: 22px; font-weight: 1000; color: #0369a1;">0</div>
        </div>
        <div data-status="GIÁM ĐỐC" onclick="filterByStatus('GIÁM ĐỐC')" class="stat-card" style="background: #fdf4ff; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #86198f; text-transform: uppercase; margin-bottom: 5px; white-space: nowrap;">CHỜ GĐ DUYỆT</div>
            <div id="stat-gd" style="font-size: 22px; font-weight: 1000; color: #86198f;">0</div>
        </div>
        <div data-status="ADMIN" onclick="filterByStatus('ADMIN')" class="stat-card" style="background: #eff6ff; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #2563eb; text-transform: uppercase; margin-bottom: 5px; white-space: nowrap;">CHỜ ADMIN</div>
            <div id="stat-admin" style="font-size: 22px; font-weight: 1000; color: #2563eb;">0</div>
        </div>
        <div data-status="HOÀN TẤT" onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #ecfdf5; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #10b981; text-transform: uppercase; margin-bottom: 5px; white-space: nowrap;">HOÀN TẤT</div>
            <div id="stat-xong" style="font-size: 22px; font-weight: 1000; color: #10b981;">0</div>
        </div>
        <div data-status="ĐÃ HỦY" onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 5px; white-space: nowrap;">ĐÃ HỦY</div>
            <div id="stat-huy" style="font-size: 22px; font-weight: 1000; color: #b91c1c;">0</div>
        </div>
    </div>

    @* --- TABLE AREA --- *@
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <table id="dataTable" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 3px solid #f1f5f9;">
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nội dung đơn</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 140px;">Tiến độ</th>
                    <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                    <th style="padding: 18px 20px; text-align: right;"></th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <tr>
                    <td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none;">
                        <i class="fa fa-spinner fa-spin" style="font-size: 32px; margin-bottom: 15px;"></i>
                        <p style="font-weight: 600;">Đang tải danh sách B2...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* --- PHẦN PHÂN TRANG --- *@
    <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; margin-top: 5px;">
        <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
        <div style="text-align: right;">
            <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                Trang <span id="currentPageNum" style="color: #0369a1;">1</span> / <span id="totalPagesNum">1</span>
            </div>
            <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];
        let filteredData = [];
        let currentPage = 1;
        let rowsPerPage = 20;

        // Lưu trạng thái thẻ màu
        let currentActiveStatusFilter = "";

        document.addEventListener("DOMContentLoaded", async () => {
            // --- 1. PHỤC HỒI TEXT SEARCH ---
            const savedText = sessionStorage.getItem("savedB2XetDuyetText");
            if (savedText) document.getElementById("quickSearch").value = savedText;

            // --- 2. PHỤC HỒI NGÀY THÁNG LỌC NÂNG CAO ---
            const savedFrom = sessionStorage.getItem("savedFromDateB2XD");
            if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

            const savedTo = sessionStorage.getItem("savedToDateB2XD");
            if (savedTo) document.getElementById("txtToDate").value = savedTo;

            // --- 3. PHỤC HỒI TRẠNG THÁI THẺ CARD ---
            const savedStatus = sessionStorage.getItem("savedB2XetDuyetStatus");
            if (savedStatus !== null) {
                currentActiveStatusFilter = savedStatus;
            }

            // Lắng nghe sự kiện thay đổi trạng thái Checkbox lồng trong Dropdown Menu mới
            $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
                const $menu = $(this).closest('.dropdown-combo-menu');
                updateDropdownButtonLabel($menu);
                handleFilterAndPaginate();
            });

            try {
                const response = await fetch('/FormHR/GetQuanLyXetDuyetB2Data');
                masterData = await response.json();

                // Đổ dữ liệu Checkbox động
                populateDropdowns(masterData);

                // --- 4. PHỤC HỒI CACHE TRẠNG THÁI TÍCH CHỌN MULTI-SELECT ---
                const savedBoPhanStr = sessionStorage.getItem("savedBoPhanB2XD");
                if (savedBoPhanStr) {
                    try {
                        let arrDept = JSON.parse(savedBoPhanStr) || [];
                        if (!Array.isArray(arrDept) && savedBoPhanStr) arrDept = [savedBoPhanStr];
                        arrDept.forEach(d => { $(`.chk-dept[value="${d}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuBoPhan'));
                    } catch(e){}
                }

                const savedStaffStr = sessionStorage.getItem("savedStaffB2XD");
                if (savedStaffStr) {
                    try {
                        let arrStaff = JSON.parse(savedStaffStr) || [];
                        if (!Array.isArray(arrStaff) && savedStaffStr) arrStaff = [savedStaffStr];
                        arrStaff.forEach(s => { $(`.chk-staff[value="${s}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuStaff'));
                    } catch(e){}
                }

                updateStatistics(masterData);
                updateVisualStatusCard(currentActiveStatusFilter);
                handleFilterAndPaginate();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: red;">Lỗi tải dữ liệu. Vui lòng F5.</td></tr>`;
            }
        });

        // Nạp dữ liệu các Checkbox động
        function populateDropdowns(data) {
            const menuBoPhan = document.getElementById("menuBoPhan");
            const menuStaff = document.getElementById("menuStaff");

            const depts = [...new Set(data.map(x => x.boPhan).filter(Boolean))].sort();
            menuBoPhan.innerHTML = '';
            depts.forEach(d => {
                menuBoPhan.insertAdjacentHTML('beforeend', `
                    <label class="dropdown-combo-item">
                        <input type="checkbox" class="chk-dept" value="${d}">
                        <span>${d}</span>
                    </label>
                `);
            });

            const staffSet = [...new Set(data.map(x => x.supportName).filter(n => n && n !== "Chưa chỉ định"))].sort();
            menuStaff.innerHTML = '';
            staffSet.forEach(s => {
                menuStaff.insertAdjacentHTML('beforeend', `
                    <label class="dropdown-combo-item">
                        <input type="checkbox" class="chk-staff" value="${s}">
                        <span>${s}</span>
                    </label>
                `);
            });
        }

        // Cập nhật nhãn hiển thị nút bấm Dropdown Checkbox dựa trên số ô đã tích
        function updateDropdownButtonLabel($menu) {
            let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
            let $btn = $menu.siblings('.dropdown-combo-btn');

            if (totalChecked === 0) {
                $btn.text('-- Tất cả --');
            } else if (totalChecked === 1) {
                $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
            } else {
                $btn.text(`Đã chọn (${totalChecked})`);
            }
        }

        function updateStatistics(data) {
            document.getElementById("stat-total").innerText = data.length;
            document.getElementById("stat-b2").innerText = data.filter(x => x.statusTag === "BP XÁC NHẬN").length;
            document.getElementById("stat-gd").innerText = data.filter(x => x.statusTag === "GIÁM ĐỐC").length;
            document.getElementById("stat-admin").innerText = data.filter(x => x.statusTag === "ADMIN").length;
            document.getElementById("stat-xong").innerText = data.filter(x => x.statusTag === "HOÀN TẤT").length;
            document.getElementById("stat-huy").innerText = data.filter(x => x.statusTag === "ĐÃ HỦY").length;
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            currentPage = 1;
            handleFilterAndPaginate();
        }

        function updateVisualStatusCard(status) {
            document.querySelectorAll('.stat-card').forEach(el => {
                el.style.border = "2px solid rgba(0,0,0,0.03)";
                el.style.boxShadow = "0 4px 6px rgba(0,0,0,0.05)";
            });

            if(status) {
                const targetCard = document.querySelector(`.stat-card[data-status="${status}"]`);
                if (targetCard) {
                    targetCard.style.border = "2px solid #0369a1";
                    targetCard.style.boxShadow = "0 0 0 3px rgba(3, 105, 161, 0.2)";
                }
            }
        }

        function filterByStatus(status) {
            if(currentActiveStatusFilter === status) {
                currentActiveStatusFilter = "";
            } else {
                currentActiveStatusFilter = status;
            }

            sessionStorage.setItem("savedB2XetDuyetStatus", currentActiveStatusFilter);
            updateVisualStatusCard(currentActiveStatusFilter);

            currentPage = 1;
            handleFilterAndPaginate();

            let table = document.getElementById("dataTable");
            table.style.opacity = "0.4";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }

        function clearAllFilters() {
            document.getElementById("quickSearch").value = "";
            document.getElementById("txtFromDate").value = "";
            document.getElementById("txtToDate").value = "";

            $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
            $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });

            sessionStorage.removeItem("savedB2XetDuyetText");
            sessionStorage.removeItem("savedFromDateB2XD");
            sessionStorage.removeItem("savedToDateB2XD");
            sessionStorage.removeItem("savedBoPhanB2XD");
            sessionStorage.removeItem("savedStaffB2XD");
            sessionStorage.removeItem("savedB2XetDuyetStatus");

            currentActiveStatusFilter = "";
            updateVisualStatusCard("");

            currentPage = 1;
            handleFilterAndPaginate();
        }

        // ====================================================
        // HÀM LỌC TỔNG HỢP MỚI (XỬ LÝ MẢNG MULTI-CHECKBOX ARRAY INCLUDES)
        // ====================================================
        function handleFilterAndPaginate() {
            const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();
            const fromDateStr = document.getElementById("txtFromDate").value;
            const toDateStr = document.getElementById("txtToDate").value;

            // Thu thập mảng các giá trị đang tích chọn từ Checkbox lơ lửng
            const selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
            const selectedStaffs = $('.chk-staff:checked').map(function() { return $(this).val(); }).get();

            // Đồng bộ lưu thông số vào Session Storage chống mất bộ lọc khi Refresh (F5)
            sessionStorage.setItem("savedB2XetDuyetText", document.getElementById("quickSearch").value);
            sessionStorage.setItem("savedFromDateB2XD", fromDateStr);
            sessionStorage.setItem("savedToDateB2XD", toDateStr);
            sessionStorage.setItem("savedBoPhanB2XD", JSON.stringify(selectedDepts));
            sessionStorage.setItem("savedStaffB2XD", JSON.stringify(selectedStaffs));

            filteredData = masterData.filter(item => {
                if (currentActiveStatusFilter && item.statusTag !== currentActiveStatusFilter) return false;

                // Kiểm tra bộ lọc đa Bộ phận
                if (selectedDepts.length > 0 && !selectedDepts.includes(item.boPhan)) return false;

                // Kiểm tra bộ lọc đa Người hỗ trợ
                if (selectedStaffs.length > 0 && !selectedStaffs.includes(item.supportName)) return false;

                if (fromDateStr || toDateStr) {
                    if (!item.timeNguoiTao || item.timeNguoiTao === "--") return false;

                    const parts = item.timeNguoiTao.split('/');
                    if (parts.length === 3) {
                        const itemDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
                        if (fromDateStr) {
                            const fromD = new Date(fromDateStr + "T00:00:00");
                            if (itemDate < fromD) return false;
                        }
                        if (toDateStr) {
                            const toD = new Date(toDateStr + "T23:59:59");
                            if (itemDate > toD) return false;
                        }
                    }
                }

                if (searchText) {
                    const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${item.supportName} ${item.statusTag}`.toUpperCase();
                    if (!rowString.includes(searchText)) return false;
                }

                return true;
            });

            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const pageData = filteredData.slice(startIndex, endIndex);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" style="padding: 50px 15px; text-align: center; color: #94a3b8; width: 100%; display: table-cell !important; border: none !important;">
                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
                                <i class="fa fa-folder-open-o" style="font-size: 40px; margin-bottom: 10px; opacity: 0.5; color: #64748b;"></i>
                                <span style="font-weight: 600; font-size: 14px; white-space: normal; text-align: center; color: #64748b;">
                                    Không tìm thấy dữ liệu yêu cầu phù hợp với bộ lọc.
                                </span>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-clock-o"></i> ${item.timeNguoiTao}</span>`;

                if (item.hasB2) {
                    badgesHtml += `<span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff; margin-left:5px;"><i class="fa fa-users"></i> B2 (${item.b2DuyetCount}/${item.b2TotalCount})</span>`;
                }
                if (item.hasGD) {
                    badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:5px;"><i class="fa fa-briefcase"></i> GĐ (${item.gdDuyetCount}/${item.gdTotalCount})</span>`;
                }

                const isCancelled = item.statusTag === "ĐÃ HỦY";

                let btnClass = (item.isB2Processing && !isCancelled) ? "fa-edit" : "fa-eye";
                let btnText = (item.isB2Processing && !isCancelled) ? "Xử lý B2" : "Xem lại";
                let btnBg = (item.isB2Processing && !isCancelled) ? "#0369a1" : "#f1f5f9";
                let btnColor = (item.isB2Processing && !isCancelled) ? "#ffffff" : "#64748b";

                html += `
                    <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div class="mobile-td-val" style="align-items: flex-start;">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #0369a1;">MS: ${item.soNhanVien}</span></div>
                            </div>
                        </td>
                        <td data-label="Nội dung đơn" style="padding: 15px 20px;">
                            <div class="mobile-td-val" style="align-items: flex-start;">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; flex-wrap: wrap; align-items: center; margin-top:4px;">
                                    ${badgesHtml}
                                </div>
                            </div>
                        </td>
                        <td data-label="Hỗ Trợ" style="padding: 15px 20px;">
                            <div style="display: flex; align-items: center; gap: 8px; justify-content: flex-end;">
                                <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                <div style="font-weight: 700; color: #334155; font-size: 13px;">${item.supportName}</div>
                            </div>
                        </td>
                        <td data-label="Tiến độ" style="padding: 15px 20px;">
                            <div style="width: 120px; margin-left: auto;">
                                <div style="font-size: 9px; font-weight: 1000; color: ${item.pColor}; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>${item.pText}</span> <span>${item.pWidth}</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                    <div style="width: ${item.pWidth}; height: 100%; background: ${item.pColor}; border-radius: 10px; transition: 0.5s ease;"></div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <span class="status-pill" style="background:${item.bg}; color:${item.fg}; border: 1.5px solid ${item.fg};">${item.statusTag}</span>
                        </td>
                        <td style="padding: 15px 20px; text-align: right;">
                            <a href="/FormHR/ChiTiet/${item.id}"
                               style="text-decoration: none; padding: 10px 20px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: ${btnBg}; color: ${btnColor}; width: 100%; text-align: center; box-sizing: border-box;"
                               onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                                 <i class="fa ${btnClass}"></i> ${btnText}
                            </a>
                        </td>
                    </tr>`;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = ""; if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) {
                        const dot = document.createElement("span");
                        dot.innerText = "..."; dot.style.padding = "8px"; dot.style.color = "#64748b"; dot.style.fontWeight = "700";
                        container.appendChild(dot);
                    }
                    continue;
                }

                const btn = document.createElement("button");
                btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i; handleFilterAndPaginate(); window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}