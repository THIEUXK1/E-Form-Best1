@using System.Security.Claims
@{
    ViewData["Title"] = "Báo Cáo - Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    body {
        background-color: #f8fafc;
    }

    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 26px;
        height: 26px;
        background: #eff6ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e40af;
        border: 1px solid #dbeafe;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
    }

    .filter-input {
        padding: 8px 12px;
        border-radius: 10px;
        border: 2px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        outline: none;
        transition: 0.3s;
        height: 42px;
        box-sizing: border-box;
    }

        .filter-input:focus {
            border-color: #1e40af;
        }

    /* Nút lọc Làm mới */
    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
        padding: 11px 18px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 800;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
        height: 42px;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* Phân trang JS CSS */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* ========================================================
        CSS MỚI: HỆ THỐNG DROPDOWN CHECKBOX (MULTI-SELECT)
        ======================================================== */
    .dropdown-combo-btn {
        text-align: left;
        background-color: #fff;
        border: 2px solid #cbd5e1;
        padding: 8px 28px 8px 12px;
        font-size: 13px;
        font-weight: 600;
        border-radius: 10px;
        color: #1e293b;
        position: relative;
        min-width: 160px;
        height: 42px;
        transition: border-color 0.3s;
    }

        .dropdown-combo-btn:after {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
        }

        .dropdown-combo-btn:focus {
            border-color: #1e40af;
            outline: 0;
        }

    .dropdown-combo-menu {
        min-width: 220px;
        max-height: 280px;
        overflow-y: auto;
        padding: 8px 0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        z-index: 1050;
    }

    .dropdown-combo-item {
        display: flex;
        align-items: center;
        padding: 6px 16px;
        cursor: pointer;
        user-select: none;
        font-size: 13px;
        color: #334155;
        transition: background-color 0.15s ease;
    }

        .dropdown-combo-item:hover {
            background-color: #f1f5f9;
        }

        .dropdown-combo-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #1e40af;
            flex-shrink: 0;
        }

        .dropdown-combo-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    /* Modal Styles */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        z-index: 9998;
        backdrop-filter: blur(4px);
    }

    .type-filter-modal {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        width: 500px;
        max-width: 95%;
        border-radius: 20px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        z-index: 9999;
        padding: 25px;
        overflow: hidden;
    }

    .type-checkbox-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 20px;
        margin-bottom: 25px;
        max-height: 350px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .type-item-label {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 15px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        cursor: pointer;
        transition: 0.2s;
        font-size: 13px;
        font-weight: 700;
        color: #334155;
    }

        .type-item-label:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

    .type-checkbox {
        width: 18px;
        height: 18px;
        accent-color: #1e40af;
        cursor: pointer;
    }

    /* ========================================================
        BỔ SUNG CSS CHO MOBILE RESPONSIVE
        ======================================================== */
    @@media (max-width: 768px) {
        .mobile-top-bar {
            flex-direction: column !important;
            align-items: stretch !important;
        }

        .mobile-controls {
            flex-direction: column !important;
            width: 100% !important;
        }

        .mobile-search-input {
            width: 100% !important;
        }

        .filter-form {
            flex-direction: column !important;
            align-items: stretch !important;
        }

        .dropdown-combo-btn {
            width: 100% !important;
        }

        .filter-input {
            width: 100% !important;
        }

        .mobile-stat-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }

        .type-checkbox-grid {
            grid-template-columns: 1fr !important;
        }

        #dataTable thead {
            display: none;
        }

        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }

            #dataTable tr {
                margin-bottom: 15px;
                border: 1px solid #e2e8f0 !important;
                border-radius: 15px;
                overflow: hidden;
                background: #fff;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            }

            #dataTable td {
                text-align: right !important;
                padding: 12px 15px !important;
                border-bottom: 1px dashed #f1f5f9;
                position: relative;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                #dataTable td:last-child {
                    border-bottom: none;
                    background: #f8fafc;
                    justify-content: center;
                }

                #dataTable td::before {
                    content: attr(data-label);
                    float: left;
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                }

        .mobile-td-val {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            max-width: 65%;
        }

        .pagination-container {
            flex-direction: column !important;
            gap: 20px;
            text-align: center !important;
        }

        #paginationButtons {
            justify-content: center;
        }
    }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1600px; margin: 0 auto;">

        @* --- TOP BAR --- *@
        <div class="mobile-top-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
            <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
                <span style="background: #1e40af; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);">
                    <i class="fa fa-bar-chart"></i>
                </span>
                XUẤT BÁO CÁO HR (ĐÃ HOÀN TẤT)
            </h2>

            <div class="mobile-controls" style="display: flex; gap: 12px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #cbd5e1;">
                    <span style="font-size: 12px; font-weight: 700; color: #64748b;">Hiển thị:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #1e40af; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div class="mobile-search-input" style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                    <input type="text" id="quickSearch" onkeyup="applyAllFilters()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 10px 15px 10px 40px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700; width: 100%; box-sizing: border-box;">
                </div>

                <button type="button" onclick="openTypeFilterModal()" style="padding: 10px 15px; background: white; border: 2px solid #cbd5e1; border-radius: 12px; color: #475569; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 8px;" onmouseover="this.style.borderColor='#94a3b8'; this.style.color='#1e293b'" onmouseout="this.style.borderColor='#cbd5e1'; this.style.color='#475569'">
                    <i class="fa fa-filter"></i> <span class="d-none d-md-inline">Phân loại đơn</span>
                </button>

                <div style="font-size: 11px; background: #1e40af; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- BỘ LỌC NÂNG CAO DROPDOWN MULTI-CHECKBOX --- *@
        <div style="background: white; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; margin-bottom: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
            <form action="/FormHR/ExportExcelHR" method="get" class="filter-form" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">

                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">TỪ NGÀY (HOÀN TẤT)</label>
                    <input type="date" id="txtFromDate" name="tuNgay" class="filter-input" onchange="applyAllFilters()">
                </div>

                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">ĐẾN NGÀY</label>
                    <input type="date" id="txtToDate" name="denNgay" class="filter-input" onchange="applyAllFilters()">
                </div>

                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">BỘ PHẬN (Lọc Bảng)</label>
                    <div class="dropdown">
                        <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropBoPhan" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            -- Tất cả --
                        </button>
                        <div class="dropdown-menu dropdown-combo-menu" id="menuBoPhan" aria-labelledby="btnDropBoPhan">
                        </div>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">NGƯỜI HỖ TRỢ (Lọc Bảng)</label>
                    <div class="dropdown">
                        <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropStaff" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            -- Tất cả --
                        </button>
                        <div class="dropdown-menu dropdown-combo-menu" id="menuStaff" aria-labelledby="btnDropStaff">
                        </div>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">LOẠI ĐƠN</label>
                    <div class="dropdown">
                        <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropLoaiDon" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" style="min-width: 200px;">
                            -- Tất cả loại đơn --
                        </button>
                        <div class="dropdown-menu dropdown-combo-menu" id="menuLoaiDon" aria-labelledby="btnDropLoaiDon">
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_XinRaNgoai_1"><span>Ra ngoài (1)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_MangHangHoaRaCong_2"><span>Hàng hóa (2)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_XeCongTac_3"><span>Xe công tác (3)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_XeDaily_4"><span>Xe Daily (4)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_DonTiepKhac_5"><span>Đón khách (5)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_NhaThauQuaCong_6"><span>Nhà thầu (6)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_HoTroTienDienThoai_7"><span>Tiền ĐT (7)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_DoiCaLam_8"><span>Đổi ca (8)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_DonHoTroCongTac_9"><span>HT Công tác (9)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_DonKiTucXa_10"><span>Ký túc xá (10)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_DonLamLaiThe_11"><span>Làm lại thẻ (11)</span></label>
                            <label class="dropdown-combo-item"><input type="checkbox" class="chk-form-type" value="HR_DonSuDungDienThoai_12"><span>Sử dụng ĐT (12)</span></label>
                        </div>
                    </div>
                    <input type="hidden" id="hfExportLoaiDon" name="loaiDon" value="" />
                </div>

                <div style="display: flex; gap: 10px;">
                    <button type="button" class="btn-clear-filter" onclick="clearAllFilters()">
                        <i class="fa fa-refresh"></i> Làm mới
                    </button>
                    <button type="submit" style="background: #10b981; color: white; border: none; padding: 0 25px; border-radius: 12px; font-weight: 1000; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s; height: 42px;">
                        <i class="fa fa-file-excel-o"></i> XUẤT EXCEL
                    </button>
                </div>
            </form>
        </div>

        @* --- STATS ROW --- *@
        <div class="mobile-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 25px;">
            <div class="stat-card" style="background: white; padding: 20px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <div style="font-size: 10px; font-weight: 900; color: #1e293b; text-transform: uppercase; margin-bottom: 5px;">TỔNG HOÀN TẤT</div>
                <div id="stat-total" style="font-size: 26px; font-weight: 1000; color: #1e293b;">0</div>
            </div>
            <div class="stat-card" style="background: #eff6ff; padding: 20px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <div style="font-size: 10px; font-weight: 900; color: #1e40af; text-transform: uppercase; margin-bottom: 5px;">KẾT QUẢ TÌM KIẾM</div>
                <div id="stat-hr" style="font-size: 26px; font-weight: 1000; color: #1e40af;">0</div>
            </div>
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 180px;">Thông tin hoàn tất</th>
                        <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 18px 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr>
                        <td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none;">
                            <i class="fa fa-spinner fa-spin" style="font-size: 32px; margin-bottom: 15px;"></i>
                            <p style="font-weight: 600;">Đang tải dữ liệu báo cáo...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @* --- PHẦN PHÂN TRANG --- *@
        <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; margin-top: 5px;">
            <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: #1e40af;">1</span> / <span id="totalPagesNum">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                    Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
                </div>
            </div>
        </div>

    </div>
</div>

@* --- CẤU TRÚC MODAL BỘ LỌC ĐƠN TÙY CHỈNH --- *@
<div id="modalOverlay" class="modal-overlay" onclick="closeTypeFilterModal()"></div>
<div id="typeFilterModal" class="type-filter-modal">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
        <h3 style="margin: 0; color: #1e293b; font-size: 18px; font-weight: 900; display: flex; align-items: center; gap: 8px;">
            <i class="fa fa-sliders" style="color: #1e40af;"></i> CÀI ĐẶT HIỂN THỊ ĐƠN
        </h3>
        <button onclick="closeTypeFilterModal()" style="background: none; border: none; font-size: 20px; color: #94a3b8; cursor: pointer;">&times;</button>
    </div>

    <div class="type-checkbox-grid">
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XinRaNgoai_1" onchange="updateToggleBtnText()"> Đơn ra ngoài</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_MangHangHoaRaCong_2" onchange="updateToggleBtnText()"> Đơn hàng hóa</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XeCongTac_3" onchange="updateToggleBtnText()"> Xe công tác</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XeDaily_4" onchange="updateToggleBtnText()"> Xe Daily</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonTiepKhac_5" onchange="updateToggleBtnText()"> Đón khách</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_NhaThauQuaCong_6" onchange="updateToggleBtnText()"> Nhà thầu</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_HoTroTienDienThoai_7" onchange="updateToggleBtnText()"> Tiền ĐT</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DoiCaLam_8" onchange="updateToggleBtnText()"> Đổi ca</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonHoTroCongTac_9" onchange="updateToggleBtnText()"> HT Công tác</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonKiTucXa_10" onchange="updateToggleBtnText()"> Ký túc xá</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonLamLaiThe_11" onchange="updateToggleBtnText()"> Làm lại thẻ</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonSuDungDienThoai_12" onchange="updateToggleBtnText()"> SD Điện thoại</label>
    </div>

    <div style="display: flex; justify-content: space-between; gap: 10px;">
        <button id="btnToggleSelectAll" type="button" onclick="toggleSelectAll()" style="padding: 12px; background: #f1f5f9; color: #475569; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; flex: 1; transition: 0.2s;" onmouseover="this.style.background='#e2e8f0'">Chọn tất cả</button>
        <button onclick="saveAndApplyTypeFilters()" style="padding: 12px; background: #1e40af; color: white; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; flex: 2; transition: 0.2s; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);" onmouseover="this.style.background='#1e3a8a'">
            <i class="fa fa-save"></i> Lưu & Áp dụng
        </button>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];
        let filteredData = [];
        let currentPage = 1;
        let rowsPerPage = 20;

        const STORAGE_KEY = 'HrSelectedFormTypes_v2';

        const formMapping = {
            "HR_XinRaNgoai_1": "RA NGOÀI",
            "HR_MangHangHoaRaCong_2": "HÀNG HÓA",
            "HR_XeCongTac_3": "XE CÔNG TÁC",
            "HR_XeDaily_4": "DAILY",
            "HR_DonTiepKhac_5": "ĐÓN KHÁCH",
            "HR_NhaThauQuaCong_6": "NHÀ THẦU",
            "HR_HoTroTienDienThoai_7": "TIỀN ĐIỆN THOẠI",
            "HR_DoiCaLam_8": "ĐỔI CA",
            "HR_DonHoTroCongTac_9": "HỖ TRỢ CÔNG TÁC",
            "HR_DonKiTucXa_10": "KÝ TÚC XÁ",
            "HR_DonLamLaiThe_11": "LÀM LẠI THẺ",
            "HR_DonSuDungDienThoai_12": "SỬ DỤNG ĐIỆN THOẠI"
        };

        document.addEventListener("DOMContentLoaded", async () => {
            // --- 1. PHỤC HỒI TEXT SEARCH ---
            const savedText = sessionStorage.getItem("savedBaoCaoText");
            if (savedText) document.getElementById("quickSearch").value = savedText;

            // --- 2. PHỤC HỒI NGÀY THÁNG ---
            const savedFrom = sessionStorage.getItem("savedFromDateBaoCao");
            if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

            const savedTo = sessionStorage.getItem("savedToDateBaoCao");
            if (savedTo) document.getElementById("txtToDate").value = savedTo;

            // Lắng nghe sự kiện thay đổi trạng thái Checkbox lồng trong Dropdown Menu nâng cao mới
            $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
                const $menu = $(this).closest('.dropdown-combo-menu');
                updateDropdownButtonLabel($menu);

                // Nếu thay đổi ở cụm chọn Loại Đơn xuất Excel, đồng bộ giá trị sang ô input ẩn và text nút bấm chính
                if ($menu.attr('id') === 'menuLoaiDon') {
                    let selectedValues = $('.chk-form-type:checked').map(function() { return $(this).val(); }).get();
                    // Để giữ khả năng tương thích submit form GET của C#, lấy giá trị đầu tiên hoặc chuỗi rỗng
                    document.getElementById('hfExportLoaiDon').value = selectedValues.length > 0 ? selectedValues[0] : "";
                }

                applyAllFilters();
            });

            try {
                const response = await fetch('/FormHR/GetXuatBaoCaoData');
                masterData = await response.json();

                document.getElementById("stat-total").innerText = masterData.length;

                // Nạp các Checkbox vào danh sách thả xuống
                populateDropdowns(masterData);

                // --- 3. PHỤC HỒI CACHE TRẠNG THÁI TÍCH CHỌN MULTI-SELECT ---
                const savedBoPhanStr = sessionStorage.getItem("savedBoPhanBaoCao");
                if (savedBoPhanStr) {
                    try {
                        let arrDept = JSON.parse(savedBoPhanStr) || [];
                        if (!Array.isArray(arrDept) && savedBoPhanStr) arrDept = [savedBoPhanStr];
                        arrDept.forEach(d => { $(`.chk-dept[value="${d}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuBoPhan'));
                    } catch(e){}
                }

                const savedStaffStr = sessionStorage.getItem("savedStaffBaoCao");
                if (savedStaffStr) {
                    try {
                        let arrStaff = JSON.parse(savedStaffStr) || [];
                        if (!Array.isArray(arrStaff) && savedStaffStr) arrStaff = [savedStaffStr];
                        arrStaff.forEach(s => { $(`.chk-staff[value="${s}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuStaff'));
                    } catch(e){}
                }

                const savedLoaiDonStr = sessionStorage.getItem("savedLoaiDonBaoCao");
                if (savedLoaiDonStr) {
                    try {
                        let arrLoai = JSON.parse(savedLoaiDonStr) || [];
                        if (!Array.isArray(arrLoai) && savedLoaiDonStr) arrLoai = [savedLoaiDonStr];
                        arrLoai.forEach(l => { $(`.chk-form-type[value="${l}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuLoaiDon'));
                        document.getElementById('hfExportLoaiDon').value = arrLoai.length > 0 ? arrLoai[0] : "";
                    } catch(e){}
                }

                // Modal filter cấu hình phân loại đơn phụ
                loadSavedTypeFilters();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: red; border:none;">Lỗi tải dữ liệu. Vui lòng F5.</td></tr>`;
            }
        });

        // Sinh động cấu trúc Checkbox lồng bên trong Menu
        function populateDropdowns(data) {
            const menuBoPhan = document.getElementById("menuBoPhan");
            const menuStaff = document.getElementById("menuStaff");

            // Danh sách Bộ phận duy nhất
            const depts = [...new Set(data.map(x => x.boPhan).filter(Boolean))].sort();
            menuBoPhan.innerHTML = '';
            depts.forEach(d => {
                menuBoPhan.insertAdjacentHTML('beforeend', `
                    <label class="dropdown-combo-item">
                        <input type="checkbox" class="chk-dept" value="${d}">
                        <span>${d}</span>
                    </label>
                `);
            });

            // Gộp tất cả tên người hỗ trợ từ mảng supportNames
            let allStaffs = [];
            data.forEach(item => {
                if(item.supportNames && item.supportNames.length > 0) {
                    allStaffs.push(...item.supportNames);
                }
            });
            const staffSet = [...new Set(allStaffs.filter(n => n && n !== "N/A"))].sort();
            menuStaff.innerHTML = '';
            staffSet.forEach(s => {
                menuStaff.insertAdjacentHTML('beforeend', `
                    <label class="dropdown-combo-item">
                        <input type="checkbox" class="chk-staff" value="${s}">
                        <span>${s}</span>
                    </label>
                `);
            });
        }

        // Hàm cập nhật nhãn cho khối nút bấm Dropdown Checkbox
        function updateDropdownButtonLabel($menu) {
            let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
            let $btn = $menu.siblings('.dropdown-combo-btn');

            if (totalChecked === 0) {
                $btn.text($menu.attr('id') === 'menuLoaiDon' ? '-- Tất cả loại đơn --' : '-- Tất cả --');
            } else if (totalChecked === 1) {
                $btn.text($menu.find('input[type="checkbox"]:checked').first().parent().text().trim());
            } else {
                $btn.text(`Đã chọn (${totalChecked})`);
            }
        }

        function openTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'block';
            document.getElementById('typeFilterModal').style.display = 'block';
        }

        function closeTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'none';
            document.getElementById('typeFilterModal').style.display = 'none';
            loadSavedTypeFilters(false);
        }

        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !isAllChecked);
            updateToggleBtnText();
        }

        function updateToggleBtnText() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            const btn = document.getElementById("btnToggleSelectAll");
            if (btn) btn.innerText = isAllChecked ? "Bỏ chọn tất cả" : "Chọn tất cả";
        }

        function loadSavedTypeFilters(applyToTable = true) {
            let saved = localStorage.getItem(STORAGE_KEY);
            let checkboxes = document.querySelectorAll('.type-checkbox');

            if (saved) {
                let selectedArray = JSON.parse(saved);
                checkboxes.forEach(cb => cb.checked = selectedArray.includes(cb.value));
            } else {
                checkboxes.forEach(cb => cb.checked = true);
            }

            updateToggleBtnText();
            if (applyToTable) applyAllFilters();
        }

        function saveAndApplyTypeFilters() {
            let selectedArray = [];
            document.querySelectorAll('.type-checkbox:checked').forEach(cb => {
                selectedArray.push(cb.value);
            });
            localStorage.setItem(STORAGE_KEY, JSON.stringify(selectedArray));
            closeTypeFilterModal();
            applyAllFilters();
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            applyAllFilters();
        }

        function clearAllFilters() {
            document.getElementById("quickSearch").value = "";
            document.getElementById("txtFromDate").value = "";
            document.getElementById("txtToDate").value = "";

            // Gỡ bỏ trạng thái tích chọn toàn bộ hệ thống ô Checkbox bộ lọc mới
            $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
            $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });
            document.getElementById('hfExportLoaiDon').value = "";

            sessionStorage.removeItem("savedBaoCaoText");
            sessionStorage.removeItem("savedFromDateBaoCao");
            sessionStorage.removeItem("savedToDateBaoCao");
            sessionStorage.removeItem("savedBoPhanBaoCao");
            sessionStorage.removeItem("savedStaffBaoCao");
            sessionStorage.removeItem("savedLoaiDonBaoCao");

            applyAllFilters();
        }

        // ====================================================
        // HÀM LỌC TỔNG HỢP MỚI (HỖ TRỢ MẢNG ARRAY INCLUDES)
        // ====================================================
        function applyAllFilters() {
            const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();
            const fromDateStr = document.getElementById("txtFromDate").value;
            const toDateStr = document.getElementById("txtToDate").value;

            // Thu thập mảng các giá trị đang được chọn từ Checkbox Dropdown
            const selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
            const selectedStaffs = $('.chk-staff:checked').map(function() { return $(this).val(); }).get();
            const selectedLoaiDons = $('.chk-form-type:checked').map(function() { return $(this).val(); }).get();

            sessionStorage.setItem("savedBaoCaoText", document.getElementById("quickSearch").value);
            sessionStorage.setItem("savedFromDateBaoCao", fromDateStr);
            sessionStorage.setItem("savedToDateBaoCao", toDateStr);
            sessionStorage.setItem("savedBoPhanBaoCao", JSON.stringify(selectedDepts));
            sessionStorage.setItem("savedStaffBaoCao", JSON.stringify(selectedStaffs));
            sessionStorage.setItem("savedLoaiDonBaoCao", JSON.stringify(selectedLoaiDons));

            let savedTypesStr = localStorage.getItem(STORAGE_KEY);
            let allowedTypes = savedTypesStr ? JSON.parse(savedTypesStr) : null;

            filteredData = masterData.filter(item => {
                // 1. Lọc Modal phụ (Phân loại đơn)
                if (allowedTypes && item.idForm && !allowedTypes.includes(item.idForm)) return false;

                // 2. Lọc mảng nhiều Bộ phận cùng lúc
                if (selectedDepts.length > 0 && !selectedDepts.includes(item.boPhan)) return false;

                // 3. Lọc mảng nhiều Người hỗ trợ (Giao cắt mảng)
                if (selectedStaffs.length > 0) {
                    let itemStaffs = item.supportNames || [];
                    let hasMatch = itemStaffs.some(staff => selectedStaffs.includes(staff));
                    if (!hasMatch) return false;
                }

                // 4. Lọc mảng nhiều Loại Đơn từ Checkbox Dropdown
                if (selectedLoaiDons.length > 0) {
                    let hasMatchLoai = selectedLoaiDons.some(typeKey => {
                        const keyword = formMapping[typeKey];
                        return keyword && item.tenForm.toUpperCase().includes(keyword);
                    });
                    if (!hasMatchLoai) return false;
                }

                // 5. Lọc Khoảng Thời Gian Hoàn Tất (Format: dd/MM/yyyy HH:mm)
                if (fromDateStr || toDateStr) {
                    if (!item.timeAdmin || item.timeAdmin === "--") return false;
                    const datePart = item.timeAdmin.split(' ')[0];
                    const parts = datePart.split('/');
                    if (parts.length === 3) {
                        const itemDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
                        if (fromDateStr) {
                            const fromD = new Date(fromDateStr + "T00:00:00");
                            if (itemDate < fromD) return false;
                        }
                        if (toDateStr) {
                            const toD = new Date(toDateStr + "T23:59:59");
                            if (itemDate > toD) return false;
                        }
                    }
                }

                // 6. Lọc văn bản tìm kiếm tự do
                if (searchText) {
                    const supportText = item.supportNames.join(" ");
                    const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${supportText} ${item.tenAdmin}`.toUpperCase();
                    if (!rowString.includes(searchText)) return false;
                }

                return true;
            });

            document.getElementById("stat-hr").innerText = filteredData.length;

            currentPage = 1;
            renderCurrentPage();
        }

        function renderCurrentPage() {
            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const pageData = filteredData.slice(startIndex, endIndex);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" style="padding: 50px 15px; text-align: center; color: #94a3b8; width: 100%; display: table-cell !important; border: none !important;">
                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
                                <i class="fa fa-folder-open-o" style="font-size: 40px; margin-bottom: 10px; opacity: 0.5; color: #64748b;"></i>
                                <span style="font-weight: 600; font-size: 14px; white-space: normal; text-align: center; color: #64748b;">
                                    Không tìm thấy dữ liệu yêu cầu phù hợp với bộ lọc.
                                </span>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-calendar"></i> ${item.timeNguoiTao}</span>`;
                if (item.hasB2) badgesHtml += `<span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff; margin-left:5px;">BP.XN OK</span>`;
                if (item.hasGD) badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:5px;">GĐ OK</span>`;

                let supportHtml = "";
                if (item.supportNames.length > 0) {
                    item.supportNames.forEach(name => {
                        supportHtml += `
                            <div style="display: flex; align-items: center; gap: 6px; justify-content: flex-end;">
                                <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                <span style="font-weight: 700; color: #334155; font-size: 13px;">${name}</span>
                            </div>`;
                    });
                } else {
                    supportHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">N/A</span>`;
                }

                html += `
                    <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #1e40af;">MS: ${item.soNhanVien}</span></div>
                            </div>
                        </td>
                        <td data-label="Thông tin đơn" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center; margin-top:4px; justify-content: flex-end;">
                                    ${badgesHtml}
                                </div>
                            </div>
                        </td>
                        <td data-label="Hỗ trợ" style="padding: 15px 20px;">
                            <div class="mobile-td-val" style="gap: 5px;">${supportHtml}</div>
                        </td>
                        <td data-label="Hoàn tất" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-size: 11px; font-weight: 800; color: #1e40af;">
                                    <i class="fa fa-check-square-o"></i> ${item.tenAdmin}
                                </div>
                                <div style="font-size: 10px; color: #64748b; font-weight: 700; margin-top: 4px;">
                                    <i class="fa fa-clock-o"></i> ${item.timeAdmin}
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <span style="background:#ecfdf5; color:#047857; padding:6px 12px; border-radius:8px; font-size:10px; font-weight:1000; border: 1.5px solid #047857; display: inline-block; min-width: 100px; text-transform: uppercase;">
                                ${item.trangThai}
                            </span>
                        </td>
                        <td style="padding: 15px 20px; text-align: right;">
                            <a href="/FormHR/ChiTiet/${item.id}"
                               style="text-decoration: none; padding: 10px 20px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: #1e40af; color: #ffffff; width: 100%; text-align: center; box-sizing: border-box;">
                                Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                            </a>
                        </td>
                    </tr>`;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = ""; if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) {
                        const dot = document.createElement("span");
                        dot.innerText = "..."; dot.style.padding = "8px"; dot.style.color = "#64748b"; dot.style.fontWeight = "700";
                        container.appendChild(dot);
                    }
                    continue;
                }

                const btn = document.createElement("button");
                btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    renderCurrentPage();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}