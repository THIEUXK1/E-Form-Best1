
@{
    ViewData["Title"] = "XuatBaoCao";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";
}

@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@using System.Security.Claims

@{

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";

    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.TrangThai == "Hoàn tất") ?? 0;
    var processing = Model?.Count(x => x.TrangThai == "HR Đang xử lý") ?? 0;
    var cancelled = Model?.Count(x => x.TrangThai == "Đã hủy") ?? 0;
    var waitingManager = Model?.Count(x => x.TrangThai == "Chờ QL Duyệt") ?? 0;
}

<style>
    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 26px;
        height: 26px;
        background: #eff6ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e40af;
        border: 1px solid #dbeafe;
    }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', 'Segoe UI', sans-serif; color: #1e293b;">
    <div style="max-width: 1550px; margin: 0 auto;">

        @* --- TOP BAR --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
            <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
                <span style="background: #1e40af; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);">
                    <i class="fa fa-archive"></i>
                </span>
                KHO LƯU TRỮ ĐƠN HR
            </h2>

            <div style="display: flex; gap: 12px; align-items: center;">
                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 10px 15px 10px 40px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700;">
                </div>
                <div style="font-size: 11px; background: #1e40af; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- STATS ROW --- *@
        <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 25px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG LƯU TRỮ", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                    new { Label = "CHỜ QL DUYỆT", Value = waitingManager, Color = "#b45309", Bg = "#fffbeb", Filter = "Chờ QL Duyệt" },
                    new { Label = "HR ĐANG XỬ LÝ", Value = processing, Color = "#1e40af", Bg = "#eff6ff", Filter = "HR Đang xử lý" },
                    new { Label = "ĐÃ HOÀN TẤT", Value = completed, Color = "#10b981", Bg = "#ecfdf5", Filter = "Hoàn tất" },
                    new { Label = "ĐƠN ĐÃ HỦY", Value = cancelled, Color = "#b91c1c", Bg = "#fef2f2", Filter = "Đã hủy" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')"
                     style="background: @s.Bg; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);"
                     onmouseover="this.style.transform='translateY(-3px)'; this.style.borderColor='@s.Color';"
                     onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(0,0,0,0.03)';">
                    <div style="font-size: 11px; font-weight: 900; color: @s.Color; text-transform: uppercase; margin-bottom: 5px;">@s.Label</div>
                    <div style="font-size: 26px; font-weight: 1000; color: @s.Color;">@s.Value</div>
                </div>
            }
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 150px;">Tiến trình</th>
                        <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 18px 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        string pWidth, pColor, stBg, stFg;
                        switch (item.TrangThai)
                        {
                            case "Đã hủy": pWidth = "100%"; pColor = "#ef4444"; stBg = "#fee2e2"; stFg = "#b91c1c"; break;
                            case "Hoàn tất": pWidth = "100%"; pColor = "#10b981"; stBg = "#ecfdf5"; stFg = "#047857"; break;
                            case "HR Đang xử lý": pWidth = "65%"; pColor = "#1e40af"; stBg = "#dbeafe"; stFg = "#1e40af"; break;
                            case "Chờ QL Duyệt": pWidth = "35%"; pColor = "#f59e0b"; stBg = "#fef3c7"; stFg = "#b45309"; break;
                            default: pWidth = "10%"; pColor = "#94a3b8"; stBg = "#f1f5f9"; stFg = "#475569"; break;
                        }

                        <tr style="border-bottom: 1px solid #f1f5f9;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">@item.BoPhan • <span style="color: #1e40af;">MS: @item.SoNhanVien</span></div>
                            </td>

                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                    <span>ID: #@item.Id • <i class="fa fa-clock-o"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>

                                    @if (item.HrNguoiXacNhans != null && item.HrNguoiXacNhans.Any())
                                    {
                                        var listXN = item.HrNguoiXacNhans.ToList();
                                        int countDone = listXN.Count(x => x.TrangThaiXacNhan == 1);
                                        int countAll = listXN.Count;
                                        
                                        // Logic màu sắc giống bên Quản lý
                                        string xnColor = listXN.Any(x => x.TrangThaiXacNhan == 2) ? "#ef4444" : (countDone == countAll ? "#10b981" : "#f59e0b");
                                        
                                        <span class="sub-badge" style="color: @xnColor; border-color: @xnColor; background: @(xnColor)10;">
                                            <i class="fa fa-check-circle"></i> XN (@countDone/@countAll)
                                        </span>
                                    }
                                </div>
                            </td>

                            <td style="padding: 15px 20px;">
                                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                                    @if (item.HrCtNguoiHoTros != null && item.HrCtNguoiHoTros.Any())
                                    {
                                        foreach (var support in item.HrCtNguoiHoTros)
                                        {
                                            <div style="display: flex; align-items: center; gap: 6px;">
                                                <div class="support-avatar">
                                                    <i class="fa fa-user-circle-o"></i>
                                                </div>
                                                <span style="font-weight: 700; color: #334155; font-size: 13px;">@(support.IdHrNguoiHoTroNavigation?.Ten ?? "N/A")</span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa chỉ định</span>
                                    }
                                </div>
                            </td>

                            <td style="padding: 15px 20px;">
                                <div style="font-size: 9px; font-weight: 1000; color: @pColor; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>TIẾN ĐỘ</span> <span>@pWidth</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                    <div style="width: @pWidth; height: 100%; background: @pColor; border-radius: 10px;"></div>
                                </div>
                            </td>

                            <td style="padding: 15px 20px; text-align: center;">
                                <span style="background:@stBg; color:@stFg; padding:6px 12px; border-radius:8px; font-size:10px; font-weight:1000; border: 1.5px solid @stFg; display: inline-block; min-width: 90px; text-transform: uppercase;">
                                    @item.TrangThai
                                </span>
                            </td>

                            <td style="padding: 15px 20px; text-align: right;">
                                <a href="/FormHR/ChiTiet/@item.Id"
                                       style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: #1e40af; color: #ffffff;">
                                    Chi tiết <i class="fa fa-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const input = document.getElementById("searchInput");
        const filter = input.value.toUpperCase();
        const tr = document.querySelectorAll("#dataTable tbody tr");
        tr.forEach(row => {
            const text = row.innerText.toUpperCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    }

    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();
        const table = document.getElementById("dataTable");
        table.style.opacity = "0.5";
        setTimeout(() => { table.style.opacity = "1"; }, 150);
    }
</script>