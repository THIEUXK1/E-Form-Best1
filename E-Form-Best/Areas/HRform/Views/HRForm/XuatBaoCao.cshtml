@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- 1. LẤY THÔNG TIN ROLE ---
    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";

    // --- 2. LOGIC THỐNG KÊ (Dựa trên Model đã lọc từ Controller) ---
    var total = Model?.Count() ?? 0;
    var listData = Model?.ToList() ?? new List<E_Form_Best.Models.ITForm.FormHr>();

    // Vì trang này chỉ hiện đơn Hoàn tất (IdAdmin != null), các trạng thái khác sẽ bằng 0
    // nhưng tôi vẫn giữ logic để giao diện không bị thay đổi so với bản gốc của bạn.
    var completed = listData.Count(x => x.TrangThai == "Hoàn tất");
    var cancelled = listData.Count(x => x.TrangThai == "Đã hủy/Từ chối");
    var processing = listData.Count(x => x.TrangThai == "HR Đang xử lý");
}

<style>
    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 26px;
        height: 26px;
        background: #eff6ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e40af;
        border: 1px solid #dbeafe;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
    }

    .filter-input {
        padding: 8px 12px;
        border-radius: 10px;
        border: 2px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        outline: none;
    }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1600px; margin: 0 auto;">

        @* --- TOP BAR: TIÊU ĐỀ & TÌM KIẾM --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
            <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
                <span style="background: #1e40af; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);">
                    <i class="fa fa-archive"></i>
                </span>
                KHO LƯU TRỮ ĐƠN HR (ĐÃ HOÀN TẤT)
            </h2>

            <div style="display: flex; gap: 12px; align-items: center;">
                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 10px 15px 10px 40px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700;">
                </div>
                <div style="font-size: 11px; background: #1e40af; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- BỘ LỌC & XUẤT EXCEL (MỚI THÊM) --- *@
        <div style="background: white; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; margin-bottom: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
            <form action="/FormHR/ExportExcelHR" method="get" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">TỪ NGÀY (HOÀN TẤT)</label>
                    <input type="date" name="tuNgay" class="filter-input">
                </div>
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">ĐẾN NGÀY</label>
                    <input type="date" name="denNgay" class="filter-input">
                </div>
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">LOẠI ĐƠN</label>
                    <select name="loaiDon" class="filter-input" style="min-width: 200px;">
                        <option value="">-- Tất cả loại đơn --</option>
                        <option value="HR_XinRaNgoai_1">Ra ngoài (1)</option>
                        <option value="HR_MangHangHoaRaCong_2">Hàng hóa (2)</option>
                        <option value="HR_XeCongTac_3">Xe công tác (3)</option>
                        <option value="HR_XeDaily_4">Xe Daily (4)</option>
                        <option value="HR_DonTiepKhac_5">Đón khách (5)</option>
                        <option value="HR_NhaThauQuaCong_6">Nhà thầu (6)</option>
                        <option value="HR_HoTroTienDienThoai_7">Tiền ĐT (7)</option>
                        <option value="HR_DoiCaLam_8">Đổi ca (8)</option>
                        <option value="HR_DonHoTroCongTac_9">HT Công tác (9)</option>
                    </select>
                </div>
                <button type="submit" style="background: #10b981; color: white; border: none; padding: 11px 25px; border-radius: 12px; font-weight: 1000; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.3s;">
                    <i class="fa fa-file-excel-o"></i> XUẤT EXCEL
                </button>
            </form>
        </div>

        @* --- STATS ROW --- *@
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 25px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG HOÀN TẤT", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                    new { Label = "NGƯỜI DUYỆT HR", Value = total, Color = "#1e40af", Bg = "#eff6ff", Filter = "Hoàn tất" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')" class="stat-card"
                     style="background: @s.Bg; padding: 20px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                    <div style="font-size: 10px; font-weight: 900; color: @s.Color; text-transform: uppercase; margin-bottom: 5px;">@s.Label</div>
                    <div style="font-size: 26px; font-weight: 1000; color: @s.Color;">@s.Value</div>
                </div>
            }
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 180px;">Thông tin hoàn tất</th>
                        <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 18px 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            // Trạng thái đơn ở đây mặc định là hoàn tất vì đã lọc từ Controller
                            string stBg = "#ecfdf5"; string stFg = "#047857";

                            <tr style="border-bottom: 1px solid #f1f5f9;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                                <td style="padding: 15px 20px;">
                                    <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                    <div style="font-size: 11px; color: #64748b; font-weight: 800;">@item.BoPhan • <span style="color: #1e40af;">MS: @item.SoNhanVien</span></div>
                                </td>

                                <td style="padding: 15px 20px;">
                                    <div style="font-weight: 800; color: #1e293b; font-size: 14px;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                    <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                        <span>ID: #@item.Id • <i class="fa fa-calendar"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>
                                        
                                        @if (item.HrQuanLyDuyetB2s?.Any() == true)
                                        {
                                            <span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff;">BP.XN OK</span>
                                        }
                                        @if (item.HrNguoiXacNhans?.Any() == true)
                                        {
                                            <span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff;">GĐ OK</span>
                                        }
                                    </div>
                                </td>

                                <td style="padding: 15px 20px;">
                                    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                                        @if (item.HrCtNguoiHoTros != null && item.HrCtNguoiHoTros.Any())
                                        {
                                            foreach (var support in item.HrCtNguoiHoTros)
                                            {
                                                <div style="display: flex; align-items: center; gap: 6px;">
                                                    <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                                    <span style="font-weight: 700; color: #334155; font-size: 13px;">@(support.IdHrNguoiHoTroNavigation?.Ten ?? "N/A")</span>
                                                </div>
                                            }
                                        }
                                        else
                                        {

                                            <span style="color: #cbd5e1; font-size: 12px; font-style: italic;">N/A</span>
                                        }
                                    </div>
                                </td>

                                <td style="padding: 15px 20px;">
                                    <div style="font-size: 11px; font-weight: 800; color: #1e40af;">
                                        <i class="fa fa-check-square-o"></i> Duyệt bởi: @item.TenAdmin
                                    </div>
                                    <div style="font-size: 10px; color: #64748b; font-weight: 700; margin-top: 4px;">
                                        <i class="fa fa-clock-o"></i> Lúc: @item.TimeAdmin?.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </td>

                                <td style="padding: 15px 20px; text-align: center;">
                                    <span style="background:@stBg; color:@stFg; padding:6px 12px; border-radius:8px; font-size:10px; font-weight:1000; border: 1.5px solid @stFg; display: inline-block; min-width: 100px; text-transform: uppercase;">
                                        HOÀN TẤT
                                    </span>
                                </td>

                                <td style="padding: 15px 20px; text-align: right;">
                                    <a href="/FormHR/ChiTiet/@item.Id"
                                           style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: #1e40af; color: #ffffff;">
                                        Chi tiết <i class="fa fa-arrow-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const filter = document.getElementById("searchInput").value.toUpperCase();
        const trs = document.querySelectorAll("#dataTable tbody tr");
        trs.forEach(row => {
            row.style.display = row.innerText.toUpperCase().includes(filter) ? "" : "none";
        });
    }

    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();
        const table = document.getElementById("dataTable");
        table.style.opacity = "0.5";
        setTimeout(() => { table.style.opacity = "1"; }, 150);
    }
</script>