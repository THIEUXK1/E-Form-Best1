@using System.Security.Claims

@{
    ViewData["Title"] = "Báo Cáo - Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    .sub-badge {
        font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 700;
        display: inline-flex; align-items: center; gap: 3px; border: 1px solid; margin-top: 2px;
    }
    .support-avatar {
        width: 26px; height: 26px; background: #eff6ff; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: #1e40af; border: 1px solid #dbeafe;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important; }
    .filter-input {
        padding: 8px 12px; border-radius: 10px; border: 2px solid #cbd5e1; font-size: 13px; font-weight: 600; outline: none;
    }

    /* Phân trang JS CSS */
    .page-btn {
        padding: 8px 16px; border-radius: 10px; border: 1px solid #e2e8f0; background: white; color: #64748b; font-weight: 700; font-size: 13px; cursor: pointer; transition: 0.3s;
    }
    .page-btn.active {
        background: #1e40af; color: white; border-color: #1e40af; box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
    }
    .page-btn:hover:not(.active) {
        background: #f8fafc; border-color: #cbd5e1;
    }

    /* ==========================================
       BỔ SUNG CSS CHO MOBILE RESPONSIVE
       ========================================== */
    @@media (max-width: 768px) {
        .mobile-top-bar {
            flex-direction: column !important;
            align-items: stretch !important;
        }
        .mobile-controls {
            flex-direction: column !important;
            width: 100% !important;
        }
        .mobile-search-input {
            width: 100% !important;
        }
        .mobile-stat-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }
        .filter-form {
            flex-direction: column !important;
            align-items: stretch !important;
        }
        .filter-input {
            width: 100% !important;
        }
        
        /* Chuyển bảng thành dạng Card */
        #dataTable thead {
            display: none; 
        }
        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }
        #dataTable tr {
            margin-bottom: 15px;
            border: 1px solid #e2e8f0 !important;
            border-radius: 15px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }
        #dataTable td {
            text-align: right !important;
            padding: 12px 15px !important;
            border-bottom: 1px dashed #f1f5f9;
            position: relative;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        #dataTable td:last-child {
            border-bottom: none;
            background: #f8fafc;
            justify-content: center;
        }
        /* Hiển thị nhãn cột bằng data-label */
        #dataTable td::before {
            content: attr(data-label);
            float: left;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
            font-size: 10px;
        }
        .mobile-td-val {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            max-width: 65%;
        }
        .pagination-container {
            flex-direction: column !important;
            gap: 20px;
            text-align: center !important;
        }
        #paginationButtons {
            justify-content: center;
        }
    }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1600px; margin: 0 auto;">

        @* --- TOP BAR --- *@
        <div class="mobile-top-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
            <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
                <span style="background: #1e40af; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);">
                    <i class="fa fa-bar-chart"></i>
                </span>
                XUẤT BÁO CÁO HR (ĐÃ HOÀN TẤT)
            </h2>

            <div class="mobile-controls" style="display: flex; gap: 12px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #cbd5e1;">
                    <span style="font-size: 12px; font-weight: 700; color: #64748b;">Hiển thị:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #1e40af; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div class="mobile-search-input" style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                    <input type="text" id="quickSearch" onkeyup="handleFilterAndPaginate()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 10px 15px 10px 40px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700; width: 100%; box-sizing: border-box;">
                </div>
                <div style="font-size: 11px; background: #1e40af; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- BỘ LỌC & XUẤT EXCEL --- *@
        <div style="background: white; padding: 20px; border-radius: 20px; border: 1px solid #e2e8f0; margin-bottom: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
            <form action="/FormHR/ExportExcelHR" method="get" class="filter-form" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">TỪ NGÀY (HOÀN TẤT)</label>
                    <input type="date" name="tuNgay" class="filter-input">
                </div>
                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">ĐẾN NGÀY</label>
                    <input type="date" name="denNgay" class="filter-input">
                </div>
                <div style="display: flex; flex-direction: column; gap: 5px; flex-grow: 1;">
                    <label style="font-size: 11px; font-weight: 800; color: #64748b;">LOẠI ĐƠN</label>
                    <select name="loaiDon" class="filter-input" style="min-width: 200px;">
                        <option value="">-- Tất cả loại đơn --</option>
                        <option value="HR_XinRaNgoai_1">Ra ngoài (1)</option>
                        <option value="HR_MangHangHoaRaCong_2">Hàng hóa (2)</option>
                        <option value="HR_XeCongTac_3">Xe công tác (3)</option>
                        <option value="HR_XeDaily_4">Xe Daily (4)</option>
                        <option value="HR_DonTiepKhac_5">Đón khách (5)</option>
                        <option value="HR_NhaThauQuaCong_6">Nhà thầu (6)</option>
                        <option value="HR_HoTroTienDienThoai_7">Tiền ĐT (7)</option>
                        <option value="HR_DoiCaLam_8">Đổi ca (8)</option>
                        <option value="HR_DonHoTroCongTac_9">HT Công tác (9)</option>
                    </select>
                </div>
                <button type="submit" style="background: #10b981; color: white; border: none; padding: 11px 25px; border-radius: 12px; font-weight: 1000; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s; flex-grow: 0;">
                    <i class="fa fa-file-excel-o"></i> XUẤT EXCEL
                </button>
            </form>
        </div>

        @* --- STATS ROW --- *@
        <div class="mobile-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 25px;">
            <div class="stat-card" style="background: white; padding: 20px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <div style="font-size: 10px; font-weight: 900; color: #1e293b; text-transform: uppercase; margin-bottom: 5px;">TỔNG HOÀN TẤT</div>
                <div id="stat-total" style="font-size: 26px; font-weight: 1000; color: #1e293b;">0</div>
            </div>
            <div class="stat-card" style="background: #eff6ff; padding: 20px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                <div style="font-size: 10px; font-weight: 900; color: #1e40af; text-transform: uppercase; margin-bottom: 5px;">NGƯỜI DUYỆT HR</div>
                <div id="stat-hr" style="font-size: 26px; font-weight: 1000; color: #1e40af;">0</div>
            </div>
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 180px;">Thông tin hoàn tất</th>
                        <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 18px 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr>
                        <td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none;">
                            <i class="fa fa-spinner fa-spin" style="font-size: 32px; margin-bottom: 15px;"></i>
                            <p style="font-weight: 600;">Đang tải dữ liệu báo cáo...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @* --- PHẦN PHÂN TRANG --- *@
        <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; margin-top: 5px;">
            <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: #1e40af;">1</span> / <span id="totalPagesNum">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                    Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];     
        let filteredData = [];   
        let currentPage = 1;
        let rowsPerPage = 20;

        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const response = await fetch('/FormHR/GetXuatBaoCaoData');
                masterData = await response.json();
                
                document.getElementById("stat-total").innerText = masterData.length;
                document.getElementById("stat-hr").innerText = masterData.length; 
                
                handleFilterAndPaginate();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: red; border:none;">Lỗi tải dữ liệu. Vui lòng F5.</td></tr>`;
            }
        });

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            currentPage = 1;
            handleFilterAndPaginate();
        }

        function handleFilterAndPaginate() {
            const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();

            filteredData = masterData.filter(item => {
                const supportText = item.supportNames.join(" ");
                const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${supportText} ${item.tenAdmin}`.toUpperCase();
                return searchText === "" || rowString.includes(searchText);
            });

            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const pageData = filteredData.slice(startIndex, endIndex);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border:none; display:block;">Không tìm thấy dữ liệu.</td></tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-calendar"></i> ${item.timeNguoiTao}</span>`;
                if (item.hasB2) badgesHtml += `<span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff; margin-left:5px;">BP.XN OK</span>`;
                if (item.hasGD) badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:5px;">GĐ OK</span>`;

                let supportHtml = "";
                if (item.supportNames.length > 0) {
                    item.supportNames.forEach(name => {
                        supportHtml += `
                            <div style="display: flex; align-items: center; gap: 6px; justify-content: flex-end;">
                                <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                <span style="font-weight: 700; color: #334155; font-size: 13px;">${name}</span>
                            </div>`;
                    });
                } else {
                    supportHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">N/A</span>`;
                }

                html += `
                    <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #1e40af;">MS: ${item.soNhanVien}</span></div>
                            </div>
                        </td>
                        <td data-label="Thông tin đơn" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center; margin-top:4px; justify-content: flex-end;">
                                    ${badgesHtml}
                                </div>
                            </div>
                        </td>
                        <td data-label="Hỗ Trợ" style="padding: 15px 20px;">
                            <div class="mobile-td-val" style="gap: 5px;">${supportHtml}</div>
                        </td>
                        <td data-label="Hoàn tất" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-size: 11px; font-weight: 800; color: #1e40af;">
                                    <i class="fa fa-check-square-o"></i> ${item.tenAdmin}
                                </div>
                                <div style="font-size: 10px; color: #64748b; font-weight: 700; margin-top: 4px;">
                                    <i class="fa fa-clock-o"></i> ${item.timeAdmin}
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <span style="background:#ecfdf5; color:#047857; padding:6px 12px; border-radius:8px; font-size:10px; font-weight:1000; border: 1.5px solid #047857; display: inline-block; min-width: 100px; text-transform: uppercase;">
                                ${item.trangThai}
                            </span>
                        </td>
                        <td style="padding: 15px 20px; text-align: right;">
                            <a href="/FormHR/ChiTiet/${item.id}"
                               style="text-decoration: none; padding: 10px 20px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: #1e40af; color: #ffffff; width: 100%; text-align: center; box-sizing: border-box;">
                                Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                            </a>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = "";
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) {
                        const dot = document.createElement("span");
                        dot.innerText = "...";
                        dot.style.padding = "8px"; dot.style.color = "#64748b"; dot.style.fontWeight = "700";
                        container.appendChild(dot);
                    }
                    continue;
                }

                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    handleFilterAndPaginate();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}