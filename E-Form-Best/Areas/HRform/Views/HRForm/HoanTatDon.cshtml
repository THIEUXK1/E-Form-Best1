@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@using System.Security.Claims
@using System.Linq

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";

    // --- HELPER FUNCTIONS ĐỂ XỬ LÝ LOGIC AND/OR ---
    Func<E_Form_Best.Models.ITForm.FormHr, bool> checkB2Approved = (form) => {
        if (form.HrQuanLyDuyetB2s == null || !form.HrQuanLyDuyetB2s.Any()) return true;
        string type = form.HrQuanLyDuyetB2s.FirstOrDefault()?.Loai?.ToUpper() ?? "AND";
        if (type == "OR" || type == "ANY") return form.HrQuanLyDuyetB2s.Any(x => x.TrangThaiXacNhan == 1);
        return form.HrQuanLyDuyetB2s.All(x => x.TrangThaiXacNhan == 1);
    };

    Func<E_Form_Best.Models.ITForm.FormHr, bool> checkB2Rejected = (form) => {
        if (form.HrQuanLyDuyetB2s == null || !form.HrQuanLyDuyetB2s.Any()) return false;
        return form.HrQuanLyDuyetB2s.Any(x => x.TrangThaiXacNhan == 2);
    };

    // --- 1. LOGIC THỐNG KÊ CHI TIẾT (Đồng bộ tuyệt đối với bảng) ---
    var total = Model?.Count() ?? 0;
    var activeList = Model?.Where(x => !(x.TenForm ?? "").Contains("[ĐÃ HỦY]")).ToList() ?? new List<E_Form_Best.Models.ITForm.FormHr>();

    var daHuy = Model?.Count(x => (x.TenForm ?? "").Contains("[ĐÃ HỦY]")) ?? 0;
    
    var choQuanLy = activeList.Count(x => x.IdNguoiDuyet == null);
    
    var choBPXacNhan = activeList.Count(x => x.IdNguoiDuyet != null && 
                                             x.HrQuanLyDuyetB2s != null && x.HrQuanLyDuyetB2s.Any() && 
                                             !checkB2Approved(x));

    var choGiamDoc = activeList.Count(x => x.IdNguoiDuyet != null && 
                                           (x.HrQuanLyDuyetB2s == null || checkB2Approved(x)) &&
                                           x.HrNguoiXacNhans != null && x.HrNguoiXacNhans.Any() &&
                                           !x.HrNguoiXacNhans.All(s => s.TrangThaiXacNhan == 1));

    var choAdmin = activeList.Count(x => x.IdNguoiDuyet != null && 
                                         (x.HrQuanLyDuyetB2s == null || checkB2Approved(x)) &&
                                         (x.HrNguoiXacNhans == null || x.HrNguoiXacNhans.All(s => s.TrangThaiXacNhan == 1)) &&
                                         x.IdAdmin == null);

    var hoanTat = activeList.Count(x => x.IdAdmin != null);
}

<style>
    .sub-badge {
        font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 700;
        display: inline-flex; align-items: center; gap: 3px; border: 1px solid; margin-top: 2px;
    }
    .support-avatar {
        width: 26px; height: 26px; background: #eff6ff; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: #1e40af; border: 1px solid #dbeafe;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important; transition: 0.3s; }

    /* Modal Styles */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); z-index: 9998; backdrop-filter: blur(4px); }
    .type-filter-modal { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; width: 500px; max-width: 90%; border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); z-index: 9999; padding: 25px; overflow: hidden; }
    .type-checkbox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; margin-bottom: 25px; max-height: 350px; overflow-y: auto; padding-right: 5px; }
    .type-item-label { display: flex; align-items: center; gap: 10px; padding: 12px 15px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; cursor: pointer; transition: 0.2s; font-size: 13px; font-weight: 700; color: #334155; }
    .type-item-label:hover { background: #f1f5f9; border-color: #cbd5e1; }
    .type-checkbox { width: 18px; height: 18px; accent-color: #1e40af; cursor: pointer; }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', 'Segoe UI', sans-serif; color: #1e293b;">
    <div style="max-width: 1550px; margin: 0 auto;">

        @* --- TOP BAR --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
            <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
                <span style="background: #1e40af; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);">
                    <i class="fa fa-archive"></i>
                </span>
                KHO LƯU TRỮ ĐƠN HR
            </h2>

            <div style="display: flex; gap: 12px; align-items: center;">
                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="applyAllFilters()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 10px 15px 10px 40px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700;">
                </div>
                
                @* NÚT MỞ CÀI ĐẶT HIỂN THỊ *@
                <button onclick="openTypeFilterModal()" style="padding: 10px 15px; background: white; border: 2px solid #cbd5e1; border-radius: 12px; color: #475569; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 8px;" onmouseover="this.style.borderColor='#94a3b8'; this.style.color='#1e293b'" onmouseout="this.style.borderColor='#cbd5e1'; this.style.color='#475569'">
                    <i class="fa fa-filter"></i> Hiển thị
                </button>

                <div style="font-size: 11px; background: #1e40af; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- STATS ROW (Đầy đủ 7 trạng thái để lọc) --- *@
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 25px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG LƯU TRỮ", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                    new { Label = "CHỜ QL DUYỆT", Value = choQuanLy, Color = "#b45309", Bg = "#fffbeb", Filter = "CHỜ QL" },
                    new { Label = "BP XÁC NHẬN", Value = choBPXacNhan, Color = "#0369a1", Bg = "#e0f2fe", Filter = "BP XÁC NHẬN" },
                    new { Label = "GIÁM ĐỐC", Value = choGiamDoc, Color = "#86198f", Bg = "#fdf4ff", Filter = "GIÁM ĐỐC" },
                    new { Label = "CHỜ ADMIN", Value = choAdmin, Color = "#1e40af", Bg = "#eff6ff", Filter = "CHỜ ADMIN" },
                    new { Label = "ĐÃ HOÀN TẤT", Value = hoanTat, Color = "#10b981", Bg = "#ecfdf5", Filter = "HOÀN TẤT" },
                    new { Label = "ĐƠN ĐÃ HỦY", Value = daHuy, Color = "#b91c1c", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')" class="stat-card"
                     style="background: @s.Bg; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                    <div style="font-size: 11px; font-weight: 900; color: @s.Color; text-transform: uppercase; margin-bottom: 5px;">@s.Label</div>
                    <div style="font-size: 26px; font-weight: 1000; color: @s.Color;">@s.Value</div>
                </div>
            }
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Hỗ trợ</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 150px;">Tiến trình</th>
                        <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 18px 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            // --- LOGIC XÁC ĐỊNH TRẠNG THÁI (Đã áp dụng Helper AND/OR) ---
                            bool isCancelled = (item.TenForm ?? "").Contains("[ĐÃ HỦY]");
                            bool isFinished = item.IdAdmin != null;
                            bool isManagerApproved = item.IdNguoiDuyet != null;

                            bool hasB2 = item.HrQuanLyDuyetB2s != null && item.HrQuanLyDuyetB2s.Any();
                            bool isB2Approved = hasB2 && checkB2Approved(item);
                            bool isB2Rejected = hasB2 && checkB2Rejected(item);

                            bool hasGD = item.HrNguoiXacNhans != null && item.HrNguoiXacNhans.Any();
                            bool isGDApproved = hasGD && item.HrNguoiXacNhans.All(x => x.TrangThaiXacNhan == 1);
                            bool isGDRejected = hasGD && item.HrNguoiXacNhans.Any(x => x.TrangThaiXacNhan == 2);

                            string pWidth, pColor, pText, bg, fg, statusTag;

                            if (isCancelled || isB2Rejected || isGDRejected)
                            {
                                pWidth = "100%"; pColor = "#ef4444"; pText = "ĐÃ HỦY/TỪ CHỐI"; bg = "#fee2e2"; fg = "#b91c1c"; statusTag = "ĐÃ HỦY";
                            }
                            else if (isFinished)
                            {
                                pWidth = "100%"; pColor = "#10b981"; pText = "HOÀN TẤT"; bg = "#ecfdf5"; fg = "#047857"; statusTag = "HOÀN TẤT";
                            }
                            else if (!isManagerApproved)
                            {
                                pWidth = "25%"; pColor = "#f59e0b"; pText = "CHỜ QL DUYỆT"; bg = "#fef3c7"; fg = "#b45309"; statusTag = "CHỜ QL";
                            }
                            else if (hasB2 && !isB2Approved)
                            {
                                pWidth = "45%"; pColor = "#0ea5e9"; pText = "BP XÁC NHẬN"; bg = "#e0f2fe"; fg = "#0369a1"; statusTag = "BP XÁC NHẬN";
                            }
                            else if (hasGD && !isGDApproved)
                            {
                                pWidth = "70%"; pColor = "#d946ef"; pText = "GIÁM ĐỐC"; bg = "#fdf4ff"; fg = "#86198f"; statusTag = "GIÁM ĐỐC";
                            }
                            else
                            {
                                pWidth = "85%"; pColor = "#1e40af"; pText = "CHỜ ADMIN"; bg = "#dbeafe"; fg = "#1e40af"; statusTag = "CHỜ ADMIN";
                            }

                            /* THÊM THUỘC TÍNH data-idform VÀO ĐÂY ĐỂ LỌC BẰNG JAVASCRIPT */
                            <tr data-idform="@item.IdForm" style="border-bottom: 1px solid #f1f5f9;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                                <td style="padding: 15px 20px;">
                                    <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                    <div style="font-size: 11px; color: #64748b; font-weight: 800;">@item.BoPhan • <span style="color: #1e40af;">MS: @item.SoNhanVien</span></div>
                                </td>

                                <td style="padding: 15px 20px;">
                                    <div style="font-weight: 800; color: #1e293b; font-size: 14px;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                    <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                        <span>ID: #@item.Id • <i class="fa fa-clock-o"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>

                                        @if (hasB2) {
                                            <span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff;"><i class="fa fa-users"></i> BP.XN (@item.HrQuanLyDuyetB2s.Count(x => x.TrangThaiXacNhan == 1)/@item.HrQuanLyDuyetB2s.Count())</span>
                                        }
                                        @if (hasGD) {
                                            <span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff;"><i class="fa fa-briefcase"></i> GĐ (@item.HrNguoiXacNhans.Count(x => x.TrangThaiXacNhan == 1)/@item.HrNguoiXacNhans.Count())</span>
                                        }
                                    </div>
                                </td>

                                <td style="padding: 15px 20px;">
                                    <div style="display: flex; flex-direction: column; gap: 4px;">
                                        @{
                                            var latestSupport = item.HrCtNguoiHoTros?.OrderByDescending(x => x.Stt).FirstOrDefault();
                                        }
                                        @if (latestSupport != null)
                                        {
                                            <div style="display: flex; align-items: center; gap: 6px;">
                                                <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                                <span style="font-weight: 700; color: #334155; font-size: 12px;">@(latestSupport.IdHrNguoiHoTroNavigation?.Ten ?? "N/A")</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color: #cbd5e1; font-size: 11px; font-style: italic;">Chưa chỉ định</span>
                                        }
                                    </div>
                                </td>

                                <td style="padding: 15px 20px;">
                                    <div style="font-size: 9px; font-weight: 1000; color: @pColor; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                        <span>@pText</span> <span>@pWidth</span>
                                    </div>
                                    <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                        <div style="width: @pWidth; height: 100%; background: @pColor; border-radius: 10px; transition: 0.5s ease;"></div>
                                    </div>
                                </td>

                                <td style="padding: 15px 20px; text-align: center;">
                                    <span style="background:@bg; color:@fg; padding:6px 12px; border-radius:8px; font-size:10px; font-weight:1000; border: 1.5px solid @fg; display: inline-block; min-width: 95px; text-transform: uppercase;">
                                        @statusTag
                                    </span>
                                </td>

                                <td style="padding: 15px 20px; text-align: right;">
                                    <a href="/FormHR/ChiTiet/@item.Id"
                                       style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: #1e40af; color: #ffffff; box-shadow: 0 2px 4px rgba(30,64,175,0.2);">
                                        Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* --- CẤU TRÚC MODAL BỘ LỌC ĐƠN TÙY CHỈNH --- *@
<div id="modalOverlay" class="modal-overlay" onclick="closeTypeFilterModal()"></div>
<div id="typeFilterModal" class="type-filter-modal">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
        <h3 style="margin: 0; color: #1e293b; font-size: 18px; font-weight: 900; display: flex; align-items: center; gap: 8px;">
            <i class="fa fa-sliders" style="color: #1e40af;"></i> CÀI ĐẶT HIỂN THỊ ĐƠN
        </h3>
        <button onclick="closeTypeFilterModal()" style="background: none; border: none; font-size: 20px; color: #94a3b8; cursor: pointer;">&times;</button>
    </div>
    
    <div class="type-checkbox-grid">
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XinRaNgoai_1" onchange="updateToggleBtnText()"> Đơn ra ngoài</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_MangHangHoaRaCong_2" onchange="updateToggleBtnText()"> Đơn hàng hóa</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XeCongTac_3" onchange="updateToggleBtnText()"> Xe công tác</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XeDaily_4" onchange="updateToggleBtnText()"> Xe Daily</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonTiepKhac_5" onchange="updateToggleBtnText()"> Đón khách</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_NhaThauQuaCong_6" onchange="updateToggleBtnText()"> Nhà thầu</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_HoTroTienDienThoai_7" onchange="updateToggleBtnText()"> Tiền ĐT</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DoiCaLam_8" onchange="updateToggleBtnText()"> Đổi ca</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonHoTroCongTac_9" onchange="updateToggleBtnText()"> HT Công tác</label>
    </div>

    <div style="display: flex; justify-content: space-between; gap: 10px;">
        <button id="btnToggleSelectAll" type="button" onclick="toggleSelectAll()" style="padding: 12px; background: #f1f5f9; color: #475569; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; flex: 1; transition: 0.2s;" onmouseover="this.style.background='#e2e8f0'">Chọn tất cả</button>
        <button onclick="saveAndApplyTypeFilters()" style="padding: 12px; background: #1e40af; color: white; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; flex: 2; transition: 0.2s; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.3);" onmouseover="this.style.background='#1e3a8a'">
            <i class="fa fa-save"></i> Lưu & Áp dụng
        </button>
    </div>
</div>

@section Scripts {
    <script>
        // Khi tải trang xong, tự động chạy hàm load cấu hình lọc
        document.addEventListener('DOMContentLoaded', function() {
            loadSavedTypeFilters();
        });

        /* ---- LOGIC CÀI ĐẶT HIỂN THỊ ĐƠN (LOCALSTORAGE) ---- */
        const STORAGE_KEY = 'HrSelectedFormTypes';

        function openTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'block';
            document.getElementById('typeFilterModal').style.display = 'block';
        }

        function closeTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'none';
            document.getElementById('typeFilterModal').style.display = 'none';
            // Phục hồi lại trạng thái checkbox từ storage nếu user tắt mà chưa bấm Lưu
            loadSavedTypeFilters(false);
        }

        // HÀM TOGGLE MỚI: TỰ ĐỘNG NHẬN DIỆN VÀ ĐẢO NGƯỢC TRẠNG THÁI
        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            // Kiểm tra xem có phải tất cả đều đang được tích không
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            
            // Nếu tất cả đang tích thì bỏ tích, ngược lại thì tích tất cả
            checkboxes.forEach(cb => {
                cb.checked = !isAllChecked;
            });
            
            // Cập nhật lại chữ hiển thị của nút
            updateToggleBtnText();
        }

        // Cập nhật text của nút dựa theo số lượng ô được chọn
        function updateToggleBtnText() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            const btn = document.getElementById("btnToggleSelectAll");
            if (btn) {
                btn.innerText = isAllChecked ? "Bỏ chọn tất cả" : "Chọn tất cả";
            }
        }

        function loadSavedTypeFilters(applyToTable = true) {
            let saved = localStorage.getItem(STORAGE_KEY);
            let checkboxes = document.querySelectorAll('.type-checkbox');
            
            if (saved) {
                let selectedArray = JSON.parse(saved);
                checkboxes.forEach(cb => {
                    cb.checked = selectedArray.includes(cb.value);
                });
            } else {
                // Mặc định lần đầu vào trang là chọn tất cả
                checkboxes.forEach(cb => { cb.checked = true; });
            }

            // Gọi cập nhật trạng thái text nút "Chọn tất cả" / "Bỏ chọn tất cả"
            updateToggleBtnText();

            if (applyToTable) {
                applyAllFilters();
            }
        }

        function saveAndApplyTypeFilters() {
            let selectedArray = [];
            document.querySelectorAll('.type-checkbox:checked').forEach(cb => {
                selectedArray.push(cb.value);
            });
            
            // Lưu vào trình duyệt
            localStorage.setItem(STORAGE_KEY, JSON.stringify(selectedArray));
            
            closeTypeFilterModal();
            applyAllFilters(); // Tự động chạy lại bộ lọc bảng
        }


        /* ---- KẾT HỢP LỌC CHỮ, LỌC TRẠNG THÁI VÀ LỌC LOẠI ĐƠN ---- */
        function applyAllFilters() {
            const input = document.getElementById("searchInput");
            const textFilter = input.value.toUpperCase();
            
            const table = document.getElementById("dataTable");
            const tr = table.getElementsByTagName("tr");

            // Đọc cấu hình hiển thị loại đơn từ LocalStorage
            let savedTypesStr = localStorage.getItem(STORAGE_KEY);
            let allowedTypes = savedTypesStr ? JSON.parse(savedTypesStr) : null;

            for (let i = 1; i < tr.length; i++) {
                // 1. Kiểm tra chữ / Trạng thái
                let rowText = tr[i].innerText.toUpperCase();
                let matchText = rowText.includes(textFilter);

                // 2. Kiểm tra loại đơn (data-idform)
                let rowFormType = tr[i].getAttribute("data-idform");
                let matchType = true;
                
                // Nếu có cài đặt, và loại đơn này không rỗng, và loại đơn không nằm trong danh sách đã tích -> Ẩn
                if (allowedTypes && rowFormType && !allowedTypes.includes(rowFormType)) {
                    matchType = false;
                }

                // Nếu thỏa mãn cả 2 điều kiện thì hiện, không thì ẩn
                tr[i].style.display = (matchText && matchType) ? "" : "none";
            }
        }

        /* Gọi từ các cục trạng thái bên trên */
        function filterByStatus(s) {
            // Gán giá trị vào ô tìm kiếm và kích hoạt hàm lọc chung
            document.getElementById("searchInput").value = s;
            applyAllFilters();
            
            // Hiệu ứng nháy nhẹ bảng khi lọc
            const table = document.getElementById("dataTable");
            table.style.opacity = "0.5";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }
        
        // Giữ lại hàm cũ để tránh lỗi gọi từ HTML
        function filterTable() {
            applyAllFilters();
        }
    </script>
}