@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 26px;
        height: 26px;
        background: #eff6ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e40af;
        border: 1px solid #dbeafe;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
        transition: 0.3s;
    }

    /* Modal Styles */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        z-index: 9998;
        backdrop-filter: blur(4px);
    }

    .type-filter-modal {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        width: 500px;
        max-width: 95%;
        border-radius: 20px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        z-index: 9999;
        padding: 25px;
        overflow: hidden;
    }

    .type-checkbox-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 20px;
        margin-bottom: 25px;
        max-height: 350px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .type-item-label {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 15px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        cursor: pointer;
        transition: 0.2s;
        font-size: 13px;
        font-weight: 700;
        color: #334155;
    }

        .type-item-label:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

    .type-checkbox {
        width: 18px;
        height: 18px;
        accent-color: #1e40af;
        cursor: pointer;
    }

    /* Phân trang */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* ==========================================
           BỔ SUNG CSS CHO MOBILE RESPONSIVE
           ========================================== */
    @@media (max-width: 768px) {
        .mobile-top-bar {
            flex-direction: column !important;
            align-items: stretch !important;
        }

        .mobile-controls {
            flex-direction: column !important;
            width: 100% !important;
        }

        .mobile-search-input {
            width: 100% !important;
        }

        .mobile-stat-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }

        .type-checkbox-grid {
            grid-template-columns: 1fr !important; /* Modal filter 1 cột trên mobile */
        }
        /* Chuyển bảng thành dạng Card */
        #dataTable thead {
            display: none;
        }

        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }

            #dataTable tr {
                margin-bottom: 15px;
                border: 1px solid #e2e8f0 !important;
                border-radius: 15px;
                overflow: hidden;
                background: #fff;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            }

            #dataTable td {
                text-align: right !important;
                padding: 12px 15px !important;
                border-bottom: 1px dashed #f1f5f9;
                position: relative;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                #dataTable td:last-child {
                    border-bottom: none;
                    background: #f8fafc;
                    justify-content: center;
                }
                /* Hiển thị nhãn cột bằng data-label */
                #dataTable td::before {
                    content: attr(data-label);
                    float: left;
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                }

        .mobile-td-val {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            max-width: 65%;
        }

        .pagination-container {
            flex-direction: column !important;
            gap: 20px;
            text-align: center !important;
        }

        #paginationButtons {
            justify-content: center;
        }
    }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', 'Segoe UI', sans-serif; color: #1e293b;">
    <div style="max-width: 1550px; margin: 0 auto;">

        @* --- TOP BAR --- *@
        <div class="mobile-top-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
            <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
                <span style="background: #1e40af; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.2);">
                    <i class="fa fa-archive"></i>
                </span>
                KHO LƯU TRỮ ĐƠN HR
            </h2>

            <div class="mobile-controls" style="display: flex; gap: 12px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #cbd5e1;">
                    <span style="font-size: 12px; font-weight: 700; color: #64748b;">Hiển thị:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #1e40af; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div class="mobile-search-input" style="position: relative; flex-grow: 1;">
                    <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="applyAllFilters()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 10px 15px 10px 40px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700; width: 100%; box-sizing: border-box;">
                </div>

                <button onclick="openTypeFilterModal()" style="padding: 10px 15px; background: white; border: 2px solid #cbd5e1; border-radius: 12px; color: #475569; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 8px;" onmouseover="this.style.borderColor='#94a3b8'; this.style.color='#1e293b'" onmouseout="this.style.borderColor='#cbd5e1'; this.style.color='#475569'">
                    <i class="fa fa-filter"></i> <span class="d-none d-md-inline">Phân loại đơn</span>
                </button>

                <div style="font-size: 11px; background: #1e40af; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- STATS ROW --- *@
        <div class="mobile-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 25px;">
            <div onclick="filterByStatus('')" class="stat-card" style="background: white; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #1e293b; text-transform: uppercase; margin-bottom: 5px;">TỔNG LƯU TRỮ</div>
                <div id="stat-total" style="font-size: 26px; font-weight: 1000; color: #1e293b;">0</div>
            </div>
            <div onclick="filterByStatus('CHỜ QL')" class="stat-card" style="background: #fffbeb; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #b45309; text-transform: uppercase; margin-bottom: 5px;">CHỜ QL DUYỆT</div>
                <div id="stat-ql" style="font-size: 26px; font-weight: 1000; color: #b45309;">0</div>
            </div>
            <div onclick="filterByStatus('BP XÁC NHẬN')" class="stat-card" style="background: #e0f2fe; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #0369a1; text-transform: uppercase; margin-bottom: 5px;">BP XÁC NHẬN</div>
                <div id="stat-b2" style="font-size: 26px; font-weight: 1000; color: #0369a1;">0</div>
            </div>
            <div onclick="filterByStatus('GIÁM ĐỐC')" class="stat-card" style="background: #fdf4ff; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #86198f; text-transform: uppercase; margin-bottom: 5px;">GIÁM ĐỐC</div>
                <div id="stat-gd" style="font-size: 26px; font-weight: 1000; color: #86198f;">0</div>
            </div>
            <div onclick="filterByStatus('CHỜ ADMIN')" class="stat-card" style="background: #eff6ff; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #1e40af; text-transform: uppercase; margin-bottom: 5px;">CHỜ ADMIN</div>
                <div id="stat-admin" style="font-size: 26px; font-weight: 1000; color: #1e40af;">0</div>
            </div>
            <div onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #ecfdf5; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #10b981; text-transform: uppercase; margin-bottom: 5px;">ĐÃ HOÀN TẤT</div>
                <div id="stat-hoanTat" style="font-size: 26px; font-weight: 1000; color: #10b981;">0</div>
            </div>
            <div onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 18px 15px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 5px;">ĐƠN ĐÃ HỦY</div>
                <div id="stat-huy" style="font-size: 26px; font-weight: 1000; color: #b91c1c;">0</div>
            </div>
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Hỗ trợ</th>
                        <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 150px;">Tiến trình</th>
                        <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 18px 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr>
                        <td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none;">
                            <i class="fa fa-spinner fa-spin" style="font-size: 32px; margin-bottom: 15px;"></i>
                            <p style="font-weight: 600;">Đang tải danh sách kho lưu trữ...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @* --- PHẦN PHÂN TRANG --- *@
        <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; margin-top: 5px;">
            <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: #1e40af;">1</span> / <span id="totalPagesNum">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                    Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
                </div>
            </div>
        </div>
    </div>
</div>

@* --- CẤU TRÚC MODAL BỘ LỌC ĐƠN TÙY CHỈNH --- *@
<div id="modalOverlay" class="modal-overlay" onclick="closeTypeFilterModal()"></div>
<div id="typeFilterModal" class="type-filter-modal">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
        <h3 style="margin: 0; color: #1e293b; font-size: 18px; font-weight: 900; display: flex; align-items: center; gap: 8px;">
            <i class="fa fa-sliders" style="color: #1e40af;"></i> CÀI ĐẶT HIỂN THỊ ĐƠN
        </h3>
        <button onclick="closeTypeFilterModal()" style="background: none; border: none; font-size: 20px; color: #94a3b8; cursor: pointer;">&times;</button>
    </div>

    <div class="type-checkbox-grid">
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XinRaNgoai_1" onchange="updateToggleBtnText()"> Đơn ra ngoài</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_MangHangHoaRaCong_2" onchange="updateToggleBtnText()"> Đơn hàng hóa</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XeCongTac_3" onchange="updateToggleBtnText()"> Xe công tác</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_XeDaily_4" onchange="updateToggleBtnText()"> Xe Daily</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonTiepKhac_5" onchange="updateToggleBtnText()"> Đón khách</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_NhaThauQuaCong_6" onchange="updateToggleBtnText()"> Nhà thầu</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_HoTroTienDienThoai_7" onchange="updateToggleBtnText()"> Tiền ĐT</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DoiCaLam_8" onchange="updateToggleBtnText()"> Đổi ca</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonHoTroCongTac_9" onchange="updateToggleBtnText()"> HT Công tác</label>
        <!-- BỔ SUNG 3 LOẠI ĐƠN MỚI -->
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonKiTucXa_10" onchange="updateToggleBtnText()"> Ký túc xá</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonLamLaiThe_11" onchange="updateToggleBtnText()"> Làm lại thẻ</label>
        <label class="type-item-label"><input type="checkbox" class="type-checkbox" value="HR_DonSuDungDienThoai_12" onchange="updateToggleBtnText()"> SD Điện thoại</label>
    </div>

    <div style="display: flex; justify-content: space-between; gap: 10px;">
        <button id="btnToggleSelectAll" type="button" onclick="toggleSelectAll()" style="padding: 12px; background: #f1f5f9; color: #475569; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; flex: 1; transition: 0.2s;" onmouseover="this.style.background='#e2e8f0'">Chọn tất cả</button>
        <button onclick="saveAndApplyTypeFilters()" style="padding: 12px; background: #1e40af; color: white; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; flex: 2; transition: 0.2s; box-shadow: 0 4px 6px rgba(30, 64, 175, 0.3);" onmouseover="this.style.background='#1e3a8a'">
            <i class="fa fa-save"></i> Lưu & Áp dụng
        </button>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];
        let filteredData = [];
        let currentPage = 1;
        let rowsPerPage = 20;
        // Đã đổi tên STORAGE_KEY thành v2 để reset lại cache filter trên trình duyệt
        const STORAGE_KEY = 'HrSelectedFormTypes_v2';

        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const response = await fetch('/FormHR/GetHoanTatDonData');
                masterData = await response.json();

                updateStatistics(masterData);
                loadSavedTypeFilters();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: red; border: none;">Lỗi tải dữ liệu. Vui lòng F5.</td></tr>`;
            }
        });

        function updateStatistics(data) {
            document.getElementById("stat-total").innerText = data.length;
            document.getElementById("stat-ql").innerText = data.filter(x => x.statusTag === "CHỜ QL").length;
            document.getElementById("stat-b2").innerText = data.filter(x => x.statusTag === "BP XÁC NHẬN").length;
            document.getElementById("stat-gd").innerText = data.filter(x => x.statusTag === "GIÁM ĐỐC").length;
            document.getElementById("stat-admin").innerText = data.filter(x => x.statusTag === "CHỜ ADMIN").length;
            document.getElementById("stat-hoanTat").innerText = data.filter(x => x.statusTag === "HOÀN TẤT").length;
            document.getElementById("stat-huy").innerText = data.filter(x => x.statusTag === "ĐÃ HỦY").length;
        }

        function openTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'block';
            document.getElementById('typeFilterModal').style.display = 'block';
        }

        function closeTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'none';
            document.getElementById('typeFilterModal').style.display = 'none';
            loadSavedTypeFilters(false);
        }

        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !isAllChecked);
            updateToggleBtnText();
        }

        function updateToggleBtnText() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            const btn = document.getElementById("btnToggleSelectAll");
            if (btn) btn.innerText = isAllChecked ? "Bỏ chọn tất cả" : "Chọn tất cả";
        }

        function loadSavedTypeFilters(applyToTable = true) {
            let saved = localStorage.getItem(STORAGE_KEY);
            let checkboxes = document.querySelectorAll('.type-checkbox');

            if (saved) {
                let selectedArray = JSON.parse(saved);
                checkboxes.forEach(cb => cb.checked = selectedArray.includes(cb.value));
            } else {
                checkboxes.forEach(cb => cb.checked = true);
            }

            updateToggleBtnText();
            if (applyToTable) applyAllFilters();
        }

        function saveAndApplyTypeFilters() {
            let selectedArray = [];
            document.querySelectorAll('.type-checkbox:checked').forEach(cb => {
                selectedArray.push(cb.value);
            });
            localStorage.setItem(STORAGE_KEY, JSON.stringify(selectedArray));
            closeTypeFilterModal();
            applyAllFilters();
        }

        function filterByStatus(s) {
            document.getElementById("searchInput").value = s;
            applyAllFilters();

            let table = document.getElementById("tableBody");
            table.style.opacity = "0.4";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            applyAllFilters();
        }

        function applyAllFilters() {
            const searchText = document.getElementById("searchInput").value.toUpperCase().trim();

            let savedTypesStr = localStorage.getItem(STORAGE_KEY);
            let allowedTypes = savedTypesStr ? JSON.parse(savedTypesStr) : null;

            filteredData = masterData.filter(item => {
                const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${item.supportName || ''} ${item.statusTag}`.toUpperCase();
                const matchText = searchText === "" || rowString.includes(searchText);

                let matchType = true;
                if (allowedTypes && item.idForm && !allowedTypes.includes(item.idForm)) {
                    matchType = false;
                }

                return matchText && matchType;
            });

            currentPage = 1;
            renderCurrentPage();
        }

        function renderCurrentPage() {
            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const pageData = filteredData.slice(startIndex, endIndex);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none; display: block;">Không tìm thấy dữ liệu phù hợp bộ lọc.</td></tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-clock-o"></i> ${item.timeNguoiTao}</span>`;
                if (item.hasB2) badgesHtml += `<span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff; margin-left:5px;"><i class="fa fa-users"></i> BP.XN (${item.b2DoneCount}/${item.b2TotalCount})</span>`;
                if (item.hasGD) badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:5px;"><i class="fa fa-briefcase"></i> GĐ (${item.gdDoneCount}/${item.gdTotalCount})</span>`;

                let supportHtml = item.supportName
                    ? `<div style="display: flex; align-items: center; gap: 6px;"><div class="support-avatar"><i class="fa fa-user-circle-o"></i></div><span style="font-weight: 700; color: #334155; font-size: 12px;">${item.supportName}</span></div>`
                    : `<span style="color: #cbd5e1; font-size: 11px; font-style: italic;">Chưa chỉ định</span>`;

                html += `
                    <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #1e40af;">MS: ${item.soNhanVien}</span></div>
                            </div>
                        </td>
                        <td data-label="Thông tin đơn" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; flex-wrap: wrap; align-items: center; margin-top:4px; justify-content: flex-end;">
                                    ${badgesHtml}
                                </div>
                            </div>
                        </td>
                        <td data-label="Hỗ trợ" style="padding: 15px 20px;">
                            <div style="display: flex; flex-direction: column; gap: 4px; align-items: flex-end;">${supportHtml}</div>
                        </td>
                        <td data-label="Tiến trình" style="padding: 15px 20px;">
                            <div style="width: 120px; margin-left: auto;">
                                <div style="font-size: 9px; font-weight: 1000; color: ${item.pColor}; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>${item.pText}</span> <span>${item.pWidth}</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                    <div style="width: ${item.pWidth}; height: 100%; background: ${item.pColor}; border-radius: 10px; transition: 0.5s ease;"></div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <span style="background:${item.bg}; color:${item.fg}; padding:6px 12px; border-radius:8px; font-size:10px; font-weight:1000; border: 1.5px solid ${item.fg}; display: inline-block; min-width: 95px; text-transform: uppercase;">
                                ${item.statusTag}
                            </span>
                        </td>
                        <td style="padding: 15px 20px; text-align: right;">
                            <a href="/FormHR/ChiTiet/${item.id}" style="text-decoration: none; padding: 10px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: #1e40af; color: #ffffff; width: 100%; text-align: center; box-sizing: border-box;">
                                Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                            </a>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = "";
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) {
                        const dot = document.createElement("span");
                        dot.innerText = "...";
                        dot.style.padding = "8px"; dot.style.color = "#64748b"; dot.style.fontWeight = "700";
                        container.appendChild(dot);
                    }
                    continue;
                }

                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    renderCurrentPage();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}