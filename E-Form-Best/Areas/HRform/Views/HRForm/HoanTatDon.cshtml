@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.IdAdmin != null && !(x.TenForm?.Contains("[ĐÃ HỦY]") ?? false)) ?? 0;
    var cancelled = Model?.Count(x => x.TenForm?.Contains("[ĐÃ HỦY]") ?? false) ?? 0;
    var pending = total - completed - cancelled;

    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "N/A";
}

<div style="background: #f8fafc; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1400px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #be123c; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #be123c; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(190, 18, 60, 0.3);">
                        <i class="fa fa-file-text"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN HR
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e293b; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@userRole</span>
                    <span style="background: #cbd5e1; color: #1e293b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">NHÂN SỰ & QUẢN LÝ</span>
                </div>
            </div>

            <div style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm nhân viên, mã đơn, trạng thái..."
                       style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 350px; font-size: 14px; font-weight: 700; outline: none; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            </div>
        </div>

        @* --- STATS --- *@
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG ĐƠN HR", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                    new { Label = "CHỜ XỬ LÝ", Value = pending, Color = "#b45309", Bg = "#fffbeb", Filter = "CHỜ" },
                    new { Label = "HOÀN TẤT", Value = completed, Color = "#047857", Bg = "#ecfdf5", Filter = "XONG" },
                    new { Label = "ĐÃ HỦY", Value = cancelled, Color = "#b91c1c", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')" style="background: @s.Bg; padding: 22px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
                    <div style="font-size: 10px; font-weight: 900; color: @s.Color; letter-spacing: 1px; text-transform: uppercase;">@s.Label</div>
                    <div style="font-size: 32px; font-weight: 1000; color: @s.Color; margin-top: 8px;">@s.Value</div>
                </div>
            }
        </div>

        @* --- TABLE --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Biểu mẫu & Tiến độ</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Phòng ban</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 20px; width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        bool isCancelled = item.TenForm?.Contains("[ĐÃ HỦY]") ?? false;
                        bool isFinished = item.IdAdmin != null;
                        bool isApproved = item.IdNguoiDuyet != null;

                        string pWidth = isCancelled ? "100%" : (isFinished ? "100%" : (isApproved ? "66%" : "33%"));
                        string pColor = isCancelled ? "#ef4444" : (isFinished ? "#10b981" : (isApproved ? "#2563eb" : "#f59e0b"));
                        string stTxt = isCancelled ? "ĐÃ HỦY" : (isFinished ? "XONG" : "CHỜ");

                        <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                            <td style="padding: 20px;">
                                <div style="font-weight: 900; color: #0f172a;">@item.TenNguoiNv</div>
                                <div style="font-size: 12px; color: #64748b; font-weight: 700;">#@item.Id • MS: @item.SoNhanVien</div>
                            </td>
                            <td style="padding: 20px;">
                                <div style="font-weight: 800; font-size: 14px; margin-bottom: 8px; color: #1e293b;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div style="flex-grow: 1; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 150px;">
                                        <div style="width: @pWidth; height: 100%; background: @pColor;"></div>
                                    </div>
                                    <span style="font-size: 10px; font-weight: 900; color: #64748b;">@item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>
                                </div>
                            </td>
                            <td style="padding: 20px; font-weight: 700; color: #475569; font-size: 13px;">@item.BoPhan</td>
                            <td style="padding: 20px; text-align: center;">
                                <span style="border: 2px solid @pColor; color: @pColor; padding: 5px 12px; border-radius: 10px; font-size: 10px; font-weight: 1000;">@stTxt</span>
                            </td>
                            <td style="padding: 20px;">
                                <a href="/FormHR/ChiTiet/@item.Id" style="color: #64748b; font-size: 18px;"><i class="fa fa-chevron-right"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const filter = document.getElementById("searchInput").value.toUpperCase();
        const trs = document.querySelectorAll("#dataTable tbody tr");
        trs.forEach(tr => tr.style.display = tr.innerText.toUpperCase().includes(filter) ? "" : "none");
    }
    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();
    }
</script>