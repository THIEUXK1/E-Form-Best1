@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn HR";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- LOGIC THỐNG KÊ ---
    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.IdAdmin != null && !(x.TenForm?.Contains("[ĐÃ HỦY]") ?? false)) ?? 0;
    var cancelled = Model?.Count(x => x.TenForm?.Contains("[ĐÃ HỦY]") ?? false) ?? 0;
    var pending = total - completed - cancelled;

    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "N/A";
}

<style>
    .sub-status-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: 1px solid;
        margin-top: 4px;
    }
    
    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 20px -5px rgba(0,0,0,0.1) !important;
    }

    #dataTable tbody tr:hover {
        background-color: #f8fafc !important;
    }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1500px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #be123c; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #be123c; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(190, 18, 60, 0.3);">
                        <i class="fa fa-archive"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN HR
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e293b; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5px;">QUYỀN: @userRole</span>
                    <span style="background: white; color: #64748b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; border: 1px solid #e2e8f0;">DỮ LIỆU TẬP TRUNG</span>
                </div>
            </div>

            <div style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #94a3b8;"></i>
                <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên nhân viên, mã đơn, bộ phận..."
                       style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 1px solid #e2e8f0; width: 400px; font-size: 14px; font-weight: 600; outline: none; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03); transition: 0.3s;"
                       onfocus="this.style.borderColor='#be123c'; this.style.boxShadow='0 0 0 4px rgba(190, 18, 60, 0.1)'"
                       onblur="this.style.borderColor='#e2e8f0'">
            </div>
        </div>

        @* --- STATS --- *@
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG LƯU TRỮ", Value = total, Color = "#1e293b", Bg = "white", Filter = "", Icon="fa-database" },
                    new { Label = "ĐANG XỬ LÝ", Value = pending, Color = "#b45309", Bg = "white", Filter = "CHỜ", Icon="fa-clock-o" },
                    new { Label = "ĐÃ HOÀN TẤT", Value = completed, Color = "#047857", Bg = "white", Filter = "XONG", Icon="fa-check-circle" },
                    new { Label = "ĐƠN ĐÃ HỦY", Value = cancelled, Color = "#b91c1c", Bg = "white", Filter = "ĐÃ HỦY", Icon="fa-trash" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')" class="stat-card" style="background: @s.Bg; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); display: flex; align-items: center; gap: 20px;">
                    <div style="background: @(s.Color == "#1e293b" ? "#f1f5f9" : s.Color + "10"); color: @s.Color; width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                        <i class="fa @s.Icon"></i>
                    </div>
                    <div>
                        <div style="font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase;">@s.Label</div>
                        <div style="font-size: 28px; font-weight: 1000; color: @s.Color;">@s.Value</div>
                    </div>
                </div>
            }
        </div>

        @* --- TABLE --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <div style="overflow-x: auto;">
                <table id="dataTable" style="width: 100%; border-collapse: collapse; min-width: 1000px;">
                    <thead>
                        <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                            <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nhân viên / Mã đơn</th>
                            <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nội dung & Tiến độ</th>
                            <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Xác nhận chi tiết</th>
                            <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Bộ phận</th>
                            <th style="padding: 20px; text-align: center; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Trạng thái</th>
                            <th style="padding: 20px; width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                bool isCancelled = item.TenForm?.Contains("[ĐÃ HỦY]") ?? false;
                                bool isFinished = item.IdAdmin != null;
                                bool isApproved = item.IdNguoiDuyet != null;

                                string pWidth = isCancelled ? "100%" : (isFinished ? "100%" : (isApproved ? "66%" : "33%"));
                                string pColor = isCancelled ? "#ef4444" : (isFinished ? "#10b981" : (isApproved ? "#2563eb" : "#f59e0b"));
                                string stTxt = isCancelled ? "ĐÃ HỦY" : (isFinished ? "XONG" : "CHỜ");

                                <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;">
                                    <td style="padding: 20px;">
                                        <div style="font-weight: 900; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                        <div style="font-size: 11px; color: #2563eb; font-weight: 800; margin-top: 4px;">#@item.Id <span style="color: #94a3b8; font-weight: 500;">• MS: @item.SoNhanVien</span></div>
                                    </td>
                                    <td style="padding: 20px;">
                                        <div style="font-weight: 800; font-size: 13px; margin-bottom: 8px; color: #1e293b;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <div style="flex-grow: 1; height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden; max-width: 120px; border: 1px solid #e2e8f0;">
                                                <div style="width: @pWidth; height: 100%; background: @pColor; transition: 0.5s;"></div>
                                            </div>
                                            <span style="font-size: 10px; font-weight: 800; color: #94a3b8;"><i class="fa fa-calendar-o"></i> @item.Ngay?.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>
                                    <td style="padding: 20px;">
                                        @* --- CHI TIẾT HỘI ĐỒNG XÁC NHẬN --- *@
                                        @if (item.HrNguoiXacNhans != null && item.HrNguoiXacNhans.Any())
                                        {
                                            var listXN = item.HrNguoiXacNhans.ToList();
                                            int doneCount = listXN.Count(x => x.TrangThaiXacNhan == 1);
                                            int totalCount = listXN.Count;

                                            string xnColor = listXN.Any(x => x.TrangThaiXacNhan == 2) ? "#ef4444" : (doneCount == totalCount ? "#10b981" : "#f59e0b");
                                            
                                            <div class="sub-status-badge" style="background: @(xnColor)10; color: @xnColor; border-color: @xnColor;">
                                                <i class="fa fa-users"></i> XN: @doneCount/@totalCount
                                            </div>
                                        }

                                        @* --- CHI TIẾT BẢO VỆ --- *@
                                        @if (item.BaoVeHrs != null && item.BaoVeHrs.Any())
                                        {
                                            var bv = item.BaoVeHrs.FirstOrDefault();
                                            if (bv != null)
                                            {
                                                string bvColor = bv.TrangThai == 1 ? "#10b981" : "#64748b";
                                                <div class="sub-status-badge" style="background: #f8fafc; color: @bvColor; border-color: #e2e8f0; margin-left: 5px;">
                                                    <i class="fa fa-shield"></i> @(bv.TrangThai == 1 ? "BV Xong" : "BV Chờ")
                                                </div>
                                            }
                                        }
                                    </td>
                                    <td style="padding: 20px;">
                                        <div style="font-weight: 700; color: #475569; font-size: 12px; background: #f8fafc; padding: 4px 10px; border-radius: 6px; display: inline-block; border: 1px solid #e2e8f0;">
                                            @item.BoPhan
                                        </div>
                                    </td>
                                    <td style="padding: 20px; text-align: center;">
                                        <span style="border: 2px solid @pColor; color: @pColor; padding: 4px 10px; border-radius: 8px; font-size: 10px; font-weight: 1000; display: inline-block; min-width: 70px;">
                                            @stTxt
                                        </span>
                                    </td>
                                    <td style="padding: 20px; text-align: right;">
                                        <a href="/FormHR/ChiTiet/@item.Id" style="background: #f1f5f9; color: #64748b; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: 0.2s;" onmouseover="this.style.background='#be123c'; this.style.color='white'">
                                            <i class="fa fa-chevron-right" style="font-size: 12px;"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            @if (Model == null || !Model.Any())
            {
                <div style="padding: 100px; text-align: center;">
                    <i class="fa fa-folder-open-o" style="font-size: 50px; color: #cbd5e1; margin-bottom: 15px;"></i>
                    <p style="color: #94a3b8; font-weight: 600;">Không có dữ liệu đơn từ trong kho lưu trữ.</p>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const filter = document.getElementById("searchInput").value.toUpperCase();
        const trs = document.querySelectorAll("#dataTable tbody tr");
        
        trs.forEach(tr => {
            const text = tr.innerText.toUpperCase();
            tr.style.display = text.includes(filter) ? "" : "none";
        });
    }

    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();
        
        // Hiệu ứng nháy nhẹ bảng để phản hồi người dùng
        const table = document.getElementById("dataTable");
        table.style.opacity = "0.5";
        setTimeout(() => { table.style.opacity = "1"; }, 100);
    }
</script>