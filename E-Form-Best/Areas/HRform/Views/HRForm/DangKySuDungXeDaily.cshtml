@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký sử dụng xe Daily";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- MÀU CHỦ ĐẠO MỚI ---
    string primaryColor = "#ed8936";
    string secondaryColor = "#c05621";
    string lightBg = "#fffaf0";
    string softBorder = "#fbd38d";

    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 10px; border: 1px solid {softBorder}; background: #fffdfa; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {secondaryColor};";
    string labelStyle = $"font-weight: 700; color: {secondaryColor}; font-size: 11px; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.5px;";
    string pasteZoneStyle = $"width: 100%; border: 2px dotted {softBorder}; height: 180px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: {lightBg}; color: {primaryColor}; cursor: pointer; overflow: hidden; font-size: 12px; font-weight: 600; transition: 0.3s; margin-top: 10px; position: relative; outline: none;";
}

<style>
    /* Grid cho ô lộ trình động */
    .dynamic-row-xe {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 45px;
        gap: 10px;
        align-items: center;
        margin-bottom: 10px;
    }

    @@media (max-width: 768px) {
        .mobile-wrapper { padding: 15px 10px !important; }
        .mobile-card { border-radius: 20px !important; }
        .mobile-header { padding: 30px 15px !important; }
        .mobile-header h2 { font-size: 18px !important; margin-top: 12px !important; }
        .system-badge { position: relative !important; top: 0 !important; right: 0 !important; display: inline-block; margin-bottom: 10px; }
        .mobile-body { padding: 20px 15px !important; }
        .grid-mobile-1 { grid-template-columns: 1fr !important; gap: 12px !important; }
        .mobile-section { padding: 15px !important; }
        
        /* Grid mobile cho ô lộ trình */
        .dynamic-row-xe { grid-template-columns: 1fr !important; gap: 8px !important; padding: 10px; border: 1px dashed #fbd38d; border-radius: 8px; margin-bottom: 15px; position: relative; }
        .btn-remove-row { position: absolute; top: -10px; right: -10px; width: 30px !important; height: 30px !important; border-radius: 50% !important; font-size: 14px !important; }
    }
</style>

<div class="mobile-wrapper" style="background: linear-gradient(135deg, #fffaf0 0%, #feebc8 100%); padding: 40px 15px; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    <form id="hrForm" class="mobile-card" method="post" enctype="multipart/form-data" action="/FormHR/DangKySuDungXeDaily"
          style="max-width: 900px; margin: 0 auto; background: #ffffff; border-radius: 30px; box-shadow: 0 20px 50px rgba(237, 137, 54, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        <div class="mobile-header" style="background: linear-gradient(135deg, @primaryColor 0%, @secondaryColor 100%); padding: 40px; color: #ffffff; text-align: center; position: relative;">
            <div class="system-badge" style="position: absolute; top: 15px; right: 25px; font-size: 11px; opacity: 0.9; font-weight: 500; letter-spacing: 1px;">HỆ THỐNG E-FORM V3.0</div>
            <h2 style="margin: 0; font-size: 24px; text-transform: uppercase; font-weight: 900; letter-spacing: 1.5px;">Đăng ký sử dụng xe Daily</h2>
            <div style="margin-top: 12px; display: inline-block; padding: 6px 16px; background: rgba(255,255,255,0.2); border-radius: 50px; font-size: 13px;">
                📅 Ngày lập đơn: <span style="font-weight: 700; color: #ffffff;">@ngayHienThi</span>
            </div>
        </div>

        <div class="mobile-body" style="padding: 40px;">
            @* --- PHẦN 1: THÔNG TIN NHÂN SỰ --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: @secondaryColor; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @primaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">1</span>
                    Thông tin người đăng ký
                </h3>
                <div class="grid-mobile-1" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px;">
                    <div><label style="@labelStyle">Họ tên nhân viên</label><input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #fffaf0; border-color: #fbd38d;"></div>
                    <div><label style="@labelStyle">Phòng ban</label><input name="BoPhan" value="@phongBan" readonly style="@inputStyle; background: #fffaf0; border-color: #fbd38d;"></div>
                    <div><label style="@labelStyle">Mã nhân viên</label><input name="SoNhanVien" value="@soNhanVien" readonly style="@inputStyle; background: #fffaf0; border-color: #fbd38d;"></div>
                </div>

                <div class="grid-mobile-1" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div><label style="@labelStyle">Đơn vị / Công ty</label><input name="TenCongTy" value="@tenCongTy" readonly style="@inputStyle; background: #fffaf0; border-style: dashed;"></div>
                    <div><label style="@labelStyle">Danh mục hồ sơ</label><input name="Danhmuc" value="ĐƠN ĐĂNG KÝ SỬ DỤNG XE DAILY" readonly style="@inputStyle; background: #fffaf0; border-style: dashed; color: @primaryColor;"></div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT ĐĂNG KÝ XE --- *@
            <div class="mobile-section" style="background: #fffcf9; padding: 25px; border-radius: 20px; border: 1px solid @softBorder; margin-bottom: 30px; box-shadow: inset 0 2px 4px rgba(237, 137, 54, 0.02);">
                <h3 style="color: @secondaryColor; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @secondaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">2</span>
                    Nội dung và Lộ trình
                </h3>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Lý do sử dụng xe <span style="color:@primaryColor">*</span></label>
                    <textarea name="chiTiet.LiDo" placeholder="Vui lòng nhập mục đích sử dụng xe..." required style="@inputStyle; height: 80px; resize: none; border: 1px solid @primaryColor;"></textarea>
                </div>

                @* --- KHUNG THÊM NHIỀU LỘ TRÌNH --- *@
                <div style="margin-bottom: 25px; padding: 20px; border-radius: 12px; background: #ffffff; border: 1px dashed @primaryColor;">
                    <label style="@labelStyle">Danh sách lộ trình (Mã NV - Họ Tên, Điểm đón, Thời gian) <span style="color:#e53e3e">*</span></label>
                    <div id="dynamicItemsWrapper">
                        <div class="dynamic-row-xe">
                            <input type="text" name="arrHoTen" placeholder="VD: V01234 - Nguyễn Văn A" style="@inputStyle" required>
                            <input type="text" name="arrDiemDon" placeholder="Điểm đón" style="@inputStyle" required>
                            <input type="datetime-local" name="arrTime" class="inp-time-xe" style="@inputStyle" required>
                            <button type="button" onclick="addXeRow()" style="background: @primaryColor; color: white; border: none; border-radius: 10px; height: 42px; font-size: 20px; font-weight: 900; cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='@secondaryColor'" onmouseout="this.style.background='@primaryColor'">+</button>
                        </div>
                    </div>
                </div>

                <div class="grid-mobile-1" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelStyle">Ảnh minh chứng (Click & Ctrl+V)</label>
                        <div id="paste_AnhXe" class="paste-zone" style="@pasteZoneStyle" tabindex="0">
                            Nhấp vào đây và nhấn Ctrl+V để dán ảnh
                        </div>
                        <input type="file" id="AnhXe" name="AnhXe" hidden accept="image/*">
                    </div>

                    <div>
                        <label style="@labelStyle">Tài liệu đính kèm (PDF/Scan)</label>
                        <div style="margin-top:10px; background: #ffffff; padding: 15px; border-radius: 12px; border: 1px dashed @softBorder; height: 180px; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;">
                            <input type="file" name="UploadFile" style="font-size: 13px; width: 100%;">
                            <p style="font-size: 11px; color: @secondaryColor; margin-top: 15px; line-height: 1.4; opacity: 0.8;">Đính kèm lộ trình chi tiết hoặc file liên quan.</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CHỌN LOẠI YÊU CẦU HỖ TRỢ --- *@
            <div class="mobile-section" style="background: #ffffff; padding: 25px; border-radius: 20px; border: 1px solid @softBorder; margin-bottom: 30px; box-shadow: 0 4px 6px rgba(237, 137, 54, 0.05);">
                <h3 style="color: @secondaryColor; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @primaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">3</span>
                    Chọn loại yêu cầu hỗ trợ
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px;">
                    @if (ViewBag.ListNguoiHoTro != null)
                    {
                        foreach (var item in (List<E_Form_Best.Models.ITForm.HrNguoiHoTro>)ViewBag.ListNguoiHoTro)
                        {
                            foreach (var cv in item.CongViecHrs)
                            {
                                <label style="display: flex; align-items: center; gap: 12px; padding: 15px; border: 1px solid @softBorder; border-radius: 12px; cursor: pointer; transition: 0.2s; background: #fffdfa;"
                                       onmouseover="this.style.borderColor='@primaryColor'; this.style.background='#fffaf0'; this.style.transform='translateY(-2px)';"
                                       onmouseout="this.style.borderColor='@softBorder'; this.style.background='#fffdfa'; this.style.transform='translateY(0)';"
                                       title="Phụ trách bởi: @item.Ten">
                                    
                                    <input type="checkbox" name="SelectedCongViecIds" value="@cv.Id" style="width: 20px; height: 20px; accent-color: @primaryColor;">
                                    
                                    <div style="flex: 1;">
                                        <div style="font-weight: 700; color: @secondaryColor; font-size: 14px; display: flex; align-items: center; gap: 8px;">
                                            <span style="font-size: 16px;">🚌</span> @cv.Ten
                                        </div>
                                        <div style="font-size: 11px; color: @secondaryColor; opacity: 0.7; margin-top: 2px;">
                                            Tiếp nhận: @item.Ten
                                        </div>
                                    </div>
                                </label>
                            }
                        }
                    }
                    else
                    {
                        <p style="font-size: 12px; color: @secondaryColor; font-style: italic; grid-column: 1/-1;">Đang tải danh sách hỗ trợ...</p>
                    }
                </div>
            </div>

            @* --- PHẦN 4: QUY ĐỊNH & CAM KẾT --- *@
            <div class="mobile-section" style="background: #fffaf0; border: 1.5px solid @primaryColor; border-radius: 20px; padding: 25px; margin-bottom: 30px;">
                <h3 style="color: @secondaryColor; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 15px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-car"></i> Quy định sử dụng xe công ty
                </h3>
                <ul style="margin: 0 0 20px 20px; padding: 0; color: @secondaryColor; font-size: 12px; line-height: 1.8; font-weight: 600; list-style-type: disc;">
                    <li>Việc đăng ký phải thực hiện trước ít nhất 24h.</li>
                    <li>Sử dụng đúng mục đích và bảo quản tài sản công.</li>
                </ul>

                <label id="containerCamKet" style="cursor: pointer; display: flex; align-items: flex-start; gap: 12px; background: #ffffff; padding: 15px; border-radius: 12px; border: 2px solid @softBorder; transition: 0.3s;">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; margin-top: 2px; accent-color: @primaryColor; cursor: pointer;">
                    <span style="font-size: 13px; font-weight: 800; color: @secondaryColor; line-height: 1.5;">
                        Tôi cam kết tuân thủ quy định và chịu trách nhiệm về nội dung khai báo.
                    </span>
                </label>
            </div>

            <div style="text-align: center;">
                <button type="button" onclick="xuLyLuuDon()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, @primaryColor, @secondaryColor); color: #fff; border: none; border-radius: 15px; font-weight: 900; font-size: 18px; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(237, 137, 54, 0.4); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-paper-plane" style="margin-right: 10px;"></i> Xác nhận đăng ký xe
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    window.onload = function() {
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        const timeString = now.toISOString().slice(0, 16);
        
        // Gán thời gian hiện tại cho ô datetime-local đầu tiên
        const inputs = document.getElementsByClassName('inp-time-xe');
        if(inputs.length > 0) inputs[0].value = timeString;
    };

    function handlePaste(e, inputId, zoneId) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        let blob = null;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                blob = items[i].getAsFile();
                break;
            }
        }
        if (blob) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const zone = document.getElementById(zoneId);
                zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:10px;">`;
                zone.style.border = "2px solid @primaryColor";

                const fileInput = document.getElementById(inputId);
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(blob);
                fileInput.files = dataTransfer.files;
            };
            reader.readAsDataURL(blob);
        }
    }

    const zoneEl = document.getElementById("paste_AnhXe");
    if (zoneEl) {
        zoneEl.addEventListener('paste', (e) => handlePaste(e, "AnhXe", "paste_AnhXe"));
        zoneEl.onclick = () => zoneEl.focus();
    }

    // --- HÀM THÊM Ô LỘ TRÌNH ĐỘNG ---
    function addXeRow() {
        const wrapper = document.getElementById('dynamicItemsWrapper');
        const row = document.createElement('div');
        row.className = 'dynamic-row-xe';

        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        const timeString = now.toISOString().slice(0, 16);

        row.innerHTML = `
            <input type="text" name="arrHoTen" placeholder="VD: V01234 - Nguyễn Văn A" style="@inputStyle" required>
            <input type="text" name="arrDiemDon" placeholder="Điểm đón" style="@inputStyle" required>
            <input type="datetime-local" name="arrTime" value="${timeString}" class="inp-time-xe" style="@inputStyle" required>
            <button type="button" class="btn-remove-row" onclick="this.parentElement.remove()" style="background: #e53e3e; color: white; border: none; border-radius: 10px; height: 42px; width: 100%; font-size: 20px; font-weight: 900; cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='#c53030'" onmouseout="this.style.background='#e53e3e'">-</button>
        `;
        wrapper.appendChild(row);
    }

    function xuLyLuuDon() {
        const liDo = document.querySelector('textarea[name="chiTiet.LiDo"]').value.trim();
        const chk = document.getElementById('chkCamKet');
        const selectedHoTro = document.querySelectorAll('input[name="SelectedCongViecIds"]:checked');

        // KIỂM TRA MẢNG ĐỘNG
        const arrHoTen = document.getElementsByName('arrHoTen');
        const arrDiemDon = document.getElementsByName('arrDiemDon');
        const arrTime = document.getElementsByName('arrTime');
        
        for (let i = 0; i < arrHoTen.length; i++) {
            if (!arrHoTen[i].value.trim() || !arrDiemDon[i].value.trim() || !arrTime[i].value) {
                alert("⚠️ Vui lòng điền đầy đủ (Họ tên, Điểm đón, Thời gian) ở danh sách lộ trình!");
                return;
            }
        }

        if (liDo.length < 5) {
            alert("⚠️ Vui lòng nhập lý do sử dụng xe cụ thể!");
            return;
        }
        if (selectedHoTro.length === 0) {
            alert("⚠️ Vui lòng chọn ít nhất một loại yêu cầu hỗ trợ!");
            return;
        }
        if (!chk.checked) {
            alert("⚠️ Bạn chưa tích chọn cam kết!");
            return;
        }

        if (confirm("Xác nhận gửi đơn đăng ký xe Daily?")) {
            document.getElementById("hrForm").submit();
        }
    }
</script>