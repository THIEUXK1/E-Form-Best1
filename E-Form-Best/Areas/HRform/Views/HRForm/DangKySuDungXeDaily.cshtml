@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký xe Daily hàng ngày";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- CHUYỂN ĐỔI TỪ SESSION SANG COOKIE CLAIMS (CK) ---
    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // Toolkit Style màu Cam/Hổ phách chủ đạo cho xe Daily
    string primaryColor = "#f59e0b"; // Amber 500
    string darkColor = "#78350f";
    string lightBg = "#fffbeb";

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid #fde68a; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {darkColor};";
    string labelStyle = "font-weight: 800; color: #92400e; font-size: 11px; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 1px;";
    string boxStyle = $"background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #fde68a; margin-bottom: 25px; box-shadow: 0 10px 15px -3px rgba(245, 158, 11, 0.05);";
}

<div style="background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%); padding: 50px 15px; min-height: 100vh; font-family: 'Inter', sans-serif;">

    <form id="dailyCarForm" method="post" enctype="multipart/form-data" action="/FormHR/DangKySuDungXeDaily"
          style="max-width: 850px; margin: 0 auto; background: #ffffff; border-radius: 35px; box-shadow: 0 25px 50px -12px rgba(120, 53, 15, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER GRADIENT --- *@
        <div style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); padding: 45px 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 20px; right: 30px; font-size: 10px; opacity: 0.8; font-weight: 700; letter-spacing: 2px;">E-FORM DAILY SHUTTLE</div>
            <h2 style="margin: 0; font-size: 26px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px;">Đăng ký sử dụng xe Daily</h2>
            <div style="margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; background: rgba(255,255,255,0.2); border-radius: 100px; font-size: 13px; backdrop-filter: blur(4px);">
                <span>📅 Ngày đăng ký:</span>
                <span style="font-weight: 800;">@ngayHienThi</span>
            </div>
        </div>

        <div style="padding: 40px;">

            @* --- PHẦN 1: THÔNG TIN NHÂN SỰ (Lấy từ CK) --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: #92400e; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-id-badge" style="font-size: 18px; color: #f59e0b;"></i> Thông tin nhân viên
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                    <div><label style="@labelStyle">Họ tên</label><input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #fffcf0; border-color: #fef3c7;"></div>
                    <div><label style="@labelStyle">Bộ phận</label><input name="PhanBo" value="@phongBan" readonly style="@inputStyle; background: #fffcf0; border-color: #fef3c7;"></div>
                    <div><label style="@labelStyle">Mã NV / Email</label><input value="@soNhanVien" readonly style="@inputStyle; background: #fffcf0; border-color: #fef3c7;"></div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT ĐĂNG KÝ XE DAILY --- *@
            <div style="@boxStyle">
                <h3 style="color: #92400e; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 25px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-bus" style="font-size: 18px; color: #f59e0b;"></i> Lộ trình & Thời gian đăng ký
                </h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px;">
                    <div>
                        <label style="@labelStyle">Thời gian bắt đầu đi <span style="color:#ef4444">*</span></label>
                        <input type="datetime-local" id="inpTimeDuTinh" name="TimeDuTinh"
                               style="@inputStyle; border-color: #f59e0b; box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.05);" required>
                    </div>
                    <div>
                        <label style="@labelStyle">Điểm đón / Tuyến xe <span style="color:#ef4444">*</span></label>
                        <input type="text" name="DiemDon" placeholder="VD: Trạm chờ A, Cổng số 2..."
                               style="@inputStyle;" required>
                    </div>
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="@labelStyle">Lý do sử dụng xe / Ghi chú chi tiết <span style="color:#ef4444">*</span></label>
                    <textarea name="LiDo" placeholder="Mô tả mục đích đi lại hàng ngày hoặc các yêu cầu đặc biệt..."
                              style="@inputStyle; height: 100px; resize: none;" required></textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                    @* Khu vực dán ảnh minh chứng *@
                    <div>
                        <label style="@labelStyle">Ảnh minh chứng / Thẻ xe (Ctrl+V)</label>
                        <div id="paste_AnhXe" tabindex="0" class="paste-zone"
                             style="width: 100%; border: 2.5px dashed #f59e0b; height: 160px; border-radius: 18px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fffcf0; color: #d97706; cursor: pointer; transition: 0.3s; gap: 10px; outline: none;">
                            <i class="fa fa-camera" style="font-size: 24px;"></i>
                            <span style="font-size: 11px; font-weight: 700; text-align:center; padding:0 10px;">Dán ảnh mặt trước thẻ NV hoặc lịch trình tại đây</span>
                        </div>
                        <input type="file" id="AnhXe" name="AnhXe" hidden accept="image/*">
                    </div>

                    @* Khu vực đính kèm file phụ trợ *@
                    <div>
                        <label style="@labelStyle">File đính kèm (Nếu có)</label>
                        <div style="background: #ffffff; border: 2px dashed #e2e8f0; border-radius: 18px; padding: 20px; height: 160px; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                            <i class="fa fa-cloud-upload" style="font-size: 24px; color: #cbd5e1; margin-bottom: 10px;"></i>
                            <input type="file" name="UploadFile" style="font-size: 11px; width: 100%; color: #64748b;">
                            <p style="font-size: 9px; color: #94a3b8; margin-top: 10px; text-align: center;">Hỗ trợ PDF, Excel, JPG</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CAM KẾT VÀ NỘI QUY --- *@
            <div style="@boxStyle; border-color: #fde68a; background: #fffbeb; padding: 25px;">
                <h3 style="color: #92400e; font-size: 13px; display: flex; align-items: center; gap: 10px; margin-bottom: 15px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-info-circle"></i> Nội quy sử dụng xe Daily
                </h3>
                <ul style="margin: 0 0 20px 20px; padding: 0; color: #92400e; font-size: 12px; line-height: 1.8; font-weight: 600; list-style-type: square;">
                    <li>Nhân viên phải có mặt tại điểm đón ít nhất 5 phút trước giờ xe chạy.</li>
                    <li>Tuyệt đối tuân thủ sự sắp xếp chỗ ngồi của quản lý xe/tài xế.</li>
                    <li>Giữ gìn vệ sinh chung, không hút thuốc hoặc mang thực phẩm nặng mùi lên xe.</li>
                </ul>

                @* Ô CHECKBOX CAM KẾT *@
                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer; padding: 15px; background: #ffffff; border-radius: 15px; border: 2px solid #fcd34d; transition: 0.3s;" id="labelCamKet">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; cursor: pointer; accent-color: #f59e0b;">
                    <span style="font-size: 13px; color: #78350f; font-weight: 800; line-height: 1.4;">
                        Tôi xác nhận thông tin đăng ký là chính xác và cam kết tuân thủ nội quy sử dụng xe của công ty.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="margin-top: 30px; text-align: center;">
                <button type="button" onclick="guiDonDaily()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, #f59e0b, #d97706); color: #fff; border: none; border-radius: 20px; font-weight: 900; font-size: 17px; cursor: pointer; transition: 0.3s; box-shadow: 0 15px 30px -5px rgba(245, 158, 11, 0.4); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-check-circle" style="margin-right: 10px;"></i> Gửi yêu cầu xe Daily
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // 1. Tự động thiết lập thời gian mặc định
    window.onload = function() {
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById('inpTimeDuTinh').value = now.toISOString().slice(0, 16);
    };

    // 2. Logic dán ảnh (Paste) từ Clipboard
    const zone = document.getElementById("paste_AnhXe");
    if (zone) {
        zone.addEventListener('paste', (e) => {
            const items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    const blob = items[i].getAsFile();
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">`;
                        zone.style.borderColor = "#f59e0b";
                        zone.style.background = "#ffffff";

                        const fileInput = document.getElementById("AnhXe");
                        const dataTransfer = new DataTransfer();
                        dataTransfer.items.add(blob);
                        fileInput.files = dataTransfer.files;
                    };
                    reader.readAsDataURL(blob);
                }
            }
        });
        zone.addEventListener('click', () => zone.focus());
        zone.addEventListener('focus', () => zone.style.borderColor = "#d97706");
        zone.addEventListener('blur', () => {
             if (!document.getElementById("AnhXe").files.length) {
                zone.style.borderColor = "#f59e0b";
             }
        });
    }

    // 3. Hàm gửi đơn và kiểm tra dữ liệu
    function guiDonDaily() {
        const timeValue = document.getElementById('inpTimeDuTinh').value;
        const diemDon = document.querySelector('input[name="DiemDon"]').value;
        const lyDo = document.querySelector('textarea[name="LiDo"]').value;
        const labelCamKet = document.getElementById("labelCamKet");

        // Kiểm tra các trường bắt buộc
        if (!timeValue) {
            alert("⚠️ Vui lòng chọn thời gian đi dự kiến!");
            return;
        }
        if (!diemDon.trim()) {
            alert("⚠️ Vui lòng nhập điểm đón hoặc tuyến xe!");
            return;
        }
        if (lyDo.trim().length < 5) {
            alert("⚠️ Vui lòng nhập lý do sử dụng xe chi tiết hơn!");
            return;
        }

        // Kiểm tra cam kết
        if (!document.getElementById('chkCamKet').checked) {
            alert("⚠️ Bạn chưa xác nhận cam kết tuân thủ nội quy!");
            labelCamKet.style.borderColor = "#ef4444";
            labelCamKet.style.background = "#fee2e2";
            return;
        } else {
            labelCamKet.style.borderColor = "#fcd34d";
            labelCamKet.style.background = "#ffffff";
        }

        // Xác nhận cuối cùng và nộp form
        if (confirm("Xác nhận gửi đơn đăng ký xe Daily này?")) {
            document.getElementById("dailyCarForm").submit();
        }
    }
</script>