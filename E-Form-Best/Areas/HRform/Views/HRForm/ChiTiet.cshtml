                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(xn.GhiChu))
                                                {
                                                    <div id="xnGhiChu-@xn.Id" style="margin-top:6px;padding:5px 10px;background:rgba(255,255,255,0.7);border-radius:8px;font-size:11px;color:#475569;border-left:3px solid @badgeBg;font-style:italic;">
                                                        <i class="fa fa-comment"></i> @xn.GhiChu
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div id="xnGhiChu-@xn.Id"></div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (myXacNhan != null && !isCancelled)
                            {
                                <div style="padding:0 20px 20px 20px;">
                                    <div style="background:#faf5ff;border:2px dashed #c4b5fd;border-radius:18px;padding:20px;">
                                        <p style="margin:0 0 12px 0;font-size:13px;font-weight:800;color:#6b21a8;display:flex;align-items:center;gap:8px;">
                                            <i class="fa fa-pen"></i> HÀNH ĐỘNG CỦA BẠN:
                                        </p>
                                        <textarea id="txtGhiChuXacNhan" placeholder="Ghi chú (tùy chọn)..."
                                                  style="width:100%;padding:10px 12px;border:1.5px solid #ddd6fe;border-radius:10px;font-size:13px;resize:vertical;min-height:60px;outline:none;font-family:'Segoe UI',sans-serif;box-sizing:border-box;margin-bottom:12px;transition:border 0.2s;"
                                                  onfocus="this.style.borderColor='#7c3aed'" onblur="this.style.borderColor='#ddd6fe'"></textarea>
                                        <div style="display:flex;gap:10px;">
                                            <button id="btnXnDuyet" onclick="giamDocXacNhan(@myXacNhan.Id, 'Approve')"
                                                    style="flex:1;padding:13px;background:#059669;color:white;border:none;border-radius:12px;font-weight:800;cursor:pointer;font-size:14px;box-shadow:0 4px 10px rgba(5,150,105,0.3);transition:all 0.2s;"
                                                    onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                                                <i class="fa fa-check"></i> DUYỆT
                                            </button>
                                            <button id="btnXnTuChoi" onclick="giamDocXacNhan(@myXacNhan.Id, 'Reject')"
                                                    style="flex:1;padding:13px;background:white;color:#dc2626;border:2px solid #dc2626;border-radius:12px;font-weight:800;cursor:pointer;font-size:14px;transition:all 0.2s;"
                                                    onmouseover="this.style.background='#fef2f2';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='white';this.style.transform=''">
                                                <i class="fa fa-times"></i> TỪ CHỐI
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (!isCancelled && !isFinished)
                    {
                        <div style="display:flex;flex-direction:column;gap:15px;margin-bottom:25px;">
                            @if (!isApprovedByManager && (User.IsInRole("All") || User.IsInRole("AdminHR") || User.IsInRole("QuanLyDuyetDonHR")))
                            {
                                <button id="btnDuyet" onclick="handleAction('Duyet')"
                                        style="background:#059669;color:white;border:none;padding:20px;border-radius:18px;font-weight:900;cursor:pointer;font-size:16px;box-shadow:0 10px 15px -3px rgba(5,150,105,0.3);transition:all 0.2s;"
                                        onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                                    <i class="fa fa-check-circle"></i> DUYỆT ĐƠN (QUẢN LÝ)
                                </button>
                            }
                            @if (isApprovedByManager && (User.IsInRole("All") || User.IsInRole("AdminHR")))
                            {
                                <button id="btnHoanThanh" onclick="handleXacNhanHoanThanh()"
                                        style="background:#1e40af;color:white;border:none;padding:20px;border-radius:18px;font-weight:900;cursor:pointer;font-size:16px;box-shadow:0 10px 15px -3px rgba(30,64,175,0.3);transition:all 0.2s;"
                                        onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                                    <i class="fa fa-star"></i> XÁC NHẬN HOÀN TẤT (HR)
                                </button>
                            }
                            @if (User.IsInRole("All") || User.IsInRole("AdminHR") || User.IsInRole("QuanLyDuyetDonHR"))
                            {
                                <button id="btnHuy" onclick="handleAction('Huy')"
                                        style="background:white;color:#dc2626;border:2px solid #dc2626;padding:18px;border-radius:18px;font-weight:800;cursor:pointer;font-size:15px;transition:all 0.2s;"
                                        onmouseover="this.style.background='#fef2f2';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='white';this.style.transform=''">
                                    <i class="fa fa-times-circle"></i> HỦY ĐƠN PHIẾU
                                </button>
                            }
                        </div>
                    }

                    <div style="background:#fff;border-radius:28px;border:1px solid #e2e8f0;overflow:hidden;box-shadow:0 10px 15px -3px rgba(0,0,0,0.04);margin-bottom:25px;">
                        <div style="background:linear-gradient(135deg,#f8fafc,#fff);padding:20px 25px;border-bottom:2px solid #e2e8f0;">
                            <h4 style="margin:0;font-size:16px;font-weight:900;color:#1e293b;display:flex;align-items:center;gap:10px;">
                                <i class="fa fa-comments"></i>
                                <span>BÌNH LUẬN</span>
                                <span id="commentCount" style="background:#3b82f6;color:white;padding:2px 10px;border-radius:12px;font-size:12px;">0</span>
                            </h4>
                        </div>
                        <div id="commentList" style="max-height:450px;overflow-y:auto;padding:20px;background:#f8fafc;scrollbar-width:thin;">
                            <div style="text-align:center;color:#94a3b8;padding:20px;">
                                <i class="fa fa-spinner fa-spin" style="font-size:24px;"></i>
                                <p style="margin-top:10px;font-size:14px;">Đang tải bình luận...</p>
                            </div>
                        </div>
                        <div style="padding:20px;background:white;border-top:2px solid #e2e8f0;">
                            <form id="formBinhLuan" enctype="multipart/form-data">
                                <textarea id="txtBinhLuan" name="noiDung" placeholder="Nhập bình luận..."
                                          style="width:100%;padding:12px;border:2px solid #e2e8f0;border-radius:12px;font-size:14px;resize:vertical;min-height:80px;outline:none;font-family:'Segoe UI',sans-serif;box-sizing:border-box;margin-bottom:12px;"
                                          onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#e2e8f0'"></textarea>
                                <div class="mobile-comment-action" style="display:flex;align-items:center;gap:12px;">
                                    <label for="fileBinhLuan"
                                           style="flex:1;padding:12px;background:#f8fafc;border:2px dashed #cbd5e1;border-radius:12px;cursor:pointer;text-align:center;font-size:14px;color:#64748b;font-weight:600;display:flex;align-items:center;justify-content:center;gap:8px;transition:all 0.2s;"
                                           onmouseover="this.style.borderColor='#3b82f6';this.style.background='#eff6ff'" onmouseout="this.style.borderColor='#cbd5e1';this.style.background='#f8fafc'">
                                        <i class="fa fa-paperclip"></i>
                                        <span id="fileLabel">Đính kèm file (max 50MB)</span>
                                        <input type="file" id="fileBinhLuan" name="file" style="display:none;" onchange="updateFileLabel(this)">
                                    </label>
                                    <button type="submit" id="btnGuiBinhLuan"
                                            style="padding:12px 30px;background:linear-gradient(135deg,#3b82f6,#1e40af);color:white;border:none;border-radius:12px;font-weight:800;cursor:pointer;font-size:14px;white-space:nowrap;"
                                            onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                                        <i class="fa fa-paper-plane"></i> Gửi
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    @if (User.IsInRole("All") || User.IsInRole("AdminHR") || User.IsInRole("BaoVeHR"))
                    {
                        <div style="background:#fff;border-radius:28px;border:1px solid #d1d5db;overflow:hidden;box-shadow:0 10px 15px -3px rgba(0,0,0,0.06);">
                            <div style="background:linear-gradient(135deg,#1c1917 0%,#44403c 100%);padding:18px 25px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
                                <h4 style="margin:0;font-size:15px;font-weight:900;color:white;display:flex;align-items:center;gap:10px;">
                                    <i class="fa fa-shield"></i> BẢO VỆ
                                </h4>
                                @if (daBaoVe)
                                {
                                    <span style="background:@(baoVeHoanTat ? "#059669" : "#d97706");color:white;padding:3px 12px;border-radius:12px;font-size:11px;font-weight:800;">
                                        <i class="fa fa-@(baoVeHoanTat ? "check-circle" : "clock-o")"></i>
                                        @(baoVeHoanTat ? "HOÀN TẤT" : "ĐANG XỬ LÝ")
                                    </span>
                                }
                            </div>
                            <div style="padding:22px;">
                                @if (!daBaoVe)
                                {
                                    <p style="margin:0 0 14px 0;font-size:13px;color:#78716c;line-height:1.6;">
                                        Gửi phiếu này đến đội <strong>Bảo Vệ</strong> để xử lý. Bảo Vệ sẽ bổ bật thông tin sau.
                                    </p>
                                    <button id="btnDayBaoVe" onclick="dayDenBaoVe()"
                                            style="width:100%;padding:16px;background:linear-gradient(135deg,#292524,#57534e);color:white;border:none;border-radius:14px;font-weight:900;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 6px 12px rgba(0,0,0,0.18);transition:all 0.2s;"
                                            onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 10px 20px rgba(0,0,0,0.25)'"
                                            onmouseout="this.style.transform='';this.style.boxShadow='0 6px 12px rgba(0,0,0,0.18)'">
                                        <i class="fa fa-shield"></i> ĐẨY SANG BẢO VỆ
                                    </button>
                                }
                                else if (baoVeHoanTat)
                                {
                                    <div style="background:#f0fdf4;border:2px solid #bbf7d0;border-radius:16px;padding:18px;">
                                        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                                            <div style="width:42px;height:42px;background:#059669;border-radius:12px;display:flex;align-items:center;justify-content:center;color:white;font-size:20px;flex-shrink:0;">
                                                <i class="fa fa-check"></i>
                                            </div>
                                            <div>
                                                <div style="font-weight:900;color:#065f46;font-size:15px;">Bảo Vệ đã xác nhận hoàn tất</div>
                                                <div style="font-size:12px;color:#059669;margin-top:2px;word-break:break-word;">
                                                    <i class="fa fa-user"></i> @baoVeRecord!.TenBaoVe
                                                    &nbsp;·&nbsp;
                                                    <i class="fa fa-clock-o"></i> @baoVeRecord.TimeBaoVe?.ToString("HH:mm dd/MM/yyyy")
                                                </div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(baoVeRecord!.GhiChu))
                                        {
                                            <div style="background:white;border-left:4px solid #059669;padding:10px 14px;border-radius:8px;font-size:13px;color:#374151;font-style:italic;word-break:break-word;">
                                                <i class="fa fa-comment" style="color:#059669;"></i> @baoVeRecord.GhiChu
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="background:#fff7ed;border:2px solid #fed7aa;border-radius:16px;padding:18px;margin-bottom:16px;">
                                        <div style="display:flex;align-items:center;gap:10px;">
                                            <i class="fa fa-clock-o" style="color:#d97706;font-size:22px;"></i>
                                            <div>
                                                <div style="font-weight:800;color:#92400e;font-size:14px;">Đang chờ Bảo Vệ xử lý</div>
                                                <div style="font-size:12px;color:#b45309;margin-top:2px;">Phiếu đã được gửi đến đội Bảo Vệ</div>
                                            </div>
                                        </div>
                                    </div>
                                    @if (canBaoVeAction)
                                    {
                                        <div style="background:#f8fafc;border:2px dashed #94a3b8;border-radius:16px;padding:18px;">
                                            <p style="margin:0 0 12px 0;font-size:13px;font-weight:800;color:#334155;display:flex;align-items:center;gap:8px;">
                                                <i class="fa fa-shield"></i> XÁC NHẬN HOÀN TẤT (BẢO VỆ):
                                            </p>
                                            <textarea id="txtGhiChuBaoVe" placeholder="Nhập ghi chú xác nhận (tùy chọn)..."
                                                      style="width:100%;padding:10px 12px;border:1.5px solid #cbd5e1;border-radius:10px;font-size:13px;resize:vertical;min-height:70px;outline:none;font-family:'Segoe UI',sans-serif;box-sizing:border-box;margin-bottom:12px;transition:border 0.2s;"
                                                      onfocus="this.style.borderColor='#475569'" onblur="this.style.borderColor='#cbd5e1'"></textarea>
                                            <button id="btnBaoVeXacNhan" onclick="baoVeXacNhan(@baoVeRecord!.Id)"
                                                    style="width:100%;padding:14px;background:linear-gradient(135deg,#1c1917,#44403c);color:white;border:none;border-radius:12px;font-weight:900;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 10px rgba(0,0,0,0.2);transition:all 0.2s;"
                                                    onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
                                                <i class="fa fa-check-circle"></i> XÁC NHẬN HOÀN TẤT
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* --- OVERLAY ZOOM CÓ NÚT XOAY ẢNH SIÊU ĐẸP, 100% INLINE CSS --- *@
    <div id="imageOverlay" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,0.95);z-index:9999;justify-content:center;align-items:center;backdrop-filter:blur(8px);">
        <!-- Thanh công cụ chứa các nút bấm -->
        <div class="mobile-zoom-toolbar" style="position:absolute;top:25px;right:35px;display:flex;gap:15px;z-index:10000;">
            <button onclick="rotateImage(-90, event)" style="background:rgba(255,255,255,0.15);color:white;border:1.5px solid rgba(255,255,255,0.3);border-radius:16px;width:54px;height:54px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:22px;transition:all 0.3s;backdrop-filter:blur(8px);" onmouseover="this.style.background='rgba(255,255,255,0.3)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.15)';this.style.transform='none'" title="Xoay trái">
                <i class="fa fa-undo"></i>
            </button>
            <button onclick="rotateImage(90, event)" style="background:rgba(255,255,255,0.15);color:white;border:1.5px solid rgba(255,255,255,0.3);border-radius:16px;width:54px;height:54px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:22px;transition:all 0.3s;backdrop-filter:blur(8px);" onmouseover="this.style.background='rgba(255,255,255,0.3)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.15)';this.style.transform='none'" title="Xoay phải">
                <i class="fa fa-rotate-right"></i>
            </button>
            <div style="width:2px;background:rgba(255,255,255,0.2);margin:10px 0;"></div>
            <button onclick="closeZoom(event)" style="background:#ef4444;color:white;border:none;border-radius:16px;width:54px;height:54px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:26px;transition:all 0.3s;box-shadow:0 4px 15px rgba(239,68,68,0.4);" onmouseover="this.style.background='#dc2626';this.style.transform='translateY(-2px) scale(1.05)'" onmouseout="this.style.background='#ef4444';this.style.transform='none'" title="Đóng">
                <i class="fa fa-times"></i>
            </button>
        </div>
        <!-- Vùng nhấp chuột bên ngoài để đóng -->
        <div style="position:absolute;top:0;left:0;width:100%;height:100%;z-index:9998;" onclick="closeZoom()"></div>
        <!-- Container chứa ảnh -->
        <div style="position:relative;z-index:9999;width:95%;height:95%;display:flex;align-items:center;justify-content:center;pointer-events:none;">
            <img id="fullImage" src="" style="max-width:100%;max-height:100%;border-radius:16px;transition:transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);object-fit:contain;box-shadow:0 25px 50px -12px rgba(0,0,0,0.5);pointer-events:auto;">
        </div>
    </div>
</div>

<script>
    const formId        = @Model.Id;
    const currentUserId = '@currentUserId';
    const userRoles     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                        User.FindAll(ClaimTypes.Role).Select(r => r.Value).ToList()));
    const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    function hasRole(r) { return userRoles.includes(r); }
    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                          .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    async function apiPost(url, body, btnIds) {
        if (btnIds) btnIds.forEach(id => { const b=document.getElementById(id); if(b) b.disabled=true; });
        try {
            const res  = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':TOKEN}, body:JSON.stringify(body) });
            const data = await res.json();
            if (data.success) { alert(data.message||'Thành công!'); location.reload(); }
            else {
                alert(data.message||'Thất bại');
                if (btnIds) btnIds.forEach(id=>{ const b=document.getElementById(id); if(b) b.disabled=false; });
            }
        } catch(err) {
            alert('Lỗi kết nối máy chủ.');
            if (btnIds) btnIds.forEach(id=>{ const b=document.getElementById(id); if(b) b.disabled=false; });
        }
    }

    // ── ZOOM & XOAY ẢNH ──
    let currentImageRotation = 0;

    function openZoom(src) {
        const imgEl = document.getElementById('fullImage');
        imgEl.src = src;
        currentImageRotation = 0; // Reset góc xoay mỗi khi mở ảnh mới
        imgEl.style.transform = `rotate(${currentImageRotation}deg)`;
        
        document.getElementById('imageOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    
    function closeZoom(event) {
        if(event) event.stopPropagation();
        document.getElementById('imageOverlay').style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    function rotateImage(degree, event) {
        if(event) event.stopPropagation(); // Ngăn sự kiện click đóng ảnh bên dưới
        currentImageRotation += degree;
        const imgEl = document.getElementById('fullImage');
        imgEl.style.transform = `rotate(${currentImageRotation}deg)`;
    }

    document.addEventListener('keydown', e => { if (e.key==='Escape') closeZoom(); });

    // ── DUYỆT BƯỚC 2 (B2) ──
    async function duyetB2(idRecord, action) {
        const ghiChu = prompt('Ghi chú (tùy chọn):', '') || '';
        if (!confirm('Xác nhận ' + (action === 'Approve' ? 'duyệt' : 'từ chối') + ' bước này?')) return;
        try {
            const res = await fetch('/FormHR/DuyetB2', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
                body: JSON.stringify({ idB2: idRecord, idForm: formId, loaiHanhDong: action, ghiChu })
            });
            const data = await res.json();
            if (data.success) {
                alert(data.message || 'Thành công');
                location.reload();
            } else {
                alert(data.message || 'Thất bại');
            }
        } catch (err) {
            alert('Lỗi kết nối: ' + err.message);
        }
    }

    // ── GIÁM ĐỐC XÁC NHẬN ──
    async function giamDocXacNhan(idXacNhan, action) {
        const ghiChu = document.getElementById('txtGhiChuXacNhan')?.value?.trim() ?? '';
        const label  = action === 'Approve' ? 'DUYỆT' : 'TỪ CHỐI';
        if (!confirm(`Xác nhận ${label} đơn này?`)) return;
        const btnD = document.getElementById('btnXnDuyet');
        const btnR = document.getElementById('btnXnTuChoi');
        if (btnD) btnD.disabled = true;
        if (btnR) btnR.disabled = true;
        try {
            const res  = await fetch('/FormHR/GiamDocPheDuyet', { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':TOKEN}, body:JSON.stringify({ idForm:formId, idNguoiXacNhan:idXacNhan, loaiHanhDong:action, lyDo:ghiChu }) });
            const data = await res.json();
            if (data.success) {
                const isApprove = data.trangThai === 1;
                const cardEl   = document.getElementById(`xnCard-${idXacNhan}`);
                const badgeEl  = document.getElementById(`xnBadge-${idXacNhan}`);
                const timeEl   = document.getElementById(`xnTime-${idXacNhan}`);
                const ghiChuEl = document.getElementById(`xnGhiChu-${idXacNhan}`);
                if (cardEl)  { cardEl.style.background=isApprove?'#f0fdf4':'#fff1f2'; cardEl.style.borderColor=isApprove?'#bbf7d0':'#fecaca'; }
                if (badgeEl) { badgeEl.style.background=isApprove?'#059669':'#dc2626'; badgeEl.innerHTML=isApprove?'<i class="fa fa-check-circle"></i> ĐÃ DUYỆT':'<i class="fa fa-times-circle"></i> TỪ CHỐI'; }
                if (timeEl && data.thoiGian) timeEl.innerHTML=`<div style="font-size:11px;color:#94a3b8;margin-top:3px;"><i class="fa fa-clock-o"></i> ${data.thoiGian}</div>`;
                if (ghiChuEl && ghiChu) { const bc=isApprove?'#059669':'#dc2626'; ghiChuEl.style.cssText=`margin-top:6px;padding:5px 10px;background:rgba(255,255,255,0.7);border-radius:8px;font-size:11px;color:#475569;border-left:3px solid ${bc};font-style:italic;`; ghiChuEl.innerHTML=`<i class="fa fa-comment"></i> ${escapeHtml(ghiChu)}`; }
                const actionBox = document.getElementById('btnXnDuyet')?.closest('div[style*="dashed"]');
                if (actionBox) actionBox.parentElement.style.display='none';
                alert(data.message);
            } else {
                alert(data.message||'Thất bại');
                if (btnD) btnD.disabled=false;
                if (btnR) btnR.disabled=false;
            }
        } catch(err) { alert('Lỗi kết nối: '+err.message); if(btnD) btnD.disabled=false; if(btnR) btnR.disabled=false; }
    }

    // ── NGHIỆP VỤ ĐƠN ──
    function handleAction(type) {
        let reason = null;
        if (type === 'Huy') {
            reason = prompt('Vui lòng nhập lý do hủy đơn:');
            if (reason === null || reason.trim() === '') return;
        }
        if (!hasRole('All') && !hasRole('AdminHR') && !hasRole('QuanLyDuyetDonHR'))
            return alert('Bạn không có quyền thực hiện thao tác này!');
        if (confirm('Xác nhận thao tác?'))
            apiPost('/FormHR/XuLyDon', { id:formId, action:type, reason }, ['btnDuyet','btnHuy']);
    }

    function handleXacNhanHoanThanh() {
        if (!hasRole('All') && !hasRole('AdminHR')) return alert('Chỉ HR Admin mới có quyền xác nhận hoàn tất!');
        if (confirm('Xác nhận đã hoàn thành?'))
            apiPost('/FormHR/XacNhanHoanThanh', { id:formId }, ['btnHoanThanh']);
    }

    function changeSupporter() {
        const select = document.getElementById('selectHR');
        const maNv   = select?.value;
        const tenNv  = select?.options[select.selectedIndex]?.text;
        if (!maNv) return alert('Vui lòng chọn một nhân viên HR!');
        if (!hasRole('All') && !hasRole('AdminHR'))
            return alert('Bạn không có quyền gán người hỗ trợ!');
        if (confirm(`Xác nhận chỉ định [${tenNv}] hỗ trợ đơn này?`))
            apiPost('/FormHR/ThemNguoiHoTro', { idFormHr:formId, maNv });
    }

    // ĐẨY SANG BẢO VỆ
    async function dayDenBaoVe() {
        if (!hasRole('All') && !hasRole('AdminHR') && !hasRole('BaoVeHR') && !hasRole('QuanLyDuyetDonHR'))
            return alert('Bạn không có quyền thực hiện thao tác này!');
        if (!confirm('Xác nhận đẩy phiếu này sang Bảo Vệ?')) return;
        const btn = document.getElementById('btnDayBaoVe');
        if (btn) { btn.disabled=true; btn.innerHTML='<i class="fa fa-spinner fa-spin"></i> Đang gửi...'; }
        try {
            const res  = await fetch('/FormHR/DayDenBaoVe', { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':TOKEN}, body:JSON.stringify({ idFormHr:formId }) });
            const data = await res.json();
            if (data.success) { alert(data.message||'Đã gửi sang Bảo Vệ thành công!'); location.reload(); }
            else { alert(data.message||'Thất bại!'); if(btn) { btn.disabled=false; btn.innerHTML='<i class="fa fa-shield"></i> ĐẨY SANG BẢO VỆ'; } }
        } catch(err) { alert('Lỗi kết nối: '+err.message); if(btn) { btn.disabled=false; btn.innerHTML='<i class="fa fa-shield"></i> ĐẨY SANG BẢO VỆ'; } }
    }

    // BẢO VỆ XÁC NHẬN HOÀN TẤT
    async function baoVeXacNhan(idBaoVe) {
        if (!hasRole('All') && !hasRole('BaoVeHR'))
            return alert('Bạn không có quyền xác nhận!');
        const ghiChu = document.getElementById('txtGhiChuBaoVe')?.value?.trim() ?? '';
        if (!confirm('Xác nhận hoàn tất xử lý Bảo Vệ?')) return;
        const btn = document.getElementById('btnBaoVeXacNhan');
        if (btn) { btn.disabled=true; btn.innerHTML='<i class="fa fa-spinner fa-spin"></i> Đang xử lý...'; }
        try {
            const res  = await fetch('/FormHR/BaoVeXacNhan', { method:'POST', headers:{'Content-Type':'application/json','RequestVerificationToken':TOKEN}, body:JSON.stringify({ idBaoVe, ghiChu }) });
            const data = await res.json();
            if (data.success) { alert(data.message||'Xác nhận hoàn tất thành công!'); location.reload(); }
            else { alert(data.message||'Thất bại!'); if(btn) { btn.disabled=false; btn.innerHTML='<i class="fa fa-check-circle"></i> XÁC NHẬN HOÀN TẤT'; } }
        } catch(err) { alert('Lỗi kết nối: '+err.message); if(btn) { btn.disabled=false; btn.innerHTML='<i class="fa fa-check-circle"></i> XÁC NHẬN HOÀN TẤT'; } }
    }

    // BÌNH LUẬN
    let currentSkipComment=0, hasMoreComments=true, isLoadingComments=false, totalComments=0, isSubmitting=false;
    const takeComment = 20;

    async function taiBinhLuan(isLoadMore=false) {
        if (isLoadingComments) return;
        isLoadingComments = true;
        try {
            const res  = await fetch(`/FormHR/LayBinhLuan/${formId}?skip=${currentSkipComment}&take=${takeComment}`);
            const data = await res.json();
            if (data.success) {
                const list = document.getElementById('commentList');
                if (!isLoadMore) { list.innerHTML=''; currentSkipComment=0; totalComments=0; }
                if (!data.data.length) {
                    if (!isLoadMore) list.innerHTML=`<div style="text-align:center;color:#94a3b8;padding:40px;"><i class="fa fa-comment-o" style="font-size:48px;opacity:0.3;display:block;margin-bottom:15px;"></i><p style="font-style:italic;font-size:14px;margin:0;">Chưa có bình luận nào.</p></div>`;
                    hasMoreComments = false;
                } else {
                    data.data.forEach(bl => { list.insertAdjacentHTML(isLoadMore?'afterbegin':'beforeend', renderComment(bl)); totalComments++; });
                    currentSkipComment += data.data.length;
                    if (data.data.length < takeComment) hasMoreComments = false;
                    if (!isLoadMore) setTimeout(()=>{ list.scrollTop=list.scrollHeight; }, 100);
                }
                updateCommentCount();
            }
        } catch(err) {
            document.getElementById('commentList').innerHTML=`<div style="text-align:center;color:#ef4444;padding:40px;">Lỗi tải bình luận.</div>`;
        } finally { isLoadingComments = false; }
    }

    function renderComment(bl) {
        const isOwn  = currentUserId === String(bl.idNguoiBinhLuan);
        const canDel = isOwn || hasRole('All') || hasRole('AdminHR');
        const time   = new Date(bl.thoiGian).toLocaleString('vi-VN',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit',year:'numeric'});
        let fileHtml = '';
        if (bl.fileDinhKem) {
            const name = bl.fileDinhKem.split('_').slice(2).join('_');
            const ext  = bl.fileDinhKem.split('.').pop().toLowerCase();
            const isImg = ['jpg','jpeg','png','gif','webp'].includes(ext);
            fileHtml = isImg
                ? `<div style="margin-top:8px;"><img src="/FormHR/DownloadBinhLuanFile/${encodeURIComponent(bl.fileDinhKem)}" onclick="openZoom(this.src)" style="max-width:200px;border-radius:8px;cursor:zoom-in;border:1px solid #e2e8f0;"/></div>`
                : `<div style="margin-top:10px;padding:10px;background:#f1f5f9;border-radius:8px;display:inline-flex;align-items:center;gap:8px;"><i class="fa fa-paperclip" style="color:#64748b;"></i><a href="/FormHR/DownloadBinhLuanFile/${encodeURIComponent(bl.fileDinhKem)}" download style="color:#3b82f6;text-decoration:none;font-weight:600;font-size:13px;">${escapeHtml(name)}</a></div>`;
        }
        const initial = (bl.tenNguoiBinhLuan || 'U').substring(0,1).toUpperCase();
        return `<div style="margin-bottom:15px;display:flex;gap:12px;${isOwn?'flex-direction:row-reverse;':''}" data-comment-id="${bl.id}">
            <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,${isOwn?'#3b82f6':'#94a3b8'},${isOwn?'#1e40af':'#64748b'});display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:16px;flex-shrink:0;">${initial}</div>
            <div style="flex:1;${isOwn?'text-align:right;':''}">
                <div style="display:inline-block;max-width:85%;">
                    <div style="display:flex;align-items:flex-start;gap:8px;margin-bottom:8px;${isOwn?'justify-content:flex-end;flex-direction:row-reverse;':''}">
                        <span style="font-weight:800;color:#1e293b;font-size:14px;">${escapeHtml(bl.tenNguoiBinhLuan||'Unknown')}</span>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <span style="font-size:11px;color:#94a3b8;">${time}</span>
                            ${canDel?`<i class="fa fa-trash" onclick="xoaBinhLuan(${bl.id})" style="color:#ef4444;cursor:pointer;font-size:12px;" title="Xóa"></i>`:''}
                        </div>
                    </div>
                    <div style="background:${isOwn?'#dbeafe':'white'};padding:12px 16px;border-radius:16px;border:1px solid #e2e8f0;text-align:left;">
                        ${bl.noiDung?`<div style="color:#1e293b;font-size:14px;line-height:1.6;word-wrap:break-word;white-space:pre-wrap;">${escapeHtml(bl.noiDung)}</div>`:''}
                        ${fileHtml}
                    </div>
                </div>
            </div></div>`;
    }

    async function guiBinhLuan(e) {
        e.preventDefault();
        if (isSubmitting) return;
        const noiDung = document.getElementById('txtBinhLuan').value.trim();
        const file    = document.getElementById('fileBinhLuan').files[0];
        if (!noiDung && !file) return alert('Vui lòng nhập nội dung hoặc đính kèm file!');
        if (file && file.size > 50*1024*1024) return alert('File không được vượt quá 50MB!');
        const fd = new FormData();
        fd.append('idForm', formId); fd.append('noiDung', noiDung);
        if (file) fd.append('file', file);
        const btn = document.getElementById('btnGuiBinhLuan');
        isSubmitting=true; btn.disabled=true; btn.innerHTML='<i class="fa fa-spinner fa-spin"></i> Đang gửi...';
        try {
            const res  = await fetch('/FormHR/ThemBinhLuan',{method:'POST',body:fd});
            const data = await res.json();
            if (data.success) {
                const list = document.getElementById('commentList');
                if (list.innerHTML.includes('Chưa có')) list.innerHTML='';
                list.insertAdjacentHTML('beforeend', renderComment(data.data));
                setTimeout(()=>{ list.scrollTop=list.scrollHeight; },100);
                document.getElementById('formBinhLuan').reset();
                document.getElementById('fileLabel').textContent='Đính kèm file (max 50MB)';
                totalComments++; updateCommentCount();
            } else alert(data.message||'Lỗi');
        } catch(err) { alert('Lỗi: '+err.message); }
        finally { isSubmitting=false; btn.disabled=false; btn.innerHTML='<i class="fa fa-paper-plane"></i> Gửi'; }
    }

    async function xoaBinhLuan(id) {
        if (!confirm('Xóa bình luận này?')) return;
        const res  = await fetch('/FormHR/XoaBinhLuan',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});
        const data = await res.json();
        if (data.success) {
            document.querySelector(`[data-comment-id="${id}"]`)?.remove();
            totalComments--; updateCommentCount();
            if (!document.getElementById('commentList').children.length)
                document.getElementById('commentList').innerHTML=`<div style="text-align:center;color:#94a3b8;padding:40px;">Chưa có bình luận nào.</div>`;
        } else alert(data.message);
    }

    function updateFileLabel(input) {
        const f = input.files[0];
        document.getElementById('fileLabel').textContent = f ? `${f.name} (${(f.size/1024/1024).toFixed(2)}MB)` : 'Đính kèm file (max 50MB)';
    }
    function updateCommentCount() { const e=document.getElementById('commentCount'); if(e) e.textContent=totalComments; }

    document.getElementById('commentList')?.addEventListener('scroll', function() {
        if (this.scrollTop===0 && hasMoreComments && !isLoadingComments) {
            const h = this.scrollHeight;
            taiBinhLuan(true).then(()=>{ this.scrollTop=this.scrollHeight-h; });
        }
    });
    document.getElementById('formBinhLuan')?.addEventListener('submit', guiBinhLuan);
    
    // Tải bình luận lần đầu khi load trang
    window.addEventListener('DOMContentLoaded', () => {
        taiBinhLuan();
    });
</script>