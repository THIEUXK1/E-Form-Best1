                                    string cardBg, cardBorder, badgeBg, badgeText, badgeIcon;
                                    switch (tt)
                                    {
                                        case 1: cardBg = "#f0fdf4"; cardBorder = "#bbf7d0"; badgeBg = "#059669"; badgeText = "ĐÃ DUYỆT"; badgeIcon = "fa-check-circle"; break;
                                        case 2: cardBg = "#fff1f2"; cardBorder = "#fecaca"; badgeBg = "#dc2626"; badgeText = "TỪ CHỐI"; badgeIcon = "fa-times-circle"; break;
                                        default: cardBg = "#faf5ff"; cardBorder = "#e9d5ff"; badgeBg = "#7c3aed"; badgeText = "CHỜ DUYỆT"; badgeIcon = "fa-clock-o"; break;
                                    }
