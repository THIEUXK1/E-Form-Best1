                            <div style="background:linear-gradient(135deg,#faf5ff,#f3e8ff);padding:18px 25px;border-bottom:2px solid #e9d5ff;display:flex;flex-wrap:wrap;gap:10px;align-items:center;">
                                <h4 style="margin:0;font-size:15px;font-weight:900;color:#6b21a8;display:flex;align-items:center;gap:10px;">
