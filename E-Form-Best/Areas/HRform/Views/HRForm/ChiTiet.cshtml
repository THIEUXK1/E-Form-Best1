                                <div style="position:absolute;left:-37px;top:0;width:14px;height:14px;border-radius:50%;background:@(isApprovedByManager ? "#d97706" : "#cbd5e1");border:3px solid white;box-shadow:0 0 0 2px @(isApprovedByManager ? "#d97706" : "#cbd5e1");"></div>
