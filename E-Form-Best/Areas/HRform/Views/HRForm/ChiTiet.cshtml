                                <div style="font-weight:800;font-size:15px;color:#1e293b;">HR Xử lý: @(Model.TenAdmin ?? "---")</div>
                                <div style="font-size:13px;color:#64748b;margin-top:4px;">@(Model.TimeAdmin?.ToString("HH:mm dd/MM/yyyy") ?? "Đang xử lý...")</div>
