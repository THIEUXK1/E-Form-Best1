                            <div style="background:linear-gradient(135deg,#faf5ff,#f3e8ff);padding:14px 18px;border-bottom:2px solid #e9d5ff;display:flex;flex-wrap:wrap;gap:10px;align-items:center;">
                                <h4 style="margin:0;font-size:15px;font-weight:900;color:#6b21a8;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                                    <i class="fa fa-users"></i> BƯỚC 2 — DANH SÁCH DUYỆT
                                    <span style="background:#f3e8ff; color:#9333ea; padding:2px 8px; border-radius:8px; font-size:11px; border:1px solid #d8b4fe;">
                                        @(hinhThucDuyetB2 == "OR" || hinhThucDuyetB2 == "ANY" ? "CHỈ CẦN 1 NGƯỜI DUYỆT" : "YÊU CẦU TẤT CẢ DUYỆT")
                                    </span>
                                </h4>
                                <span style="margin-left:auto;background:#7c3aed;color:white;padding:2px 10px;border-radius:12px;font-size:12px;font-weight:800;">
                                    @soNguoiB2DaDuyet / @danhSachB2.Count đã duyệt
                                </span>
                            </div>
                            <div style="padding:12px 16px;display:flex;flex-direction:column;gap:10px;">
                                @foreach (var b2 in danhSachB2)
                                {
                                    int tt = b2.TrangThaiXacNhan ?? 0;
                                    string statusTextB2 = tt == 1 ? "ĐÃ DUYỆT" : tt == 2 ? "TỪ CHỐI" : "CHỜ DUYỆT";
                                    string statusColorB2 = tt == 1 ? "#059669" : tt == 2 ? "#dc2626" : "#7c3aed";
                                    <div class="mobile-b2-item" data-b2-id="@b2.Id" style="display:flex;justify-content:space-between;align-items:center;padding:12px;border-radius:12px;border:1px solid #f1ecff;background:#fff;">
                                        <div>
                                            <div style="font-weight:800;color:#1f2937;">@b2.TenNguoiXacNhan</div>
                                            <div style="font-size:12px;color:#6b7280;margin-top:4px;">Thứ tự: @b2.ThuTuXacNhan &nbsp;·&nbsp; @b2.MaNguoiXacNhan</div>
                                            @if (b2.ThoiGianXacNhan.HasValue)
                                            {
                                                <div style="font-size:12px;color:#94a3b8;margin-top:6px;">@b2.ThoiGianXacNhan.Value.ToString("HH:mm dd/MM/yyyy")</div>
                                            }
                                            @if (!string.IsNullOrEmpty(b2.GhiChu))
                                            {
                                                <div style="margin-top:6px;font-size:13px;color:#374151;"><i class="fa fa-comment"></i> @b2.GhiChu</div>
                                            }
                                        </div>
                                        <div class="mobile-b2-actions" style="text-align:right;min-width:160px;">
                                            <div style="display:inline-block;background:@statusColorB2;color:white;padding:6px 10px;border-radius:10px;font-weight:800;font-size:12px;">@statusTextB2</div>
                                            @if ((string.Equals(b2.MaNguoiXacNhan ?? "", userEmailView, StringComparison.OrdinalIgnoreCase) || b2.IdnguoiXacNhan == currentUserId)
                                                  && (b2.TrangThaiXacNhan ?? 0) == 0 && !isCancelled && !isFinished)
                                            {
                                                <div style="margin-top:8px;display:flex;gap:8px;justify-content:flex-end;">
                                                    <button onclick="duyetB2(@b2.Id, 'Approve')" style="flex:1;background:#059669;color:white;border:none;padding:8px 12px;border-radius:8px;font-weight:800;">Duyệt</button>
                                                    <button onclick="duyetB2(@b2.Id, 'Reject')" style="flex:1;background:white;color:#dc2626;border:2px solid #dc2626;padding:8px 12px;border-radius:8px;font-weight:800;">Từ chối</button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (danhSachXacNhan.Any())
                    {
