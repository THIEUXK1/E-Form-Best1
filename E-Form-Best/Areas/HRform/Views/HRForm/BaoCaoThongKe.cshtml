@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>

@{
    ViewData["Title"] = "Thống kê & Báo cáo HR";
    Layout = "~/Areas/HRForm/Views/Shared/_Layout.cshtml";
}

<style>
    body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
    .stat-card { background: white; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); transition: transform 0.2s; }
    .stat-card:hover { transform: translateY(-5px); }
    .card-title { font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    .card-value { font-size: 24px; font-weight: 900; margin-top: 5px; display: block; }
    .chart-container { background: white; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0; margin-bottom: 20px; }
    .chart-header { font-weight: 800; color: #1e293b; margin-bottom: 15px; font-size: 16px; display: flex; align-items: center; gap: 10px; }
    
    .custom-table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 13px; }
    .custom-table th { background-color: #f1f5f9; color: #475569; text-align: left; padding: 12px; border-bottom: 2px solid #e2e8f0; }
    .custom-table td { padding: 12px; border-bottom: 1px solid #f1f5f9; color: #1e293b; }
    .badge-count { background: #f0fdf4; color: #166534; padding: 2px 8px; border-radius: 12px; font-weight: bold; }
    .badge-time { color: #0f172a; font-weight: 700; }
</style>

<div style="max-width: 1400px; margin: 20px auto; padding: 0 20px;">
    
    <div style="margin-bottom: 30px;">
        <h2 style="font-weight: 900; color: #1e293b; margin: 0;">
            <i class="fa fa-pie-chart" style="color: #059669;"></i> HỆ THỐNG QUẢN TRỊ BÁO CÁO NHÂN SỰ (HR)
        </h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px;">
        <div class="stat-card" style="border-top: 4px solid #64748b;"><span class="card-title">Tổng đơn HR</span><span class="card-value" id="lblTotal">0</span></div>
        <div class="stat-card" style="border-top: 4px solid #f59e0b;"><span class="card-title">Chờ QL duyệt</span><span class="card-value" id="lblWaitQL" style="color: #d97706;">0</span></div>
        <div class="stat-card" style="border-top: 4px solid #3b82f6;"><span class="card-title">HR đang xử lý</span><span class="card-value" id="lblProcessing" style="color: #2563eb;">0</span></div>
        <div class="stat-card" style="border-top: 4px solid #10b981;"><span class="card-title">Đã hoàn tất</span><span class="card-value" id="lblDone" style="color: #059669;">0</span></div>
        <div class="stat-card" style="border-top: 4px solid #ef4444;"><span class="card-title">Đơn đã hủy</span><span class="card-value" id="lblCancel" style="color: #dc2626;">0</span></div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-bottom: 20px;">
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-tasks"></i> Tỉ lệ Trạng thái đơn</div>
            <div style="height: 300px;"><canvas id="chartStatus"></canvas></div>
        </div>
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-users"></i> Yêu cầu theo Bộ phận</div>
            <div style="height: 300px;"><canvas id="chartDept"></canvas></div>
        </div>
    </div>

    <div class="chart-container">
        <div class="chart-header"><i class="fa fa-user-circle"></i> Hiệu suất Nhân viên HR (Chi tiết trạng thái đơn)</div>
        <div style="height: 400px;"><canvas id="chartStaff"></canvas></div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-tag"></i> Thống kê theo Danh mục HR</div>
            <div style="height: 350px;"><canvas id="chartCategory"></canvas></div>
        </div>
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-file-text-o"></i> Thống kê theo Loại đơn (IdForm)</div>
            <div style="height: 350px;"><canvas id="chartIdForm"></canvas></div>
        </div>
    </div>

    <div class="chart-container">
        <div class="chart-header"><i class="fa fa-list-alt"></i> Báo cáo chi tiết theo Người hỗ trợ & Danh mục</div>
        <div style="overflow-x: auto;">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Nhân Viên Phụ Trách</th>
                        <th>Danh Mục Nghiệp Vụ</th>
                        <th style="text-align: center;">Số Đơn</th>
                        <th style="text-align: center;">TG Xử Lý Trung Bình</th>
                    </tr>
                </thead>
                <tbody id="tblStaffBody"></tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
    Chart.register(ChartDataLabels);

    const commonLabelOptions = {
        color: '#fff',
        font: { weight: 'bold', family: 'Inter', size: 11 },
        formatter: (value) => value > 0 ? value : '',
        anchor: 'center',
        align: 'center'
    };

    function formatDuration(totalMinutes) {
        if (!totalMinutes || totalMinutes <= 0) return "-";
        const days = Math.floor(totalMinutes / 1440);
        const hours = Math.floor((totalMinutes % 1440) / 60);
        const mins = Math.round(totalMinutes % 60);
        let result = "";
        if (days > 0) { result += days + " ngày "; if (hours > 0) result += hours + " giờ"; }
        else if (hours > 0) { result += hours + " giờ "; if (mins > 0) result += mins + " phút"; }
        else { result += mins + " phút"; }
        return result.trim();
    }

    async function initStats() {
        try {
            const [resChung, resStaff] = await Promise.all([
                fetch('/FormHR/GetDataThongKe'),
                fetch('/FormHR/GetDataNguoiHoTro')
            ]);

            const dataChung = await resChung.json();
            const dataStaff = await resStaff.json();

            const statusResults = processStatusLogic(dataChung);
            updateCounters(statusResults);
            drawStatusChart(statusResults);
            
            drawDeptChart(dataChung);
            drawCategoryChart(dataChung);
            drawIdFormChart(dataChung);
            drawStaffChart(dataStaff);
            
            renderTable(dataStaff);

        } catch (e) { console.error("Lỗi dữ liệu HR:", e); }
    }

    function renderTable(data) {
        const summary = data.reduce((acc, curr) => {
            const key = `${curr.tenNguoiHoTro}|${curr.danhMuc}`;
            if (!acc[key]) {
                acc[key] = { name: curr.tenNguoiHoTro, cat: curr.danhMuc, count: 0, totalMin: 0, timeCount: 0 };
            }
            acc[key].count++;
            if (curr.phutXuLy !== null) {
                acc[key].totalMin += curr.phutXuLy;
                acc[key].timeCount++;
            }
            return acc;
        }, {});

        const tbody = document.getElementById('tblStaffBody');
        tbody.innerHTML = Object.values(summary)
            .sort((a, b) => b.count - a.count)
            .map(item => `
                <tr>
                    <td style="font-weight: 600;">${item.name}</td>
                    <td style="color: #64748b;">${item.cat}</td>
                    <td style="text-align: center;"><span class="badge-count">${item.count}</span></td>
                    <td style="text-align: center;" class="badge-time">
                        ${item.timeCount > 0 ? formatDuration(item.totalMin / item.timeCount) : '-'}
                    </td>
                </tr>
            `).join('');
    }

    function processStatusLogic(data) {
        let stats = { "HỦY": 0, "CHỜ QL": 0, "HR XỬ LÝ": 0, "HOÀN TẤT": 0 };
        data.forEach(item => {
            const isCancelled = (item.tenForm || "").includes("[ĐÃ HỦY]");
            if (isCancelled) stats["HỦY"]++;
            else if (item.idAdmin) stats["HOÀN TẤT"]++;
            else if (item.idNguoiDuyet) stats["HR XỬ LÝ"]++;
            else stats["CHỜ QL"]++;
        });
        return stats;
    }

    function updateCounters(s) {
        document.getElementById('lblTotal').innerText = Object.values(s).reduce((a, b) => a + b, 0);
        document.getElementById('lblWaitQL').innerText = s["CHỜ QL"];
        document.getElementById('lblProcessing').innerText = s["HR XỬ LÝ"];
        document.getElementById('lblDone').innerText = s["HOÀN TẤT"];
        document.getElementById('lblCancel').innerText = s["HỦY"];
    }

    function drawStatusChart(s) {
        new Chart(document.getElementById('chartStatus'), {
            type: 'doughnut',
            data: {
                labels: Object.keys(s),
                datasets: [{
                    data: Object.values(s),
                    backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6', '#10b981']
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' }, datalabels: commonLabelOptions }
            }
        });
    }

    function drawDeptChart(data) {
        const group = groupData(data, 'boPhan');
        new Chart(document.getElementById('chartDept'), {
            type: 'bar',
            data: {
                labels: Object.keys(group),
                datasets: [{ label: 'Đơn', data: Object.values(group), backgroundColor: '#059669', borderRadius: 5 }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { datalabels: { ...commonLabelOptions, anchor: 'end', align: 'top', color: '#444' } }
            }
        });
    }

    function drawStaffChart(dataStaff) {
        const staffs = [...new Set(dataStaff.map(item => item.tenNguoiHoTro))];
        const statuses = ["CHỜ QL", "HR XỬ LÝ", "HOÀN TẤT"];
        const colors = ['#f59e0b', '#3b82f6', '#10b981'];

        const datasets = statuses.map((status, i) => ({
            label: status,
            data: staffs.map(staff => dataStaff.filter(x => x.tenNguoiHoTro === staff && x.trangThai === status).length),
            backgroundColor: colors[i],
            stack: 'HRStack'
        }));

        new Chart(document.getElementById('chartStaff'), {
            type: 'bar',
            data: { labels: staffs, datasets: datasets },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top' }, datalabels: commonLabelOptions },
                scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true } }
            }
        });
    }

    function drawCategoryChart(data) {
        const group = groupData(data, 'danhmuc');
        new Chart(document.getElementById('chartCategory'), {
            type: 'bar',
            data: {
                labels: Object.keys(group),
                datasets: [{ label: 'Đơn', data: Object.values(group), backgroundColor: '#6366f1', borderRadius: 5 }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { datalabels: { ...commonLabelOptions, anchor: 'end', align: 'top', color: '#444' } }
            }
        });
    }

    function drawIdFormChart(data) {
        const group = groupData(data, 'idForm');
        new Chart(document.getElementById('chartIdForm'), {
            type: 'bar',
            data: {
                labels: Object.keys(group),
                datasets: [{ label: 'Đơn', data: Object.values(group), backgroundColor: '#f43f5e', borderRadius: 5 }]
            },
            options: {
                indexAxis: 'y',
                maintainAspectRatio: false,
                plugins: { datalabels: { ...commonLabelOptions, anchor: 'end', align: 'right', color: '#444' } }
            }
        });
    }

    function groupData(data, key) {
        return data.reduce((acc, x) => {
            let val = x[key] || "N/A";
            acc[val] = (acc[val] || 0) + 1;
            return acc;
        }, {});
    }

    document.addEventListener('DOMContentLoaded', initStats);
</script>