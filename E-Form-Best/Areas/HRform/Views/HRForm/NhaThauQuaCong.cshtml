@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký Nhà thầu qua cổng";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- LẤY THÔNG TIN TỪ CLAIMS ---
    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // Toolkit Style
    string primaryColor = "#0d9488";
    string darkColor = "#134e4a";
    string lightBg = "#f0fdfa";

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid #99f6e4; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {darkColor};";
    string labelStyle = "font-weight: 800; color: #115e59; font-size: 11px; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 1px;";
    string boxStyle = $"background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #ccfbf1; margin-bottom: 25px; box-shadow: 0 10px 15px -3px rgba(13, 148, 136, 0.05);";
}

<div style="background: linear-gradient(135deg, #f0fdfa 0%, #ccfbf1 100%); padding: 50px 15px; min-height: 100vh; font-family: 'Inter', sans-serif;">

    <form id="nhaThauForm" method="post" enctype="multipart/form-data" action="/FormHR/NhaThauQuaCong"
          style="max-width: 850px; margin: 0 auto; background: #ffffff; border-radius: 35px; box-shadow: 0 25px 50px -12px rgba(13, 78, 74, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div style="background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%); padding: 45px 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 20px; right: 30px; font-size: 10px; opacity: 0.8; font-weight: 700; letter-spacing: 2px;">E-FORM SECURITY</div>
            <h2 style="margin: 0; font-size: 26px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px;">Đăng ký Nhà thầu qua cổng</h2>
            <div style="margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; background: rgba(255,255,255,0.2); border-radius: 100px; font-size: 13px; backdrop-filter: blur(4px);">
                <span>📅 Ngày yêu cầu:</span>
                <span style="font-weight: 800;">@ngayHienThi</span>
            </div>
        </div>

        <div style="padding: 40px;">

            @* --- PHẦN 1: THÔNG TIN NGƯỜI PHỤ TRÁCH --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: #115e59; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-user-shield" style="font-size: 18px; color: #0d9488;"></i> Người phụ trách nhân sự
                </h3>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px;">
                    <div>
                        <label style="@labelStyle">Họ tên nhân viên</label>
                        <input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #f0fdfa;">
                    </div>
                    <div>
                        <label style="@labelStyle">Phòng ban</label>
                        <input name="BoPhan" value="@phongBan" readonly style="@inputStyle; background: #f0fdfa;">
                    </div>
                    <div>
                        <label style="@labelStyle">Mã nhân viên</label>
                        <input name="SoNhanVien" value="@soNhanVien" readonly style="@inputStyle; background: #f0fdfa;">
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label style="@labelStyle">Đơn vị / Công ty</label>
                        <input name="TenCongTy" value="@tenCongTy" readonly style="@inputStyle; background: #f0fdfa; border-style: dashed;">
                    </div>
                    <div>
                        <label style="@labelStyle">Danh mục hồ sơ</label>
                        <input name="Danhmuc" value="ĐƠN ĐĂNG KÝ NHÀ THẦU QUA CỔNG" readonly style="@inputStyle; background: #f0fdfa; border-style: dashed; color: #0d9488;">
                    </div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT NHÀ THẦU --- *@
            <div style="@boxStyle">
                <h3 style="color: #115e59; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 25px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-building" style="font-size: 18px; color: #0d9488;"></i> Thông tin hồ sơ nhà thầu
                </h3>

                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label style="@labelStyle">Tên đơn vị nhà thầu <span style="color:red">*</span></label>
                        <input name="TenNhaThau" placeholder="Nhập tên công ty nhà thầu..." required style="@inputStyle">
                    </div>
                    <div>
                        <label style="@labelStyle">Số lượng người</label>
                        <input type="number" name="SoNguoi" value="1" min="1" style="@inputStyle">
                    </div>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Người đăng ký (Đại diện nhà thầu)</label>
                    <input name="NguoiDangKy" placeholder="Họ tên người dẫn đoàn hoặc đại diện..." style="@inputStyle">
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="@labelStyle">Mục đích công việc / Nội dung thực hiện</label>
                    <textarea name="MucDichCongViec" placeholder="Mô tả ngắn gọn nội dung nhà thầu thực hiện..."
                              style="@inputStyle; height: 80px; resize: none; font-family: inherit;"></textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    @* VÙNG DÁN ẢNH *@
                    <div>
                        <label style="@labelStyle">Ảnh minh chứng (Thẻ/Lệnh làm việc)</label>
                        <div id="paste_AnhNhaThau" tabindex="0" class="paste-zone"
                             style="width: 100%; border: 2.5px dashed #0d9488; height: 180px; border-radius: 18px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f0fdfa; color: #0f766e; cursor: pointer; transition: 0.3s; gap: 10px; outline: none;">
                            <i class="fa fa-id-card-o" style="font-size: 30px;"></i>
                            <span style="font-size: 10px; font-weight: 700; text-align:center; padding: 0 15px;">Click & Ctrl+V để dán ảnh</span>
                        </div>
                        <input type="file" id="Anh" name="Anh" hidden accept="image/*">
                    </div>

                    @* FILE ĐÍNH KÈM *@
                    <div>
                        <label style="@labelStyle">Danh sách/Phương án (PDF/Excel)</label>
                        <div style="background: #ffffff; border: 2px dashed #cbd5e1; border-radius: 18px; padding: 20px; height: 180px; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 15px; box-sizing: border-box;">
                            <i class="fa fa-file-excel-o" style="font-size: 24px; color: #0d9488;"></i>
                            <input type="file" name="UploadFile" style="font-size: 12px; color: #475569; width: 100%;">
                            <p style="margin: 0; font-size: 10px; color: #94a3b8; font-weight: 600;">Hỗ trợ: .pdf, .xls, .xlsx</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CHỌN LOẠI YÊU CẦU HỖ TRỢ --- *@
            <div style="@boxStyle">
                <h3 style="color: #115e59; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-cogs" style="font-size: 18px; color: #0d9488;"></i> Chọn loại yêu cầu hỗ trợ
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px;">
                    @if (ViewBag.ListNguoiHoTro != null)
                    {
                        foreach (var item in (List<E_Form_Best.Models.ITForm.HrNguoiHoTro>)ViewBag.ListNguoiHoTro)
                        {
                            foreach (var cv in item.CongViecHrs)
                            {
                                <label style="display: flex; align-items: center; gap: 12px; padding: 15px; border: 1.5px solid #ccfbf1; border-radius: 15px; cursor: pointer; transition: 0.2s; background: #ffffff;"
                                       onmouseover="this.style.borderColor='#0d9488'; this.style.background='#f0fdfa'; this.style.transform='translateY(-2px)';"
                                       onmouseout="this.style.borderColor='#ccfbf1'; this.style.background='#ffffff'; this.style.transform='translateY(0)';"
                                       title="Tiếp nhận: @item.Ten">
                                    <input type="checkbox" name="SelectedCongViecIds" value="@cv.Id" style="width: 20px; height: 20px; accent-color: #0d9488;">
                                    <div style="flex: 1;">
                                        <div style="font-weight: 700; color: #134e4a; font-size: 13px;">🏗️ @cv.Ten</div>
                                        <div style="font-size: 10px; color: #0d9488; font-weight: 600;">@item.Ten</div>
                                    </div>
                                </label>
                            }
                        }
                    }
                    else
                    {
                        <p style="font-size: 12px; color: #64748b; font-style: italic;">Đang tải danh sách công việc hỗ trợ...</p>
                    }
                </div>
            </div>

            @* --- PHẦN 4: QUY ĐỊNH & CAM KẾT --- *@
            <div style="@boxStyle; border-color: #fde68a; background: #fffbeb; padding: 25px;">
                <h3 style="color: #92400e; font-size: 13px; display: flex; align-items: center; gap: 10px; margin-bottom: 15px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-exclamation-triangle"></i> Cam kết an toàn & Nội quy
                </h3>
                <ul style="margin: 0 0 20px 20px; padding: 0; color: #92400e; font-size: 12px; line-height: 1.8; font-weight: 600; list-style-type: square;">
                    <li>Tuân thủ tuyệt đối quy định An toàn lao động và PPE của công ty.</li>
                    <li>Cam kết chịu trách nhiệm về mọi hành vi của nhà thầu trong khuôn viên.</li>
                </ul>

                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer; padding: 15px; background: #ffffff; border-radius: 15px; border: 2px solid #fcd34d; transition: 0.3s;" id="labelCamKet">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; cursor: pointer; accent-color: #0d9488;">
                    <span style="font-size: 13px; color: #134e4a; font-weight: 800; line-height: 1.4;">
                        Tôi đã kiểm tra và xác nhận nội dung trên hoàn toàn đúng sự thật.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="guiDonNhaThau()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, #0d9488, #0f766e); color: #fff; border: none; border-radius: 20px; font-weight: 900; font-size: 17px; cursor: pointer; transition: 0.3s; box-shadow: 0 15px 30px -5px rgba(13, 148, 136, 0.4); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-check-square-o" style="margin-right: 10px;"></i> Xác nhận đăng ký nhà thầu
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // Xử lý dán ảnh
    const zone = document.getElementById("paste_AnhNhaThau");
    const input = document.getElementById("Anh");

    zone.addEventListener('paste', (e) => {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                const blob = items[i].getAsFile();
                const reader = new FileReader();
                reader.onload = function (event) {
                    zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:15px;">`;
                    zone.style.borderColor = "#0d9488";

                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(blob);
                    input.files = dataTransfer.files;
                };
                reader.readAsDataURL(blob);
            }
        }
    });

    zone.addEventListener('click', () => zone.focus());

    function guiDonNhaThau() {
        const tenNT = document.querySelector('input[name="TenNhaThau"]').value.trim();
        const chk = document.getElementById("chkCamKet");
        const selectedCV = document.querySelectorAll('input[name="SelectedCongViecIds"]:checked');

        if (tenNT === "") {
            alert("⚠️ Vui lòng nhập tên nhà thầu!");
            return;
        }
        if (selectedCV.length === 0) {
            alert("⚠️ Vui lòng chọn ít nhất một loại yêu cầu hỗ trợ!");
            return;
        }
        if (!chk.checked) {
            alert("⚠️ Vui lòng tích chọn cam kết!");
            return;
        }

        if (confirm("Xác nhận gửi đơn đăng ký nhà thầu?")) {
            document.getElementById("nhaThauForm").submit();
        }
    }
</script>