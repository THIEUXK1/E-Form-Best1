@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký Nhà thầu qua cổng";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- CHUYỂN ĐỔI TỪ SESSION SANG COOKIE CLAIMS (CK) ---
    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? ""; // Thường dùng Email hoặc NameIdentifier cho mã NV
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // Toolkit Style: Tông màu Teal (Xanh lục bảo) chuyên nghiệp cho kỹ thuật/nhà thầu
    string primaryColor = "#0d9488"; // Teal 600
    string darkColor = "#134e4a";
    string lightBg = "#f0fdfa";

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid #99f6e4; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {darkColor};";
    string labelStyle = "font-weight: 800; color: #115e59; font-size: 11px; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 1px;";
    string boxStyle = $"background: #ffffff; padding: 30px; border-radius: 24px; border: 1px solid #ccfbf1; margin-bottom: 25px; box-shadow: 0 10px 15px -3px rgba(13, 148, 136, 0.05);";
}

<div style="background: linear-gradient(135deg, #f0fdfa 0%, #ccfbf1 100%); padding: 50px 15px; min-height: 100vh; font-family: 'Inter', sans-serif;">

    <form id="nhaThauForm" method="post" enctype="multipart/form-data" action="/FormHR/NhaThauQuaCong"
          style="max-width: 850px; margin: 0 auto; background: #ffffff; border-radius: 35px; box-shadow: 0 25px 50px -12px rgba(13, 78, 74, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div style="background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%); padding: 45px 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 20px; right: 30px; font-size: 10px; opacity: 0.8; font-weight: 700; letter-spacing: 2px;">E-FORM SECURITY</div>
            <h2 style="margin: 0; font-size: 26px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px;">Đăng ký Nhà thầu qua cổng</h2>
            <div style="margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; padding: 6px 18px; background: rgba(255,255,255,0.2); border-radius: 100px; font-size: 13px; backdrop-filter: blur(4px);">
                <span>📅 Ngày yêu cầu:</span>
                <span style="font-weight: 800;">@ngayHienThi</span>
            </div>
        </div>

        <div style="padding: 40px;">

            @* --- THÔNG TIN NHÂN VIÊN PHỤ TRÁCH (Lấy từ CK) --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: #115e59; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-user-shield" style="font-size: 18px; color: #0d9488;"></i> Người phụ trách nhà thầu
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                    <div><label style="@labelStyle">Họ tên</label><input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #f0fdfa;"></div>
                    <div><label style="@labelStyle">Bộ phận</label><input name="PhanBo" value="@phongBan" readonly style="@inputStyle; background: #f0fdfa;"></div>
                    <div><label style="@labelStyle">Mã NV / Email</label><input value="@soNhanVien" readonly style="@inputStyle; background: #f0fdfa;"></div>
                </div>
            </div>

            @* --- CHI TIẾT NHÀ THẦU --- *@
            <div style="@boxStyle">
                <h3 style="color: #115e59; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 25px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-building" style="font-size: 18px; color: #0d9488;"></i> Hồ sơ nhà thầu & Minh chứng
                </h3>

                @* VÙNG DÁN ẢNH: LỆNH CÔNG TÁC / THẺ NHÀ THẦU *@
                <div style="margin-bottom: 25px;">
                    <label style="@labelStyle">Ảnh minh chứng: Thẻ nhà thầu / Lệnh làm việc (Ctrl+V)</label>
                    <div id="paste_AnhNhaThau" tabindex="0" class="paste-zone"
                         style="width: 100%; border: 2.5px dashed #0d9488; height: 220px; border-radius: 18px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f0fdfa; color: #0f766e; cursor: pointer; transition: 0.3s; gap: 10px; outline: none;">
                        <i class="fa fa-id-card-o" style="font-size: 35px;"></i>
                        <span style="font-size: 11px; font-weight: 700; text-align:center; padding: 0 20px;">
                            Click vào đây rồi nhấn Ctrl+V để dán ảnh thẻ nhà thầu hoặc giấy phép vào cổng
                        </span>
                    </div>
                    @* Input này khớp với tên trong Model: Anh *@
                    <input type="file" id="Anh" name="Anh" hidden accept="image/*">
                </div>

                @* FILE ĐÍNH KÈM: DANH SÁCH CÔNG NHÂN *@
                <div>
                    <label style="@labelStyle">Danh sách nhà thầu / Phương án thi công (PDF, Excel)</label>
                    <div style="background: #ffffff; border: 2px dashed #cbd5e1; border-radius: 18px; padding: 20px; display: flex; align-items: center; gap: 15px; transition: 0.3s;">
                        <i class="fa fa-file-excel-o" style="font-size: 24px; color: #0d9488;"></i>
                        <div style="flex: 1;">
                            <input type="file" name="UploadFile" style="font-size: 13px; color: #475569; width: 100%;">
                            <p style="margin: 5px 0 0 0; font-size: 10px; color: #94a3b8; font-weight: 600;">Hỗ trợ: .pdf, .xls, .xlsx, .doc</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- GHI CHÚ & XÁC NHẬN CAM KẾT --- *@
            <div style="@boxStyle; border-color: #fde68a; background: #fffbeb; padding: 25px;">
                <h3 style="color: #92400e; font-size: 13px; display: flex; align-items: center; gap: 10px; margin-bottom: 15px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-exclamation-triangle"></i> Quy định & Cam kết an toàn
                </h3>

                <ul style="margin: 0 0 20px 20px; padding: 0; color: #92400e; font-size: 12px; line-height: 1.8; font-weight: 600; list-style-type: square;">
                    <li>Người phụ trách phải đảm bảo nhà thầu tuân thủ các quy định về An toàn lao động và Nội quy công ty.</li>
                    <li>Nhà thầu phải mặc đầy đủ bảo hộ lao động (PPE) khi làm việc tại khu vực sản xuất.</li>
                    <li>Tuyệt đối không quay phim, chụp ảnh tại các khu vực chưa được phép.</li>
                </ul>

                @* CHECKBOX CAM KẾT *@
                <label style="display: flex; align-items: center; gap: 15px; cursor: pointer; padding: 15px; background: #ffffff; border-radius: 15px; border: 2px solid #fcd34d; transition: 0.3s;" id="labelCamKet">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; cursor: pointer; accent-color: #0d9488;">
                    <span style="font-size: 13px; color: #134e4a; font-weight: 800; line-height: 1.4;">
                        Tôi xác nhận đã kiểm tra và cam kết chịu trách nhiệm về an toàn, nội quy của nhà thầu nêu trên.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="guiDonNhaThau()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, #0d9488, #0f766e); color: #fff; border: none; border-radius: 20px; font-weight: 900; font-size: 17px; cursor: pointer; transition: 0.3s; box-shadow: 0 15px 30px -5px rgba(13, 148, 136, 0.4); text-transform: uppercase;">
                    <i class="fa fa-check-square-o" style="margin-right: 10px;"></i> Đăng ký nhà thầu qua cổng
                </button>
            </div>

        </div>
    </form>
</div>

<script>
    // Hàm xử lý dán ảnh dùng chung
    function setupPasteImage(zoneId, inputId) {
        const zone = document.getElementById(zoneId);
        const input = document.getElementById(inputId);

        zone.addEventListener('paste', (e) => {
            const items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    const blob = items[i].getAsFile();
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">`;
                        zone.style.background = "#ffffff";
                        zone.style.borderColor = "#0d9488";

                        const dataTransfer = new DataTransfer();
                        dataTransfer.items.add(blob);
                        input.files = dataTransfer.files;
                    };
                    reader.readAsDataURL(blob);
                }
            }
        });

        // Hiệu ứng hover/focus
        zone.addEventListener('focus', () => {
            zone.style.borderColor = "#134e4a";
            zone.style.background = "#f0fdfa";
        });
        zone.addEventListener('blur', () => {
            if (!input.files.length) {
                zone.style.borderColor = "#0d9488";
            }
        });
        // Click để focus hỗ trợ paste tốt hơn
        zone.addEventListener('click', () => zone.focus());
    }

    // Khởi tạo vùng dán cho Nhà thầu
    setupPasteImage("paste_AnhNhaThau", "Anh");

    function guiDonNhaThau() {
        // 1. Kiểm tra dán ảnh
        const anhInput = document.getElementById("Anh");
        if (anhInput.files.length === 0) {
            alert("⚠️ Vui lòng dán ảnh minh chứng (Thẻ nhà thầu hoặc Lệnh làm việc) trước khi gửi.");
            document.getElementById("paste_AnhNhaThau").focus();
            return;
        }

        // 2. Kiểm tra xác nhận cam kết
        const chkCamKet = document.getElementById("chkCamKet");
        const labelCamKet = document.getElementById("labelCamKet");
        if (!chkCamKet.checked) {
            alert("⚠️ Bạn phải tích chọn xác nhận cam kết chịu trách nhiệm trước khi gửi đơn.");
            labelCamKet.style.borderColor = "#dc2626"; // Đỏ để cảnh báo
            return;
        } else {
            labelCamKet.style.borderColor = "#fcd34d";
        }

        // 3. Xác nhận và submit
        if (confirm("Xác nhận gửi đơn đăng ký nhà thầu qua cổng này?")) {
            document.getElementById("nhaThauForm").submit();
        }
    }
</script>