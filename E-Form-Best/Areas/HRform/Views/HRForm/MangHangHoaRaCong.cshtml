@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký mang hàng hóa ra cổng";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- CẤU HÌNH MÀU CHỦ ĐẠO ---
    string primaryColor = "#48bb78";
    string darkGreen = "#2f855a";
    string lightGreen = "#f0fff4";
    string borderGreen = "#9ae6b4";

    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 10px; border: 1px solid {borderGreen}; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {darkGreen};";
    string labelStyle = $"font-weight: 700; color: {darkGreen}; font-size: 11px; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.5px;";
    string pasteZoneStyle = $"width: 100%; border: 2px dotted {borderGreen}; height: 180px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: {lightGreen}; color: {darkGreen}; cursor: pointer; overflow: hidden; font-size: 12px; font-weight: 600; transition: 0.3s; margin-top: 10px; position: relative; outline: none;";
}

<div style="background: linear-gradient(135deg, #f0fff4 0%, #c6f6d5 100%); padding: 40px 15px; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    <form id="hrForm" method="post" enctype="multipart/form-data" action="/FormHR/MangHangHoaRaCong"
          style="max-width: 900px; margin: 0 auto; background: #ffffff; border-radius: 30px; box-shadow: 0 20px 50px rgba(72, 187, 120, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div style="background: linear-gradient(135deg, @primaryColor 0%, @darkGreen 100%); padding: 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 15px; right: 25px; font-size: 11px; opacity: 0.9; font-weight: 500; letter-spacing: 1px;">HỆ THỐNG E-FORM V3.0</div>
            <h2 style="margin: 0; font-size: 24px; text-transform: uppercase; font-weight: 900; letter-spacing: 1.5px;">Đăng ký mang hàng hóa ra cổng</h2>
            <div style="margin-top: 12px; display: inline-block; padding: 6px 16px; background: rgba(255,255,255,0.2); border-radius: 50px; font-size: 13px;">
                📦 Trạng thái: <span style="font-weight: 700; color: #ffffff;">KHỞI TẠO ĐƠN</span> | 📅 @ngayHienThi
            </div>
        </div>

        <div style="padding: 40px;">
            @* --- PHẦN 1: THÔNG TIN NHÂN SỰ --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: @darkGreen; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @primaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">1</span>
                    Thông tin người đăng ký
                </h3>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px;">
                    <div><label style="@labelStyle">Họ tên nhân viên</label><input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #f9fffb;"></div>
                    <div><label style="@labelStyle">Phòng ban</label><input name="BoPhan" value="@phongBan" readonly style="@inputStyle; background: #f9fffb;"></div>
                    <div><label style="@labelStyle">Mã nhân viên</label><input name="SoNhanVien" value="@soNhanVien" readonly style="@inputStyle; background: #f9fffb;"></div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div><label style="@labelStyle">Công ty</label><input name="TenCongTy" value="@tenCongTy" readonly style="@inputStyle; background: #f0fff4; border-style: dashed;"></div>
                    <div><label style="@labelStyle">Danh mục</label><input name="Danhmuc" value="ĐƠN MANG HÀNG HÓA RA CỔNG" readonly style="@inputStyle; background: #f0fff4; border-style: dashed; color: @primaryColor;"></div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT HÀNG HÓA --- *@
            <div style="background: #f7fafc; padding: 25px; border-radius: 20px; border: 1px solid @borderGreen; margin-bottom: 30px;">
                <h3 style="color: @darkGreen; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @darkGreen; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">2</span>
                    Chi tiết hàng hóa & Thời gian
                </h3>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Mô tả hàng hóa (Số lượng, chủng loại...) <span style="color:#e53e3e">*</span></label>
                    @* Đã sửa: name="chiTiet.MoTa" *@
                    <textarea name="chiTiet.MoTa" placeholder="Ví dụ: 05 kiện hàng nguyên seal, 01 bộ dụng cụ sửa chữa..." required style="@inputStyle; height: 80px; resize: none; border: 1px solid @primaryColor;"></textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px;">
                    <div>
                        <label style="@labelStyle">🕒 Thời gian mang ra dự kiến</label>
                        @* Đã sửa: name="chiTiet.TimeDuTinh" *@
                        <input type="datetime-local" id="inpTimeDuTinh" name="chiTiet.TimeDuTinh" required style="@inputStyle; border: 1px solid @primaryColor;">
                    </div>
                    <div>
                        <label style="@labelStyle">🛡️ Tên Cổng ra</label>
                        @* Đã sửa: name="chiTiet.TenCong" *@
                        <input name="chiTiet.TenCong" placeholder="Ví dụ: Cổng 1, Cổng chính..." style="@inputStyle">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelStyle">Ảnh hàng hóa minh chứng (Ctrl+V)</label>
                        <div id="paste_AnhHangHoa" class="paste-zone" style="@pasteZoneStyle" tabindex="0">
                            Nhấp vào đây và nhấn Ctrl+V để dán ảnh
                        </div>
                        @* Input này giữ nguyên name="AnhHangHoa" vì Controller lấy qua Request.Form.Files["AnhHangHoa"] *@
                        <input type="file" id="AnhHangHoa" name="AnhHangHoa" hidden accept="image/*">
                    </div>

                    <div>
                        <label style="@labelStyle">Tài liệu / Phiếu xuất kho</label>
                        <div style="margin-top:10px; background: #ffffff; padding: 15px; border-radius: 12px; border: 1px dashed @borderGreen; height: 180px; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;">
                            <input type="file" name="UploadFile" style="font-size: 13px; width: 100%;">
                            <p style="font-size: 11px; color: @darkGreen; margin-top: 15px; line-height: 1.4; opacity: 0.7;">Đính kèm bản scan hoặc ảnh chụp chứng từ liên quan.</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CAM KẾT --- *@
            <div style="background: #f0fff4; border: 1.5px solid @primaryColor; border-radius: 20px; padding: 25px; margin-bottom: 30px;">
                <label id="containerCamKet" style="cursor: pointer; display: flex; align-items: flex-start; gap: 12px; background: #ffffff; padding: 15px; border-radius: 12px; border: 2px solid @borderGreen; transition: 0.3s;">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; margin-top: 2px; accent-color: @primaryColor; cursor: pointer;">
                    <span style="font-size: 13px; font-weight: 700; color: @darkGreen; line-height: 1.5;">
                        Tôi cam kết hàng hóa mang ra đúng mục đích, số lượng và chủng loại như trên. Nếu sai lệch tôi xin chịu hoàn toàn trách nhiệm.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="xuLyLuuDon()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, @primaryColor, @darkGreen); color: #fff; border: none; border-radius: 15px; font-weight: 900; font-size: 18px; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(72, 187, 120, 0.3); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-share-square" style="margin-right: 10px;"></i> Gửi yêu cầu phê duyệt
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    window.onload = function() {
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById('inpTimeDuTinh').value = now.toISOString().slice(0, 16);
    };

    function handlePaste(e, inputId, zoneId) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        let blob = null;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                blob = items[i].getAsFile();
                break;
            }
        }
        if (blob) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const zone = document.getElementById(zoneId);
                zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:10px;">`;
                zone.style.border = "2px solid @primaryColor";

                const fileInput = document.getElementById(inputId);
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(blob);
                fileInput.files = dataTransfer.files;
            };
            reader.readAsDataURL(blob);
        }
    }

    const zoneEl = document.getElementById("paste_AnhHangHoa");
    if (zoneEl) {
        zoneEl.addEventListener('paste', (e) => handlePaste(e, "AnhHangHoa", "paste_AnhHangHoa"));
        zoneEl.onclick = () => zoneEl.focus();
    }

    function xuLyLuuDon() {
        // Cập nhật selector để lấy đúng name mới
        const moTa = document.querySelector('textarea[name="chiTiet.MoTa"]').value.trim();
        const chk = document.getElementById('chkCamKet');
        const timeDuTinh = document.getElementById('inpTimeDuTinh').value;

        if (moTa.length < 5) {
            alert("⚠️ Vui lòng nhập mô tả hàng hóa chi tiết!");
            return;
        }
        if (!timeDuTinh) {
            alert("⚠️ Vui lòng chọn thời gian dự tính!");
            return;
        }
        if (!chk.checked) {
            alert("⚠️ Bạn chưa tích chọn xác nhận cam kết!");
            return;
        }

        if (confirm("Xác nhận gửi đơn mang hàng hóa này đi phê duyệt?")) {
            document.getElementById("hrForm").submit();
        }
    }
</script>