@model E_Form_Best.Models.ITForm.FormHr
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký hỗ trợ tiền điện thoại";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #bfdbfe; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: #1e3a8a;";
    string labelStyle = "font-weight: 700; color: #1e40af; font-size: 11px; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.5px;";
    string pasteZoneStyle = $"width: 100%; border: 2px dotted #93c5fd; height: 180px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: #f0f7ff; color: #2563eb; cursor: pointer; overflow: hidden; font-size: 12px; font-weight: 600; transition: 0.3s; margin-top: 10px; position: relative; outline: none;";
}

<div style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); padding: 40px 15px; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    <form id="hrForm" method="post" enctype="multipart/form-data" action="/FormHR/HoTroTienDienThoai"
          style="max-width: 900px; margin: 0 auto; background: #ffffff; border-radius: 30px; box-shadow: 0 20px 50px rgba(59, 130, 246, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); padding: 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 15px; right: 25px; font-size: 11px; opacity: 0.9; font-weight: 500; letter-spacing: 1px;">E-FORM SYSTEM V3.0</div>
            <h2 style="margin: 0; font-size: 24px; text-transform: uppercase; font-weight: 900; letter-spacing: 1.5px;">Đơn đăng ký hỗ trợ tiền điện thoại</h2>
            <div style="margin-top: 12px; display: inline-block; padding: 6px 16px; background: rgba(255,255,255,0.2); border-radius: 50px; font-size: 13px;">
                📅 Ngày lập đơn: <span style="font-weight: 700; color: #ffffff;">@ngayHienThi</span>
            </div>
        </div>

        <div style="padding: 40px;">
            @* --- PHẦN 1: THÔNG TIN NHÂN SỰ --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: #1d4ed8; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: #3b82f6; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">1</span>
                    Thông tin nhân sự
                </h3>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px;">
                    <div>
                        <label style="@labelStyle">Họ tên nhân viên</label>
                        <input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #f8fafc; border-color: #e2e8f0;">
                    </div>
                    <div>
                        <label style="@labelStyle">Phòng ban</label>
                        <input name="BoPhan" value="@phongBan" readonly style="@inputStyle; background: #f8fafc; border-color: #e2e8f0;">
                    </div>
                    <div>
                        <label style="@labelStyle">Mã nhân viên</label>
                        <input name="SoNhanVien" value="@soNhanVien" readonly style="@inputStyle; background: #f8fafc; border-color: #e2e8f0;">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label style="@labelStyle">Đơn vị / Công ty</label>
                        <input name="TenCongTy" value="@tenCongTy" readonly style="@inputStyle; background: #f8fafc; border-style: dashed;">
                    </div>
                    <div>
                        <label style="@labelStyle">Danh mục hồ sơ</label>
                        <input name="Danhmuc" value="ĐƠN HỖ TRỢ TIỀN ĐIỆN THOẠI" readonly style="@inputStyle; background: #f8fafc; border-style: dashed; color: #3b82f6;">
                    </div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT HỖ TRỢ --- *@
            <div style="background: #fcfdfe; padding: 25px; border-radius: 20px; border: 1px solid #dbeafe; margin-bottom: 30px;">
                <h3 style="color: #1d4ed8; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: #2563eb; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">2</span>
                    Nội dung đề nghị
                </h3>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label style="@labelStyle">Số điện thoại nhận hỗ trợ <span style="color:#ef4444">*</span></label>
                        <input name="SoDienThoai" placeholder="09xxx..." required style="@inputStyle; border-color: #3b82f6;">
                    </div>
                    <div>
                        <label style="@labelStyle">Mức hỗ trợ đề xuất (VNĐ) <span style="color:#ef4444">*</span></label>
                        <input type="number" name="MucHoTro" placeholder="Nhập số tiền..." required style="@inputStyle; border-color: #3b82f6;">
                    </div>
                    <div>
                        <label style="@labelStyle">Thông tin bổ sung (Nhà mạng...)</label>
                        <input name="ThongTinNhanVien" placeholder="Viettel, Mobi..." style="@inputStyle; border-color: #3b82f6;">
                    </div>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Lý do / Mục đích công việc <span style="color:#ef4444">*</span></label>
                    <textarea name="MucDich" placeholder="Mô tả chi tiết mục đích sử dụng cho công việc..." required style="@inputStyle; height: 80px; resize: none; border-color: #3b82f6;"></textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelStyle">Ảnh minh chứng (Paste ảnh Ctrl+V)</label>
                        <div id="paste_Anh" class="paste-zone" style="@pasteZoneStyle" tabindex="0">
                            Nhấp vào đây và nhấn Ctrl+V để dán ảnh
                        </div>
                        <input type="file" id="Anh" name="Anh" hidden accept="image/*">
                    </div>

                    <div>
                        <label style="@labelStyle">File đính kèm (PDF/Excel)</label>
                        <div style="margin-top:10px; background: #ffffff; padding: 15px; border-radius: 12px; border: 1px dashed #3b82f6; height: 180px; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;">
                            <input type="file" name="UploadFile" style="font-size: 13px; width: 100%;">
                            <p style="font-size: 11px; color: #64748b; margin-top: 15px; line-height: 1.4;">Tải lên các tài liệu chứng minh định mức sử dụng (nếu có).</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CAM KẾT --- *@
            <div style="background: #f0f7ff; border: 1px solid #bfdbfe; border-radius: 20px; padding: 25px; margin-bottom: 30px;">
                <label id="containerCamKet" style="cursor: pointer; display: flex; align-items: flex-start; gap: 12px; background: #ffffff; padding: 15px; border-radius: 12px; border: 2px solid #3b82f6; transition: 0.3s;">
                    <input type="checkbox" id="chkCamKet" style="width: 20px; height: 20px; margin-top: 2px; accent-color: #3b82f6; cursor: pointer;">
                    <span style="font-size: 13px; font-weight: 700; color: #1e40af; line-height: 1.5;">
                        Tôi xin cam đoan các thông tin trên là chính xác và hoàn toàn chịu trách nhiệm về nội dung kê khai.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="xuLyLuuDon()"
                        style="width: 100%; padding: 18px; background: linear-gradient(to right, #3b82f6, #2563eb); color: #fff; border: none; border-radius: 15px; font-weight: 800; font-size: 16px; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-paper-plane" style="margin-right: 10px;"></i> Gửi đơn xét duyệt
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // Logic Paste ảnh từ Clipboard
    function handlePaste(e, inputId, zoneId) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        let blob = null;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                blob = items[i].getAsFile();
                break;
            }
        }
        if (blob) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const zone = document.getElementById(zoneId);
                zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:10px;">`;
                zone.style.border = "2px solid #3b82f6";
                zone.style.background = "#ffffff";

                const fileInput = document.getElementById(inputId);
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(blob);
                fileInput.files = dataTransfer.files;
            };
            reader.readAsDataURL(blob);
        }
    }

    const zoneEl = document.getElementById("paste_Anh");
    if (zoneEl) {
        zoneEl.addEventListener('paste', (e) => handlePaste(e, "Anh", "paste_Anh"));
    }

    // Kiểm tra dữ liệu trước khi gửi
    function xuLyLuuDon() {
        const sdt = document.querySelector('input[name="SoDienThoai"]').value.trim();
        const mucHoTro = document.querySelector('input[name="MucHoTro"]').value;
        const mucDich = document.querySelector('textarea[name="MucDich"]').value.trim();
        const chk = document.getElementById('chkCamKet');

        if (sdt.length < 10) {
            alert("⚠️ Vui lòng nhập số điện thoại hợp lệ!");
            return;
        }
        if (!mucHoTro || mucHoTro <= 0) {
            alert("⚠️ Vui lòng nhập mức hỗ trợ đề xuất!");
            return;
        }
        if (mucDich.length < 5) {
            alert("⚠️ Vui lòng nhập mục đích sử dụng!");
            return;
        }
        if (!chk.checked) {
            alert("⚠️ Bạn chưa xác nhận cam kết!");
            return;
        }

        if (confirm("Xác nhận gửi đơn này?")) {
            document.getElementById("hrForm").submit();
        }
    }
</script>