@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@{
    ViewData["Title"] = "Phê Duyệt Cấp Cao";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // Tính toán thống kê nhanh
    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.IdAdmin != null && !(x.TenForm?.Contains("[ĐÃ HỦY]") ?? false)) ?? 0;
    var cancelled = Model?.Count(x => x.TenForm?.Contains("[ĐÃ HỦY]") ?? false) ?? 0;
    var pending = total - completed - cancelled;

    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "GIÁM ĐỐC HR";
}

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1400px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #2563eb; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #2563eb; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);">
                        <i class="fa fa-check-circle"></i>
                    </span>
                    PHÊ DUYỆT CẤP CAO
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e293b; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@userRole</span>
                    <span style="background: #dbeafe; color: #1e40af; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">XỬ LÝ NGHIỆP VỤ</span>
                </div>
            </div>

            <div style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên nhân viên, loại đơn, phòng ban..."
                       style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 380px; font-size: 14px; font-weight: 700; outline: none; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            </div>
        </div>

        @* --- THỐNG KÊ --- *@
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG ĐƠN NHẬN", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                    new { Label = "ĐANG CHỜ DUYỆT", Value = pending, Color = "#2563eb", Bg = "#eff6ff", Filter = "CHỜ" },
                    new { Label = "ĐÃ HOÀN TẤT", Value = completed, Color = "#059669", Bg = "#ecfdf5", Filter = "XONG" },
                    new { Label = "ĐƠN HỦY/TỪ CHỐI", Value = cancelled, Color = "#dc2626", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')" style="background: @s.Bg; padding: 22px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);"
                     onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div style="font-size: 10px; font-weight: 900; color: @s.Color; letter-spacing: 1px; text-transform: uppercase;">@s.Label</div>
                    <div style="font-size: 32px; font-weight: 1000; color: @s.Color; margin-top: 8px;">@s.Value</div>
                </div>
            }
        </div>

        @* --- DANH SÁCH --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Người tạo đơn</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Thông tin biểu mẫu</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Bộ phận</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 20px; width: 80px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            bool isCancelled = item.TenForm?.Contains("[ĐÃ HỦY]") ?? false;
                            bool isFinished = item.IdAdmin != null;

                            // Cấp cao thì "CHỜ" nghĩa là Quản lý đã duyệt (IdNguoiDuyet != null) nhưng Admin/GĐHR chưa chốt (IdAdmin == null)
                            string pWidth = isCancelled ? "100%" : (isFinished ? "100%" : "50%");
                            string pColor = isCancelled ? "#ef4444" : (isFinished ? "#10b981" : "#3b82f6");
                            string stTxt = isCancelled ? "ĐÃ HỦY" : (isFinished ? "XONG" : "CHỜ");

                            <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f0f7ff'" onmouseout="this.style.background='transparent'">
                                <td style="padding: 20px;">
                                    <div style="font-weight: 900; color: #0f172a;">@item.TenNguoiNv</div>
                                    <div style="font-size: 12px; color: #64748b; font-weight: 700;">#@item.Id • MS: @item.SoNhanVien</div>
                                </td>
                                <td style="padding: 20px;">
                                    <div style="font-weight: 800; font-size: 14px; margin-bottom: 8px; color: #1e293b;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <div style="flex-grow: 1; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 150px;">
                                            <div style="width: @pWidth; height: 100%; background: @pColor;"></div>
                                        </div>
                                        <span style="font-size: 11px; font-weight: 800; color: #64748b;">@item.TimeNguoiTao?.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                </td>
                                <td style="padding: 20px; font-weight: 700; color: #475569; font-size: 13px;">@item.BoPhan</td>
                                <td style="padding: 20px; text-align: center;">
                                    <span style="border: 2px solid @pColor; color: @pColor; background: white; padding: 6px 14px; border-radius: 12px; font-size: 11px; font-weight: 1000;">
                                        @stTxt
                                    </span>
                                </td>
                                <td style="padding: 20px;">
                                    <a href="/FormHR/ChiTiet/@item.Id"
                                           style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 12px; background: #f1f5f9; color: #2563eb; transition: 0.3s; text-decoration: none;"
                                           onmouseover="this.style.background='#2563eb'; this.style.color='white'">
                                        <i class="fa fa-arrow-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="padding: 50px; text-align: center; color: #94a3b8; font-weight: 700;">
                                <i class="fa fa-inbox" style="font-size: 40px; margin-bottom: 10px; display: block;"></i>
                                Không có đơn nào cần phê duyệt trong danh sách này.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const filter = document.getElementById("searchInput").value.toUpperCase();
        const trs = document.querySelectorAll("#dataTable tbody tr");
        
        trs.forEach(tr => {
            const text = tr.innerText.toUpperCase();
            tr.style.display = text.includes(filter) ? "" : "none";
        });
    }

    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();
    }
</script>