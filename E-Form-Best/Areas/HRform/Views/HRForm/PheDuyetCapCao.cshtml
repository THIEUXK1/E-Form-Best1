@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@{
    ViewData["Title"] = "Phê Duyệt Cấp Cao";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- LOGIC THỐNG KÊ CHI TIẾT ---
    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.IdAdmin != null && !(x.TenForm?.Contains("[ĐÃ HỦY]") ?? false)) ?? 0;
    var cancelled = Model?.Count(x => x.TenForm?.Contains("[ĐÃ HỦY]") ?? false) ?? 0;
    var pending = total - completed - cancelled;

    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "GIÁM ĐỐC / QUẢN TRỊ";
}

<style>
    .sub-status-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: 1px solid;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 30px -5px rgba(37, 99, 235, 0.15) !important;
        border-color: #2563eb !important;
    }

    #dataTable tbody tr:hover {
        background-color: #f0f7ff !important;
    }

    .status-badge-premium {
        border: 2px solid;
        padding: 5px 12px;
        border-radius: 12px;
        font-size: 10px;
        font-weight: 1000;
        text-transform: uppercase;
        background: white;
    }
</style>

<div style="background: #f8fafc; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1500px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #1e40af; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #2563eb; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);">
                        <i class="fa fa-shield"></i>
                    </span>
                    PHÊ DUYỆT CẤP CAO
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e293b; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5px;">@userRole</span>
                    <span style="background: #dbeafe; color: #1e40af; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; border: 1px solid #bfdbfe;">HỆ THỐNG XÉT DUYỆT TẬP TRUNG</span>
                </div>
            </div>

            <div style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm nhân viên, mã đơn, bộ phận..."
                       style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 400px; font-size: 14px; font-weight: 700; outline: none; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: 0.3s;"
                       onfocus="this.style.border-color='#2563eb'">
            </div>
        </div>

        @* --- THỐNG KÊ --- *@
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG ĐƠN HỆ THỐNG", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                    new { Label = "ĐANG CHỜ PHÊ DUYỆT", Value = pending, Color = "#2563eb", Bg = "#eff6ff", Filter = "CHỜ" },
                    new { Label = "ĐÃ HOÀN TẤT (XONG)", Value = completed, Color = "#059669", Bg = "#ecfdf5", Filter = "XONG" },
                    new { Label = "ĐƠN HỦY / TỪ CHỐI", Value = cancelled, Color = "#dc2626", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')" class="stat-card" style="background: @s.Bg; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
                    <div style="font-size: 10px; font-weight: 900; color: @s.Color; letter-spacing: 1px; text-transform: uppercase;">@s.Label</div>
                    <div style="font-size: 32px; font-weight: 1000; color: @s.Color; margin-top: 8px;">@s.Value</div>
                </div>
            }
        </div>

        @* --- DANH SÁCH --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nhân viên tạo đơn</th>
                        <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nội dung biểu mẫu</th>
                        <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Tiến độ xác nhận</th>
                        <th style="padding: 20px; text-align: left; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Bộ phận</th>
                        <th style="padding: 20px; text-align: center; font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 20px; width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            bool isCancelled = item.TenForm?.Contains("[ĐÃ HỦY]") ?? false;
                            bool isFinished = item.IdAdmin != null;

                            // Tiến độ: Cấp cao xem khi QL đã duyệt (33%), XN xong (66%), Admin chốt (100%)
                            string pWidth = isCancelled ? "100%" : (isFinished ? "100%" : "66%");
                            string pColor = isCancelled ? "#ef4444" : (isFinished ? "#10b981" : "#2563eb");
                            string stTxt = isCancelled ? "ĐÃ HỦY" : (isFinished ? "XONG" : "CHỜ");

                            <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;">
                                <td style="padding: 20px;">
                                    <div style="font-weight: 900; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                    <div style="font-size: 12px; color: #2563eb; font-weight: 800; margin-top: 4px;">#@item.Id • MS: @item.SoNhanVien</div>
                                </td>
                                <td style="padding: 20px;">
                                    <div style="font-weight: 800; font-size: 14px; margin-bottom: 8px; color: #1e293b;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <div style="flex-grow: 1; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 150px;">
                                            <div style="width: @pWidth; height: 100%; background: @pColor; transition: 0.5s;"></div>
                                        </div>
                                        <span style="font-size: 10px; font-weight: 900; color: #94a3b8;"><i class="fa fa-clock-o"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </td>
                                <td style="padding: 20px;">
                                    @* --- CHI TIẾT HỘI ĐỒNG XÁC NHẬN --- *@
                                    @if (item.HrNguoiXacNhans != null && item.HrNguoiXacNhans.Any())
                                    {
                                        var listXN = item.HrNguoiXacNhans.ToList();
                                        int done = listXN.Count(x => x.TrangThaiXacNhan == 1);
                                        int totalCount = listXN.Count;
                                        string xnColor = listXN.Any(x => x.TrangThaiXacNhan == 2) ? "#ef4444" : (done == totalCount ? "#10b981" : "#f59e0b");

                                        <div class="sub-status-badge" style="background: @(xnColor)10; color: @xnColor; border-color: @xnColor;">
                                            <i class="fa fa-users"></i> Hội đồng: @done/@totalCount
                                        </div>
                                    }

                                    @* --- TRẠNG THÁI BẢO VỆ (NẾU CÓ) --- *@
                                    @if (item.BaoVeHrs != null && item.BaoVeHrs.Any())
                                    {
                                        var bv = item.BaoVeHrs.FirstOrDefault();
                                        if (bv != null)
                                        {
                                            string bvColor = bv.TrangThai == 1 ? "#10b981" : "#64748b";
                                            <div class="sub-status-badge" style="background: #f8fafc; color: @bvColor; border-color: #e2e8f0; margin-left: 5px;">
                                                <i class="fa fa-shield"></i> BV: @(bv.TrangThai == 1 ? "Xong" : "Chờ")
                                            </div>
                                        }
                                    }
                                </td>
                                <td style="padding: 20px;">
                                    <div style="font-weight: 800; color: #475569; font-size: 12px; background: #f1f5f9; padding: 4px 10px; border-radius: 8px; display: inline-block;">
                                        @item.BoPhan
                                    </div>
                                </td>
                                <td style="padding: 20px; text-align: center;">
                                    <span class="status-badge-premium" style="border-color: @pColor; color: @pColor;">
                                        @stTxt
                                    </span>
                                </td>
                                <td style="padding: 20px;">
                                    <a href="/FormHR/ChiTiet/@item.Id"
                                           style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 12px; background: #f1f5f9; color: #2563eb; transition: 0.3s; text-decoration: none;"
                                           onmouseover="this.style.background='#2563eb'; this.style.color='white'">
                                        <i class="fa fa-chevron-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" style="padding: 80px; text-align: center; color: #94a3b8;">
                                <i class="fa fa-check-square-o" style="font-size: 50px; margin-bottom: 15px; display: block; opacity: 0.3;"></i>
                                <span style="font-weight: 700; font-size: 16px;">Hiện tại không có đơn nào cần phê duyệt cấp cao.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const filter = document.getElementById("searchInput").value.toUpperCase();
        const trs = document.querySelectorAll("#dataTable tbody tr");

        trs.forEach(tr => {
            const text = tr.innerText.toUpperCase();
            tr.style.display = text.includes(filter) ? "" : "none";
        });
    }

    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();

        // Hiệu ứng nháy nhẹ bảng để phản hồi thao tác
        const table = document.getElementById("dataTable");
        table.style.opacity = "0.6";
        setTimeout(() => { table.style.opacity = "1"; }, 150);
    }
</script>