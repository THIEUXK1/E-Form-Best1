@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@using System.Security.Claims

@{
    ViewData["Title"] = "Phê Duyệt Cấp Cao";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    // --- 1. LẤY THÔNG TIN ĐỊNH DANH NGƯỜI DUYỆT (Email/MaNV) ---
    var userEmail = ViewBag.UserEmail as string ?? "";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "GIÁM ĐỐC / QUẢN TRỊ";

    // --- 2. LOGIC THỐNG KÊ CHI TIẾT (Đồng bộ logic bảng) ---
    var total = Model?.Count() ?? 0;
    var activeList = Model?.Where(x => !(x.TenForm ?? "").Contains("[ĐÃ HỦY]")).ToList() ?? new List<E_Form_Best.Models.ITForm.FormHr>();

    var daHuy = Model?.Count(x => (x.TenForm ?? "").Contains("[ĐÃ HỦY]")) ?? 0;
    
    // Đang chờ: Những đơn mà người dùng hiện tại chưa xác nhận (TrangThaiXacNhan == 0)
    var choPheDuyet = activeList.Count(f => f.HrNguoiXacNhans != null && 
                                            f.HrNguoiXacNhans.Any(xn => xn.MaNguoiXacNhan == userEmail && xn.TrangThaiXacNhan == 0));

    // Đã xử lý: Những đơn mà người dùng hiện tại đã xác nhận xong
    var daXuLy = activeList.Count(f => f.HrNguoiXacNhans != null && 
                                       f.HrNguoiXacNhans.Any(xn => xn.MaNguoiXacNhan == userEmail && xn.TrangThaiXacNhan != 0));

    var hoanTatHeThong = activeList.Count(x => x.IdAdmin != null);
}

<style>
    .sub-badge {
        font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 700;
        display: inline-flex; align-items: center; gap: 3px; border: 1px solid; margin-top: 2px;
    }
    .support-avatar {
        width: 28px; height: 28px; background: #f0f7ff; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: #2563eb; border: 1px solid #dbeafe;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.1) !important; }
    .status-pill {
        padding: 6px 12px; border-radius: 8px; font-size: 10px; font-weight: 1000;
        display: inline-block; min-width: 90px; text-align: center; border: 1.5px solid;
    }
</style>

<div style="padding: 20px; background: #f8fafc; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    @* --- TOP BAR --- *@
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 15px;">
        <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
            <span style="background: #2563eb; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);">
                <i class="fa fa-shield"></i>
            </span>
            PHÊ DUYỆT CẤP CAO
        </h2>

        <div style="display: flex; gap: 10px; align-items: center;">
            <div style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="filterTable()" placeholder="Tìm tên NV, mã đơn, bộ phận..."
                       style="padding: 10px 12px 10px 38px; border-radius: 12px; border: 2px solid #e2e8f0; font-size: 14px; width: 300px; outline: none; font-weight: 700;">
            </div>
            <div style="font-size: 11px; background: #1e293b; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase;">@userRole</div>
        </div>
    </div>

    @* --- STATS ROW --- *@
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin-bottom: 25px;">
        @{
            var stats = new[] {
                new { Label = "TỔNG ĐƠN ĐỊNH TUYẾN", Value = total, Color = "#1e293b", Bg = "white", Filter = "" },
                new { Label = "CẦN TÔI DUYỆT", Value = choPheDuyet, Color = "#2563eb", Bg = "#eff6ff", Filter = "CHỜ DUYỆT" },
                new { Label = "TÔI ĐÃ XỬ LÝ", Value = daXuLy, Color = "#059669", Bg = "#ecfdf5", Filter = "ĐÃ XỬ LÝ" },
                new { Label = "HỆ THỐNG HOÀN TẤT", Value = hoanTatHeThong, Color = "#1e40af", Bg = "#f0f7ff", Filter = "HOÀN TẤT" },
                new { Label = "ĐÃ HỦY/TỪ CHỐI", Value = daHuy, Color = "#b91c1c", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
            };
        }
        @foreach (var s in stats)
        {
            <div onclick="filterByStatus('@s.Filter')" class="stat-card"
                 style="background: @s.Bg; padding: 15px 12px; border-radius: 16px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: @s.Color; text-transform: uppercase; margin-bottom: 5px;">@s.Label</div>
                <div style="font-size: 24px; font-weight: 1000; color: @s.Color;">@s.Value</div>
            </div>
        }
    </div>

    @* --- TABLE AREA --- *@
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <table id="dataTable" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 3px solid #f1f5f9;">
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên tạo đơn</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 150px;">Tiến trình hệ thống</th>
                    <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                    <th style="padding: 18px 20px; text-align: right;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        // 1. Phân tích trạng thái đơn
                        bool isCancelled = (item.TenForm ?? "").Contains("[ĐÃ HỦY]");
                        bool isFinished = item.IdAdmin != null;

                        // 2. Phân tích trạng thái của Người Duyệt hiện tại trong Hội đồng (HĐ)
                        var currentNguoiXN = item.HrNguoiXacNhans?.FirstOrDefault(x => x.MaNguoiXacNhan == userEmail);
                        bool isNeedAction = currentNguoiXN != null && currentNguoiXN.TrangThaiXacNhan == 0 && !isCancelled;
                        bool isProcessed = currentNguoiXN != null && currentNguoiXN.TrangThaiXacNhan != 0;

                        // 3. Logic hiển thị Progress Bar & Tag
                        string pWidth, pColor, pText, bg, fg, statusTag;

                        if (isCancelled) {
                            pWidth = "100%"; pColor = "#ef4444"; pText = "ĐÃ HỦY"; bg = "#fee2e2"; fg = "#b91c1c"; statusTag = "ĐÃ HỦY";
                        } else if (isFinished) {
                            pWidth = "100%"; pColor = "#10b981"; pText = "HOÀN TẤT"; bg = "#d1fae5"; fg = "#047857"; statusTag = "HOÀN TẤT";
                        } else if (isNeedAction) {
                            pWidth = "66%"; pColor = "#2563eb"; pText = "CẦN PHÊ DUYỆT"; bg = "#eff6ff"; fg = "#2563eb"; statusTag = "CHỜ DUYỆT";
                        } else if (isProcessed) {
                            pWidth = "85%"; pColor = "#f59e0b"; pText = "ĐÃ XỬ LÝ (CHỜ ADMIN)"; bg = "#fff7ed"; fg = "#c2410c"; statusTag = "ĐÃ XỬ LÝ";
                        } else {
                            pWidth = "33%"; pColor = "#64748b"; pText = "ĐANG LUÂN CHUYỂN"; bg = "#f1f5f9"; fg = "#475569"; statusTag = "LUÂN CHUYỂN";
                        }

                        var supportLog = item.HrCtNguoiHoTros?.OrderByDescending(x => x.Stt).FirstOrDefault();
                        string supportName = supportLog?.IdHrNguoiHoTroNavigation?.Ten ?? "Chưa chỉ định";

                        <tr style="border-bottom: 1px solid #f1f5f9;" onmouseover="this.style.background='#f0f7ff'" onmouseout="this.style.background='transparent'">
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">@item.TenNguoiNv</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">@item.BoPhan • <span style="color: #2563eb;">MS: @item.SoNhanVien</span></div>
                            </td>
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center;">
                                    <span>ID: #@item.Id • <i class="fa fa-clock-o"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")</span>
                                    @if (item.HrNguoiXacNhans != null && item.HrNguoiXacNhans.Any()) {
                                        int done = item.HrNguoiXacNhans.Count(x => x.TrangThaiXacNhan == 1);
                                        int totalXN = item.HrNguoiXacNhans.Count();
                                        <span class="sub-badge" style="color: #1e40af; border-color: #bfdbfe; background: #eff6ff;"><i class="fa fa-users"></i> HĐ: @done/@totalXN</span>
                                    }
                                </div>
                            </td>
                            <td style="padding: 15px 20px;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <div class="support-avatar"><i class="fa fa-user-md" style="font-size: 14px;"></i></div>
                                    <div style="font-weight: 700; color: #334155; font-size: 13px;">@supportName</div>
                                </div>
                            </td>
                            <td style="padding: 15px 20px;">
                                <div style="font-size: 9px; font-weight: 1000; color: @pColor; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>@pText</span> <span>@pWidth</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                    <div style="width: @pWidth; height: 100%; background: @pColor; border-radius: 10px; transition: 0.5s ease;"></div>
                                </div>
                            </td>
                            <td style="padding: 15px 20px; text-align: center;">
                                <span class="status-pill" style="background:@bg; color:@fg; border-color: @fg;">@statusTag</span>
                            </td>
                            <td style="padding: 15px 20px; text-align: right;">
                                <a href="/FormHR/ChiTiet/@item.Id"
                                   style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s;
                                   background: @(isNeedAction ? "#2563eb" : "#f1f5f9");
                                   color: @(isNeedAction ? "#ffffff" : "#64748b");">
                                   <i class="fa @(isNeedAction ? "fa-edit" : "fa-eye")"></i> 
                                   @(isNeedAction ? "Xử lý ngay" : "Xem lại")
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            const input = document.getElementById("quickSearch");
            const filter = input.value.toUpperCase();
            const table = document.getElementById("dataTable");
            const tr = table.getElementsByTagName("tr");

            for (let i = 1; i < tr.length; i++) {
                let rowText = tr[i].innerText.toUpperCase();
                tr[i].style.display = rowText.includes(filter) ? "" : "none";
            }
        }

        function filterByStatus(s) {
            document.getElementById("quickSearch").value = s;
            filterTable();
            const table = document.getElementById("dataTable");
            table.style.opacity = "0.5";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }
    </script>
}