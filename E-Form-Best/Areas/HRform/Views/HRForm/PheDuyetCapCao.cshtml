@using System.Security.Claims

@{
    ViewData["Title"] = "Phê Duyệt Cấp Cao";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var userEmail = ViewBag.UserEmail as string ?? "";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "GIÁM ĐỐC / QUẢN TRỊ";
}

<style>
    .sub-badge {
        font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 700;
        display: inline-flex; align-items: center; gap: 3px; border: 1px solid; margin-top: 2px;
    }
    .support-avatar {
        width: 28px; height: 28px; background: #f0f7ff; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: #2563eb; border: 1px solid #dbeafe;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.1) !important; }
    .status-pill {
        padding: 6px 12px; border-radius: 8px; font-size: 10px; font-weight: 1000;
        display: inline-block; min-width: 90px; text-align: center; border: 1.5px solid;
    }

    /* CSS cho Phân trang mượt mà */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }
    .page-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
        box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
    }
    .page-btn:hover:not(.active) {
        background: #f8fafc;
        border-color: #cbd5e1;
    }

    /* ==========================================
       BỔ SUNG CSS CHO MOBILE RESPONSIVE
       ========================================== */
    @@media (max-width: 768px) {
        .mobile-top-bar {
            flex-direction: column !important;
            align-items: stretch !important;
        }
        .mobile-controls {
            flex-direction: column !important;
            width: 100% !important;
        }
        .mobile-search-input {
            width: 100% !important;
        }
        .mobile-stat-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }
        
        /* Chuyển bảng thành dạng Card */
        #dataTable thead {
            display: none; 
        }
        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }
        #dataTable tr {
            margin-bottom: 15px;
            border: 1px solid #e2e8f0 !important;
            border-radius: 15px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }
        #dataTable td {
            text-align: right !important;
            padding: 12px 15px !important;
            border-bottom: 1px dashed #f1f5f9;
            position: relative;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        #dataTable td:last-child {
            border-bottom: none;
            background: #f8fafc;
            justify-content: center;
        }
        /* Hiển thị nhãn cột bằng data-label */
        #dataTable td::before {
            content: attr(data-label);
            float: left;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
            font-size: 10px;
        }
        .mobile-td-val {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            max-width: 60%;
        }

        .pagination-container {
            flex-direction: column !important;
            gap: 20px;
            text-align: center !important;
        }
        #paginationButtons {
            justify-content: center;
        }
    }
</style>

<div style="padding: 20px; background: #f8fafc; min-height: 100vh; font-family: 'Inter', 'Segoe UI', sans-serif;">

    @* --- TOP BAR --- *@
    <div class="mobile-top-bar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 15px;">
        <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
            <span style="background: #2563eb; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);">
                <i class="fa fa-shield"></i>
            </span>
            PHÊ DUYỆT CẤP CAO
        </h2>

        <div class="mobile-controls" style="display: flex; gap: 10px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #e2e8f0;">
                <span style="font-size: 12px; font-weight: 700; color: #64748b;">Hiển thị:</span>
                <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #2563eb; cursor: pointer; background: transparent; font-size: 14px;">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>

            <div class="mobile-search-input" style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="handleFilterAndPaginate()" placeholder="Tìm tên NV, mã đơn, bộ phận..."
                       style="padding: 10px 12px 10px 38px; border-radius: 12px; border: 2px solid #e2e8f0; font-size: 14px; width: 300px; outline: none; font-weight: 700; box-sizing: border-box; width: 100%;">
            </div>
            <div style="font-size: 11px; background: #1e293b; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">@userRole</div>
        </div>
    </div>

    @* --- STATS ROW --- *@
    <div class="mobile-stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px; margin-bottom: 25px;">
        <div onclick="filterByStatus('')" class="stat-card" style="background: white; padding: 15px 12px; border-radius: 16px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; text-align: center;">
            <div style="font-size: 10px; font-weight: 900; color: #1e293b; text-transform: uppercase; margin-bottom: 5px;">TỔNG ĐƠN ĐỊNH TUYẾN</div>
            <div id="stat-total" style="font-size: 24px; font-weight: 1000; color: #1e293b;">0</div>
        </div>
        <div onclick="filterByStatus('CHỜ DUYỆT')" class="stat-card" style="background: #eff6ff; padding: 15px 12px; border-radius: 16px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; text-align: center;">
            <div style="font-size: 10px; font-weight: 900; color: #2563eb; text-transform: uppercase; margin-bottom: 5px;">CẦN TÔI DUYỆT</div>
            <div id="stat-canDuyet" style="font-size: 24px; font-weight: 1000; color: #2563eb;">0</div>
        </div>
        <div onclick="filterByStatus('ĐÃ XỬ LÝ')" class="stat-card" style="background: #ecfdf5; padding: 15px 12px; border-radius: 16px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; text-align: center;">
            <div style="font-size: 10px; font-weight: 900; color: #059669; text-transform: uppercase; margin-bottom: 5px;">TÔI ĐÃ XỬ LÝ</div>
            <div id="stat-daXuLy" style="font-size: 24px; font-weight: 1000; color: #059669;">0</div>
        </div>
        <div onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #f0f7ff; padding: 15px 12px; border-radius: 16px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; text-align: center;">
            <div style="font-size: 10px; font-weight: 900; color: #1e40af; text-transform: uppercase; margin-bottom: 5px;">HỆ THỐNG HOÀN TẤT</div>
            <div id="stat-hoanTat" style="font-size: 24px; font-weight: 1000; color: #1e40af;">0</div>
        </div>
        <div onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 15px 12px; border-radius: 16px; border: 1px solid #e2e8f0; cursor: pointer; transition: 0.3s; text-align: center;">
            <div style="font-size: 10px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 5px;">ĐÃ HỦY/TỪ CHỐI</div>
            <div id="stat-huy" style="font-size: 24px; font-weight: 1000; color: #b91c1c;">0</div>
        </div>
    </div>

    @* --- TABLE AREA --- *@
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <table id="dataTable" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 3px solid #f1f5f9;">
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên tạo đơn</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin đơn</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 150px;">Tiến trình hệ thống</th>
                    <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                    <th style="padding: 18px 20px; text-align: right;"></th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <tr>
                    <td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none;">
                        <i class="fa fa-spinner fa-spin" style="font-size: 32px; margin-bottom: 15px;"></i>
                        <p style="font-weight: 600;">Đang tải danh sách chờ phê duyệt...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* --- PHẦN PHÂN TRANG --- *@
    <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; margin-top: 5px;">
        <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
        <div style="text-align: right;">
            <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                Trang <span id="currentPageNum" style="color: #2563eb;">1</span> / <span id="totalPagesNum">1</span>
            </div>
            <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];     
        let filteredData = [];   
        let currentPage = 1;
        let rowsPerPage = 20;

        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const response = await fetch('/FormHR/GetPheDuyetCapCaoData');
                masterData = await response.json();
                
                updateStatistics(masterData);
                handleFilterAndPaginate();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: red; border: none;">Lỗi tải dữ liệu. Vui lòng F5.</td></tr>`;
            }
        });

        function updateStatistics(data) {
            document.getElementById("stat-total").innerText = data.length;
            document.getElementById("stat-canDuyet").innerText = data.filter(x => x.isNeedAction === true).length;
            document.getElementById("stat-daXuLy").innerText = data.filter(x => x.isProcessed === true).length;
            document.getElementById("stat-hoanTat").innerText = data.filter(x => x.isFinished === true).length;
            document.getElementById("stat-huy").innerText = data.filter(x => x.isCancelled === true).length;
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            currentPage = 1;
            handleFilterAndPaginate();
        }

        function filterByStatus(s) {
            document.getElementById("quickSearch").value = s;
            currentPage = 1;
            handleFilterAndPaginate();
            
            let table = document.getElementById("dataTable");
            table.style.opacity = "0.4";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }

        function handleFilterAndPaginate() {
            const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();

            filteredData = masterData.filter(item => {
                const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${item.supportName} ${item.statusTag}`.toUpperCase();
                return searchText === "" || rowString.includes(searchText);
            });

            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const pageData = filteredData.slice(startIndex, endIndex);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none; display: block;">Không tìm thấy dữ liệu.</td></tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-clock-o"></i> ${item.timeNguoiTao}</span>`;
                
                if (item.hasGD) {
                    badgesHtml += `<span class="sub-badge" style="color: #1e40af; border-color: #bfdbfe; background: #eff6ff; margin-left:5px;"><i class="fa fa-users"></i> HĐ: ${item.gdDone}/${item.gdTotal}</span>`;
                }

                let btnClass = item.isNeedAction ? "fa-edit" : "fa-eye";
                let btnText = item.isNeedAction ? "Xử lý ngay" : "Xem lại";
                let btnBg = item.isNeedAction ? "#2563eb" : "#f1f5f9";
                let btnColor = item.isNeedAction ? "#ffffff" : "#64748b";

                html += `
                    <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f0f7ff'" onmouseout="this.style.background='transparent'">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #2563eb;">MS: ${item.soNhanVien}</span></div>
                            </div>
                        </td>
                        <td data-label="Thông tin đơn" style="padding: 15px 20px;">
                            <div class="mobile-td-val">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; flex-wrap: wrap; align-items: center; margin-top:4px; justify-content: flex-end;">
                                    ${badgesHtml}
                                </div>
                            </div>
                        </td>
                        <td data-label="Hỗ Trợ" style="padding: 15px 20px;">
                            <div style="display: flex; align-items: center; gap: 8px; justify-content: flex-end;">
                                <div class="support-avatar"><i class="fa fa-user-md" style="font-size: 14px;"></i></div>
                                <div style="font-weight: 700; color: #334155; font-size: 13px;">${item.supportName}</div>
                            </div>
                        </td>
                        <td data-label="Tiến trình" style="padding: 15px 20px;">
                            <div style="width: 120px; margin-left: auto;">
                                <div style="font-size: 9px; font-weight: 1000; color: ${item.pColor}; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                    <span>${item.pText}</span> <span>${item.pWidth}</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                    <div style="width: ${item.pWidth}; height: 100%; background: ${item.pColor}; border-radius: 10px; transition: 0.5s ease;"></div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <span class="status-pill" style="background:${item.bg}; color:${item.fg}; border-color: ${item.fg};">${item.statusTag}</span>
                        </td>
                        <td style="padding: 15px 20px; text-align: right;">
                            <a href="/FormHR/ChiTiet/${item.id}"
                               style="text-decoration: none; padding: 10px 20px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: ${btnBg}; color: ${btnColor}; width: 100%; text-align: center; box-sizing: border-box;"
                               onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                                 <i class="fa ${btnClass}"></i> ${btnText}
                            </a>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = "";
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) {
                        const dot = document.createElement("span");
                        dot.innerText = "...";
                        dot.style.padding = "8px";
                        dot.style.color = "#64748b";
                        dot.style.fontWeight = "700";
                        container.appendChild(dot);
                    }
                    continue;
                }

                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    handleFilterAndPaginate();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}