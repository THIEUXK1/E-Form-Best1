                <span>Lịch sử truy cập</span>
            </a>

            <div style="padding: 20px 25px 10px; font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px;">Cấu hình Quy trình</div>
            
            <a href="/QLtaiKhoan/QLGiamDoc" data-active="@(Context.Request.Path.Value == "/QLtaiKhoan/QLGiamDoc" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLtaiKhoan/QLGiamDoc" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-user-tie" style="width: 20px; color: #f6ad55;"></i>
                <span>Quản lý Giám đốc</span>
            </a>
            
            <a href="/HR_QuanLyDuyetB2" data-active="@(Context.Request.Path.Value == "/HR_QuanLyDuyetB2" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/HR_QuanLyDuyetB2" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-project-diagram" style="width: 20px; color: #63b3ed;"></i>
                <span>Quản lý Duyệt Bước 2</span>
            </a>

            <div style="padding: 20px 25px 10px; font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px;">Hỗ trợ E-Form</div>
            
            <a href="/QLtaiKhoan/NguoiHoTro" data-active="@(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTro" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTro" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-user-shield" style="width: 20px;"></i>
                <span>Người hỗ trợ IT</span>
            </a>

            <a href="/QLtaiKhoan/NguoiHoTroHR" data-active="@(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTroHR" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTroHR" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-user-tie" style="width: 20px;"></i>
                <span>Người hỗ trợ HR</span>
            </a>

            <a href="/QLtaiKhoan/NguoiHoTroSHD" data-active="@(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTroSHD" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTroSHD" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-hand-holding-heart" style="width: 20px; color: #f687b3;"></i>
                <span>Người hỗ trợ SHD</span>
            </a>

            <a href="/QLPhongHopHR" data-active="@(Context.Request.Path.Value == "/QLPhongHopHR" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLPhongHopHR" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-door-open" style="width: 20px; color: #4fd1c5;"></i>
                <span>Quản lý Phòng họp HR</span>
            </a>
        </nav>

        <div style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
            <a href="/Logout" style="color: #feb2b2; font-size: 14px; display: flex; align-items: center; gap: 10px; transition: opacity 0.2s; text-decoration: none;" onmouseenter="this.style.opacity='0.8'" onmouseleave="this.style.opacity='1'">
                <i class="fas fa-sign-out-alt"></i>
                <strong>Đăng xuất</strong>
            </a>
        </div>
    </aside>

    <!-- Nền mờ cho Mobile Menu -->
    <div id="sidebar-backdrop" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; opacity: 0; transition: opacity 0.3s;"></div>

    <main style="flex-grow: 1; display: flex; flex-direction: column; min-width: 0;">
        <header id="main-header" style="background: white; padding: 15px 30px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 998; transition: padding 0.3s;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <!-- Nút bật menu trên Mobile -->
                <button id="mobile-menu-btn" style="display: none; background: none; border: none; font-size: 20px; color: #4a5568; cursor: pointer; padding: 0;">
                    <i class="fas fa-bars"></i>
                </button>
                <div style="font-weight: 500; color: #4a5568;">
                    <i class="fas fa-chevron-right me-2" style="font-size: 12px; color: #cbd5e0;"></i> @ViewData["Title"]
                </div>
            </div>
            <div id="header-info-text" style="font-size: 13px; color: #718096; display: block;">
                Hệ thống quản lý E-Form <i class="fas fa-check-circle" style="color: #38a169;"></i>
            </div>
        </header>

        <div style="padding: 30px; width: 100%; box-sizing: border-box;">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.11/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.11/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Script xử lý Giao diện, Responsive & Thanh cuộn (Tuyệt đối không dùng thẻ style) -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        // Tùy chỉnh thanh cuộn cho web (hỗ trợ các trình duyệt chuẩn mới)
        document.documentElement.style.scrollbarWidth = "thin";
        document.documentElement.style.scrollbarColor = "#cbd5e0 #f1f1f1";

        var sidebar = document.getElementById('sidebar');
        var mobileBtn = document.getElementById('mobile-menu-btn');
        var backdrop = document.getElementById('sidebar-backdrop');
        var header = document.getElementById('main-header');
        var infoText = document.getElementById('header-info-text');

        // Xử lý Responsive thay vì dùng @@media trong CSS
        function handleResize() {
        if (window.innerWidth <= 768) {
        mobileBtn.style.display = 'block';
        header.style.padding = '15px';
        infoText.style.display = 'none';
        if (sidebar.getAttribute('data-open') !== 'true') {
        sidebar.style.position = 'fixed';
        sidebar.style.transform = 'translateX(-100%)';
        }
        } else {
        mobileBtn.style.display = 'none';
        header.style.padding = '15px 30px';
        infoText.style.display = 'block';
        sidebar.style.position = 'sticky';
        sidebar.style.transform = 'translateX(0)';
        sidebar.setAttribute('data-open', 'false');
        backdrop.style.display = 'none';
        backdrop.style.opacity = '0';
        }
        }

        // Mở menu trên mobile
        mobileBtn.addEventListener('click', function() {
        sidebar.style.position = 'fixed';
        sidebar.style.transform = 'translateX(0)';
        sidebar.setAttribute('data-open', 'true');
        backdrop.style.display = 'block';
        setTimeout(function() { backdrop.style.opacity = '1'; }, 10);
        });

        // Đóng menu khi bấm ra ngoài nền mờ
        backdrop.addEventListener('click', function() {
        sidebar.style.transform = 'translateX(-100%)';
        sidebar.setAttribute('data-open', 'false');
        backdrop.style.opacity = '0';
        setTimeout(function() { backdrop.style.display = 'none'; }, 300);
        });

        window.addEventListener('resize', handleResize);
        handleResize(); // Khởi tạo lần đầu
            
        // Xử lý giao diện cho Select2
        $(document).on('select2:open', function() {
        setTimeout(function() {
        $('.select2-container--default .select2-selection--single').css({
        'height': '38px',
        'border': '1px solid #dee2e6',
        'display': 'flex',
        'align-items': 'center'
        });
        }, 0);
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>