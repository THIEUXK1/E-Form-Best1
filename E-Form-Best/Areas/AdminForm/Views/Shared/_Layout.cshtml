<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Hệ thống quản trị Best Pacific</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #cbd5e0; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #a0aec0; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background: #f4f7fa;
            min-height: 100vh;
            display: flex;
            color: #1a202c;
        }

        aside a { text-decoration: none !important; }

        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 13px 25px;
            color: rgba(255,255,255,0.7);
            transition: all 0.2s;
            gap: 12px;
            font-size: 14px;
            border-left: 4px solid transparent;
        }

        .nav-link-custom:hover {
            background: rgba(255,255,255,0.05);
            color: white;
        }

        .nav-link-custom.active {
            background: rgba(74, 144, 226, 0.15) !important;
            border-left: 4px solid #4a90e2 !important;
            color: #4a90e2 !important;
            font-weight: 600;
        }

        .nav-section-title {
            padding: 20px 25px 10px;
            font-size: 11px;
            font-weight: 700;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        main { flex-grow: 1; display: flex; flex-direction: column; min-width: 0; }
        header { background: white; padding: 15px 30px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 999; }
        
        /* Select2 Custom Style để khớp với Inter font */
        .select2-container--default .select2-selection--single {
            height: 38px;
            border: 1px solid #dee2e6;
            display: flex;
            align-items: center;
        }
    </style>
</head>
<body>

    <aside style="width: 260px; background: #1a202c; color: white; display: flex; flex-direction: column; flex-shrink: 0; box-shadow: 2px 0 10px rgba(0,0,0,0.1); position: sticky; top: 0; height: 100vh; z-index: 1000;">
        <a href="/MenuA" style="color: inherit; display: block;">
            <div style="padding: 25px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h2 style="margin: 0; font-size: 20px; letter-spacing: 1px; font-weight: 800; color: #4a90e2;">BEST PACIFIC</h2>
                <span style="font-size: 10px; opacity: 0.6;">ADMIN MANAGEMENT</span>
            </div>
        </a>

        <nav style="padding: 10px 0; flex-grow: 1; overflow-y: auto;">
            <div class="nav-section-title">Hệ thống</div>
            <a href="/QLtaiKhoan" class="nav-link-custom @(Context.Request.Path.Value == "/QLtaiKhoan" ? "active" : "")">
                <i class="fas fa-users-cog" style="width: 20px;"></i>
                <span>Quản lý tài khoản</span>
            </a>

            <a href="/QLQuyenTruyCap" class="nav-link-custom @(Context.Request.Path.Value == "/QLQuyenTruyCap" ? "active" : "")">
                <i class="fas fa-user-lock" style="width: 20px;"></i>
                <span>Quản lý Quyền</span>
            </a>

            <a href="/QLBoPhanAamin" class="nav-link-custom @(Context.Request.Path.Value == "/QLBoPhanAamin" ? "active" : "")">
                <i class="fas fa-sitemap" style="width: 20px;"></i>
                <span>Quản lý Bộ phận</span>
            </a>

            <div class="nav-section-title">Cấu hình Quy trình</div>
            <a href="/QLtaiKhoan/QLGiamDoc" class="nav-link-custom @(Context.Request.Path.Value == "/QLtaiKhoan/QLGiamDoc" ? "active" : "")">
                <i class="fas fa-user-tie" style="width: 20px; color: #f6ad55;"></i>
                <span>Quản lý Giám đốc</span>
            </a>
            
            <a href="/HR_QuanLyDuyetB2" class="nav-link-custom @(Context.Request.Path.Value == "/HR_QuanLyDuyetB2" ? "active" : "")">
                <i class="fas fa-project-diagram" style="width: 20px; color: #63b3ed;"></i>
                <span>Quản lý Duyệt Bước 2</span>
            </a>

            <div class="nav-section-title">Hỗ trợ E-Form</div>
            <a href="/QLtaiKhoan/NguoiHoTro" class="nav-link-custom @(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTro" ? "active" : "")">
                <i class="fas fa-user-shield" style="width: 20px;"></i>
                <span>Người hỗ trợ IT</span>
            </a>

            <a href="/QLtaiKhoan/NguoiHoTroHR" class="nav-link-custom @(Context.Request.Path.Value == "/QLtaiKhoan/NguoiHoTroHR" ? "active" : "")">
                <i class="fas fa-user-tie" style="width: 20px;"></i>
                <span>Người hỗ trợ HR</span>
            </a>

            <a href="/QLPhongHopHR" class="nav-link-custom @(Context.Request.Path.Value == "/QLPhongHopHR" ? "active" : "")">
                <i class="fas fa-door-open" style="width: 20px; color: #4fd1c5;"></i>
                <span>Quản lý Phòng họp HR</span>
            </a>
        </nav>

        <div style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
            <a href="/Logout" style="color: #feb2b2; font-size: 14px; display: flex; align-items: center; gap: 10px; transition: opacity 0.2s; text-decoration: none;">
                <i class="fas fa-sign-out-alt"></i>
                <strong>Đăng xuất</strong>
            </a>
        </div>
    </aside>

    <main>
        <header>
            <div style="font-weight: 500; color: #4a5568;">
                <i class="fas fa-chevron-right me-2" style="font-size: 12px; color: #cbd5e0;"></i> @ViewData["Title"]
            </div>
            <div style="font-size: 13px; color: #718096;">
                Hệ thống quản lý E-Form <i class="fas fa-check-circle" style="color: #38a169;"></i>
            </div>
        </header>

        <div style="padding: 30px; width: 100%; box-sizing: border-box;">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>