                <i class="fas fa-users-cog" style="width: 20px;"></i>
                <span>Quản lý tài khoản</span>
            </a>

            <a href="/QLQuyenTruyCap" data-active="@(Context.Request.Path.Value == "/QLQuyenTruyCap" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLQuyenTruyCap" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-user-lock" style="width: 20px;"></i>
                <span>Quản lý Quyền</span>
            </a>

            <a href="/QLBoPhanAamin" data-active="@(Context.Request.Path.Value == "/QLBoPhanAamin" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLBoPhanAamin" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
                <i class="fas fa-sitemap" style="width: 20px;"></i>
                <span>Quản lý Bộ phận</span>
            </a>

            <a href="/QLTruyCap" data-active="@(Context.Request.Path.Value == "/QLTruyCap" ? "true" : "false")" style="display: flex; align-items: center; padding: 13px 25px; transition: all 0.2s; gap: 12px; font-size: 14px; text-decoration: none; @(Context.Request.Path.Value == "/QLTruyCap" ? "background: rgba(74, 144, 226, 0.15); border-left: 4px solid #4a90e2; color: #4a90e2; font-weight: 600;" : "color: rgba(255,255,255,0.7); border-left: 4px solid transparent;")" onmouseenter="if(this.getAttribute('data-active') !== 'true') { this.style.background='rgba(255,255,255,0.05)'; this.style.color='white'; }" onmouseleave="if(this.getAttribute('data-active') !== 'true') { this.style.background='transparent'; this.style.color='rgba(255,255,255,0.7)'; }">
