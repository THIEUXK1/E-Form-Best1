@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-card {
        background: #ffffff;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #edf2f7;
        transition: transform 0.2s;
    }

        .admin-card:hover {
            transform: translateY(-2px);
        }

    .input-custom {
        width: 100%;
        padding: 12px 16px;
        border-radius: 10px;
        border: 1px solid #cbd5e0;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
    }

        .input-custom:focus {
            border-color: #4299e1;
            box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.15);
        }

    .btn-primary {
        background: #4299e1;
        color: white;
        border: none;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .btn-primary:hover {
            opacity: 0.9;
        }

    .table-container {
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        overflow: hidden;
        border: 1px solid #edf2f7;
    }

    th {
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.05em;
    }

    .pw-container {
        position: relative;
        display: inline-block;
        width: 45%;
    }

    .btn-eye {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 12px;
    }
</style>

<div style="max-width: 1200px; margin: 0 auto; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; padding: 20px;">

    <h1 style="text-align:center; color:#1a202c; margin-bottom:40px; font-weight: 800; font-size: 2.5rem; letter-spacing: -1px;">
        👤 Quản lý Tài Khoản
    </h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div class="admin-card">
            <label style="display: block; font-weight: 700; color: #4a5568; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase;">🔍 Đồng bộ từ hệ thống HR</label>
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <input type="text" id="empNoSearch" placeholder="Nhập mã EMPNO..." class="input-custom" />
                <button onclick="searchFromHR()" class="btn-primary" style="padding: 12px 20px; border-radius: 10px;">TÌM</button>
            </div>
            <div id="searchResult" style="margin-bottom: 15px;"></div>
            <button onclick="syncAll()" style="width: 100%; padding: 12px; border-radius: 10px; background: #667eea; color: white; border: none; font-weight: 700; cursor: pointer;">
                🔄 ĐỒNG BỘ TOÀN BỘ NHÂN VIÊN MỚI
            </button>
        </div>

        <div class="admin-card">
            <label style="display: block; font-weight: 700; color: #4a5568; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase;">➕ Thêm tài khoản thủ công</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <input type="text" id="add_Tk" placeholder="Mã TK (EMPNO)..." class="input-custom" style="padding: 10px;" />
                <input type="text" id="add_HoTen" placeholder="Họ và tên..." class="input-custom" style="padding: 10px;" />
                <input type="text" id="add_PhongBan" placeholder="Phòng ban..." class="input-custom" style="padding: 10px;" />
                <select id="add_VaiTro" class="input-custom" style="padding: 10px; background: white;">
                    <option value="NhanVien">Nhân Viên</option>
                    <option value="QuanLy">Quản Lý</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button onclick="addManual()" style="width: 100%; margin-top: 15px; padding: 12px; border-radius: 10px; background: #48bb78; color: white; border: none; font-weight: 700; cursor: pointer;">
                LƯU TÀI KHOẢN MỚI
            </button>
        </div>
    </div>

    <div style="background: #ffffff; padding: 20px; border-radius: 16px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border: 1px solid #edf2f7; margin-bottom: 20px; display: flex; gap: 15px; align-items: center;">
        <div style="flex: 2;">
            <input type="text" id="filterSearch" onkeyup="filterTable()" placeholder="🔍 Lọc theo tên hoặc mã tài khoản..." class="input-custom" style="padding: 10px 15px;" />
        </div>
        <div style="flex: 1;">
            <select id="filterPhongBan" onchange="filterTable()" class="input-custom" style="padding: 10px; background: white;">
                <option value="">-- Tất cả phòng ban --</option>
            </select>
        </div>
        <div style="flex: 1;">
            <select id="filterVaiTro" onchange="filterTable()" class="input-custom" style="padding: 10px; background: white;">
                <option value="">-- Tất cả vai trò --</option>
                <option value="NhanVien">Nhân Viên</option>
                <option value="QuanLy">Quản Lý</option>
                <option value="Admin">Admin</option>
            </select>
        </div>
        <button onclick="resetFilter()" style="padding: 10px 15px; background: #f7fafc; border: 1px solid #cbd5e0; border-radius: 10px; cursor: pointer; font-weight: 600; color: #4a5568;">Làm mới</button>
    </div>

    <div class="table-container">
        <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
            <thead>
                <tr style="background: #1a202c; color: #ffffff; text-align: left;">
                    <th style="padding: 18px 15px;">Nhân viên</th>
                    <th style="padding: 18px 15px;">Bảo mật & Liên hệ</th>
                    <th style="padding: 18px 15px;">Vai trò</th>
                    <th style="padding: 18px 15px;">Trạng thái</th>
                    <th style="padding: 18px 15px; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="userTableBody">
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', loadUserList);

    let allUsersData = [];

    // 1. Load danh sách
    function loadUserList() {
        const tbody = document.getElementById('userTableBody');
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:50px;"><div class="spinner">Đang tải dữ liệu...</div></td></tr>';

        fetch('/QLtaiKhoan/GetAllUsers')
            .then(res => res.json())
            .then(data => {
                allUsersData = data;
                renderTable(data);
                populatePhongBanFilter(data);
            })
            .catch(err => {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:red; padding:20px;">Lỗi tải dữ liệu</td></tr>';
            });
    }

    // Render bảng (Giữ nguyên cấu trúc của bạn, thêm toggle pass)
    function renderTable(data) {
        const tbody = document.getElementById('userTableBody');
        if (data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:20px; color: #a0aec0;">Không tìm thấy kết quả phù hợp.</td></tr>';
            return;
        }

        tbody.innerHTML = data.map(user => `
            <tr id="row-${user.idNguoiDung}" style="border-bottom: 1px solid #edf2f7; transition: background 0.2s;">
                <td style="padding: 15px;">
                    <div style="font-weight: 800; color: #2d3748;">#${user.idNguoiDung} - ${user.hoTen}</div>
                    <div style="font-size: 11px; color: #718096; background: #f7fafc; display: inline-block; padding: 2px 6px; border-radius: 4px; margin-top: 4px;">🏢 ${user.phongBan || 'N/A'}</div>
                </td>
                <td style="padding: 15px;">
                    <div style="font-weight: 600; color: #718096; font-size: 12px; margin-bottom: 5px;">TK: <span style="color:#2b6cb0">${user.tk}</span></div>
                    <div style="display: flex; gap: 5px; align-items: center;">
                        <div class="pw-container">
                            <input type="password" id="pass-${user.idNguoiDung}" value="${user.matKhau || ''}"
                                   style="width: 100%; padding: 6px; border-radius: 6px; border: 1px solid #e2e8f0; font-size: 12px;" />
                            <button class="btn-eye" onclick="togglePass(${user.idNguoiDung})">👁️</button>
                        </div>
                        <input type="text" id="phone-${user.idNguoiDung}" value="${user.soDienThoai || ''}" placeholder="SĐT"
                               style="width: 45%; padding: 6px; border-radius: 6px; border: 1px solid #e2e8f0; font-size: 12px;" />
                    </div>
                </td>
                <td style="padding: 15px;">
                    <select id="role-${user.idNguoiDung}" style="width: 100%; padding: 8px; border-radius: 8px; border: 1px solid #e2e8f0; background: white;">
                        <option value="NhanVien" ${user.vaiTro === 'NhanVien' ? 'selected' : ''}>Nhân Viên</option>
                        <option value="QuanLy" ${user.vaiTro === 'QuanLy' ? 'selected' : ''}>Quản Lý</option>
                        <option value="Admin" ${user.vaiTro === 'Admin' ? 'selected' : ''}>Admin</option>
                    </select>
                </td>
                <td style="padding: 15px;">
                    <span style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; background: #e6fffa; color: #234e52; border: 1px solid #b2f5ea;">
                        ● ${user.trangThai || 'Đang làm'}
                    </span>
                </td>
                <td style="padding: 15px; text-align: center;">
                    <div style="display: flex; gap: 5px; justify-content: center;">
                        <button onclick="updateUser(${user.idNguoiDung})" style="padding: 8px 15px; border-radius: 8px; background: #38a169; color: white; border: none; cursor: pointer; font-weight: 600;">LƯU</button>
                        <button onclick="deleteUser(${user.idNguoiDung})" style="padding: 8px 15px; border-radius: 8px; background: #fff5f5; color: #e53e3e; border: 1px solid #feb2b2; cursor: pointer; font-weight: 600;">XÓA</button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    // Helper: Ẩn hiện mật khẩu
    function togglePass(id) {
        const input = document.getElementById(`pass-${id}`);
        input.type = input.type === 'password' ? 'text' : 'password';
    }

    // Logic Lọc (Giữ nguyên)
    function filterTable() {
        const searchText = document.getElementById('filterSearch').value.toLowerCase();
        const filterPB = document.getElementById('filterPhongBan').value;
        const filterVT = document.getElementById('filterVaiTro').value;

        const filteredData = allUsersData.filter(user => {
            const matchesSearch = (user.hoTen || "").toLowerCase().includes(searchText) ||
                                  (user.tk || "").toLowerCase().includes(searchText);
            const matchesPB = filterPB === "" || user.phongBan === filterPB;
            const matchesVT = filterVT === "" || user.vaiTro === filterVT;
            return matchesSearch && matchesPB && matchesVT;
        });
        renderTable(filteredData);
    }

    function populatePhongBanFilter(data) {
        const select = document.getElementById('filterPhongBan');
        const currentVal = select.value;
        const depts = [...new Set(data.map(u => u.phongBan).filter(p => p))];
        select.innerHTML = '<option value="">-- Tất cả phòng ban --</option>' +
            depts.sort().map(d => `<option value="${d}" ${d === currentVal ? 'selected' : ''}>${d}</option>`).join('');
    }

    function resetFilter() {
        document.getElementById('filterSearch').value = '';
        document.getElementById('filterPhongBan').value = '';
        document.getElementById('filterVaiTro').value = '';
        renderTable(allUsersData);
    }

    // 2. Thêm thủ công (Giữ nguyên)
    function addManual() {
        const data = {
            Tk: document.getElementById('add_Tk').value,
            HoTen: document.getElementById('add_HoTen').value,
            PhongBan: document.getElementById('add_PhongBan').value,
            VaiTro: document.getElementById('add_VaiTro').value
        };

        if(!data.Tk || !data.HoTen) return Swal.fire('Lỗi', 'Vui lòng nhập Mã TK và Họ tên', 'error');

        fetch('/QLtaiKhoan/ThemThuCong', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(res => {
            if(res.ok) {
                Swal.fire('Thành công', 'Đã thêm tài khoản mới', 'success');
                loadUserList();
                document.getElementById('add_Tk').value = '';
                document.getElementById('add_HoTen').value = '';
                document.getElementById('add_PhongBan').value = '';
            } else res.text().then(text => Swal.fire('Lỗi', text, 'error'));
        });
    }

    // 3. Cập nhật (Giữ nguyên + update local data)
    function updateUser(id) {
        const data = {
            IdNguoiDung: id,
            MatKhau: document.getElementById(`pass-${id}`).value,
            SoDienThoai: document.getElementById(`phone-${id}`).value,
            VaiTro: document.getElementById(`role-${id}`).value
        };

        fetch('/QLtaiKhoan/CapNhatNguoiDung', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(res => {
            if(res.ok) {
                const userIdx = allUsersData.findIndex(u => u.idNguoiDung == id);
                if(userIdx > -1) {
                    allUsersData[userIdx].matKhau = data.MatKhau;
                    allUsersData[userIdx].soDienThoai = data.SoDienThoai;
                    allUsersData[userIdx].vaiTro = data.VaiTro;
                }
                Swal.fire({ title: 'Thành công', text: 'Đã lưu thay đổi', icon: 'success', timer: 1500, showConfirmButton: false });
            }
        });
    }

    // 4. Xóa (Giữ nguyên)
    function deleteUser(id) {
        Swal.fire({
            title: 'Xác nhận xóa?',
            text: "Dữ liệu này không thể khôi phục!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e53e3e',
            cancelButtonColor: '#718096',
            confirmButtonText: 'Đúng, xóa nó!',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/QLtaiKhoan/XoaNguoiDung?id=' + id, { method: 'POST' })
                    .then(res => {
                        if(res.ok) {
                            allUsersData = allUsersData.filter(u => u.idNguoiDung != id);
                            document.getElementById(`row-${id}`).style.opacity = '0';
                            setTimeout(() => document.getElementById(`row-${id}`).remove(), 300);
                            Swal.fire('Đã xóa!', '', 'success');
                        }
                    });
            }
        });
    }

    // 5. HR Sync (Giữ nguyên)
    function searchFromHR() {
        const empNo = document.getElementById('empNoSearch').value;
        const div = document.getElementById('searchResult');
        if(!empNo) return;

        div.innerHTML = '<span style="color:#667eea">🔎 Đang tìm kiếm...</span>';

        fetch('/QLtaiKhoan/GetNhanVien?empNo=' + empNo)
            .then(res => res.json())
            .then(emp => {
                if(!emp || !emp.USER_NAME) return div.innerHTML = '<span style="color:#e53e3e; font-weight:bold;">❌ Không tìm thấy nhân viên này!</span>';
                div.innerHTML = `
                    <div style="padding:12px; background:#f0fff4; border:1px solid #c6f6d5; border-radius:10px; display:flex; justify-content:between; align-items:center;">
                        <div style="flex:1">
                            <b style="color:#2f855a">${emp.USER_NAME}</b><br/>
                            <small style="color:#48bb78">${emp.DEPT_NAME || 'Phòng ban trống'}</small>
                        </div>
                        <button onclick="addUserHR('${emp.EMPNO}')" style="background:#48bb78; color:white; border:none; padding:8px 16px; border-radius:8px; cursor:pointer; font-weight:bold;">+ THÊM NGAY</button>
                    </div>`;
            }).catch(() => div.innerHTML = '<span style="color:red">Lỗi kết nối Server</span>');
    }

    function addUserHR(empNo) {
        fetch('/QLtaiKhoan/ThemNhanVien', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ empNo: empNo })
        }).then(res => {
            if(res.ok) {
                loadUserList();
                Swal.fire('Thành công', 'Đã đồng bộ nhân viên vào hệ thống', 'success');
                document.getElementById('searchResult').innerHTML = '';
                document.getElementById('empNoSearch').value = '';
            }
        });
    }

    function syncAll() {
        Swal.fire({
            title: 'Đang đồng bộ...',
            text: 'Hệ thống đang kiểm tra danh sách nhân viên mới',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        fetch('/QLtaiKhoan/DongBoNhanVien', { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                loadUserList();
                Swal.fire('Hoàn tất', data.message || 'Đồng bộ thành công', 'success');
            })
            .catch(() => Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ HR', 'error'));
    }
</script>