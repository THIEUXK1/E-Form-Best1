@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<div id="main-container" style="max-width: 1300px; margin: 0 auto; font-family: 'Segoe UI', Roboto, sans-serif; color: #2d3748; padding: 20px; background-color: #f7fafc; min-height: 100vh;">

    <h1 style="text-align:center; color:#1a202c; margin-bottom:40px; font-weight: 800; font-size: 2.5rem; letter-spacing: -1px;">
        👤 Quản lý Tài Khoản
    </h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div style="background: #ffffff; padding: 25px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #edf2f7;">
            <label style="display: block; font-weight: 700; color: #4a5568; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase;">🔍 Đồng bộ từ hệ thống HR</label>
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <input type="text" id="empNoSearch" placeholder="Nhập mã EMPNO..." style="width: 100%; padding: 12px 16px; border-radius: 10px; border: 1px solid #cbd5e0; outline: none;" />
                <button onclick="searchFromHR()" style="background: #4299e1; color: white; border: none; font-weight: 700; cursor: pointer; padding: 12px 25px; border-radius: 10px; white-space: nowrap;">TÌM KIẾM</button>
            </div>
            <div id="searchResult" style="margin-bottom: 15px;"></div>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 10px;">
                <div style="display:flex; gap:8px;">
                    <button onclick="syncAll('BPVN')" style="padding: 12px 15px; border-radius: 10px; background: #667eea; color: white; border: none; font-weight: 700; cursor: pointer;">🔄 BPVN</button>
                    <button onclick="syncAll('PFVN')" style="padding: 12px 15px; border-radius: 10px; background: #ed64a6; color: white; border: none; font-weight: 700; cursor: pointer;">🔄 PFVN</button>
                </div>
                <select id="hrCompany" style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;">
                    <option value="BPVN">Best Pacific (BPVN)</option>
                    <option value="PFVN">Pacific Fabric (PFVN)</option>
                </select>
            </div>
        </div>

        <div style="background: #ffffff; padding: 25px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #edf2f7;">
            <label style="display: block; font-weight: 700; color: #4a5568; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase;">➕ Thêm tài khoản thủ công</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <input type="text" id="add_Tk" placeholder="Mã TK..." style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;" />
                <input type="text" id="add_HoTen" placeholder="Họ tên..." style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;" />
                <input type="text" id="add_PhongBan" placeholder="Phòng ban..." style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;" />
                <select id="add_VaiTro" style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0; background: white;">
                    <option value="NhanVien">Nhân Viên</option>
                    <option value="QuanLy">Quản Lý</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button onclick="addManual()" style="width: 100%; margin-top: 15px; padding: 12px; border-radius: 10px; background: #48bb78; color: white; border: none; font-weight: 700; cursor: pointer;">LƯU TÀI KHOẢN MỚI</button>
        </div>
    </div>

    <div style="background: #ffffff; padding: 20px; border-radius: 16px; border: 1px solid #edf2f7; margin-bottom: 20px; display: flex; gap: 15px; align-items: center;">
        <div style="flex: 2;">
            <input type="text" id="filterSearch" onkeyup="filterTable()" placeholder="🔍 Lọc nhanh theo tên hoặc mã..." style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #cbd5e0;" />
        </div>
        <div style="flex: 1;">
            <select id="filterPhongBan" onchange="filterTable()" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #cbd5e0;"></select>
        </div>
        <div style="flex: 1;">
            <select id="filterVaiTro" onchange="filterTable()" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #cbd5e0;">
                <option value="">-- Tất cả vai trò --</option>
                <option value="NhanVien">Nhân Viên</option>
                <option value="QuanLy">Quản Lý</option>
                <option value="Admin">Admin</option>
                <option value="AdminHR">AdminHR</option>
                <option value="BaoVe">Bảo Vệ</option>
            </select>
        </div>
        <button onclick="resetFilter()" style="padding: 12px 20px; background: #f7fafc; border: 1px solid #cbd5e0; border-radius: 10px; cursor: pointer;">Làm mới</button>
    </div>

    <div style="background: white; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.05); overflow-x: auto; border: 1px solid #edf2f7;">
        <table style="width: 100%; border-collapse: collapse; font-size: 13px; min-width: 1100px;">
            <thead>
                <tr style="background: #1a202c; color: #ffffff; text-align: left;">
                    <th style="padding: 15px;">Thông tin nhân viên (Tên, PB, Cty)</th>
                    <th style="padding: 15px;">Tài khoản & Bảo mật (Mã, Pass, SĐT)</th>
                    <th style="padding: 15px; width: 130px;">Vai trò</th>
                    <th style="padding: 15px; width: 130px;">Trạng thái</th>
                    <th style="padding: 15px; text-align: center; width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="userTableBody"></tbody>
        </table>
    </div>
    <div id="scrollStatus" style="text-align: center; padding: 20px; color: #718096; font-style: italic;"></div>
</div>

<div id="detailModal" style="display:none; position:fixed; z-index:9999; left:0; top:0; width:100%; height:100%; background:rgba(0,0,0,0.6); backdrop-filter: blur(4px); overflow-y:auto;">
    <div style="background:white; max-width:850px; margin:40px auto; border-radius:20px; padding:0; position:relative; box-shadow:0 25px 50px rgba(0,0,0,0.3); animation: slideDown 0.3s ease-out;">
        <div style="padding: 20px 30px; border-bottom: 1px solid #edf2f7; display: flex; justify-content: space-between; align-items: center; background: #f8fafc; border-radius: 20px 20px 0 0;">
            <h2 id="detailTitle" style="margin:0; color:#1a202c; font-size: 1.5rem;">Chi tiết & Phân quyền</h2>
            <button onclick="$('#detailModal').hide()" style="background:none; border:none; font-size:28px; cursor:pointer; color:#a0aec0;">&times;</button>
        </div>

        <div style="padding: 30px; display:grid; grid-template-columns: 1fr 1fr; gap:25px;">
            <div style="background:#fff; padding:20px; border-radius:15px; border:1px solid #e2e8f0; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                <h4 style="margin-top:0; color:#2d3748; display:flex; align-items:center; gap:10px;">🔐 Quyền hệ thống</h4>
                <div id="permissionsList" style="max-height:400px; overflow-y:auto; padding-right:10px;"></div>
            </div>

            <div style="background:#fff; padding:20px; border-radius:15px; border:1px solid #e2e8f0; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                <h4 style="margin-top:0; color:#2d3748; display:flex; align-items:center; gap:10px;">🏢 Bộ phận quản lý</h4>
                <div id="departmentsList" style="max-height:400px; overflow-y:auto; padding-right:10px;"></div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes slideDown {
        from { transform: translateY(-30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .permission-item:hover { background: #f7fafc; }
    #permissionsList::-webkit-scrollbar, #departmentsList::-webkit-scrollbar { width: 5px; }
    #permissionsList::-webkit-scrollbar-thumb, #departmentsList::-webkit-scrollbar-thumb { background: #cbd5e0; border-radius: 10px; }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', loadUserList);

    let allUsersData = [];
    let currentFilteredData = [];
    let displayLimit = 25;
    const batchSize = 20;

    function loadUserList() {
        const tbody = document.getElementById('userTableBody');
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:50px;">⏳ Đang tải dữ liệu...</td></tr>';
        fetch('/QLtaiKhoan/GetAllUsers')
            .then(res => res.json())
            .then(data => {
                allUsersData = data;
                currentFilteredData = data;
                renderTable();
                populatePhongBanFilter(data);
            });
    }

    function renderTable() {
        const tbody = document.getElementById('userTableBody');
        const status = document.getElementById('scrollStatus');
        const dataToDisplay = currentFilteredData.slice(0, displayLimit);

        if (currentFilteredData.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:50px;">📭 Không tìm thấy dữ liệu.</td></tr>';
            return;
        }

        tbody.innerHTML = dataToDisplay.map(user => `
            <tr id="row-${user.idNguoiDung}" style="border-bottom: 1px solid #edf2f7;">
                <td style="padding: 10px;">
                    <input type="text" id="name-${user.idNguoiDung}" value="${user.hoTen || ''}" style="width: 95%; padding: 6px; border: 1px solid #e2e8f0; border-radius: 4px; font-weight: bold; margin-bottom: 5px;" placeholder="Họ tên"/>
                    <div style="display: flex; gap: 5px;">
                        <input type="text" id="dept-${user.idNguoiDung}" value="${user.phongBan || ''}" style="width: 50%; padding: 4px; border: 1px solid #e2e8f0; font-size: 11px;" placeholder="Phòng ban"/>
                        <input type="text" id="comp-${user.idNguoiDung}" value="${user.tenCongTy || ''}" style="width: 45%; padding: 4px; border: 1px solid #e2e8f0; font-size: 11px;" placeholder="Công ty"/>
                    </div>
                </td>
                <td style="padding: 10px;">
                    <div style="margin-bottom: 5px; display:flex; align-items:center; gap:5px;">
                        <span style="font-size:11px; color:#718096; width:40px;">Mã:</span>
                        <input type="text" id="tk-${user.idNguoiDung}" value="${user.tk || ''}" style="flex:1; padding: 6px; border: 1px solid #e2e8f0; border-radius: 4px; color:#2b6cb0; font-weight:bold;"/>
                    </div>
                    <div style="display: flex; gap: 5px;">
                        <div style="position: relative; width: 50%;">
                            <input type="password" id="pass-${user.idNguoiDung}" value="${user.matKhau || ''}" style="width: 100%; padding: 6px; border: 1px solid #e2e8f0; border-radius: 4px; font-size: 12px;"/>
                            <button onclick="togglePass(${user.idNguoiDung})" style="position: absolute; right: 5px; top: 50%; transform: translateY(-50%); background:none; border:none; cursor:pointer;">👁️</button>
                        </div>
                        <input type="text" id="phone-${user.idNguoiDung}" value="${user.soDienThoai || ''}" style="width: 50%; padding: 6px; border: 1px solid #e2e8f0; border-radius: 4px; font-size: 12px;" placeholder="SĐT"/>
                    </div>
                </td>
                <td style="padding: 10px;">
                     <select id="role-${user.idNguoiDung}" style="width: 100%; padding: 8px; border: 1px solid #e2e8f0; border-radius: 8px; background:white;">
                        <option value="NhanVien" ${user.vaiTro === 'NhanVien' ? 'selected' : ''}>Nhân Viên</option>
                        <option value="QuanLy" ${user.vaiTro === 'QuanLy' ? 'selected' : ''}>Quản Lý</option>
                        <option value="Admin" ${user.vaiTro === 'Admin' ? 'selected' : ''}>Admin</option>
                        <option value="AdminHR" ${user.vaiTro === 'AdminHR' ? 'selected' : ''}>AdminHR</option>
                        <option value="BaoVe" ${user.vaiTro === 'BaoVe' ? 'selected' : ''}>Bảo Vệ</option>
                        <option value="All" ${user.vaiTro === 'All' ? 'selected' : ''}>All</option>
                    </select>
                </td>
                <td style="padding: 10px;">
                    <select id="status-${user.idNguoiDung}" style="width: 100%; padding: 8px; border: 1px solid #e2e8f0; border-radius: 8px; background:white;">
                        <option value="Đang làm" ${user.trangThai === 'Đang làm' ? 'selected' : ''}>Đang làm</option>
                        <option value="Đã nghỉ" ${user.trangThai === 'Đã nghỉ' ? 'selected' : ''}>Đã nghỉ</option>
                    </select>
                </td>
                <td style="padding: 10px; text-align: center;">
                    <div style="display: flex; gap: 6px; justify-content: center;">
                        <button onclick="viewDetail(${user.idNguoiDung})" style="padding: 8px 12px; border-radius: 8px; background: #4299e1; color: white; border: none; cursor: pointer; font-weight: bold; font-size:11px;">CHI TIẾT</button>
                        <button onclick="updateUser(${user.idNguoiDung})" style="padding: 8px 12px; border-radius: 8px; background: #38a169; color: white; border: none; cursor: pointer; font-weight: bold; font-size:11px;">LƯU</button>
                        <button onclick="deleteUser(${user.idNguoiDung})" style="padding: 8px 12px; border-radius: 8px; background: #fff5f5; color: #e53e3e; border: 1px solid #feb2b2; cursor: pointer; font-weight: bold; font-size:11px;">XÓA</button>
                    </div>
                </td>
            </tr>
        `).join('');
        status.innerText = displayLimit < currentFilteredData.length ? `Hiển thị ${displayLimit}/${currentFilteredData.length}. Cuộn xuống...` : `Tổng: ${currentFilteredData.length}`;
    }

    function viewDetail(userId) {
        const user = allUsersData.find(u => u.idNguoiDung == userId);
        $('#detailTitle').html(`👤 <span style="color:#2b6cb0">${user.hoTen}</span> <small style="font-size:12px; color:#718096">(${user.tk})</small>`);
        $('#permissionsList, #departmentsList').html('<p style="text-align:center; padding:20px;">Đang tải...</p>');
        $('#detailModal').show();

        fetch(`/QLtaiKhoan/GetUserDetail?id=${userId}`)
            .then(res => res.json())
            .then(data => {
                // Render Quyền (Cập nhật giao diện mượt hơn)
                let qHtml = data.allQuyen.length ? data.allQuyen.map(q => `
                    <div class="permission-item" style="padding:10px; border-bottom:1px solid #edf2f7; transition:0.2s;">
                        <label style="display:flex; align-items:center; gap:12px; cursor:pointer; width:100%;">
                            <input type="checkbox" style="width:18px; height:18px; accent-color:#4299e1;"
                                   ${data.userQuyenIds.includes(q.idQuyen) ? 'checked' : ''}
                                   onchange="togglePermission(${userId}, ${q.idQuyen}, this.checked)">
                            <div>
                                <div style="font-weight:600; color:#2d3748;">${q.tenQuyen}</div>
                                <div style="font-size:11px; color:#718096;">${q.moTa || 'Không có mô tả'}</div>
                            </div>
                        </label>
                    </div>
                `).join('') : '<p style="text-align:center; padding:20px; color:#a0aec0;">Chưa có dữ liệu quyền.</p>';
                $('#permissionsList').html(qHtml);

                // Render Bộ phận (Đã thêm phần Mô tả)
                let bHtml = data.allBoPhan.length ? data.allBoPhan.map(b => `
                    <div class="permission-item" style="padding:10px; border-bottom:1px solid #edf2f7; transition:0.2s;">
                        <label style="display:flex; align-items:center; gap:12px; cursor:pointer; width:100%;">
                            <input type="checkbox" style="width:18px; height:18px; accent-color:#38a169;"
                                   ${data.userBoPhanIds.includes(b.idBoPhan) ? 'checked' : ''}
                                   onchange="toggleDepartment(${userId}, ${b.idBoPhan}, this.checked)">
                            <div>
                                <div style="font-weight:600; color:#2d3748;">${b.tenBoPhan}</div>
                                <div style="font-size:11px; color:#718096;">${b.moTa || 'Không có mô tả bộ phận'}</div>
                            </div>
                        </label>
                    </div>
                `).join('') : '<p style="text-align:center; padding:20px; color:#a0aec0;">Chưa có dữ liệu bộ phận.</p>';
                $('#departmentsList').html(bHtml);
            });
    }

    function togglePermission(userId, quyenId, isChecked) {
        $.post('/QLtaiKhoan/TogglePermission', { userId, quyenId, isChecked });
    }

    function toggleDepartment(userId, boPhanId, isChecked) {
        $.post('/QLtaiKhoan/ToggleDepartment', { userId, boPhanId, isChecked });
    }

    window.onscroll = () => {
        if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 100) {
            if (displayLimit < currentFilteredData.length) {
                displayLimit += batchSize;
                renderTable();
            }
        }
    };

    function filterTable() {
        const s = document.getElementById('filterSearch').value.toLowerCase();
        const pb = document.getElementById('filterPhongBan').value;
        const vt = document.getElementById('filterVaiTro').value;
        currentFilteredData = allUsersData.filter(u =>
            ((u.hoTen || '').toLowerCase().includes(s) || (u.tk || '').toLowerCase().includes(s)) &&
            (pb === "" || u.phongBan === pb) &&
            (vt === "" || u.vaiTro === vt)
        );
        displayLimit = 25;
        renderTable();
    }

    function resetFilter() {
        document.getElementById('filterSearch').value = '';
        document.getElementById('filterPhongBan').value = '';
        document.getElementById('filterVaiTro').value = '';
        currentFilteredData = allUsersData;
        displayLimit = 25;
        renderTable();
    }

    function updateUser(id) {
        const data = {
            IdNguoiDung: id,
            HoTen: document.getElementById(`name-${id}`).value,
            Tk: document.getElementById(`tk-${id}`).value,
            PhongBan: document.getElementById(`dept-${id}`).value,
            TenCongTy: document.getElementById(`comp-${id}`).value,
            MatKhau: document.getElementById(`pass-${id}`).value,
            SoDienThoai: document.getElementById(`phone-${id}`).value,
            VaiTro: document.getElementById(`role-${id}`).value,
            TrangThai: document.getElementById(`status-${id}`).value
        };
        fetch('/QLtaiKhoan/CapNhatNguoiDung', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(res => {
            if (res.ok) {
                const u = allUsersData.find(x => x.idNguoiDung == id);
                if (u) Object.assign(u, {
                    hoTen: data.HoTen, tk: data.Tk, phongBan: data.PhongBan, tenCongTy: data.TenCongTy,
                    matKhau: data.MatKhau, soDienThoai: data.SoDienThoai, vaiTro: data.VaiTro, trangThai: data.TrangThai
                });
                Swal.fire({ icon: 'success', title: 'Đã lưu thay đổi', timer: 1000, showConfirmButton: false });
            }
        });
    }

    function deleteUser(id) {
        Swal.fire({ title: 'Xác nhận xóa?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#e53e3e' }).then(r => {
            if (r.isConfirmed) {
                fetch('/QLtaiKhoan/XoaNguoiDung?id=' + id, { method: 'POST' }).then(res => {
                    if (res.ok) {
                        allUsersData = allUsersData.filter(u => u.idNguoiDung != id);
                        filterTable();
                        Swal.fire('Đã xóa!', '', 'success');
                    }
                });
            }
        });
    }

    function togglePass(id) {
        const input = document.getElementById(`pass-${id}`);
        input.type = input.type === 'password' ? 'text' : 'password';
    }

    function populatePhongBanFilter(data) {
        const sel = document.getElementById('filterPhongBan');
        const depts = [...new Set(data.map(u => u.phongBan).filter(p => p))].sort();
        sel.innerHTML = '<option value="">-- Tất cả phòng ban --</option>' + depts.map(d => `<option value="${d}">${d}</option>`).join('');
    }

    function searchFromHR() {
        const empNo = document.getElementById('empNoSearch').value;
        const div = document.getElementById('searchResult');
        if (!empNo) return;
        div.innerHTML = '<span style="color:#4299e1">🔎 Đang tìm...</span>';
        fetch('/QLtaiKhoan/GetNhanVien?empNo=' + empNo).then(res => res.json()).then(emp => {
            if (!emp || !emp.USER_NAME) return div.innerHTML = '<span style="color:#e53e3e">❌ Không thấy!</span>';
            div.innerHTML = `
                <div style="padding:15px; background:#f0fff4; border:1px solid #c6f6d5; border-radius:12px; display:flex; justify-content:space-between; align-items:center;">
                    <div><b>${emp.USER_NAME}</b> (${emp.EMPNO})<br/><small>${emp.DEPT_NAME}</small></div>
                    <button onclick="addUserHR('${emp.EMPNO}')" style="background:#48bb78; color:white; border:none; padding:8px 15px; border-radius:8px; cursor:pointer;">+ THÊM</button>
                </div>`;
        });
    }

    function addUserHR(empNo) {
        const type = document.getElementById('hrCompany').value;
        fetch('/QLtaiKhoan/ThemNhanVien', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ empNo, type })
        }).then(res => { if (res.ok) { loadUserList(); Swal.fire('Thành công', 'Đã thêm nhân viên', 'success'); } });
    }

    function syncAll(type) {
        Swal.fire({ title: 'Đang đồng bộ...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
        fetch(`/QLtaiKhoan/DongBoNhanVien?type=${type}`, { method: 'POST' }).then(res => res.json()).then(data => {
            loadUserList();
            Swal.fire('Hoàn tất', data.message, 'success');
        });
    }

    function addManual() {
        const data = {
            Tk: document.getElementById('add_Tk').value,
            HoTen: document.getElementById('add_HoTen').value,
            PhongBan: document.getElementById('add_PhongBan').value,
            VaiTro: document.getElementById('add_VaiTro').value
        };
        if (!data.Tk || !data.HoTen) return Swal.fire('Lỗi', 'Nhập Mã TK và Họ tên', 'error');
        fetch('/QLtaiKhoan/ThemThuCong', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(res => { if (res.ok) { loadUserList(); Swal.fire('Thành công', 'Đã lưu', 'success'); } });
    }
</script>