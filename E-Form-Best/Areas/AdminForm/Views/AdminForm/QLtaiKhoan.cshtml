@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 1200px; margin: 0 auto; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; padding: 20px;">
    <h1 style="text-align:center; color:#1a202c; margin-bottom:40px; font-weight: 800; font-size: 2.5rem; letter-spacing: -1px;">
        👤 Quản lý Tài Khoản
    </h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">

        <div style="background: #ffffff; padding: 25px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #edf2f7;">
            <label style="display: block; font-weight: 700; color: #4a5568; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase;">🔍 Đồng bộ từ hệ thống HR</label>
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <input type="text" id="empNoSearch" placeholder="Nhập mã EMPNO..."
                       style="flex: 1; padding: 12px 16px; border-radius: 10px; border: 1px solid #cbd5e0; font-size: 15px;" />
                <button onclick="searchFromHR()" style="padding: 12px 20px; border-radius: 10px; background: #4299e1; color: white; border: none; font-weight: 700; cursor: pointer;">TÌM</button>
            </div>
            <div id="searchResult" style="margin-bottom: 15px;"></div>
            <button onclick="syncAll()" style="width: 100%; padding: 12px; border-radius: 10px; background: #667eea; color: white; border: none; font-weight: 700; cursor: pointer;">
                🔄 ĐỒNG BỘ TOÀN BỘ NHÂN VIÊN MỚI
            </button>
        </div>

        <div style="background: #ffffff; padding: 25px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #edf2f7;">
            <label style="display: block; font-weight: 700; color: #4a5568; margin-bottom: 12px; font-size: 0.9rem; text-transform: uppercase;">➕ Thêm tài khoản thủ công</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <input type="text" id="add_Tk" placeholder="Mã TK (EMPNO)..." style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;" />
                <input type="text" id="add_HoTen" placeholder="Họ và tên..." style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;" />
                <input type="text" id="add_PhongBan" placeholder="Phòng ban..." style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;" />
                <select id="add_VaiTro" style="padding: 10px; border-radius: 8px; border: 1px solid #cbd5e0;">
                    <option value="NhanVien">Nhân Viên</option>
                    <option value="QuanLy">Quản Lý</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button onclick="addManual()" style="width: 100%; margin-top: 15px; padding: 12px; border-radius: 10px; background: #48bb78; color: white; border: none; font-weight: 700; cursor: pointer;">
                LƯU TÀI KHOẢN MỚI
            </button>
        </div>
    </div>

    <div style="background: white; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.05); overflow: hidden; border: 1px solid #edf2f7;">
        <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
            <thead>
                <tr style="background: #1a202c; color: #ffffff; text-align: left;">
                    <th style="padding: 18px 15px;">Nhân viên</th>
                    <th style="padding: 18px 15px;">Bảo mật & Liên hệ</th>
                    <th style="padding: 18px 15px;">Vai trò</th>
                    <th style="padding: 18px 15px;">Trạng thái</th>
                    <th style="padding: 18px 15px; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="userTableBody">
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', loadUserList);

    // 1. Load danh sách
    function loadUserList() {
        const tbody = document.getElementById('userTableBody');
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:20px;">Đang tải...</td></tr>';

        fetch('/QLtaiKhoan/GetAllUsers')
            .then(res => res.json())
            .then(data => {
                tbody.innerHTML = data.map(user => `
                    <tr id="row-${user.idNguoiDung}" style="border-bottom: 1px solid #edf2f7;">
                        <td style="padding: 15px;">
                            <div style="font-weight: 800; color: #2d3748;">#${user.idNguoiDung} - ${user.hoTen}</div>
                            <div style="font-size: 11px; color: #a0aec0;">Phòng: ${user.phongBan || 'N/A'}</div>
                        </td>
                        <td style="padding: 15px;">
                            <div style="font-weight: 600; color: #718096; font-size: 12px;">TK: ${user.tk}</div>
                            <input type="text" id="pass-${user.idNguoiDung}" value="${user.matKhau || ''}" placeholder="Mật khẩu" style="width: 45%; padding: 6px; border-radius: 6px; border: 1px solid #e2e8f0; margin-right: 5px;" />
                            <input type="text" id="phone-${user.idNguoiDung}" value="${user.soDienThoai || ''}" placeholder="SĐT" style="width: 45%; padding: 6px; border-radius: 6px; border: 1px solid #e2e8f0;" />
                        </td>
                        <td style="padding: 15px;">
                            <select id="role-${user.idNguoiDung}" style="width: 100%; padding: 8px; border-radius: 8px; border: 1px solid #e2e8f0;">
                                <option value="NhanVien" ${user.vaiTro === 'NhanVien' ? 'selected' : ''}>Nhân Viên</option>
                                <option value="QuanLy" ${user.vaiTro === 'QuanLy' ? 'selected' : ''}>Quản Lý</option>
                                <option value="Admin" ${user.vaiTro === 'Admin' ? 'selected' : ''}>Admin</option>
                            </select>
                        </td>
                        <td style="padding: 15px;">
                            <span style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; background: #e6fffa; color: #234e52;">
                                ${user.trangThai || 'Đang làm'}
                            </span>
                        </td>
                        <td style="padding: 15px; text-align: center;">
                            <button onclick="updateUser(${user.idNguoiDung})" style="padding: 6px 12px; border-radius: 6px; background: #38a169; color: white; border: none; cursor: pointer;">LƯU</button>
                            <button onclick="deleteUser(${user.idNguoiDung})" style="padding: 6px 12px; border-radius: 6px; background: #e53e3e; color: white; border: none; cursor: pointer;">XÓA</button>
                        </td>
                    </tr>
                `).join('');
            });
    }

    // 2. Thêm thủ công
    function addManual() {
        const data = {
            Tk: document.getElementById('add_Tk').value,
            HoTen: document.getElementById('add_HoTen').value,
            PhongBan: document.getElementById('add_PhongBan').value,
            VaiTro: document.getElementById('add_VaiTro').value
        };

        if(!data.Tk || !data.HoTen) return Swal.fire('Lỗi', 'Vui lòng nhập Mã TK và Họ tên', 'error');

        fetch('/QLtaiKhoan/ThemThuCong', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(res => {
            if(res.ok) {
                Swal.fire('Thành công', 'Đã thêm tài khoản', 'success');
                loadUserList();
                document.getElementById('add_Tk').value = '';
                document.getElementById('add_HoTen').value = '';
            } else res.text().then(text => Swal.fire('Lỗi', text, 'error'));
        });
    }

    // 3. Cập nhật
    function updateUser(id) {
        const data = {
            IdNguoiDung: id,
            MatKhau: document.getElementById(`pass-${id}`).value,
            SoDienThoai: document.getElementById(`phone-${id}`).value,
            VaiTro: document.getElementById(`role-${id}`).value
        };

        fetch('/QLtaiKhoan/CapNhatNguoiDung', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(res => {
            if(res.ok) Swal.fire('Thành công', 'Đã lưu thay đổi', 'success');
        });
    }

    // 4. Xóa
    function deleteUser(id) {
        Swal.fire({
            title: 'Xác nhận xóa?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e53e3e',
            confirmButtonText: 'Đúng, xóa nó!'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/QLtaiKhoan/XoaNguoiDung?id=' + id, { method: 'POST' })
                    .then(res => {
                        if(res.ok) {
                            document.getElementById(`row-${id}`).remove();
                            Swal.fire('Đã xóa!', '', 'success');
                        }
                    });
            }
        });
    }

    // 5. HR Sync
    function searchFromHR() {
        const empNo = document.getElementById('empNoSearch').value;
        const div = document.getElementById('searchResult');
        div.innerHTML = 'Đang tìm...';

        fetch('/QLtaiKhoan/GetNhanVien?empNo=' + empNo)
            .then(res => res.json())
            .then(emp => {
                if(!emp) return div.innerHTML = '<span style="color:red">Không thấy!</span>';
                div.innerHTML = `<div style="padding:10px; background:#f0fff4; border:1px solid #c6f6d5; border-radius:8px;">
                    <b>${emp.USER_NAME}</b> - ${emp.DEPT_NAME}
                    <button onclick="addUserHR('${emp.EMPNO}')" style="float:right; background:#48bb78; color:white; border:none; padding:4px 8px; border-radius:4px; cursor:pointer;">THÊM</button>
                </div>`;
            });
    }

    function addUserHR(empNo) {
        fetch('/QLtaiKhoan/ThemNhanVien', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ empNo: empNo })
        }).then(res => {
            if(res.ok) {
                loadUserList();
                Swal.fire('Thành công', 'Đã thêm từ HR', 'success');
                document.getElementById('searchResult').innerHTML = '';
            }
        });
    }

    function syncAll() {
        Swal.fire('Đang đồng bộ...', 'Vui lòng đợi giây lát', 'info');
        fetch('/QLtaiKhoan/DongBoNhanVien', { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                loadUserList();
                Swal.fire('Kết quả', data.message, 'success');
            });
    }
</script>