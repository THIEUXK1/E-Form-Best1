@{
    ViewData["Title"] = "Quản lý Người hỗ trợ SHD";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<div style="background-color: #f0f4f8; border-radius: 15px; padding: 20px;">
    <div style="display: flex; gap: 25px; flex-wrap: wrap; align-items: flex-start;">

        <!-- BẢN: NGƯỜI HỖ TRỢ SHD -->
        <div style="flex: 1; min-width: 450px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #cbd5e0;">
            <h3 style="margin-top: 0; color: #2c5282; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #e2e8f0; padding-bottom: 15px;">
                <span style="background: #ebf8ff; padding: 8px; border-radius: 10px;">👥</span> Quản lý Người Hỗ Trợ SHD
            </h3>

            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 10px; margin-bottom: 20px; background: #edf2f7; padding: 15px; border-radius: 10px;">
                <input type="hidden" id="txtIdSHD" value="0" />
                <input type="text" id="txtMaNvSHD" placeholder="Mã NV SHD" style="padding: 10px; border: 1px solid #a0aec0; border-radius: 6px; outline: none;" />
                <input type="text" id="txtTenSHD" placeholder="Họ tên nhân viên" style="padding: 10px; border: 1px solid #a0aec0; border-radius: 6px; outline: none;" />
                <input type="text" id="txtBoPhanSHD" placeholder="Bộ phận" style="padding: 10px; border: 1px solid #a0aec0; border-radius: 6px; outline: none;" />
                <input type="text" id="txtGhiChuSHD" placeholder="Ghi chú" style="padding: 10px; border: 1px solid #a0aec0; border-radius: 6px; outline: none;" />
                <button onclick="saveNHT_SHD()" id="btnSaveNHT_SHD" style="grid-column: span 2; background: linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%); color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600; transition: all 0.3s;">Lưu Nhân Viên SHD</button>
            </div>

            <div style="overflow-x: auto;">
                <table class="table table-hover" style="font-size: 13px;">
                    <thead class="table-light">
                        <tr style="color: #2c5282; text-transform: uppercase; font-size: 11px;">
                            <th>Mã NV</th>
                            <th>Tên</th>
                            <th>Bộ Phận</th>
                            <th style="text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="bodyNHT_SHD"></tbody>
                </table>
            </div>
        </div>

        <!-- BẢN: CÔNG VIỆC SHD -->
        <div style="flex: 1.2; min-width: 500px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;">
            <h3 style="margin-top: 0; color: #2d3748; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #edf2f7; padding-bottom: 15px;">
                <span style="background: #f0fdf4; padding: 8px; border-radius: 10px;">📝</span> Danh sách Công Việc SHD
            </h3>

            <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 10px;">
                <input type="hidden" id="txtCvIdSHD" value="0" />
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 10px;">
                    <input type="text" id="txtCvTenSHD" placeholder="Tên công việc SHD..." style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                    <select id="ddlNguoiHoTroSHD" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; background: white; cursor: pointer;"></select>
                </div>
                <button onclick="saveCV_SHD()" id="btnSaveCV_SHD" style="background: linear-gradient(135deg, #059669 0%, #047857 100%); color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ THÊM CÔNG VIỆC SHD</button>
            </div>

            <div style="overflow-x: auto;">
                <table class="table table-hover" style="font-size: 13px;">
                    <thead class="table-light">
                        <tr style="text-transform: uppercase; font-size: 11px;">
                            <th>Công Việc</th>
                            <th style="text-align: center;">Trạng Thái</th>
                            <th>Phụ Trách</th>
                            <th style="text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="bodyCV_SHD"></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadNHT_SHD();
            loadCV_SHD();
        });

        const btnStyleSua = "color: #3182ce; background: #ebf8ff; padding: 4px 10px; border-radius: 4px; text-decoration: none; font-weight: 600; margin-right: 5px;";
        const btnStyleXoa = "color: #e53e3e; background: #fff5f5; padding: 4px 10px; border-radius: 4px; text-decoration: none; font-weight: 600;";

        // --- PHẦN 1: XỬ LÝ NHÂN VIÊN SHD ---
        function loadNHT_SHD() {
            $.get('/QLtaiKhoan/GetAllNguoiHoTroSHD', function (data) {
                let html = data.map(i => `
                    <tr style="vertical-align: middle;">
                        <td style="font-weight: bold;">${i.maNv || ''}</td>
                        <td>${i.ten || ''}</td>
                        <td>${i.boPhan || ''}</td>
                        <td style="text-align: center; white-space: nowrap;">
                            <a href="javascript:void(0)" onclick='editNHT_SHD(${JSON.stringify(i)})' style="${btnStyleSua}">Sửa</a>
                            <a href="javascript:void(0)" onclick="deleteNHT_SHD(${i.id})" style="${btnStyleXoa}">Xóa</a>
                        </td>
                    </tr>`).join('');
                $('#bodyNHT_SHD').html(html);

                let opt = '<option value="">-- Chọn người làm --</option>';
                data.forEach(i => opt += `<option value="${i.id}">${i.ten}</option>`);
                $('#ddlNguoiHoTroSHD').html(opt);
            });
        }

        function saveNHT_SHD() {
            let id = $('#txtIdSHD').val();
            let data = {
                Id: id,
                MaNv: $('#txtMaNvSHD').val().trim(),
                Ten: $('#txtTenSHD').val().trim(),
                BoPhan: $('#txtBoPhanSHD').val().trim(),
                GhiChu: $('#txtGhiChuSHD').val().trim()
            };

            if (!data.MaNv || !data.Ten) {
                Swal.fire("Lỗi", "Vui lòng nhập Mã NV và Tên", "error");
                return;
            }

            $.post(id == "0" ? '/QLtaiKhoan/AddNguoiHoTroSHD' : '/QLtaiKhoan/UpdateNguoiHoTroSHD', data, function () {
                Swal.fire("Thành công", "Đã cập nhật danh sách nhân viên SHD", "success");
                resetNHT_SHD();
                loadNHT_SHD();
            });
        }

        function editNHT_SHD(i) {
            $('#txtIdSHD').val(i.id);
            $('#txtMaNvSHD').val(i.maNv);
            $('#txtTenSHD').val(i.ten);
            $('#txtBoPhanSHD').val(i.boPhan || "");
            $('#txtGhiChuSHD').val(i.ghiChu || "");
            $('#btnSaveNHT_SHD').text("Cập nhật SHD").css("background", "linear-gradient(135deg, #ecc94b 0%, #d69e2e 100%)");
        }

        function resetNHT_SHD() {
            $('#txtIdSHD').val("0");
            $('#txtMaNvSHD').val("");
            $('#txtTenSHD').val("");
            $('#txtBoPhanSHD').val("");
            $('#txtGhiChuSHD').val("");
            $('#btnSaveNHT_SHD').text("Lưu Nhân Viên SHD").css("background", "linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%)");
        }

        function deleteNHT_SHD(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Xóa nhân viên sẽ ảnh hưởng đến các công việc đang phụ trách!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Đồng ý'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLtaiKhoan/DeleteNguoiHoTroSHD?id=' + id, function () {
                        loadNHT_SHD();
                        Swal.fire('Đã xóa!', '', 'success');
                    });
                }
            });
        }

        // --- PHẦN 2: XỬ LÝ CÔNG VIỆC SHD ---
        function loadCV_SHD() {
            $.get('/QLtaiKhoan/GetAllCongViecSHD', function (data) {
                let html = data.map(i => {
                    const isShow = i.trangThai === "Hiển thị" || !i.trangThai;
                    const statusStyle = isShow
                        ? "background: #c6f6d5; color: #22543d; border: 1px solid #9ae6b4;"
                        : "background: #fed7d7; color: #822727; border: 1px solid #feb2b2;";

                    return `
                    <tr style="vertical-align: middle;">
                        <td style="font-weight: 500;">${i.ten}</td>
                        <td style="text-align: center;">
                            <span onclick="toggleStatusSHD(${i.id})" style="${statusStyle} padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: bold; cursor: pointer; user-select: none;">
                                ${isShow ? "Hiển thị" : "Ẩn"}
                            </span>
                        </td>
                        <td><span style="color: #2c5282; font-weight: 600;">${i.tenNguoiHoTroSHD || 'Chưa phân công'}</span></td>
                        <td style="text-align: center; white-space: nowrap;">
                            <a href="javascript:void(0)" onclick='editCV_SHD(${JSON.stringify(i)})' style="${btnStyleSua}">Sửa</a>
                            <a href="javascript:void(0)" onclick="deleteCV_SHD(${i.id})" style="${btnStyleXoa}">Xóa</a>
                        </td>
                    </tr>`;
                }).join('');
                $('#bodyCV_SHD').html(html);
            });
        }

        function saveCV_SHD() {
            let id = $('#txtCvIdSHD').val();
            let selectedHrId = $('#ddlNguoiHoTroSHD').val();
            
            let data = {
                Id: id,
                Ten: $('#txtCvTenSHD').val().trim(),
                IdShdNguoiHoTro: selectedHrId === "" ? null : selectedHrId
            };

            if (!data.Ten) {
                Swal.fire("Thông báo", "Vui lòng nhập tên công việc", "info");
                return;
            }

            $.post(id == "0" ? '/QLtaiKhoan/AddCongViecSHD' : '/QLtaiKhoan/UpdateCongViecSHD', data, function () {
                Swal.fire("Thành công", "Đã lưu công việc SHD", "success");
                resetCV_SHD();
                loadCV_SHD();
            }).fail(function() {
                Swal.fire("Lỗi", "Không thể lưu công việc. Vui lòng kiểm tra lại.", "error");
            });
        }

        function editCV_SHD(i) {
            $('#txtCvIdSHD').val(i.id);
            $('#txtCvTenSHD').val(i.ten);
            $('#ddlNguoiHoTroSHD').val(i.idShdNguoiHoTro || "");
            $('#btnSaveCV_SHD').text("Cập Nhật Công Việc").css("background", "linear-gradient(135deg, #ecc94b 0%, #d69e2e 100%)");
        }

        function resetCV_SHD() {
            $('#txtCvIdSHD').val("0");
            $('#txtCvTenSHD').val("");
            $('#ddlNguoiHoTroSHD').val("");
            $('#btnSaveCV_SHD').text("+ THÊM CÔNG VIỆC SHD").css("background", "linear-gradient(135deg, #059669 0%, #047857 100%)");
        }

        function toggleStatusSHD(id) {
            $.post('/QLtaiKhoan/UpdateStatusCVSHD?id=' + id, function (res) {
                if (res.success) loadCV_SHD();
            });
        }

        function deleteCV_SHD(id) {
            Swal.fire({
                title: 'Xóa công việc?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Đồng ý'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLtaiKhoan/DeleteCongViecSHD?id=' + id, function () {
                        loadCV_SHD();
                    });
                }
            });
        }
    </script>
}