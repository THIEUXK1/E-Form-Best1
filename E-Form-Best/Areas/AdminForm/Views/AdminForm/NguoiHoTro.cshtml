@{
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<div style="padding: 30px; background-color: #f7fafc; min-height: 100vh; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <div style="display: flex; gap: 25px; flex-wrap: wrap; align-items: flex-start;">

        <div style="flex: 1; min-width: 500px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;">
            <h3 style="margin-top: 0; color: #2d3748; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #edf2f7; padding-bottom: 15px;">
                <span style="background: #ebf8ff; padding: 8px; border-radius: 10px;">👤</span> Quản lý Người Hỗ Trợ
            </h3>

            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 10px; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 10px;">
                <input type="hidden" id="txtId" value="0" />
                <input type="text" id="txtMaNv" placeholder="Mã NV" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                <input type="text" id="txtTen" placeholder="Họ tên nhân viên" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                <input type="text" id="txtBoPhan" placeholder="Bộ phận" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                <input type="text" id="txtGhiChu" placeholder="Ghi chú" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                <button onclick="saveNHT()" id="btnSaveNHT" style="grid-column: span 2; background: linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%); color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600; transition: all 0.3s;">Lưu Nhân Viên</button>
            </div>

            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr style="background-color: #f1f5f9; color: #4a5568; text-transform: uppercase; font-size: 11px; letter-spacing: 0.05em;">
                            <th style="padding: 12px 10px;">Mã NV</th>
                            <th style="padding: 12px 10px;">Tên</th>
                            <th style="padding: 12px 10px;">Bộ Phận</th>
                            <th style="padding: 12px 10px;">Ghi Chú</th>
                            <th style="padding: 12px 10px; text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="bodyNHT" style="color: #4a5568; font-size: 13px;"></tbody>
                </table>
            </div>
        </div>

        <div style="flex: 1; min-width: 500px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;">
            <h3 style="margin-top: 0; color: #2d3748; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #edf2f7; padding-bottom: 15px;">
                <span style="background: #f0fff4; padding: 8px; border-radius: 10px;">📋</span> Danh sách Công Việc
            </h3>

            <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 10px;">
                <input type="hidden" id="txtCvId" value="0" />
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 10px;">
                    <input type="text" id="txtCvTen" placeholder="Tên công việc mới..." style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                    <select id="ddlNguoiHoTro" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; background: white; cursor: pointer;"></select>
                </div>
                <button onclick="saveCV()" id="btnSaveCV" style="background: linear-gradient(135deg, #38a169 0%, #2f855a 100%); color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ THÊM CÔNG VIỆC</button>
            </div>

            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr style="background-color: #f1f5f9; color: #4a5568; text-transform: uppercase; font-size: 11px; letter-spacing: 0.05em;">
                            <th style="padding: 12px 10px;">Tên Công Việc</th>
                            <th style="padding: 12px 10px; text-align: center;">Trạng Thái</th>
                            <th style="padding: 12px 10px;">Người Phụ Trách</th>
                            <th style="padding: 12px 10px; text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="bodyCV" style="color: #4a5568; font-size: 13px;"></tbody>
                </table>
            </div>
            <p style="font-size: 11px; color: #a0aec0; margin-top: 10px;">* Click vào nhãn Trạng thái để thay đổi nhanh Ẩn/Hiện.</p>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => { loadNHT(); loadCV(); });

    const btnStyleSua = "color: #3182ce; background: #ebf8ff; padding: 4px 10px; border-radius: 4px; text-decoration: none; font-weight: 600; margin-right: 5px;";
    const btnStyleXoa = "color: #e53e3e; background: #fff5f5; padding: 4px 10px; border-radius: 4px; text-decoration: none; font-weight: 600;";

    // --- NGƯỜI HỖ TRỢ ---
    function loadNHT() {
        fetch('/QLtaiKhoan/GetAllNguoiHoTro').then(r => r.json()).then(data => {
            document.getElementById('bodyNHT').innerHTML = data.map(i => `
                <tr style="border-bottom: 1px solid #edf2f7;">
                    <td style="padding: 12px 10px; font-weight: bold;">${i.maNv || ''}</td>
                    <td style="padding: 12px 10px;">${i.ten || ''}</td>
                    <td style="padding: 12px 10px;">${i.boPhan || ''}</td>
                    <td style="padding: 12px 10px; font-size: 12px; color: #718096;">${i.ghiChu || ''}</td>
                    <td style="padding: 12px 10px; text-align: center; white-space: nowrap;">
                        <a href="javascript:void(0)" onclick='editNHT(${JSON.stringify(i)})' style="${btnStyleSua}">Sửa</a>
                        <a href="javascript:void(0)" onclick="deleteNHT(${i.id})" style="${btnStyleXoa}">Xóa</a>
                    </td>
                </tr>`).join('');

            let opt = '<option value="">-- Chọn người làm --</option>';
            data.forEach(i => opt += `<option value="${i.id}">${i.ten}</option>`);
            document.getElementById('ddlNguoiHoTro').innerHTML = opt;
        });
    }

    function saveNHT() {
        let id = document.getElementById('txtId').value;
        let data = {
            Id: id,
            MaNv: document.getElementById('txtMaNv').value,
            Ten: document.getElementById('txtTen').value,
            BoPhan: document.getElementById('txtBoPhan').value,
            GhiChu: document.getElementById('txtGhiChu').value
        };
        fetch(id == "0" ? '/QLtaiKhoan/AddNguoiHoTro' : '/QLtaiKhoan/UpdateNguoiHoTro', {
            method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(() => { resetNHT(); loadNHT(); });
    }

    function editNHT(i) {
        document.getElementById('txtId').value = i.id;
        document.getElementById('txtMaNv').value = i.maNv;
        document.getElementById('txtTen').value = i.ten;
        document.getElementById('txtBoPhan').value = i.boPhan || "";
        document.getElementById('txtGhiChu').value = i.ghiChu || "";
        document.getElementById('btnSaveNHT').innerText = "Cập nhật";
        document.getElementById('btnSaveNHT').style.background = "linear-gradient(135deg, #ecc94b 0%, #d69e2e 100%)";
    }

    function resetNHT() {
        document.getElementById('txtId').value = "0";
        document.getElementById('txtMaNv').value = "";
        document.getElementById('txtTen').value = "";
        document.getElementById('txtBoPhan').value = "";
        document.getElementById('txtGhiChu').value = "";
        document.getElementById('btnSaveNHT').innerText = "Lưu";
        document.getElementById('btnSaveNHT').style.background = "linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%)";
    }

    function deleteNHT(id) { if(confirm("Xóa nhân viên này?")) fetch('/QLtaiKhoan/DeleteNguoiHoTro?id='+id, {method:'POST'}).then(() => loadNHT()); }

    // --- CÔNG VIỆC ---
    function loadCV() {
        fetch('/QLtaiKhoan/GetAllCongViec').then(r => r.json()).then(data => {
            document.getElementById('bodyCV').innerHTML = data.map(i => {
                // Style cho trạng thái: Xanh nếu Hiển thị, Đỏ nếu Ẩn
                const isShow = i.trangThai === "Hiển thị" || !i.trangThai;
                const statusStyle = isShow
                    ? "background: #c6f6d5; color: #22543d; border: 1px solid #9ae6b4;"
                    : "background: #fed7d7; color: #822727; border: 1px solid #feb2b2;";

                return `
                <tr style="border-bottom: 1px solid #edf2f7;">
                    <td style="padding: 12px 10px; font-weight: 500;">${i.ten}</td>
                    <td style="padding: 12px 10px; text-align: center;">
                        <span onclick="toggleStatus(${i.id})" style="${statusStyle} padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: bold; cursor: pointer; user-select: none;">
                            ${isShow ? "Hiển thị" : "Ẩn"}
                        </span>
                    </td>
                    <td style="padding: 12px 10px;"><span style="color: #2f855a; font-weight: 600;">${i.tenNguoiHoTro}</span></td>
                    <td style="padding: 12px 10px; text-align: center; white-space: nowrap;">
                        <a href="javascript:void(0)" onclick='editCV(${JSON.stringify(i)})' style="${btnStyleSua}">Sửa</a>
                        <a href="javascript:void(0)" onclick="deleteCV(${i.id})" style="${btnStyleXoa}">Xóa</a>
                    </td>
                </tr>`;
            }).join('');
        });
    }

    // Hàm đổi trạng thái nhanh
    function toggleStatus(id) {
        fetch('/QLtaiKhoan/UpdateStatusCV?id=' + id, { method: 'POST' })
            .then(r => r.json())
            .then(res => { if(res.success) loadCV(); });
    }

    function saveCV() {
        let id = document.getElementById('txtCvId').value;
        let data = {
            Id: id,
            Ten: document.getElementById('txtCvTen').value,
            IdItNguoiHoTro: document.getElementById('ddlNguoiHoTro').value
            // Không gửi TrangThai, Backend tự xử lý mặc định hoặc giữ nguyên
        };
        if(!data.Ten) return alert("Vui lòng nhập tên công việc");
        fetch(id == "0" ? '/QLtaiKhoan/AddCongViec' : '/QLtaiKhoan/UpdateCongViec', {
            method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        }).then(() => { resetCV(); loadCV(); });
    }

    function editCV(i) {
        document.getElementById('txtCvId').value = i.id;
        document.getElementById('txtCvTen').value = i.ten;
        document.getElementById('ddlNguoiHoTro').value = i.idItNguoiHoTro || "";
        document.getElementById('btnSaveCV').innerText = "Cập Nhật Công Việc";
        document.getElementById('btnSaveCV').style.background = "linear-gradient(135deg, #ecc94b 0%, #d69e2e 100%)";
    }

    function resetCV() {
        document.getElementById('txtCvId').value = "0";
        document.getElementById('txtCvTen').value = "";
        document.getElementById('btnSaveCV').innerText = "+ THÊM CÔNG VIỆC";
        document.getElementById('btnSaveCV').style.background = "linear-gradient(135deg, #38a169 0%, #2f855a 100%)";
    }

    function deleteCV(id) { if(confirm("Xóa công việc này?")) fetch('/QLtaiKhoan/DeleteCongViec?id='+id, {method:'POST'}).then(() => loadCV()); }
</script>