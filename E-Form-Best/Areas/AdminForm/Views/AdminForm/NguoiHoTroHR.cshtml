@{
    ViewData["Title"] = "Quản lý Người hỗ trợ HR";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<div style="background-color: #fdf2f8; border-radius: 15px; padding: 20px;">
    <div style="display: flex; gap: 25px; flex-wrap: wrap; align-items: flex-start;">

        <div style="flex: 1; min-width: 450px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #fbcfe8;">
            <h3 style="margin-top: 0; color: #9d174d; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #fce7f3; padding-bottom: 15px;">
                <span style="background: #fdf2f8; padding: 8px; border-radius: 10px;">👥</span> Quản lý Người Hỗ Trợ HR
            </h3>

            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 10px; margin-bottom: 20px; background: #fff1f2; padding: 15px; border-radius: 10px;">
                <input type="hidden" id="txtIdHR" value="0" />
                <input type="text" id="txtMaNvHR" placeholder="Mã NV HR" style="padding: 10px; border: 1px solid #f9a8d4; border-radius: 6px; outline: none;" />
                <input type="text" id="txtTenHR" placeholder="Họ tên nhân viên" style="padding: 10px; border: 1px solid #f9a8d4; border-radius: 6px; outline: none;" />
                <input type="text" id="txtBoPhanHR" placeholder="Bộ phận" style="padding: 10px; border: 1px solid #f9a8d4; border-radius: 6px; outline: none;" />
                <input type="text" id="txtGhiChuHR" placeholder="Ghi chú" style="padding: 10px; border: 1px solid #f9a8d4; border-radius: 6px; outline: none;" />
                <button onclick="saveNHT_HR()" id="btnSaveNHT_HR" style="grid-column: span 2; background: linear-gradient(135deg, #db2777 0%, #be185d 100%); color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600; transition: all 0.3s;">Lưu Nhân Viên HR</button>
            </div>

            <div style="overflow-x: auto;">
                <table class="table table-hover" style="font-size: 13px;">
                    <thead class="table-light">
                        <tr style="color: #9d174d; text-transform: uppercase; font-size: 11px;">
                            <th>Mã NV</th>
                            <th>Tên</th>
                            <th>Bộ Phận</th>
                            <th style="text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="bodyNHT_HR"></tbody>
                </table>
            </div>
        </div>

        <div style="flex: 1.2; min-width: 500px; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #e2e8f0;">
            <h3 style="margin-top: 0; color: #2d3748; display: flex; align-items: center; gap: 10px; border-bottom: 2px solid #edf2f7; padding-bottom: 15px;">
                <span style="background: #f0fdf4; padding: 8px; border-radius: 10px;">📝</span> Danh sách Công Việc HR
            </h3>

            <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 10px;">
                <input type="hidden" id="txtCvIdHR" value="0" />
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 10px;">
                    <input type="text" id="txtCvTenHR" placeholder="Tên công việc HR..." style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; outline: none;" />
                    <select id="ddlNguoiHoTroHR" style="padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; background: white; cursor: pointer;"></select>
                </div>
                <button onclick="saveCV_HR()" id="btnSaveCV_HR" style="background: linear-gradient(135deg, #059669 0%, #047857 100%); color: white; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: 600;">+ THÊM CÔNG VIỆC HR</button>
            </div>

            <div style="overflow-x: auto;">
                <table class="table table-hover" style="font-size: 13px;">
                    <thead class="table-light">
                        <tr style="text-transform: uppercase; font-size: 11px;">
                            <th>Công Việc</th>
                            <th style="text-align: center;">Trạng Thái</th>
                            <th>Phụ Trách</th>
                            <th style="text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="bodyCV_HR"></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadNHT_HR();
            loadCV_HR();
        });

        const btnStyleSua = "color: #3182ce; background: #ebf8ff; padding: 4px 10px; border-radius: 4px; text-decoration: none; font-weight: 600; margin-right: 5px;";
        const btnStyleXoa = "color: #e53e3e; background: #fff5f5; padding: 4px 10px; border-radius: 4px; text-decoration: none; font-weight: 600;";

        // --- PHẦN 1: XỬ LÝ NHÂN VIÊN HR ---
        function loadNHT_HR() {
            $.get('/QLtaiKhoan/GetAllNguoiHoTroHR', function (data) {
                let html = data.map(i => `
                    <tr style="vertical-align: middle;">
                        <td style="font-weight: bold;">${i.maNv || ''}</td>
                        <td>${i.ten || ''}</td>
                        <td>${i.boPhan || ''}</td>
                        <td style="text-align: center; white-space: nowrap;">
                            <a href="javascript:void(0)" onclick='editNHT_HR(${JSON.stringify(i)})' style="${btnStyleSua}">Sửa</a>
                            <a href="javascript:void(0)" onclick="deleteNHT_HR(${i.id})" style="${btnStyleXoa}">Xóa</a>
                        </td>
                    </tr>`).join('');
                $('#bodyNHT_HR').html(html);

                let opt = '<option value="">-- Chọn người làm --</option>';
                data.forEach(i => opt += `<option value="${i.id}">${i.ten}</option>`);
                $('#ddlNguoiHoTroHR').html(opt);
            });
        }

        function saveNHT_HR() {
            let id = $('#txtIdHR').val();
            let data = {
                Id: id,
                MaNv: $('#txtMaNvHR').val().trim(),
                Ten: $('#txtTenHR').val().trim(),
                BoPhan: $('#txtBoPhanHR').val().trim(),
                GhiChu: $('#txtGhiChuHR').val().trim()
            };

            if (!data.MaNv || !data.Ten) {
                Swal.fire("Lỗi", "Vui lòng nhập Mã NV và Tên", "error");
                return;
            }

            $.post(id == "0" ? '/QLtaiKhoan/AddNguoiHoTroHR' : '/QLtaiKhoan/UpdateNguoiHoTroHR', data, function () {
                Swal.fire("Thành công", "Đã cập nhật danh sách nhân viên", "success");
                resetNHT_HR();
                loadNHT_HR();
            });
        }

        function editNHT_HR(i) {
            $('#txtIdHR').val(i.id);
            $('#txtMaNvHR').val(i.maNv);
            $('#txtTenHR').val(i.ten);
            $('#txtBoPhanHR').val(i.boPhan || "");
            $('#txtGhiChuHR').val(i.ghiChu || "");
            $('#btnSaveNHT_HR').text("Cập nhật HR").css("background", "linear-gradient(135deg, #ecc94b 0%, #d69e2e 100%)");
        }

        function resetNHT_HR() {
            $('#txtIdHR').val("0");
            $('#txtMaNvHR').val("");
            $('#txtTenHR').val("");
            $('#txtBoPhanHR').val("");
            $('#txtGhiChuHR').val("");
            $('#btnSaveNHT_HR').text("Lưu Nhân Viên HR").css("background", "linear-gradient(135deg, #db2777 0%, #be185d 100%)");
        }

        function deleteNHT_HR(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Xóa nhân viên sẽ ảnh hưởng đến các công việc đang phụ trách!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Đồng ý'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLtaiKhoan/DeleteNguoiHoTroHR?id=' + id, function () {
                        loadNHT_HR();
                        Swal.fire('Đã xóa!', '', 'success');
                    });
                }
            });
        }

        // --- PHẦN 2: XỬ LÝ CÔNG VIỆC HR ---
        function loadCV_HR() {
            $.get('/QLtaiKhoan/GetAllCongViecHR', function (data) {
                let html = data.map(i => {
                    const isShow = i.trangThai === "Hiển thị" || !i.trangThai;
                    const statusStyle = isShow
                        ? "background: #c6f6d5; color: #22543d; border: 1px solid #9ae6b4;"
                        : "background: #fed7d7; color: #822727; border: 1px solid #feb2b2;";

                    return `
                    <tr style="vertical-align: middle;">
                        <td style="font-weight: 500;">${i.ten}</td>
                        <td style="text-align: center;">
                            <span onclick="toggleStatusHR(${i.id})" style="${statusStyle} padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: bold; cursor: pointer; user-select: none;">
                                ${isShow ? "Hiển thị" : "Ẩn"}
                            </span>
                        </td>
                        <td><span style="color: #047857; font-weight: 600;">${i.tenNguoiHoTroHR || 'Chưa phân công'}</span></td>
                        <td style="text-align: center; white-space: nowrap;">
                            <a href="javascript:void(0)" onclick='editCV_HR(${JSON.stringify(i)})' style="${btnStyleSua}">Sửa</a>
                            <a href="javascript:void(0)" onclick="deleteCV_HR(${i.id})" style="${btnStyleXoa}">Xóa</a>
                        </td>
                    </tr>`;
                }).join('');
                $('#bodyCV_HR').html(html);
            });
        }

        function saveCV_HR() {
            let id = $('#txtCvIdHR').val();
            let selectedHrId = $('#ddlNguoiHoTroHR').val();
            
            let data = {
                Id: id,
                Ten: $('#txtCvTenHR').val().trim(),
                IdHrNguoiHoTro: selectedHrId === "" ? null : selectedHrId
            };

            if (!data.Ten) {
                Swal.fire("Thông báo", "Vui lòng nhập tên công việc", "info");
                return;
            }

            $.post(id == "0" ? '/QLtaiKhoan/AddCongViecHR' : '/QLtaiKhoan/UpdateCongViecHR', data, function () {
                Swal.fire("Thành công", "Đã lưu công việc", "success");
                resetCV_HR();
                loadCV_HR();
            }).fail(function() {
                Swal.fire("Lỗi", "Không thể lưu công việc. Vui lòng kiểm tra lại.", "error");
            });
        }

        function editCV_HR(i) {
            $('#txtCvIdHR').val(i.id);
            $('#txtCvTenHR').val(i.ten);
            $('#ddlNguoiHoTroHR').val(i.idHrNguoiHoTro || "");
            $('#btnSaveCV_HR').text("Cập Nhật Công Việc").css("background", "linear-gradient(135deg, #ecc94b 0%, #d69e2e 100%)");
        }

        function resetCV_HR() {
            $('#txtCvIdHR').val("0");
            $('#txtCvTenHR').val("");
            $('#ddlNguoiHoTroHR').val("");
            $('#btnSaveCV_HR').text("+ THÊM CÔNG VIỆC HR").css("background", "linear-gradient(135deg, #059669 0%, #047857 100%)");
        }

        function toggleStatusHR(id) {
            $.post('/QLtaiKhoan/UpdateStatusCVHR?id=' + id, function (res) {
                if (res.success) loadCV_HR();
            });
        }

        function deleteCV_HR(id) {
            Swal.fire({
                title: 'Xóa công việc?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Đồng ý'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLtaiKhoan/DeleteCongViecHR?id=' + id, function () {
                        loadCV_HR();
                    });
                }
            });
        }
    </script>
}