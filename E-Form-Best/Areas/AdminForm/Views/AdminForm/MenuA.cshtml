@using System.Security.Claims
@{
    ViewData["Title"] = "MenuA";
    
    // Logic lấy chữ cái đầu tiên của tên người dùng để làm ảnh đại diện thay thế (Fallback)
    string userInitial = "";
    if (User.Identity.IsAuthenticated && !string.IsNullOrEmpty(User.Identity.Name))
    {
        userInitial = User.Identity.Name.Substring(0, 1).ToUpper();
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>E-Form - @ViewData["Title"]</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📑</text></svg>">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
            /* Sử dụng @@ để thoát lỗi Razor */
            @@keyframes spin {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }

            /* CSS hiệu ứng nhấp nháy cho chấm đỏ thông báo */
            @@keyframes pulseDot {
                0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
                70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
                100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
            }

            /* ==========================================
               MOBILE RESPONSIVE
               ========================================== */
            @@media (max-width: 768px) {
                .top-left-info {
                    top: 15px !important;
                    left: 15px !important;
                }
                .top-left-info .user-name-text, .top-left-info .btn-text {
                    display: none !important; 
                }
                
                .top-right-btn {
                    top: 15px !important;
                    right: 15px !important;
                }
                .top-right-btn button {
                    padding: 8px 15px !important;
                }
                .top-right-btn .guide-text {
                    display: none !important; 
                }
                #guideMenu {
                    width: 240px !important;
                }

                .main-title {
                    font-size: 2rem !important; 
                    letter-spacing: 4px !important;
                    margin-top: 60px !important; 
                }

                .cards-container {
                    gap: 20px !important;
                }

                .menu-card {
                    width: 145px !important;
                    height: 145px !important;
                    border-radius: 20px !important;
                }
                .menu-card .icon-emoji {
                    font-size: 35px !important;
                }
                .menu-card span {
                    font-size: 22px !important;
                }
                .menu-card small {
                    font-size: 9px !important;
                }
                
                .footer-text {
                    margin-top: 40px !important;
                    font-size: 11px !important;
                }
            }
    </style>
</head>
<body style="margin: 0; padding: 0;">
    <div style="
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at center, #001f3f, #003366, #000c18);
        background-attachment: fixed;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        padding: 20px;
        position: relative;
        box-sizing: border-box;">

        <!-- GÓC TRÊN BÊN TRÁI: ĐĂNG NHẬP / THÔNG TIN NGƯỜI DÙNG -->
        <div class="top-left-info" style="position: absolute; top: 30px; left: 30px; z-index: 1000; display: flex; align-items: center; gap: 10px;">
            @if (User.Identity.IsAuthenticated)
            {
                <div style="display: flex; align-items: center; gap: 10px; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); padding: 5px 15px; border-radius: 50px; border: 1px solid rgba(0, 212, 255, 0.2);">
                    
                    @* XỬ LÝ HIỂN THỊ ẢNH ĐẠI DIỆN - SỬA LẠI THEO LOGIC TRANG HỒ SƠ *@
                    @{
                        // [FIX] Ưu tiên lấy từ ViewBag (ảnh mới nhất), sau đó mới lấy từ Claim
                        var avatarPath = ViewBag.AnhDaiDien as string ?? User.FindFirst("AnhDaiDien")?.Value;
                        if (!string.IsNullOrEmpty(avatarPath))
                        {
                            <img src="/DonXetDuyet/GetAvatar?path=@Uri.EscapeDataString(avatarPath)" 
                                 onerror="this.style.display='none'; document.getElementById('initial-avatar').style.display='flex';"
                                 style="width: 32px; height: 32px; border-radius: 50%; border: 2px solid #00d4ff; object-fit: cover;" />
                            
                            <div id="initial-avatar" style="display: none; width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #00d4ff, #004e92); border: 2px solid #00d4ff; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px;">
                                @userInitial
                            </div>
                        }
                        else
                        {
                            <div style="width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #00d4ff, #004e92); border: 2px solid #00d4ff; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px; text-shadow: 0 0 5px rgba(0,0,0,0.5);">
                                @userInitial
                            </div>
                        }
                    }

                    <span class="user-name-text" style="color: white; font-weight: 600; font-size: 14px;">@User.Identity.Name</span>
                    
                    <a href="/ThongTinTaiKhoan" title="Thông tin & Bảo mật"
                       style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; background: rgba(0, 212, 255, 0.2); border-radius: 50%; color: #00d4ff; text-decoration: none; transition: 0.3s;"
                       onmouseover="this.style.background='rgba(0, 212, 255, 0.4)'"
                       onmouseout="this.style.background='rgba(0, 212, 255, 0.2)'">
                        <i class="fa fa-shield"></i>
                    </a>
                </div>
            }
            else
            {
                <a href="/DonXetDuyet/DangNhap" 
                   style="display: flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 50px; background: rgba(0, 212, 255, 0.15); backdrop-filter: blur(10px); border: 1px solid rgba(0, 212, 255, 0.4); color: #00d4ff; text-decoration: none; font-size: 14px; font-weight: 700; transition: all 0.3s ease;"
                   onmouseover="this.style.background='rgba(0, 212, 255, 0.3)'; this.style.transform='translateY(-2px)'"
                   onmouseout="this.style.background='rgba(0, 212, 255, 0.15)'; this.style.transform='translateY(0)'">
                    <i class="fa fa-sign-in"></i> <span class="btn-text">Đăng nhập</span>
                </a>
            }
        </div>

        @* Hướng dẫn sử dụng - GÓC TRÊN BÊN PHẢI *@
        <div class="top-right-btn" style="position: absolute; top: 30px; right: 30px; z-index: 1000; display: flex; flex-direction: column; align-items: flex-end; gap: 10px;">
            <button onclick="toggleGuideMenu(event)"
                    id="btnGuide"
                    style="display: flex; align-items: center; gap: 12px; padding: 12px 20px; border-radius: 50px; background: rgba(0, 212, 255, 0.15); backdrop-filter: blur(10px); border: 1px solid rgba(0, 212, 255, 0.4); color: #00d4ff; font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.3s ease;"
                    onmouseover="this.style.background='rgba(0, 212, 255, 0.3)'; this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.background='rgba(0, 212, 255, 0.15)'; this.style.transform='translateY(0)'">
                <span class="guide-text">Hướng dẫn sử dụng</span>
                <span style="font-size: 20px;">📚</span>
            </button>

            <div id="guideMenu"
                 style="display: none; position: absolute; top: 65px; right: 0; width: 280px; background: rgba(0, 12, 24, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(0, 212, 255, 0.3); border-radius: 15px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.6);">
                <div style="padding: 15px; background: rgba(0, 212, 255, 0.2); color: #00d4ff; font-weight: bold; border-bottom: 1px solid rgba(0, 212, 255, 0.3); font-size: 13px;">
                    DANH SÁCH HƯỚNG DẪN
                </div>
                <ul style="list-style: none; padding: 0; margin: 0;">
                    <li style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <a href="~/HuongDanIT/Hướng dẫn user sử dụng hệ thông E-Form IT.pdf" download
                           style="display: flex; align-items: center; gap: 10px; padding: 15px; color: white; text-decoration: none; font-size: 14px; transition: background 0.3s;"
                           onmouseover="this.style.background='rgba(0, 212, 255, 0.1)'"
                           onmouseout="this.style.background='transparent'">
                            <span>📄</span> HDSD IT E-Form
                        </a>
                    </li>
                    <li style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <a href="~/HuongDanIT/Hướng dẫn user sử dụng hệ thông E-Form HR.pdf" download
                           style="display: flex; align-items: center; gap: 10px; padding: 15px; color: white; text-decoration: none; font-size: 14px; transition: background 0.3s;"
                           onmouseover="this.style.background='rgba(0, 212, 255, 0.1)'"
                           onmouseout="this.style.background='transparent'">
                            <span>📄</span> HDSD HR E-Form
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div style="text-align: center; margin-bottom: 60px;">
            <h1 class="main-title" style="color: #00d4ff; font-size: 3.5rem; font-weight: 900; letter-spacing: 10px; margin: 0; text-shadow: 0 0 20px rgba(0, 212, 255, 0.5); text-transform: uppercase;">
                SYSTEM MENU
            </h1>
            <div style="width: 100px; height: 4px; background: #00d4ff; margin: 15px auto; border-radius: 2px; opacity: 0.6;"></div>
        </div>

        <div class="cards-container" style="display: flex; gap: 40px; flex-wrap: wrap; justify-content: center;">
            @* Khối IT *@
            <a href="/Logo" class="menu-card"
               style="width: 220px; height: 220px; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border-radius: 30px; border: 1px solid rgba(0, 212, 255, 0.2); color: white; text-decoration: none; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative;"
                   onmouseover="this.style.transform='translateY(-15px)'; this.style.boxShadow='0 20px 40px rgba(0, 212, 255, 0.4)'; this.style.background='rgba(0, 212, 255, 0.15)';"
                   onmouseout="this.style.transform='translateY(0)'; this.style.background='rgba(255, 255, 255, 0.05)';">
                <div id="badge-it" style="display: none; position: absolute; top: 15px; right: 15px; width: 16px; height: 16px; background-color: #ef4444; border-radius: 50%; box-shadow: 0 0 8px rgba(239,68,68,0.8); animation: pulseDot 1.5s infinite;"></div>
                <div class="icon-emoji" style="font-size: 50px; margin-bottom: 10px;">💻</div>
                <span style="font-size: 28px; font-weight: 800; letter-spacing: 2px;">IT</span>
                <small style="font-size: 11px; opacity: 0.7; margin-top: 5px; text-transform: uppercase;">Technology</small>
            </a>

            @* Khối HR *@
            <a href="/HRForm/logo" class="menu-card"
               style="width: 220px; height: 220px; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border-radius: 30px; border: 1px solid rgba(0, 212, 255, 0.2); color: white; text-decoration: none; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative;"
                   onmouseover="this.style.transform='translateY(-15px)'; this.style.boxShadow='0 20px 40px rgba(0, 212, 255, 0.4)'; this.style.background='rgba(0, 212, 255, 0.15)';"
                   onmouseout="this.style.transform='translateY(0)'; this.style.background='rgba(255, 255, 255, 0.05)';">
                <div id="badge-hr" style="display: none; position: absolute; top: 15px; right: 15px; width: 16px; height: 16px; background-color: #ef4444; border-radius: 50%; box-shadow: 0 0 8px rgba(239,68,68,0.8); animation: pulseDot 1.5s infinite;"></div>
                <div class="icon-emoji" style="font-size: 50px; margin-bottom: 10px;">🤝</div>
                <span style="font-size: 28px; font-weight: 800; letter-spacing: 2px;">HR</span>
                <small style="font-size: 11px; opacity: 0.7; margin-top: 5px; text-transform: uppercase;">Human Resource</small>
            </a>

            @* Khối SHD *@
            <a href="/SHDForm/logo" class="menu-card"
               style="width: 220px; height: 220px; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border-radius: 30px; border: 1px solid rgba(0, 212, 255, 0.2); color: white; text-decoration: none; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative;"
                   onmouseover="this.style.transform='translateY(-15px)'; this.style.boxShadow='0 20px 40px rgba(0, 212, 255, 0.4)'; this.style.background='rgba(0, 212, 255, 0.15)';"
                   onmouseout="this.style.transform='translateY(0)'; this.style.background='rgba(255, 255, 255, 0.05)';">
                <div id="badge-shd" style="display: none; position: absolute; top: 15px; right: 15px; width: 16px; height: 16px; background-color: #ef4444; border-radius: 50%; box-shadow: 0 0 8px rgba(239,68,68,0.8); animation: pulseDot 1.5s infinite;"></div>
                <div class="icon-emoji" style="font-size: 50px; margin-bottom: 10px;">📦</div>
                <span style="font-size: 28px; font-weight: 800; letter-spacing: 2px;">SHD</span>
                <small style="font-size: 11px; opacity: 0.7; margin-top: 5px; text-transform: uppercase;">Import Export</small>
            </a>
        </div>

        <p class="footer-text" style="margin-top: 80px; color: #00d4ff; opacity: 0.5; font-size: 13px; letter-spacing: 1px; text-align: center;">
            © @DateTime.Now.Year E-PORTAL SYSTEM - SMART MANAGEMENT
        </p>
    </div>

    <script>
            function toggleGuideMenu(event) {
                event.stopPropagation();
                var menu = document.getElementById("guideMenu");
                menu.style.display = (menu.style.display === "none" || menu.style.display === "") ? "block" : "none";
            }

            window.onclick = function (event) {
                var menu = document.getElementById("guideMenu");
                var btn = document.getElementById("btnGuide");
                if (menu && menu.style.display === "block" && !btn.contains(event.target)) {
                    menu.style.display = "none";
                }
            }

            function checkUnreadNotifications() {
                function getReadIds(cookieName) {
                    const match = document.cookie.match(new RegExp('(^| )' + cookieName + '=([^;]+)'));
                    return match ? match[2].split(',').filter(x => x !== "") : [];
                }

                // Kiểm tra IT
                fetch('/FormIT/GetNotifications?skip=0&take=15')
                    .then(res => res.json())
                    .then(data => {
                        let items = data.top5 || data.dataList || [];
                        let readIds = getReadIds('read_notifications');
                        if (items.filter(i => !readIds.includes(i.id.toString())).length > 0) {
                            document.getElementById('badge-it').style.display = 'block';
                        }
                    }).catch(err => console.log(err));

                // Kiểm tra HR
                fetch('/FormHR/GetNotificationsHR?skip=0&take=15')
                    .then(res => res.json())
                    .then(data => {
                        let items = data.dataList || [];
                        let readIds = getReadIds('read_notifications_hr');
                        if (items.filter(i => !readIds.includes(i.id.toString())).length > 0) {
                            document.getElementById('badge-hr').style.display = 'block';
                        }
                    }).catch(err => console.log(err));

                // Kiểm tra SHD
                fetch('/FormSHD/GetNotificationsSHD?skip=0&take=15')
                    .then(res => res.json())
                    .then(data => {
                        let items = data.dataList || [];
                        let readIds = getReadIds('read_notifications_shd');
                        if (items.filter(i => !readIds.includes(i.id.toString())).length > 0) {
                            document.getElementById('badge-shd').style.display = 'block';
                        }
                    }).catch(err => console.log(err));
            }

            document.addEventListener('DOMContentLoaded', checkUnreadNotifications);
    </script>
</body>
</html>