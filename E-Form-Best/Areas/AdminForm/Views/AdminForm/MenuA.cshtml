@{
    ViewData["Title"] = "MenuA";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>E-Form - @ViewData["Title"]</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📑</text></svg>">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<div style="
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, #001f3f, #003366, #000c18);
    background-attachment: fixed;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    padding: 20px;
    position: relative;
">

    <div style="position: absolute; top: 30px; left: 30px; z-index: 1000;">
        <a href="/QL"
           style="
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px 25px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            border: 1px solid rgba(0, 212, 255, 0.2);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
            transition: all 0.4s ease;
           "
           onmouseover="this.style.transform='scale(1.05)'; this.style.background='rgba(0, 212, 255, 0.15)'; this.style.borderColor='rgba(0, 212, 255, 0.6)'"
           onmouseout="this.style.transform='scale(1)'; this.style.background='rgba(255, 255, 255, 0.05)'; this.style.borderColor='rgba(0, 212, 255, 0.2)'">

            <div style="font-size: 24px; animation: spin 4s linear infinite;">⚙️</div>
            <div style="display: flex; flex-direction: column;">
                <span style="font-size: 18px; font-weight: 800; letter-spacing: 1px; line-height: 1;">QL</span>
                <small style="font-size: 10px; opacity: 0.7; text-transform: uppercase;">Management</small>
            </div>
        </a>
    </div>

    <div style="position: absolute; top: 30px; right: 30px; z-index: 1000; display: flex; flex-direction: column; align-items: flex-end; gap: 10px;">
        <button onclick="toggleGuideMenu(event)"
                id="btnGuide"
                style="
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    padding: 12px 20px;
                    border-radius: 50px;
                    background: rgba(0, 212, 255, 0.15);
                    backdrop-filter: blur(10px);
                    border: 1px solid rgba(0, 212, 255, 0.4);
                    color: #00d4ff;
                    font-size: 15px;
                    font-weight: 700;
                    cursor: pointer;
                    transition: all 0.3s ease;
                "
                onmouseover="this.style.background='rgba(0, 212, 255, 0.3)'; this.style.transform='translateY(-2px)'"
                onmouseout="this.style.background='rgba(0, 212, 255, 0.15)'; this.style.transform='translateY(0)'">
            <span>Hướng dẫn sử dụng</span>
            <span style="font-size: 20px;">📚</span>
        </button>

        <div id="guideMenu"
             style="
                display: none;
                position: absolute;
                top: 65px;
                right: 0;
                width: 280px;
                background: rgba(0, 12, 24, 0.95);
                backdrop-filter: blur(15px);
                border: 1px solid rgba(0, 212, 255, 0.3);
                border-radius: 15px;
                overflow: hidden;
                box-shadow: 0 10px 40px rgba(0,0,0,0.6);
             ">
            <div style="padding: 15px; background: rgba(0, 212, 255, 0.2); color: #00d4ff; font-weight: bold; border-bottom: 1px solid rgba(0, 212, 255, 0.3); font-size: 13px;">
                DANH SÁCH HƯỚNG DẪN
            </div>
            <ul style="list-style: none; padding: 0; margin: 0;">
                <li style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <a href="~/HuongDanIT/Hướng dẫn user sử dụng hệ thông E-Form IT.pdf"
                       download
                       style="display: flex; align-items: center; gap: 10px; padding: 15px; color: white; text-decoration: none; font-size: 14px; transition: background 0.3s;"
                       onmouseover="this.style.background='rgba(0, 212, 255, 0.1)'"
                       onmouseout="this.style.background='transparent'">
                        <span>📄</span> HDSD IT E-Form
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div style="text-align: center; margin-bottom: 60px;">
        <h1 style="
            color: #00d4ff;
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: 10px;
            margin: 0;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
            text-transform: uppercase;
        ">
            SYSTEM MENU
        </h1>
        <div style="width: 100px; height: 4px; background: #00d4ff; margin: 15px auto; border-radius: 2px; opacity: 0.6;"></div>
    </div>

    <div style="display: flex; gap: 40px; flex-wrap: wrap; justify-content: center;">
        <a href="/Logo"
           style="
            width: 220px; height: 220px; display: flex; flex-direction: column; justify-content: center; align-items: center;
            background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border-radius: 30px; border: 1px solid rgba(0, 212, 255, 0.2);
            color: white; text-decoration: none; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
           "
           onmouseover="this.style.transform='translateY(-15px)'; this.style.boxShadow='0 20px 40px rgba(0, 212, 255, 0.4)'; this.style.background='rgba(0, 212, 255, 0.15)';"
           onmouseout="this.style.transform='translateY(0)'; this.style.background='rgba(255, 255, 255, 0.05)';">
            <div style="font-size: 50px; margin-bottom: 10px;">💻</div>
            <span style="font-size: 28px; font-weight: 800; letter-spacing: 2px;">IT</span>
            <small style="font-size: 11px; opacity: 0.7; margin-top: 5px; text-transform: uppercase;">Technology</small>
        </a>

        <a href="/HRForm/logo"
           style="
            width: 220px; height: 220px; display: flex; flex-direction: column; justify-content: center; align-items: center;
            background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px); border-radius: 30px; border: 1px solid rgba(0, 212, 255, 0.2);
            color: white; text-decoration: none; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
           "
           onmouseover="this.style.transform='translateY(-15px)'; this.style.boxShadow='0 20px 40px rgba(0, 212, 255, 0.4)'; this.style.background='rgba(0, 212, 255, 0.15)';"
           onmouseout="this.style.transform='translateY(0)'; this.style.background='rgba(255, 255, 255, 0.05)';">
            <div style="font-size: 50px; margin-bottom: 10px;">🤝</div>
            <span style="font-size: 28px; font-weight: 800; letter-spacing: 2px;">HR</span>
            <small style="font-size: 11px; opacity: 0.7; margin-top: 5px; text-transform: uppercase;">Human Resource</small>
        </a>
    </div>

    <p style="margin-top: 80px; color: #00d4ff; opacity: 0.5; font-size: 13px; letter-spacing: 1px;">
        © 2026 E-PORTAL SYSTEM - SMART MANAGEMENT
    </p>

</div>

<style>
    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }
</style>

<script>
    // --- LOGIC HƯỚNG DẪN SỬ DỤNG (GIỮ NGUYÊN) ---
    function toggleGuideMenu(event) {
        event.stopPropagation();
        var menu = document.getElementById("guideMenu");
        menu.style.display = (menu.style.display === "none" || menu.style.display === "") ? "block" : "none";
    }

    window.onclick = function(event) {
        var menu = document.getElementById("guideMenu");
        var btn = document.getElementById("btnGuide");
        if (menu && menu.style.display === "block" && !btn.contains(event.target)) {
            menu.style.display = "none";
        }
    }
</script>
