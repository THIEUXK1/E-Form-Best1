@model IEnumerable<E_Form_Best.Models.ITForm.Quyen>

@{
    ViewData["Title"] = "Quản lý Quyền Truy Cập";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<style>
    /* PHONG CÁCH HIỆN ĐẠI 2026 - GEMINI COLLABORATION */
    :root {
        --primary-indigo: #4f46e5;
        --accent-cyan: #06b6d4;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header {
        background: white;
        border-bottom: 1px solid #f1f5f9;
        padding: 20px;
    }

    .card-title {
        font-weight: 800;
        color: #1e293b;
        letter-spacing: -0.5px;
    }

    /* CSS RESPONSIVE CHO TABLE */
    @@media (max-width: 768px) {
        /* Tiêu đề card và nút bấm xếp chồng */
        .card-header {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 15px;
        }

            .card-header div {
                width: 100%;
                display: flex;
                gap: 10px;
            }

            .card-header .btn {
                flex: 1;
                padding: 10px;
            }
        /* Biến table thành cards */
        #tableQuyen thead {
            display: none; /* Ẩn header bảng */
        }

        #tableQuyen, #tableQuyen tbody, #tableQuyen tr, #tableQuyen td {
            display: block;
            width: 100% !important;
        }

            #tableQuyen tr {
                margin-bottom: 20px;
                border: 1px solid #e2e8f0;
                border-radius: 12px;
                padding: 15px;
                background: #fff;
                position: relative;
                box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            }

            #tableQuyen td {
                text-align: right;
                padding: 8px 0;
                border: none !important;
                border-bottom: 1px solid #f8fafc !important;
                min-height: 40px;
                display: flex;
                align-items: center;
                justify-content: flex-end;
            }

                #tableQuyen td:first-child {
                    justify-content: flex-start;
                    border-bottom: 2px solid #f1f5f9 !important;
                    margin-bottom: 5px;
                    padding-bottom: 12px;
                }

                #tableQuyen td:last-child {
                    border-bottom: none !important;
                    padding-top: 15px;
                    justify-content: center;
                }
                /* Hiển thị nhãn cột bằng data-label */
                #tableQuyen td::before {
                    content: attr(data-label);
                    position: absolute;
                    left: 0;
                    font-weight: 700;
                    color: #64748b;
                    font-size: 11px;
                    text-transform: uppercase;
                }

                #tableQuyen td:first-child::before {
                    content: "CHỌN MỤC NÀY";
                    position: static;
                    margin-right: 10px;
                }
        
        .btn-xs {
            width: 100%;
            padding: 12px;
            font-size: 14px;
        }
    }

    /* Hiệu ứng mượt mà cho checkbox */
    .checkItem {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }
</style>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title"><i class="fas fa-shield-alt text-primary me-2"></i>Danh sách Quyền</h3>
        <div>
            <button class="btn btn-success btn-sm rounded-pill px-3" onclick="showCreateModal()">
                <i class="fa fa-plus me-1"></i> Thêm mới
            </button>
            <button class="btn btn-danger btn-sm rounded-pill px-3" id="btnDeleteSelected" style="display:none;">
                <i class="fa fa-trash me-1"></i> Xóa (<span id="selectedCount">0</span>)
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="tableQuyen">
                <thead class="table-light">
                    <tr>
                        <th width="50px" class="text-center">
                            <input type="checkbox" id="checkAll" class="form-check-input" />
                        </th>
                        <th width="80px">ID</th>
                        <th>Tên Quyền</th>
                        <th>Mô Tả</th>
                        <th width="120px" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="row_@item.IdQuyen">
                            <td class="text-center">
                                <input type="checkbox" class="checkItem form-check-input" value="@item.IdQuyen" />
                            </td>
                            <td data-label="Mã ID">@item.IdQuyen</td>
                            <td data-label="Tên Quyền" class="ten-quyen fw-bold text-indigo">@item.TenQuyen</td>
                            <td data-label="Mô Tả" class="mo-ta text-muted">@item.MoTa</td>
                            <td class="text-center">
                                <button class="btn btn-primary btn-xs rounded-8" onclick="showEditModal(@item.IdQuyen, '@item.TenQuyen', '@item.MoTa')">
                                    <i class="fa fa-edit me-1"></i> Sửa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal giữ nguyên cấu trúc Logic -->
<div class="modal fade" id="quyenModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Thêm Quyền Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="$('#quyenModal').modal('hide')"></button>
            </div>
            <form id="formQuyen">
                <div class="modal-body">
                    <input type="hidden" id="id_quyen" name="IdQuyen" />
                    <div class="form-group mb-3">
                        <label class="fw-bold mb-2 small text-uppercase">Tên Quyền</label>
                        <input type="text" id="ten_quyen" name="TenQuyen" class="form-control rounded-10" placeholder="VD: Quản trị hệ thống..." />
                    </div>
                    <div class="form-group">
                        <label class="fw-bold mb-2 small text-uppercase">Mô Tả Chi Tiết</label>
                        <textarea id="mo_ta" name="MoTa" class="form-control rounded-10" rows="3" placeholder="Quyền này cho phép truy cập..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal" onclick="$('#quyenModal').modal('hide')">Hủy</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="saveQuyen()">Lưu dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Xử lý Checkbox chọn tất cả
        $('#checkAll').change(function() {
            $('.checkItem').prop('checked', $(this).prop('checked'));
            toggleDeleteButton();
        });

        $(document).on('change', '.checkItem', function() {
            toggleDeleteButton();
        });

        function toggleDeleteButton() {
            var count = $('.checkItem:checked').length;
            $('#selectedCount').text(count);
            if (count > 0) {
                $('#btnDeleteSelected').fadeIn();
            } else {
                $('#btnDeleteSelected').fadeOut();
                $('#checkAll').prop('checked', false);
            }
        }

        // 2. Hiển thị Modal Thêm mới
        function showCreateModal() {
            $('#formQuyen')[0].reset();
            $('#id_quyen').val(0);
            $('#modalTitle').text('Thêm Quyền Mới');
            $('#quyenModal').modal('show');
        }

        // 3. Hiển thị Modal Sửa
        function showEditModal(id, ten, mota) {
            $('#id_quyen').val(id);
            $('#ten_quyen').val(ten);
            $('#mo_ta').val(mota);
            $('#modalTitle').text('Chỉnh Sửa Quyền');
            $('#quyenModal').modal('show');
        }

        // 4. Lưu dữ liệu (Thêm hoặc Sửa) qua AJAX
        function saveQuyen() {
            var id = $('#id_quyen').val();
            var url = id == 0 ? '/QLQuyenTruyCap/Create' : '/QLQuyenTruyCap/Edit';

            var data = {
                IdQuyen: parseInt(id),
                TenQuyen: $('#ten_quyen').val(),
                MoTa: $('#mo_ta').val()
            };

            $.ajax({
                url: url,
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        alert(res.message);
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                },
                error: function () {
                    alert('Đã có lỗi xảy ra trong quá trình xử lý.');
                }
            });
        }

        // 5. AJAX Xóa nhiều mục đã chọn
        $('#btnDeleteSelected').click(function() {
            var ids = [];
            $('.checkItem:checked').each(function() {
                ids.push(parseInt($(this).val()));
            });

            if (confirm('Bạn có chắc chắn muốn xóa ' + ids.length + ' mục đã chọn?')) {
                $.ajax({
                    url: '/QLQuyenTruyCap/DeleteMultiple',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(ids),
                    success: function(res) {
                        if (res.success) {
                            alert(res.message);
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    }
                });
            }
        });
    </script>
}