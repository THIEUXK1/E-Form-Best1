@model IEnumerable<E_Form_Best.Models.ITForm.Quyen>

@{
    ViewData["Title"] = "Quản lý Quyền Truy Cập";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">Danh sách Quyền</h3>
        <div>
            <button class="btn btn-success btn-sm" onclick="showCreateModal()">
                <i class="fa fa-plus"></i> Thêm mới
            </button>
            <button class="btn btn-danger btn-sm" id="btnDeleteSelected" style="display:none;">
                <i class="fa fa-trash"></i> Xóa các mục đã chọn (<span id="selectedCount">0</span>)
            </button>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-hover table-bordered" id="tableQuyen">
            <thead>
                <tr>
                    <th width="40px" class="text-center">
                        <input type="checkbox" id="checkAll" />
                    </th>
                    <th>ID</th>
                    <th>Tên Quyền</th>
                    <th>Mô Tả</th>
                    <th width="120px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row_@item.IdQuyen">
                        <td class="text-center">
                            <input type="checkbox" class="checkItem" value="@item.IdQuyen" />
                        </td>
                        <td>@item.IdQuyen</td>
                        <td class="ten-quyen">@item.TenQuyen</td>
                        <td class="mo-ta">@item.MoTa</td>
                        <td>
                            <button class="btn btn-primary btn-xs" onclick="showEditModal(@item.IdQuyen, '@item.TenQuyen', '@item.MoTa')">
                                <i class="fa fa-edit"></i> Sửa
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="quyenModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Thêm Quyền Mới</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="$('#quyenModal').modal('hide')">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="formQuyen">
                <div class="modal-body">
                    <input type="hidden" id="id_quyen" name="IdQuyen" />
                    <div class="form-group">
                        <label>Tên Quyền</label>
                        <input type="text" id="ten_quyen" name="TenQuyen" class="form-control" placeholder="Nhập tên quyền..." />
                    </div>
                    <div class="form-group mt-3">
                        <label>Mô Tả</label>
                        <textarea id="mo_ta" name="MoTa" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal" onclick="$('#quyenModal').modal('hide')">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="saveQuyen()">Lưu dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Xử lý Checkbox chọn tất cả
        $('#checkAll').change(function() {
            $('.checkItem').prop('checked', $(this).prop('checked'));
            toggleDeleteButton();
        });

        $(document).on('change', '.checkItem', function() {
            toggleDeleteButton();
        });

        function toggleDeleteButton() {
            var count = $('.checkItem:checked').length;
            $('#selectedCount').text(count);
            if (count > 0) {
                $('#btnDeleteSelected').fadeIn();
            } else {
                $('#btnDeleteSelected').fadeOut();
                $('#checkAll').prop('checked', false);
            }
        }

        // 2. Hiển thị Modal Thêm mới
        function showCreateModal() {
            $('#formQuyen')[0].reset();
            $('#id_quyen').val(0);
            $('#modalTitle').text('Thêm Quyền Mới');
            $('#quyenModal').modal('show');
        }

        // 3. Hiển thị Modal Sửa
        function showEditModal(id, ten, mota) {
            $('#id_quyen').val(id);
            $('#ten_quyen').val(ten);
            $('#mo_ta').val(mota);
            $('#modalTitle').text('Chỉnh Sửa Quyền');
            $('#quyenModal').modal('show');
        }

        // 4. Lưu dữ liệu (Thêm hoặc Sửa) qua AJAX
        function saveQuyen() {
            var id = $('#id_quyen').val();
            var url = id == 0 ? '/QLQuyenTruyCap/Create' : '/QLQuyenTruyCap/Edit';

            var data = {
                IdQuyen: parseInt(id),
                TenQuyen: $('#ten_quyen').val(),
                MoTa: $('#mo_ta').val()
            };

            $.ajax({
                url: url,
                type: 'POST',
                data: data, // Gửi dưới dạng Form data
                success: function (res) {
                    if (res.success) {
                        alert(res.message);
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                },
                error: function () {
                    alert('Đã có lỗi xảy ra trong quá trình xử lý.');
                }
            });
        }

        // 5. AJAX Xóa nhiều mục đã chọn
        $('#btnDeleteSelected').click(function() {
            var ids = [];
            $('.checkItem:checked').each(function() {
                ids.push(parseInt($(this).val()));
            });

            if (confirm('Bạn có chắc chắn muốn xóa ' + ids.length + ' mục đã chọn?')) {
                $.ajax({
                    url: '/QLQuyenTruyCap/DeleteMultiple',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(ids),
                    success: function(res) {
                        if (res.success) {
                            alert(res.message);
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    }
                });
            }
        });
    </script>
}