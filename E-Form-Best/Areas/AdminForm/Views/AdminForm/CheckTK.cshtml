

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
    }
    /* Nếu Layout của bạn có container bao ngoài, hãy đảm bảo nó không giới hạn chiều cao */
    main, .container, .body-content {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
</style>

<div style="
    min-height: 100vh;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    background: radial-gradient(circle at top left, #1a2a6c, #b21f1f, #fdbb2d);
    font-family: 'Segoe UI', Roboto, sans-serif;
    margin: 0;
    padding: 20px;
    box-sizing: border-box;
">
    <div style="
        width: 100%;
        max-width: 450px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
        padding: 40px;
        box-sizing: border-box;
    ">

        <div style="text-align: center; margin-bottom: 40px;">
            <div style="
                width: 70px;
                height: 70px;
                background: white;
                border-radius: 20px;
                display: flex;
                justify-content: center;
                align-items: center;
                margin: 0 auto 20px;
                font-size: 30px;
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            ">
                🔑
            </div>
            <h1 style="color: white; font-size: 28px; font-weight: 800; margin: 0; letter-spacing: 1px; text-transform: uppercase;">
                Đăng Nhập
            </h1>
            <p style="color: rgba(255,255,255,0.7); font-size: 14px; margin-top: 10px;">Vui lòng truy cập tài khoản của bạn</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div style="
                            background: rgba(255, 0, 0, 0.2);
                            color: #fff;
                            padding: 12px 15px;
                            border-radius: 12px;
                            margin-bottom: 25px;
                            border: 1px solid rgba(255, 0, 0, 0.3);
                            font-size: 14px;
                            display: flex;
                            align-items: center;
                            gap: 10px;
                        ">
                <span>⚠️</span> @ViewBag.Error
            </div>
        }

        <form method="post" action="/CheckTK">
            @Html.AntiForgeryToken()

            <div style="margin-bottom: 25px; position: relative;">
                <label for="email" style="display: block; color: white; font-size: 13px; font-weight: 600; margin-bottom: 8px; margin-left: 5px; text-transform: uppercase;">Email Address</label>
                <input type="text" id="email" name="email" placeholder="email@vi-du.com"
                       onfocus="this.style.background='rgba(255,255,255,0.25)'; this.style.borderColor='white'; this.style.boxShadow='0 0 15px rgba(255,255,255,0.2)';"
                       onblur="this.style.background='rgba(255,255,255,0.15)'; this.style.borderColor='rgba(255,255,255,0.3)'; this.style.boxShadow='none';"
                       style="
                        width: 100%;
                        padding: 14px 20px;
                        background: rgba(255, 255, 255, 0.15);
                        border: 1px solid rgba(255, 255, 255, 0.3);
                        border-radius: 15px;
                        color: white;
                        font-size: 16px;
                        outline: none;
                        transition: all 0.3s ease;
                        box-sizing: border-box;
                    " required />
            </div>

            <div style="margin-bottom: 35px; position: relative;">
                <label for="matkhau" style="display: block; color: white; font-size: 13px; font-weight: 600; margin-bottom: 8px; margin-left: 5px; text-transform: uppercase;">Password</label>
                <input type="password" id="matkhau" name="matkhau" placeholder="••••••••"
                       onfocus="this.style.background='rgba(255,255,255,0.25)'; this.style.borderColor='white'; this.style.boxShadow='0 0 15px rgba(255,255,255,0.2)';"
                       onblur="this.style.background='rgba(255,255,255,0.15)'; this.style.borderColor='rgba(255,255,255,0.3)'; this.style.boxShadow='none';"
                       style="
                        width: 100%;
                        padding: 14px 20px;
                        background: rgba(255, 255, 255, 0.15);
                        border: 1px solid rgba(255, 255, 255, 0.3);
                        border-radius: 15px;
                        color: white;
                        font-size: 16px;
                        outline: none;
                        transition: all 0.3s ease;
                        box-sizing: border-box;
                    " required />
            </div>

            <button type="submit"
                    onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.2)'; this.style.filter='brightness(1.1)';"
                    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 5px 15px rgba(0,0,0,0.1)'; this.style.filter='brightness(1)';"
                    style="
                    width: 100%;
                    padding: 16px;
                    background: white;
                    color: #1a2a6c;
                    font-size: 16px;
                    font-weight: 800;
                    border: none;
                    border-radius: 15px;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
                ">
                Đăng Nhập
            </button>
        </form>

        <div style="margin-top: 30px; text-align: center;">
            <a href="#" style="color: rgba(255,255,255,0.6); text-decoration: none; font-size: 13px;"
               onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
                Quên mật khẩu?
            </a>
        </div>
    </div>
</div>