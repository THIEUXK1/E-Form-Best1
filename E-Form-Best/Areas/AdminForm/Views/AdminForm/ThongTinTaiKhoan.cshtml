@using System.Security.Claims
@{
    Layout = null;
    ViewData["Title"] = "Hồ Sơ Cá Nhân";

    var hoTen = User.Identity?.Name ?? "N/A";
    var email = User.FindFirst(ClaimTypes.Email)?.Value ?? "N/A";
    var vaiTro = User.FindFirst("UserRole")?.Value ?? "Thành viên";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "N/A";
    var congTy = User.FindFirst("TenCongTy")?.Value ?? "N/A";
    var tenBoPhan = User.FindFirst("TenBoPhan")?.Value ?? "Chưa xác định";
    var moTaBoPhan = User.FindFirst("MoTaBoPhan")?.Value ?? "Không có mô tả chi tiết";

    var anhDaiDien = ViewBag.AnhDaiDien ?? User.FindFirst("AnhDaiDien")?.Value;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
            @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

            body {
                font-family: 'Inter', sans-serif;
                background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 10px; /* Giảm padding trên mobile */
            }

            .profile-container {
                width: 100%;
                max-width: 900px;
                background: #ffffff;
                border-radius: 24px;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
                overflow: hidden;
                margin: 10px auto;
            }

            /* Mobile Adjustments */
            @@media (max-width: 768px) {
                .avatar-col {
                    border-right: none !important;
                    border-bottom: 1px solid #f1f5f9;
                    padding-right: 12px !important;
                    padding-bottom: 30px;
                    margin-bottom: 30px;
                }

                .info-col {
                    padding-left: 12px !important;
                }

                .header-section {
                    padding: 30px 20px !important;
                    text-align: center;
                }

                    .header-section .d-flex {
                        flex-direction: column;
                        gap: 15px;
                    }

                .footer-section {
                    flex-direction: column !important;
                    gap: 10px;
                    padding: 20px !important;
                }

                    .footer-section button, .footer-section a {
                        width: 100%;
                        justify-content: center;
                    }

                .avatar-wrapper {
                    width: 130px !important;
                    height: 130px !important;
                }
            }

            input:focus {
                border-color: #6366f1 !important;
                box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
            }

            .modal-backdrop-custom {
                display: none;
                position: fixed;
                z-index: 1000;
                left: 0;
                top: 0;
                width: 100%;
                height: 100%;
                background: rgba(15, 23, 42, 0.6);
                backdrop-filter: blur(4px);
                align-items: center;
                justify-content: center;
                padding: 20px;
            }

            .avatar-wrapper:hover .avatar-overlay {
                opacity: 1 !important;
            }

            .avatar-overlay {
                transition: all 0.3s ease;
            }
    </style>
</head>
<body>

    <div class="profile-container">
        <!-- Header -->
        <div class="header-section" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); padding: 40px 30px; position: relative;">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.1; background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
            <div style="position: relative; z-index: 1;" class="d-flex align-items-center justify-content-between">
                <div>
                    <h2 style="color: #ffffff; font-weight: 800; margin: 0; font-size: 1.5rem;">Hồ Sơ Cá Nhân</h2>
                    <p style="color: #94a3b8; margin: 5px 0 0 0; font-size: 0.85rem;">Thông tin tài khoản & quyền hạn</p>
                </div>
                <div style="background: rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);">
                    <span style="color: #38bdf8; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">● Online</span>
                </div>
            </div>
        </div>

        <div style="padding: 30px;">
            <div class="row">
                <!-- Cột trái: Avatar -->
                <div class="col-lg-4 text-center avatar-col" style="border-right: 1px solid #f1f5f9; padding-right: 30px;">
                    <div class="avatar-wrapper" style="position: relative; display: inline-block; margin-bottom: 20px; width: 160px; height: 160px; border-radius: 50%; border: 4px solid #fff; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); overflow: hidden; background: #f8fafc;">

                        @if (!string.IsNullOrEmpty(anhDaiDien))
                        {
                            <img src="/DonXetDuyet/GetAvatar?path=@Uri.EscapeDataString(anhDaiDien)"
                                 id="currentAvatar"
                                 style="width: 100%; height: 100%; object-fit: cover;"
                                 onerror="this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png';">
                        }
                        else
                        {
                            <div id="defaultAvatar" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f1f5f9;">
                                <i class="fas fa-user-tie" style="font-size: 60px; color: #64748b;"></i>
                            </div>
                        }

                        <div class="avatar-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.7); display: flex; align-items: center; justify-content: center; opacity: 0; gap: 15px;">
                            <button onclick="document.getElementById('fileInput').click()" style="background: #ffffff; border: none; width: 36px; height: 36px; border-radius: 50%; color: #1e293b; cursor: pointer;">
                                <i class="fas fa-camera"></i>
                            </button>
                            @if (!string.IsNullOrEmpty(anhDaiDien))
                            {
                                <button onclick="deleteAvatar()" style="background: #ef4444; border: none; width: 36px; height: 36px; border-radius: 50%; color: #ffffff; cursor: pointer;">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            }
                        </div>
                    </div>

                    <input type="file" id="fileInput" hidden accept="image/*" onchange="uploadAvatar(this)">

                    <h4 style="color: #1e293b; font-weight: 700; margin-bottom: 5px; font-size: 1.25rem;">@hoTen</h4>
                    <p style="color: #64748b; font-size: 0.85rem; margin-bottom: 15px;">@email</p>
                    <div style="background: #eff6ff; color: #1d4ed8; padding: 6px 14px; border-radius: 100px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center;">
                        <i class="fas fa-shield-alt" style="margin-right: 6px;"></i> @vaiTro
                    </div>
                </div>

                <!-- Cột phải: Thông tin -->
                <div class="col-lg-8 info-col" style="padding-left: 30px;">
                    <div class="row g-4">
                        <div class="col-sm-6 text-start">
                            <label style="display: block; color: #94a3b8; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px;">Công ty</label>
                            <div style="color: #334155; font-weight: 600; font-size: 0.95rem;">
                                <i class="fas fa-building" style="color: #cbd5e1; margin-right: 8px; width: 18px;"></i> @congTy
                            </div>
                        </div>
                        <div class="col-sm-6 text-start">
                            <label style="display: block; color: #94a3b8; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px;">Phòng ban</label>
                            <div style="color: #334155; font-weight: 600; font-size: 0.95rem;">
                                <i class="fas fa-layer-group" style="color: #cbd5e1; margin-right: 8px; width: 18px;"></i> @phongBan
                            </div>
                        </div>
                        <div class="col-12"><div style="height: 1px; background: #f1f5f9;"></div></div>
                        <div class="col-12 text-start">
                            <label style="display: block; color: #f43f5e; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 10px;">Bộ phận phụ trách</label>
                            <div style="background: #fff1f2; border-radius: 16px; padding: 15px; border: 1px solid #ffe4e6;">
                                <div style="color: #9f1239; font-weight: 700; font-size: 1rem; margin-bottom: 5px;">@tenBoPhan</div>
                                <div style="color: #e11d48; font-size: 0.85rem; line-height: 1.5; font-style: italic;">
                                    <i class="fas fa-info-circle" style="margin-right: 5px; opacity: 0.7;"></i> @moTaBoPhan
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Buttons -->
        <div class="footer-section" style="background: #f8fafc; padding: 25px 40px; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
            <div style="color: #94a3b8; font-size: 0.8rem;">
                <i class="fas fa-calendar-alt" style="margin-right: 5px;"></i> @DateTime.Now.ToString("dd/MM/yyyy")
            </div>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                <button onclick="openPasswordModal()" style="border: none; background: #6366f1; color: #fff; padding: 10px 18px; border-radius: 10px; font-weight: 600; font-size: 0.85rem; cursor: pointer;">
                    <i class="fas fa-key me-2"></i>Mật khẩu
                </button>
                <button onclick="window.close()" style="border: 1px solid #e2e8f0; background: #fff; color: #64748b; padding: 10px 18px; border-radius: 10px; font-weight: 600; font-size: 0.85rem; cursor: pointer;">
                    <i class="fas fa-times me-2"></i>Đóng
                </button>
                <a href="/DonXetDuyet/DangXuat" style="background: #ef4444; color: #fff; padding: 10px 18px; border-radius: 10px; font-weight: 600; font-size: 0.85rem; text-decoration: none; display: flex; align-items: center;">
                    <i class="fas fa-sign-out-alt me-2"></i>Thoát
                </a>
            </div>
        </div>
    </div>

    <!-- Modal Đổi mật khẩu -->
    <div id="passwordModal" class="modal-backdrop-custom">
        <div style="background: white; width: 100%; max-width: 400px; border-radius: 20px; padding: 25px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="color: #1e293b; font-weight: 700; margin: 0; font-size: 1.15rem;">Đổi mật khẩu</h3>
                <i class="fas fa-times" onclick="closePasswordModal()" style="color: #94a3b8; cursor: pointer;"></i>
            </div>
            <form id="changePasswordForm">
                <div style="margin-bottom: 12px;">
                    <label style="display: block; color: #64748b; font-size: 0.75rem; font-weight: 600; margin-bottom: 5px;">Mật khẩu hiện tại</label>
                    <input type="password" name="oldPassword" required style="width: 100%; padding: 10px 15px; border-radius: 8px; border: 1px solid #e2e8f0; outline: none;">
                </div>
                <div style="margin-bottom: 12px;">
                    <label style="display: block; color: #64748b; font-size: 0.75rem; font-weight: 600; margin-bottom: 5px;">Mật khẩu mới</label>
                    <input type="password" id="newPassword" name="newPassword" required style="width: 100%; padding: 10px 15px; border-radius: 8px; border: 1px solid #e2e8f0; outline: none;">
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display: block; color: #64748b; font-size: 0.75rem; font-weight: 600; margin-bottom: 5px;">Xác nhận mật khẩu</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required style="width: 100%; padding: 10px 15px; border-radius: 8px; border: 1px solid #e2e8f0; outline: none;">
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="submit" id="btnUpdatePass" style="flex: 2; background: #0f172a; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer;">Cập nhật</button>
                    <button type="button" onclick="closePasswordModal()" style="flex: 1; background: #f1f5f9; color: #64748b; border: none; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer;">Hủy</button>
                </div>
            </form>
        </div>
    </div>

    <script>
            // Copy lại toàn bộ script cũ của bạn ở đây
            // ... (Giữ nguyên phần script xử lý upload, delete, đổi mật khẩu)
        
            async function uploadAvatar(input) {
                if (input.files && input.files[0]) {
                    const formData = new FormData();
                    formData.append('fileAnh', input.files[0]);
                    try {
                        const response = await fetch('/DonXetDuyet/CapNhatAnh', { method: 'POST', body: formData });
                        const result = await response.json();
                        if (result.success) { alert("Cập nhật thành công!"); location.reload(); }
                        else alert(result.message);
                    } catch (err) { alert("Lỗi kết nối!"); }
                }
            }

            async function deleteAvatar() {
                if (confirm("Xóa ảnh đại diện?")) {
                    try {
                        const response = await fetch('/DonXetDuyet/XoaAnhDaiDien', { method: 'POST' });
                        const result = await response.json();
                        if (result.success) { alert("Đã xóa!"); location.reload(); }
                        else alert(result.message);
                    } catch (err) { alert("Lỗi server!"); }
                }
            }

            function openPasswordModal() { document.getElementById('passwordModal').style.display = 'flex'; }
            function closePasswordModal() { document.getElementById('passwordModal').style.display = 'none'; document.getElementById('changePasswordForm').reset(); }

            document.getElementById('changePasswordForm').onsubmit = async function(e) {
                e.preventDefault();
                const newPass = document.getElementById('newPassword').value;
                const confirmPass = document.getElementById('confirmPassword').value;
                if (newPass !== confirmPass) { alert("Mật khẩu xác nhận không khớp!"); return; }
                const btn = document.getElementById('btnUpdatePass');
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                try {
                    const formData = new FormData(this);
                    const response = await fetch('/DonXetDuyet/DoiMatKhau', { method: 'POST', body: formData });
                    const result = await response.json();
                    if (result.success) { alert("Thành công!"); closePasswordModal(); }
                    else alert(result.message);
                } catch (err) { alert("Lỗi!"); }
                finally { btn.disabled = false; btn.innerHTML = 'Cập nhật'; }
            };
    </script>
</body>
</html>