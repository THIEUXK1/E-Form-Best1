@using System.Security.Claims
@{
    Layout = null;
    ViewData["Title"] = "Hồ Sơ Cá Nhân";

    var hoTen = User.Identity?.Name ?? "N/A";
    var email = User.FindFirst(ClaimTypes.Email)?.Value ?? "N/A";
    var vaiTro = User.FindFirst("UserRole")?.Value ?? "Thành viên";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "N/A";
    var congTy = User.FindFirst("TenCongTy")?.Value ?? "N/A";
    var tenBoPhan = User.FindFirst("TenBoPhan")?.Value ?? "Chưa xác định";
    var moTaBoPhan = User.FindFirst("MoTaBoPhan")?.Value ?? "Không có mô tả chi tiết";

    // Lấy đường dẫn ảnh từ Claims hoặc ViewBag được truyền từ Controller
    var anhDaiDien = ViewBag.AnhDaiDien ?? User.FindFirst("AnhDaiDien")?.Value;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
            @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');

            body {
                font-family: 'Inter', sans-serif;
            }

            input:focus {
                border-color: #6366f1 !important;
                box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
            }

            .modal-backdrop-custom {
                display: none;
                position: fixed;
                z-index: 1000;
                left: 0;
                top: 0;
                width: 100%;
                height: 100%;
                background: rgba(15, 23, 42, 0.6);
                backdrop-filter: blur(4px);
                align-items: center;
                justify-content: center;
            }

            /* Hiệu ứng Hover Avatar */
            .avatar-wrapper:hover .avatar-overlay {
                opacity: 1 !important;
            }

            .avatar-overlay {
                transition: all 0.3s ease;
            }
    </style>
</head>
<body style="background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px;">

    <div style="width: 100%; max-width: 900px; background: #ffffff; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1); overflow: hidden;">

        <div style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); padding: 40px 30px; position: relative;">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.1; background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
            <div style="position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <h2 style="color: #ffffff; font-weight: 800; margin: 0; font-size: 1.75rem;">Hồ Sơ Cá Nhân</h2>
                    <p style="color: #94a3b8; margin: 5px 0 0 0; font-size: 0.9rem;">Thông tin tài khoản và quyền hạn hệ thống</p>
                </div>
                <div style="background: rgba(255,255,255,0.1); padding: 10px 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                    <span style="color: #38bdf8; font-size: 0.85rem; font-weight: 700; text-transform: uppercase;">Status: Online</span>
                </div>
            </div>
        </div>

        <div style="padding: 40px;">
            <div class="row">
                <div class="col-lg-4 text-center" style="border-right: 1px solid #f1f5f9; padding-right: 30px;">
                    <div class="avatar-wrapper" style="position: relative; display: inline-block; margin-bottom: 20px; width: 160px; height: 160px; border-radius: 50%; border: 4px solid #fff; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); overflow: hidden; background: #f8fafc;">

                        @if (!string.IsNullOrEmpty(anhDaiDien))
                        {
                            <img src="/DonXetDuyet/GetAvatar?path=@Uri.EscapeDataString(anhDaiDien)"
                                 id="currentAvatar"
                                 style="width: 100%; height: 100%; object-fit: cover;"
                                 onerror="this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png';">
                        }
                        else
                        {
                            <div id="defaultAvatar" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f1f5f9;">
                                <i class="fas fa-user-tie" style="font-size: 80px; color: #64748b;"></i>
                            </div>
                        }

                        <div class="avatar-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.7); display: flex; align-items: center; justify-content: center; opacity: 0; gap: 15px;">
                            <button onclick="document.getElementById('fileInput').click()" style="background: #ffffff; border: none; width: 40px; height: 40px; border-radius: 50%; color: #1e293b; cursor: pointer;" title="Thay đổi ảnh">
                                <i class="fas fa-camera"></i>
                            </button>
                            @if (!string.IsNullOrEmpty(anhDaiDien))
                            {
                                <button onclick="deleteAvatar()" style="background: #ef4444; border: none; width: 40px; height: 40px; border-radius: 50%; color: #ffffff; cursor: pointer;" title="Xóa ảnh (về mặc định)">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            }
                        </div>
                    </div>

                    <input type="file" id="fileInput" hidden accept="image/*" onchange="uploadAvatar(this)">

                    <h4 style="color: #1e293b; font-weight: 700; margin-bottom: 5px;">@hoTen</h4>
                    <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 20px;">@email</p>
                    <div style="background: #eff6ff; color: #1d4ed8; padding: 8px 16px; border-radius: 100px; font-size: 0.8rem; font-weight: 700; display: inline-flex; align-items: center;">
                        <i class="fas fa-shield-alt" style="margin-right: 6px;"></i> @vaiTro
                    </div>
                </div>

                <div class="col-lg-8" style="padding-left: 30px;">
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label style="display: block; color: #94a3b8; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px;">Cơ quan / Công ty</label>
                            <div style="color: #334155; font-weight: 600; font-size: 1rem;">
                                <i class="fas fa-building" style="color: #cbd5e1; margin-right: 10px; width: 20px;"></i> @congTy
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <label style="display: block; color: #94a3b8; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px;">Phòng ban</label>
                            <div style="color: #334155; font-weight: 600; font-size: 1rem;">
                                <i class="fas fa-layer-group" style="color: #cbd5e1; margin-right: 10px; width: 20px;"></i> @phongBan
                            </div>
                        </div>
                        <div class="col-12"><div style="height: 1px; background: #f1f5f9; margin: 10px 0;"></div></div>
                        <div class="col-12">
                            <label style="display: block; color: #f43f5e; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 12px;">Bộ phận phụ trách chi tiết</label>
                            <div style="background: #fff1f2; border-radius: 16px; padding: 20px; border: 1px solid #ffe4e6;">
                                <div style="color: #9f1239; font-weight: 700; font-size: 1.1rem; margin-bottom: 8px;">@tenBoPhan</div>
                                <div style="color: #e11d48; font-size: 0.9rem; line-height: 1.6; font-style: italic;">
                                    <i class="fas fa-info-circle" style="margin-right: 8px; opacity: 0.7;"></i> @moTaBoPhan
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div style="background: #f8fafc; padding: 25px 40px; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
            <div style="color: #94a3b8; font-size: 0.85rem;">
                <i class="fas fa-clock" style="margin-right: 5px;"></i> Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy")
            </div>
            <div style="display: flex; gap: 15px;">
                <button onclick="openPasswordModal()" style="border: none; background: #6366f1; color: #fff; padding: 10px 25px; border-radius: 12px; font-weight: 600; font-size: 0.9rem; cursor: pointer;">
                    <i class="fas fa-key me-2"></i>Đổi mật khẩu
                </button>
                <button onclick="window.close()" style="border: 1px solid #e2e8f0; background: #fff; color: #64748b; padding: 10px 25px; border-radius: 12px; font-weight: 600; font-size: 0.9rem; cursor: pointer;">
                    <i class="fas fa-times me-2"></i>Đóng
                </button>
                <a href="/DonXetDuyet/DangXuat" style="background: #ef4444; color: #fff; padding: 10px 25px; border-radius: 12px; font-weight: 600; font-size: 0.9rem; text-decoration: none;">
                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                </a>
            </div>
        </div>
    </div>

    <div id="passwordModal" class="modal-backdrop-custom">
        <div style="background: white; width: 100%; max-width: 400px; border-radius: 20px; padding: 30px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="color: #1e293b; font-weight: 700; margin: 0; font-size: 1.25rem;">Đổi mật khẩu</h3>
                <i class="fas fa-times" onclick="closePasswordModal()" style="color: #94a3b8; cursor: pointer;"></i>
            </div>
            <form id="changePasswordForm">
                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: #64748b; font-size: 0.8rem; font-weight: 600; margin-bottom: 5px;">Mật khẩu hiện tại</label>
                    <input type="password" name="oldPassword" required style="width: 100%; padding: 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; outline: none;">
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: #64748b; font-size: 0.8rem; font-weight: 600; margin-bottom: 5px;">Mật khẩu mới</label>
                    <input type="password" id="newPassword" name="newPassword" required style="width: 100%; padding: 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; outline: none;">
                </div>
                <div style="margin-bottom: 25px;">
                    <label style="display: block; color: #64748b; font-size: 0.8rem; font-weight: 600; margin-bottom: 5px;">Xác nhận mật khẩu</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required style="width: 100%; padding: 12px 15px; border-radius: 10px; border: 1px solid #e2e8f0; outline: none;">
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="submit" id="btnUpdatePass" style="flex: 2; background: #0f172a; color: white; border: none; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer;">Cập nhật</button>
                    <button type="button" onclick="closePasswordModal()" style="flex: 1; background: #f1f5f9; color: #64748b; border: none; padding: 12px; border-radius: 10px; font-weight: 600; cursor: pointer;">Hủy</button>
                </div>
            </form>
        </div>
    </div>

    <script>
            // Xử lý Upload Ảnh
            async function uploadAvatar(input) {
                if (input.files && input.files[0]) {
                    const formData = new FormData();
                    formData.append('fileAnh', input.files[0]);

                    try {
                        const response = await fetch('/DonXetDuyet/CapNhatAnh', {
                            method: 'POST',
                            body: formData
                        });
                        const result = await response.json();
                        if (result.success) {
                            alert("Cập nhật ảnh thành công!");
                            location.reload(); // Reload để cập nhật ảnh mới nhất
                        } else {
                            alert(result.message);
                        }
                    } catch (err) {
                        alert("Lỗi kết nối server!");
                    }
                }
            }

            // Xử lý Xóa Ảnh (Về mặc định)
            async function deleteAvatar() {
                if (confirm("Bạn có muốn xóa ảnh đại diện này và quay về ảnh mặc định không? (File cũ trên Server cũng sẽ bị xóa)")) {
                    try {
                        const response = await fetch('/DonXetDuyet/XoaAnhDaiDien', {
                            method: 'POST'
                        });
                        const result = await response.json();
                        if (result.success) {
                            alert("Đã xóa ảnh!");
                            location.reload();
                        } else {
                            alert(result.message);
                        }
                    } catch (err) {
                        alert("Lỗi server!");
                    }
                }
            }

            // Logic Modal & Đổi mật khẩu
            function openPasswordModal() { document.getElementById('passwordModal').style.display = 'flex'; }
            function closePasswordModal() { document.getElementById('passwordModal').style.display = 'none'; document.getElementById('changePasswordForm').reset(); }

            document.getElementById('changePasswordForm').onsubmit = async function(e) {
                e.preventDefault();
                const newPass = document.getElementById('newPassword').value;
                const confirmPass = document.getElementById('confirmPassword').value;
            
                if (newPass !== confirmPass) {
                    alert("Mật khẩu xác nhận không khớp!");
                    return;
                }

                const btn = document.getElementById('btnUpdatePass');
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

                try {
                    const formData = new FormData(this);
                    // Gửi request đến Route đã định nghĩa trong Controller
                    const response = await fetch('/DonXetDuyet/DoiMatKhau', {
                        method: 'POST',
                        body: formData
                    });
                
                    const result = await response.json();
                    if (result.success) {
                        alert(result.message || "Đổi mật khẩu thành công!");
                        closePasswordModal();
                    } else {
                        alert(result.message);
                    }
                } catch (err) {
                    alert("Lỗi kết nối!");
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = 'Cập nhật';
                }
            };
    </script>
</body>
</html>