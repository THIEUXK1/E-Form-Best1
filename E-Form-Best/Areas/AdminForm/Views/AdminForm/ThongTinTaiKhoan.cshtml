@using System.Security.Claims
@{
    Layout = null; // Loại bỏ hoàn toàn Layout
    ViewData["Title"] = "Hồ Sơ Cá Nhân";

    // Lấy dữ liệu từ Claims (Phòng trường hợp bạn chưa gán ViewBag ở Controller)
    var hoTen = User.Identity?.Name ?? "N/A";
    var email = User.FindFirst(ClaimTypes.Email)?.Value ?? "N/A";
    var vaiTro = User.FindFirst("UserRole")?.Value ?? "Thành viên";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "N/A";
    var congTy = User.FindFirst("TenCongTy")?.Value ?? "N/A";
    var tenBoPhan = User.FindFirst("TenBoPhan")?.Value ?? "Chưa xác định";
    var moTaBoPhan = User.FindFirst("MoTaBoPhan")?.Value ?? "Không có mô tả chi tiết";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body style="background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; font-family: 'Inter', system-ui, -apple-system, sans-serif;">

    <div style="width: 100%; max-width: 900px; background: #ffffff; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1); overflow: hidden;">

        <div style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); padding: 40px 30px; position: relative;">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.1; background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
            <div style="position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <h2 style="color: #ffffff; font-weight: 800; margin: 0; font-size: 1.75rem; letter-spacing: -0.025em;">Hồ Sơ Cá Nhân</h2>
                    <p style="color: #94a3b8; margin: 5px 0 0 0; font-size: 0.9rem;">Thông tin tài khoản và quyền hạn hệ thống</p>
                </div>
                <div style="background: rgba(255,255,255,0.1); padding: 10px 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                    <span style="color: #38bdf8; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Status: Online</span>
                </div>
            </div>
        </div>

        <div style="padding: 40px;">
            <div class="row">
                <div class="col-lg-4 text-center" style="border-right: 1px solid #f1f5f9; padding-right: 30px;">
                    <div style="position: relative; display: inline-block; margin-bottom: 20px;">
                        <div style="width: 140px; height: 140px; background: #f8fafc; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 4px solid #fff; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); overflow: hidden;">
                            <i class="fas fa-user-tie" style="font-size: 70px; color: #64748b;"></i>
                        </div>
                        <div style="position: absolute; bottom: 8px; right: 8px; width: 28px; height: 28px; background: #10b981; border-radius: 50%; border: 4px solid #fff;"></div>
                    </div>
                    <h4 style="color: #1e293b; font-weight: 700; margin-bottom: 5px;">@hoTen</h4>
                    <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 20px;">@email</p>

                    <div style="background: #eff6ff; color: #1d4ed8; padding: 8px 16px; border-radius: 100px; font-size: 0.8rem; font-weight: 700; display: inline-flex; align-items: center;">
                        <i class="fas fa-shield-alt" style="margin-right: 6px;"></i> @vaiTro
                    </div>
                </div>

                <div class="col-lg-8" style="padding-left: 30px;">
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label style="display: block; color: #94a3b8; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.05em;">Cơ quan / Công ty</label>
                            <div style="color: #334155; font-weight: 600; font-size: 1rem;">
                                <i class="fas fa-building" style="color: #cbd5e1; margin-right: 10px; width: 20px;"></i> @congTy
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <label style="display: block; color: #94a3b8; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.05em;">Phòng ban</label>
                            <div style="color: #334155; font-weight: 600; font-size: 1rem;">
                                <i class="fas fa-layer-group" style="color: #cbd5e1; margin-right: 10px; width: 20px;"></i> @phongBan
                            </div>
                        </div>

                        <div class="col-12">
                            <div style="height: 1px; background: #f1f5f9; margin: 10px 0;"></div>
                        </div>

                        <div class="col-12">
                            <label style="display: block; color: #f43f5e; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-bottom: 12px; letter-spacing: 0.05em;">
                                <i class="fas fa-star" style="margin-right: 5px;"></i> Bộ phận phụ trách chi tiết
                            </label>
                            <div style="background: #fff1f2; border-radius: 16px; padding: 20px; border: 1px solid #ffe4e6;">
                                <div style="color: #9f1239; font-weight: 700; font-size: 1.1rem; margin-bottom: 8px;">
                                    @tenBoPhan
                                </div>
                                <div style="color: #e11d48; font-size: 0.9rem; line-height: 1.6; font-style: italic;">
                                    <i class="fas fa-info-circle" style="margin-right: 8px; opacity: 0.7;"></i> @moTaBoPhan
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div style="background: #f8fafc; padding: 25px 40px; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
            <div style="color: #94a3b8; font-size: 0.85rem;">
                <i class="fas fa-clock" style="margin-right: 5px;"></i> Cập nhật lần cuối: @DateTime.Now.ToString("dd/MM/yyyy")
            </div>
            <div style="display: flex; gap: 15px;">
                <button onclick="window.close()" style="border: 1px solid #e2e8f0; background: #fff; color: #64748b; padding: 10px 25px; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; cursor: pointer;">
                    <i class="fas fa-times me-2"></i>Đóng Tab
                </button>
                <a href="/DonXetDuyet/DangXuat" style="background: #ef4444; color: #fff; padding: 10px 25px; border-radius: 12px; font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: all 0.2s; box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.2); cursor: pointer;">
                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                </a>
            </div>
        </div>
    </div>

    <script>
        const btns = document.querySelectorAll('button, a');
        btns.forEach(btn => {
            btn.onmouseover = () => { btn.style.opacity = '0.85'; btn.style.transform = 'translateY(-1px)'; };
            btn.onmouseout = () => { btn.style.opacity = '1'; btn.style.transform = 'translateY(0)'; };
        });
    </script>
</body>
</html>