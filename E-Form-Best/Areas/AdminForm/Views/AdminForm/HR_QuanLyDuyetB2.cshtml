@{
    ViewData["Title"] = "Quản lý Quy trình duyệt Bước 2";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<style>
    /* PHONG CÁCH SIÊU ĐẸP 2026 & MOBILE RESPONSIVE */
    :root {
        --primary-indigo: #4f46e5;
        --primary-cyan: #06b6d4;
    }

    /* Tab Navigation Tối ưu Cuộn ngang trên Mobile */
    .nav-tabs { 
        border-bottom: 2px solid #ebeef2; 
        flex-wrap: nowrap; 
        overflow-x: auto; 
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
    }
    .nav-tabs::-webkit-scrollbar { display: none; }
    .nav-tabs .nav-item { white-space: nowrap; }
    .nav-tabs .nav-link { 
        color: #6c757d; 
        font-weight: 600; 
        border: none; 
        padding: 14px 24px; 
        transition: all 0.3s ease;
    }
    .nav-tabs .nav-link:hover { 
        color: var(--primary-cyan); 
        background: rgba(6, 182, 212, 0.05); 
    }
    .nav-tabs .nav-link.active { 
        color: var(--primary-indigo); 
        border-bottom: 3px solid var(--primary-indigo); 
        background: none; 
    }

    /* Nội dung Tab - Glassmorphism */
    .tab-content { 
        border: 1px solid #ebeef2; 
        border-top: none; 
        background: rgba(255, 255, 255, 0.95); 
        backdrop-filter: blur(10px);
        border-bottom-left-radius: 12px;
        border-bottom-right-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
    }

    .table thead th { 
        vertical-align: middle; 
        text-align: center; 
        background-color: #f8fafc; 
        text-transform: uppercase; 
        font-size: 0.75rem; 
        letter-spacing: 0.5px;
        color: #475569;
        border-bottom: 2px solid var(--primary-indigo);
    }
    .card-header-flex { display: flex; justify-content: space-between; align-items: center; }

    .select2-container { z-index: 1061 !important; }
    .badge { font-weight: 600; padding: 0.5em 0.8em; border-radius: 8px; }
    .select2-result-bp__title { font-weight: 700; color: #1e293b; }
    .select2-result-bp__note { font-size: 0.8rem; color: #94a3b8; font-style: italic; }
    
    .modal.fade .modal-dialog { transform: translate(0, -20px); transition: transform 0.3s ease-out; }
    .modal.show .modal-dialog { transform: translate(0, 0); }
    .modal-content { border-radius: 16px; border: none; }

    /* CSS TABLE RESPONSIVE - BIẾN BẢNG THÀNH CARD TRÊN MOBILE */
    @@media (max-width: 991.98px) {
        .card-header-flex { flex-direction: column; gap: 12px; align-items: flex-start; }
        .card-header-flex div { width: 100%; display: flex; flex-direction: column; gap: 8px; }
        .card-header-flex div button, .card-header-flex > button { width: 100%; padding: 10px; border-radius: 8px; }

        .table-responsive { border: none; }
        .table thead { display: none; }
        
        .table tbody tr { 
            display: block; 
            margin-bottom: 1.2rem; 
            border: 1px solid #e2e8f0 !important; 
            border-radius: 12px; 
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            background: #fff;
            padding: 8px;
        }

        .table tbody td { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            text-align: right !important; 
            padding: 10px 12px !important;
            border: none !important;
            border-bottom: 1px dashed #f1f5f9 !important;
            min-height: 45px;
        }

        .table tbody td:last-child { 
            border-bottom: none !important; 
            justify-content: center; 
            padding-top: 15px !important; 
        }

        .table tbody td::before {
            content: attr(data-label);
            font-weight: 700;
            color: var(--primary-indigo);
            font-size: 0.75rem;
            text-transform: uppercase;
            text-align: left;
            margin-right: 15px;
        }

        .btn-group { display: flex; width: 100%; gap: 8px; }
        .btn-group .btn { flex: 1; border-radius: 8px !important; padding: 10px; }
    }
</style>

<div class="container-fluid mt-3 mb-5">
    @* Tab Navigation *@
    <ul class="nav nav-tabs" id="hrManageTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" id="quytrinh-tab" data-bs-toggle="tab" data-bs-target="#tab-quytrinh" type="button" role="tab">
                <i class="fa fa-project-diagram me-2"></i>Quy trình duyệt (Chính)
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="congty-tab" data-bs-toggle="tab" data-bs-target="#tab-congty" type="button" role="tab">
                <i class="fa fa-building me-2"></i>Công ty
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="bophan-tab" data-bs-toggle="tab" data-bs-target="#tab-bophan" type="button" role="tab">
                <i class="fa fa-sitemap me-2"></i>Bộ phận
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="loaidon-tab" data-bs-toggle="tab" data-bs-target="#tab-loaidon" type="button" role="tab">
                <i class="fa fa-file-alt me-2"></i>Loại đơn
            </button>
        </li>
    </ul>

    <div class="tab-content p-3 p-md-4 shadow-sm" id="hrManageTabContent">
        @* TAB 1: QUY TRÌNH CHÍNH *@
        <div class="tab-pane fade show active" id="tab-quytrinh" role="tabpanel">
            <div class="card-header-flex mb-4">
                <h5 class="mb-0 fw-bold" style="color: var(--primary-indigo);">
                    <i class="fa fa-cog me-2"></i>Cấu hình luồng duyệt Bước 2
                </h5>
                <div>
                    <button class="btn btn-outline-warning btn-sm me-md-2 fw-bold rounded-pill" onclick="syncBoPhan()">
                        <i class="fa fa-sync-alt me-1"></i> Đồng bộ Bộ phận
                    </button>
                    <button class="btn btn-primary btn-sm fw-bold px-3 shadow-sm rounded-pill" onclick="openCreateModal()">
                        <i class="fa fa-plus me-1"></i> Thêm cấu hình mới
                    </button>
                </div>
            </div>
            <div class="table-responsive border-0">
                <table id="tableMain" class="table table-hover w-100 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Công ty</th>
                            <th>Loại đơn</th>
                            <th>Bộ phận áp dụng</th>
                            <th>Thứ tự</th>
                            <th>Hình thức duyệt</th>
                            <th>Người duyệt (B2)</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

        @* TAB 2: CÔNG TY *@
        <div class="tab-pane fade" id="tab-congty" role="tabpanel">
            <div class="card-header-flex mb-4">
                <h5 class="mb-0 text-success fw-bold"><i class="fa fa-list me-2"></i>Danh sách Công ty</h5>
                <button class="btn btn-success btn-sm fw-bold px-3 shadow-sm rounded-pill" onclick="openModalCongTy()">
                    <i class="fa fa-plus me-1"></i> Thêm Công ty
                </button>
            </div>
            <div class="table-responsive border-0">
                <table id="tableCongTy" class="table table-hover w-100 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px">ID</th>
                            <th>Tên Công ty</th>
                            <th>Ghi chú</th>
                            <th>Trạng thái</th>
                            <th style="width: 80px">Thao tác</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

        @* TAB 3: BỘ PHẬN *@
        <div class="tab-pane fade" id="tab-bophan" role="tabpanel">
            <div class="card-header-flex mb-4">
                <h5 class="mb-0 text-info fw-bold"><i class="fa fa-database me-2"></i>Danh mục Bộ phận (Dữ liệu gốc)</h5>
            </div>
            <div class="table-responsive border-0">
                <table id="tableBoPhan" class="table table-hover w-100 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px">ID Gốc</th>
                            <th>Tên Bộ phận</th>
                            <th>Ghi chú (Mô tả)</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

        @* TAB 4: LOẠI ĐƠN *@
        <div class="tab-pane fade" id="tab-loaidon" role="tabpanel">
            <div class="card-header-flex mb-4">
                <h5 class="mb-0 text-dark fw-bold"><i class="fa fa-folder-open me-2"></i>Danh mục Loại đơn</h5>
                <button class="btn btn-dark btn-sm fw-bold px-3 shadow-sm rounded-pill" onclick="openModalLoaiDon()">
                    <i class="fa fa-plus me-1"></i> Thêm Loại đơn
                </button>
            </div>
            <div class="table-responsive border-0">
                <table id="tableLoaiDon" class="table table-hover w-100 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Tên Loại đơn</th>
                            <th>Trạng thái</th>
                            <th style="width: 80px">Thao tác</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@* --- MODALS SECTION --- *@

@* MODAL CẤU HÌNH QUY TRÌNH *@
<div class="modal fade" id="modalAction" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold" id="modalLabel">Thông tin cấu hình</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formAction">
                <div class="modal-body p-4">
                    <input type="hidden" id="Id" value="0" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Công ty <span class="text-danger">*</span></label>
                            <select class="form-select select2-modal" id="IdcongTy" required></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Loại đơn <span class="text-danger">*</span></label>
                            <select class="form-select select2-modal" id="IdloaiDon" required></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Bộ phận</label>
                            <select class="form-select" id="IdboPhan">
                                <option value="">-- Áp dụng cho tất cả bộ phận --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Người duyệt Bước 2 <span class="text-danger">*</span></label>
                            <select class="form-select select2-modal" id="IdnguoiXacNhan" required>
                                <option value="">-- Chọn nhân viên --</option>
                                @foreach (var item in ViewBag.NguoiXacNhan)
                                {
                                    <option value="@item.IdnguoiXacNhan">@item.MaNv - @item.HoTen</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Hình thức xác nhận <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" id="Loai" required>
                                <option value="ALL">Tất cả phải xác nhận (AND)</option>
                                <option value="ANY">Chỉ cần 1 người duyệt (OR)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Thứ tự duyệt (STT)</label>
                            <input type="number" class="form-control rounded-3" id="Stt" min="1" value="1" required />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Ghi chú cấu hình</label>
                            <input type="text" class="form-control rounded-3" id="GhiChu" placeholder="Ví dụ: Duyệt thay trưởng phòng..." />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch p-3 bg-light rounded-3 border d-flex align-items-center">
                                <input class="form-check-input ms-0 me-3" type="checkbox" id="TrangThai" checked style="width: 40px; height: 20px;">
                                <label class="form-check-label fw-bold text-dark" for="TrangThai">Kích hoạt cấu hình này</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0" style="border-radius: 0 0 16px 16px;">
                    <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill">
                        <i class="fa fa-save me-1"></i> Lưu cấu hình
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* MODAL CÔNG TY *@
<div class="modal fade" id="modalCongTy" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-success text-white border-0">
                <h5 class="modal-title fw-bold" id="modalLabelCT">Thông tin Công ty</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formCongTy">
                <div class="modal-body p-4">
                    <input type="hidden" id="IdcongTy_Modal" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase">Tên Công ty</label>
                        <input type="text" class="form-control rounded-3" id="TenCongTy" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase">Ghi chú</label>
                        <input type="text" class="form-control rounded-3" id="GhiChuCT" />
                    </div>
                    <div class="form-check form-switch border rounded-3 p-3 bg-light d-flex align-items-center">
                        <input class="form-check-input ms-0 me-3" type="checkbox" id="TrangThaiCT" checked style="width: 40px; height: 20px;">
                        <label class="form-check-label fw-bold">Đang hoạt động</label>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 16px 16px;">
                    <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill shadow-sm">Lưu dữ liệu Công ty</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* MODAL LOẠI ĐƠN *@
<div class="modal fade" id="modalLoaiDon" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-dark text-white border-0">
                <h5 class="modal-title fw-bold" id="modalLabelLD">Thông tin Loại đơn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formLoaiDon">
                <div class="modal-body p-4">
                    <input type="hidden" id="IdloaiDon_LD" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase">Mã loại đơn (Ví dụ: DXP, DXN)</label>
                        <input type="text" class="form-control text-uppercase rounded-3" id="MaLoaiDon" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase">Tên loại đơn</label>
                        <input type="text" class="form-control rounded-3" id="TenLoaiDon" required />
                    </div>
                    <div class="form-check form-switch border rounded-3 p-3 bg-light d-flex align-items-center">
                        <input class="form-check-input ms-0 me-3" type="checkbox" id="TrangThaiLD" checked style="width: 40px; height: 20px;">
                        <label class="form-check-label fw-bold">Cho phép sử dụng</label>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 16px 16px;">
                    <button type="submit" class="btn btn-dark w-100 fw-bold rounded-pill shadow-sm">Lưu Loại đơn</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let tableMain, tableCT, tableBP, tableLD;

        $(document).ready(function () {
            initTables();
            loadAllSelects();

            $('.modal').on('shown.bs.modal', function () {
                $(this).find('.select2-modal').select2({
                    dropdownParent: $(this),
                    width: '100%'
                });

                $('#IdboPhan').select2({
                    dropdownParent: $('#modalAction'),
                    width: '100%',
                    templateResult: formatBoPhan,
                    templateSelection: function(data) { return data.text; },
                    escapeMarkup: function(m) { return m; } 
                });
            });

            $('#formAction').on('submit', function (e) { e.preventDefault(); saveData(); });
            $('#formCongTy').on('submit', function (e) { e.preventDefault(); saveCongTy(); });
            $('#formLoaiDon').on('submit', function (e) { e.preventDefault(); saveLoaiDon(); });
        });

        function formatBoPhan(state) {
            if (!state.id) return state.text;
            let note = $(state.element).data('note');
            let noteHtml = note ? `<span class="select2-result-bp__note ms-2">- ${note}</span>` : "";
            return `<div class="d-flex justify-content-between align-items-center">
                        <span class="select2-result-bp__title">${state.text}</span>
                        ${noteHtml}
                    </div>`;
        }

        function initTables() {
            const commonConfig = {
                processing: true,
                serverSide: false,
                language: { url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/vi.json' }
            };

            tableMain = $('#tableMain').DataTable({
                ...commonConfig,
                ajax: '/HR_QuanLyDuyetB2/GetData',
                columns: [
                    { data: 'tenCongTy', createdCell: function (td) { $(td).attr('data-label', 'Công ty'); } },
                    { data: 'tenLoaiDon', createdCell: function (td) { $(td).attr('data-label', 'Loại đơn'); } },
                    { 
                        data: 'tenBoPhan',
                        createdCell: function (td) { $(td).attr('data-label', 'Bộ phận áp dụng'); },
                        render: d => d === "Tất cả" ? `<span class="text-muted"><i>${d}</i></span>` : `<b class="text-dark">${d}</b>`
                    },
                    { data: 'stt', className: 'text-center fw-bold text-primary', createdCell: function (td) { $(td).attr('data-label', 'Thứ tự'); } },
                    { 
                        data: 'loai',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Hình thức duyệt'); },
                        render: d => d === "ANY" 
                            ? '<span class="badge bg-info"><i class="fa fa-check me-1"></i>Chỉ cần 1 người</span>' 
                            : '<span class="badge bg-secondary"><i class="fa fa-users me-1"></i>Tất cả xác nhận</span>'
                    },
                    { data: 'hoTenNguoiDuyet', createdCell: function (td) { $(td).attr('data-label', 'Người duyệt (B2)'); } },
                    {
                        data: 'trangThai',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Trạng thái'); },
                        render: d => d ? '<span class="badge bg-success">Đang dùng</span>' : '<span class="badge bg-danger">Tạm ngưng</span>'
                    },
                    {
                        data: 'id',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Thao tác'); },
                        render: (data, type, row) => `
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-info" title="Sửa" onclick='editItem(${JSON.stringify(row)})'><i class="fa fa-edit"></i></button>
                                <button class="btn btn-sm btn-outline-danger" title="Xóa" onclick='deleteItem(${data})'><i class="fa fa-trash"></i></button>
                            </div>`
                    }
                ]
            });

            tableCT = $('#tableCongTy').DataTable({
                ...commonConfig,
                ajax: '/HR_QuanLyDuyetB2/GetCongTy',
                columns: [
                    { data: 'idcongTy', className: 'text-center', createdCell: function (td) { $(td).attr('data-label', 'ID'); } },
                    { data: 'tenCongTy', className: 'fw-bold', createdCell: function (td) { $(td).attr('data-label', 'Tên Công ty'); } },
                    { data: 'ghiChu', createdCell: function (td) { $(td).attr('data-label', 'Ghi chú'); } },
                    {
                        data: 'trangThai',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Trạng thái'); },
                        render: d => d ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Locked</span>'
                    },
                    {
                        data: 'idcongTy',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Thao tác'); },
                        render: (data, type, row) => `<button class="btn btn-sm btn-outline-success rounded-pill px-3" onclick='editCT(${JSON.stringify(row)})'><i class="fa fa-edit"></i></button>`
                    }
                ]
            });

            tableBP = $('#tableBoPhan').DataTable({
                ...commonConfig,
                ajax: '/HR_QuanLyDuyetB2/GetBoPhan',
                columns: [
                    { data: 'idboPhan', className: 'text-center fw-bold', createdCell: function (td) { $(td).attr('data-label', 'ID Gốc'); } },
                    { data: 'tenBoPhan', createdCell: function (td) { $(td).attr('data-label', 'Tên Bộ phận'); } },
                    { data: 'ghiChu', createdCell: function (td) { $(td).attr('data-label', 'Ghi chú'); } },
                    {
                        data: 'trangThai',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Trạng thái'); },
                        render: d => d ? '<span class="badge bg-info">Active</span>' : '<span class="badge bg-danger">Locked</span>'
                    }
                ]
            });

            tableLD = $('#tableLoaiDon').DataTable({
                ...commonConfig,
                ajax: '/HR_QuanLyDuyetB2/GetLoaiDon',
                columns: [
                    { data: 'maLoaiDon', className: 'fw-bold', createdCell: function (td) { $(td).attr('data-label', 'Mã đơn'); } },
                    { data: 'tenLoaiDon', createdCell: function (td) { $(td).attr('data-label', 'Tên Loại đơn'); } },
                    {
                        data: 'trangThai',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Trạng thái'); },
                        render: d => d ? '<span class="badge bg-success">Hoạt động</span>' : '<span class="badge bg-danger">Khóa</span>'
                    },
                    {
                        data: 'idloaiDon',
                        className: 'text-center',
                        createdCell: function (td) { $(td).attr('data-label', 'Thao tác'); },
                        render: (data, type, row) => `<button class="btn btn-sm btn-outline-dark rounded-pill px-3" onclick='editLD(${JSON.stringify(row)})'><i class="fa fa-edit"></i></button>`
                    }
                ]
            });
        }

        function loadAllSelects() {
            Promise.all([
                fetch('/HR_QuanLyDuyetB2/GetCongTy').then(r => r.json()),
                fetch('/HR_QuanLyDuyetB2/GetLoaiDon').then(r => r.json()),
                fetch('/HR_QuanLyDuyetB2/GetBoPhan').then(r => r.json())
            ]).then(([resCT, resLD, resBP]) => {
                $('#IdcongTy').html(resCT.data.filter(x => x.trangThai).map(c => `<option value="${c.idcongTy}">${c.tenCongTy}</option>`).join(''));
                $('#IdloaiDon').html('<option value="">-- Chọn loại đơn --</option>' + resLD.data.filter(x => x.trangThai).map(l => `<option value="${l.idloaiDon}">${l.tenLoaiDon}</option>`).join(''));

                let htmlBP = '<option value="">-- Áp dụng cho tất cả bộ phận --</option>';
                resBP.data.filter(x => x.trangThai).forEach(b => {
                    let note = b.ghiChu ? b.ghiChu : "";
                    htmlBP += `<option value="${b.idboPhan}" data-note="${note}">${b.tenBoPhan}</option>`;
                });
                $('#IdboPhan').html(htmlBP);
            });
        }

        function openCreateModal() {
            $('#formAction')[0].reset();
            $('#Id').val(0);
            $('#Loai').val("ALL");
            $('#IdcongTy, #IdloaiDon, #IdboPhan, #IdnguoiXacNhan').val(null).trigger('change');
            $('#modalLabel').text('Thêm cấu hình duyệt Bước 2');
            $('#modalAction').modal('show');
        }

        function editItem(row) {
            $('#Id').val(row.id);
            $('#IdloaiDon').val(row.idloaiDon).trigger('change');
            $('#IdcongTy').val(row.idcongTy).trigger('change');
            $('#IdboPhan').val(row.idboPhan || "").trigger('change');
            $('#Stt').val(row.stt);
            $('#IdnguoiXacNhan').val(row.idnguoiXacNhan).trigger('change');
            $('#Loai').val(row.loai || "ALL");
            $('#GhiChu').val(row.ghiChu);
            $('#TrangThai').prop('checked', row.trangThai);
            $('#modalLabel').text('Chỉnh sửa cấu hình duyệt');
            $('#modalAction').modal('show');
        }

        function saveData() {
            const model = {
                Id: parseInt($('#Id').val()),
                IdloaiDon: parseInt($('#IdloaiDon').val()),
                IdcongTy: parseInt($('#IdcongTy').val()),
                IdboPhan: $('#IdboPhan').val() ? parseInt($('#IdboPhan').val()) : null,
                Stt: parseInt($('#Stt').val()),
                IdnguoiXacNhan: parseInt($('#IdnguoiXacNhan').val()),
                Loai: $('#Loai').val(),
                GhiChu: $('#GhiChu').val(),
                TrangThai: $('#TrangThai').is(':checked')
            };

            if (!model.IdcongTy || !model.IdloaiDon || !model.IdnguoiXacNhan) {
                Swal.fire('Chú ý', 'Vui lòng chọn đầy đủ các thông tin bắt buộc!', 'warning');
                return;
            }

            fetch('/HR_QuanLyDuyetB2/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(model)
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    tableMain.ajax.reload(null, false);
                    Swal.fire({
                        icon: 'success',
                        title: 'Đã lưu cấu hình',
                        text: 'Dữ liệu đã được lưu thành công.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    
                    $('#Id').val(0);
                    $('#GhiChu').val('');
                    $('#modalAction').modal('hide');
                } else {
                    Swal.fire('Lỗi', res.message, 'error');
                }
            })
            .catch(err => {
                Swal.fire('Lỗi hệ thống', 'Không thể kết nối máy chủ.', 'error');
            });
        }

        function deleteItem(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Dữ liệu này sẽ biến mất khỏi danh sách!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Bỏ qua'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/HR_QuanLyDuyetB2/Delete/${id}`, { method: 'POST' })
                    .then(r => r.json()).then(res => {
                        if (res.success) {
                            tableMain.ajax.reload();
                            Swal.fire('Đã xóa!', '', 'success');
                        }
                    });
                }
            });
        }

        function openModalCongTy() {
            $('#formCongTy')[0].reset();
            $('#IdcongTy_Modal').val(0);
            $('#modalLabelCT').text('Thêm Công ty');
            $('#modalCongTy').modal('show');
        }

        function editCT(row) {
            $('#IdcongTy_Modal').val(row.idcongTy);
            $('#TenCongTy').val(row.tenCongTy);
            $('#GhiChuCT').val(row.ghiChu);
            $('#TrangThaiCT').prop('checked', row.trangThai);
            $('#modalLabelCT').text('Cập nhật Công ty');
            $('#modalCongTy').modal('show');
        }

        function saveCongTy() {
            const data = {
                IdcongTy: parseInt($('#IdcongTy_Modal').val()),
                TenCongTy: $('#TenCongTy').val(),
                GhiChu: $('#GhiChuCT').val(),
                TrangThai: $('#TrangThaiCT').is(':checked')
            };
            fetch('/HR_QuanLyDuyetB2/SaveCongTy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            }).then(r => r.json()).then(res => {
                if (res.success) {
                    $('#modalCongTy').modal('hide');
                    tableCT.ajax.reload();
                    loadAllSelects();
                    Swal.fire('Thành công', 'Dữ liệu công ty đã được lưu.', 'success');
                }
            });
        }

        function openModalLoaiDon() {
            $('#formLoaiDon')[0].reset();
            $('#IdloaiDon_LD').val(0);
            $('#modalLabelLD').text('Thêm Loại đơn');
            $('#modalLoaiDon').modal('show');
        }

        function editLD(row) {
            $('#IdloaiDon_LD').val(row.idloaiDon);
            $('#MaLoaiDon').val(row.maLoaiDon);
            $('#TenLoaiDon').val(row.tenLoaiDon);
            $('#TrangThaiLD').prop('checked', row.trangThai);
            $('#modalLabelLD').text('Cập nhật Loại đơn');
            $('#modalLoaiDon').modal('show');
        }

        function saveLoaiDon() {
            const data = {
                IdloaiDon: parseInt($('#IdloaiDon_LD').val()),
                MaLoaiDon: $('#MaLoaiDon').val(),
                TenLoaiDon: $('#TenLoaiDon').val(),
                TrangThai: $('#TrangThaiLD').is(':checked')
            };
            fetch('/HR_QuanLyDuyetB2/SaveLoaiDon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            }).then(r => r.json()).then(res => {
                if (res.success) {
                    $('#modalLoaiDon').modal('hide');
                    tableLD.ajax.reload();
                    loadAllSelects();
                    Swal.fire('Thành công', 'Dữ liệu loại đơn đã được lưu.', 'success');
                }
            });
        }

        function syncBoPhan() {
            Swal.fire({
                title: 'Bắt đầu đồng bộ?',
                text: "Hệ thống sẽ lấy dữ liệu bộ phận mới nhất từ bảng gốc.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Đồng bộ ngay',
                cancelButtonText: 'Để sau'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Đang xử lý...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    fetch('/HR_QuanLyDuyetB2/SyncBoPhan', { method: 'POST' })
                    .then(r => r.json()).then(res => {
                        Swal.close();
                        if(res.success){
                            Swal.fire('Thành công', res.message, 'success').then(() => {
                                tableBP.ajax.reload();
                                loadAllSelects();
                            });
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    }).catch(() => {
                        Swal.close();
                        Swal.fire('Lỗi kết nối', 'Không thể gọi Action Sync.', 'error');
                    });
                }
            });
        }
    </script>
}