@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>
@{
    ViewData["Title"] = "Kiểm Soát Cổng";
    Layout = "~/Areas/HRform/Views/Shared/_Layout.cshtml";

    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.BaoVeHrs.Any(b => b.TrangThai == 1)) ?? 0;
    var pending = total - completed;
}

<div style="background: #f8fafc; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif;">
    <div style="max-width: 1500px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <div>
                <h2 style="margin: 0; font-size: 26px; font-weight: 1000; color: #0f172a; display: flex; align-items: center; gap: 12px;">
                    <i class="fa fa-shield" style="color: #0f172a;"></i> CỔNG AN NINH
                </h2>
                <span style="background: #1e293b; color: white; padding: 4px 12px; border-radius: 6px; font-size: 10px; font-weight: 800; text-transform: uppercase;">@ViewBag.UserRole</span>
            </div>

            <div style="position: relative;">
                <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên nhân viên, mã đơn..."
                       style="padding: 12px 15px 12px 40px; border-radius: 12px; border: 1px solid #cbd5e1; width: 350px; outline: none; font-weight: 600;">
                <i class="fa fa-search" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #94a3b8;"></i>
            </div>
        </div>

        @* --- STATS --- *@
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 25px;">
            <div onclick="filterByStatus('')" style="background: white; padding: 20px; border-radius: 15px; border: 1px solid #e2e8f0; cursor: pointer;">
                <div style="font-size: 10px; font-weight: 900; color: #64748b;">TỔNG ĐƠN ĐIỀU PHỐI</div>
                <div style="font-size: 28px; font-weight: 1000; color: #0f172a;">@total</div>
            </div>
            <div onclick="filterByStatus('CHỜ')" style="background: #fffbeb; padding: 20px; border-radius: 15px; border: 1px solid #fde68a; cursor: pointer;">
                <div style="font-size: 10px; font-weight: 900; color: #b45309;">ĐANG ĐỢI TẠI CỔNG</div>
                <div style="font-size: 28px; font-weight: 1000; color: #d97706;">@pending</div>
            </div>
            <div onclick="filterByStatus('XONG')" style="background: #f0fdf4; padding: 20px; border-radius: 15px; border: 1px solid #bbf7d0; cursor: pointer;">
                <div style="font-size: 10px; font-weight: 900; color: #166534;">ĐÃ XÁC NHẬN QUA</div>
                <div style="font-size: 28px; font-weight: 1000; color: #15803d;">@completed</div>
            </div>
        </div>

        @* --- TABLE --- *@
        <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 15px 20px; text-align: left; font-size: 11px; color: #64748b; font-weight: 900; text-transform: uppercase;">Thông tin nhân viên</th>
                        <th style="padding: 15px 20px; text-align: left; font-size: 11px; color: #64748b; font-weight: 900; text-transform: uppercase;">Loại đơn</th>
                        <th style="padding: 15px 20px; text-align: left; font-size: 11px; color: #64748b; font-weight: 900; text-transform: uppercase;">BV Xác nhận</th>
                        <th style="padding: 15px 20px; text-align: center; font-size: 11px; color: #64748b; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 15px 20px; width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var bv = item.BaoVeHrs.FirstOrDefault();
                        bool isDone = bv?.TrangThai == 1;
                        string rowBg = isDone ? "white" : "#fffbeb";
                        string stColor = isDone ? "#10b981" : "#f59e0b";

                        <tr style="border-bottom: 1px solid #f1f5f9; background: @rowBg; transition: 0.2s;">
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 900; color: #1e293b;">@item.TenNguoiNv</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700;">#@item.Id • MS: @item.SoNhanVien</div>
                            </td>
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 800; font-size: 13px; color: #334155;">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</div>
                                <div style="font-size: 11px; color: #94a3b8; font-weight: 600;">Phòng: @item.BoPhan</div>
                            </td>
                            <td style="padding: 15px 20px;">
                                @if (isDone)
                                {
                                    <div style="font-size: 12px; font-weight: 800; color: #475569;">@bv.TimeBaoVe?.ToString("HH:mm dd/MM")</div>
                                    <div style="font-size: 10px; color: #94a3b8;">XN bởi: @bv.TenBaoVe</div>
                                }
                                else
                                {
                                    <span style="font-size: 11px; color: #cbd5e1; font-style: italic;">Đang đợi...</span>
                                }
                            </td>
                            <td style="padding: 15px 20px; text-align: center;">
                                <span style="border: 2px solid @stColor; color: @stColor; padding: 4px 10px; border-radius: 8px; font-size: 10px; font-weight: 1000; background: white;">
                                    @(isDone ? "XONG" : "CHỜ")
                                </span>
                            </td>
                            <td style="padding: 15px 20px;">
                                <a href="/FormHR/ChiTiet/@item.Id" style="color: #0f172a;"><i class="fa fa-arrow-right"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const filter = document.getElementById("searchInput").value.toUpperCase();
        const trs = document.querySelectorAll("#dataTable tbody tr");
        trs.forEach(tr => tr.style.display = tr.innerText.toUpperCase().includes(filter) ? "" : "none");
    }
    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        filterTable();
    }
</script>