@{
    ViewData["Title"] = "Quản lý Bộ Phận";
    Layout = "~/Areas/AdminForm/Views/Shared/_Layout.cshtml";
}

<style>
    /* Đảm bảo Select2 hiển thị đẹp trong Modal Bootstrap 5 */
    .select2-container--default .select2-selection--single {
        height: 38px;
        border: 1px solid #dee2e6;
        display: flex;
        align-items: center;
    }
    /* Style cho danh sách bộ phận dạng checkbox */
    .bp-checkbox-container {
        max-height: 250px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        padding: 10px;
        border-radius: 5px;
        background: #fdfdfd;
    }

    .bp-item {
        transition: all 0.2s;
        border: 1px solid transparent;
        margin-bottom: 2px;
    }

        .bp-item:hover {
            background-color: #f1f1f1;
            cursor: pointer;
        }

    .bp-selected {
        background-color: #fff3cd !important; /* Màu cảnh báo nhạt */
        border: 1px solid #ffeeba !important;
    }
</style>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h4 class="m-0 fw-bold text-dark">Quản lý danh mục Bộ Phận</h4>
            </div>
            <div class="col-sm-6 text-end">
                <button class="btn btn-danger me-1" id="btnDeleteSelected" onclick="deleteSelected()" style="display:none;">
                    <i class="fas fa-trash"></i> Xóa đã chọn
                </button>
                <button class="btn btn-info me-1 text-white" onclick="syncFromUser()">
                    <i class="fas fa-sync"></i> Đồng bộ từ User
                </button>
                <button class="btn btn-primary" onclick="openModalBP(0)">
                    <i class="fas fa-plus"></i> Thêm Bộ phận
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span><i class="fas fa-user-tag me-2"></i>Gán nhanh bộ phận cho nhân viên</span>
                <span class="badge bg-warning text-dark small">Tự động lưu khi tích chọn</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="small fw-bold">1. Chọn nhân viên:</label>
                        <select id="selectMainUser" class="form-control select2-main">
                            <option value="">-- Tìm nhân viên --</option>
                            @if (ViewBag.Users != null)
                            {
                                foreach (var item in ViewBag.Users)
                                {
                                    <option value="@item.IdNguoiDung">@item.HoTen (@item.Tk)</option>
                                }
                            }
                        </select>
                        <div class="mt-2">
                            <label class="small fw-bold">Loại gán mặc định:</label>
                            <input type="text" id="txtLoaiChung" class="form-control form-control-sm" placeholder="VD: Kiêm nhiệm, chính thức..." value="Chính thức" />
                        </div>
                    </div>
                    <div class="col-md-8 border-start">
                        <label class="small fw-bold">2. Danh sách bộ phận (Tích để gán - Bỏ tích để xóa):</label>
                        <div class="bp-checkbox-container mb-2" id="listBPCheckbox">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="tableBP">
                        <thead class="table-light">
                            <tr>
                                <th width="40" class="text-center">
                                    <input type="checkbox" id="selectAll" class="form-check-input" />
                                </th>
                                <th width="60">ID</th>
                                <th>Tên Bộ Phận</th>
                                <th>Mô tả (Công ty)</th>
                                <th width="120">Ngày tạo</th>
                                <th width="150" class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyBoPhan"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="modalBP" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitleBP">Thông tin bộ phận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="txtIdBoPhan" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên bộ phận <span class="text-danger">*</span></label>
                    <input type="text" id="txtTenBoPhan" class="form-control" placeholder="Nhập tên bộ phận..." autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả (Tên công ty) <span class="text-danger">*</span></label>
                    <textarea id="txtMoTa" class="form-control" rows="3" placeholder="Nhập mô tả công ty..."></textarea>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary px-4" onclick="saveBoPhan()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNhanSu" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-users me-2"></i>Thành viên: <span id="titleBP" class="fw-bold"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2 mb-4 p-3 bg-light rounded shadow-sm">
                    <div class="col-md-5">
                        <label class="small fw-bold">Chọn nhân viên:</label>
                        <select id="selectUser" class="form-control select2-modal" style="width:100%">
                            <option value="">-- Chọn nhân viên --</option>
                            @if (ViewBag.Users != null)
                            {
                                foreach (var item in ViewBag.Users)
                                {
                                    <option value="@item.IdNguoiDung">@item.HoTen (@item.Tk)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="small fw-bold">Loại nhân sự:</label>
                        <input type="text" id="txtLoai" class="form-control" placeholder="VD: Chính thức, Part-time" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-success w-100" onclick="addUserToBP()">
                            <i class="fas fa-plus"></i> Gán vào BP
                        </button>
                    </div>
                </div>

                <div class="table-responsive" style="max-height: 400px;">
                    <table class="table table-sm table-hover table-bordered">
                        <thead class="table-secondary">
                            <tr>
                                <th>Họ tên</th>
                                <th>Tài khoản</th>
                                <th>Loại</th>
                                <th width="60" class="text-center">#</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyUserInBP"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadBoPhan();

            // Khởi tạo Select2
            $('.select2-modal').select2({
                dropdownParent: $('#modalNhanSu'),
                placeholder: "-- Chọn nhân viên --",
                allowClear: true
            });

            $('.select2-main').select2({
                placeholder: "-- Chọn nhân viên --",
                allowClear: true
            });

            // 1. XỬ LÝ KHI CHỌN NHÂN VIÊN Ở PANEL GÁN NHANH
            $('#selectMainUser').on('change', function () {
                let userId = $(this).val();
                $('.multi-bp-check').prop('checked', false);
                $('.bp-item').removeClass('bp-selected');

                if (userId) {
                    $.get('/QLBoPhanAamin/GetUserCurrentBPs', { idUser: userId }, function (res) {
                        if (res.success && res.data) {
                            res.data.forEach(idBP => {
                                let cb = $(`.multi-bp-check[value="${idBP}"]`);
                                cb.prop('checked', true);
                                cb.closest('.bp-item').addClass('bp-selected');
                            });
                        }
                    });
                }
            });

            // 2. XỬ LÝ TỰ ĐỘNG LƯU/XÓA KHI TÍCH CHỌN BỘ PHẬN
            $(document).on('change', '.multi-bp-check', function () {
                let userId = $('#selectMainUser').val();
                let idBP = $(this).val();
                let isChecked = $(this).is(':checked');
                let $parentDiv = $(this).closest('.bp-item');

                if (!userId) {
                    Swal.fire("Thông báo", "Vui lòng chọn nhân viên trước khi thực hiện gán bộ phận!", "warning");
                    $(this).prop('checked', !isChecked); // Trả lại trạng thái cũ
                    return;
                }

                if (isChecked) {
                    // THÊM VÀO BỘ PHẬN
                    let loai = $('#txtLoaiChung').val() || "Chính thức";
                    $.post('/QLBoPhanAamin/AddUserToBP', { idUser: userId, idBP: idBP, loai: loai }, function (res) {
                        if (res.success) {
                            $parentDiv.addClass('bp-selected');
                        } else {
                            Swal.fire("Lỗi", res.msg, "error");
                            $(this).prop('checked', false);
                        }
                    });
                } else {
                    // XÓA KHỎI BỘ PHẬN
                    $.post('/QLBoPhanAamin/RemoveUserFromBP', { idUser: userId, idBP: idBP }, function (res) {
                        if (res.success) {
                            $parentDiv.removeClass('bp-selected');
                        } else {
                            Swal.fire("Lỗi", res.msg, "error");
                            $(this).prop('checked', true);
                        }
                    });
                }
            });

            // Chọn tất cả checkbox bảng
            $('#selectAll').on('change', function() {
                $('.item-check').prop('checked', this.checked);
                toggleDeleteBtn();
            });

            // Làm sạch modal
            $('.modal').on('hidden.bs.modal', function () {
                $(this).find('input[type="text"], textarea').val('');
                $(this).find('input[type="hidden"]').val('0');
            });
        });

        function toggleDeleteBtn() {
            let count = $('.item-check:checked').length;
            $('#btnDeleteSelected').toggle(count > 0);
        }

        function loadBoPhan() {
            $.get('/QLBoPhanAamin/GetListBoPhan', function (res) {
                let html = '';
                let checkboxHtml = '';
                if(res.data) {
                    res.data.forEach(item => {
                        html += `<tr>
                            <td class="text-center"><input type="checkbox" class="item-check form-check-input" value="${item.idBoPhan}" onchange="toggleDeleteBtn()" /></td>
                            <td class="text-muted">${item.idBoPhan}</td>
                            <td><span class="fw-bold text-primary">${item.tenBoPhan || ''}</span></td>
                            <td>${item.moTa || ''}</td>
                            <td>${item.ngayTao ? new Date(item.ngayTao).toLocaleDateString('vi-VN') : ''}</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-info" title="Thành viên" onclick="openModalUser(${item.idBoPhan}, '${item.tenBoPhan}')"><i class="fas fa-users"></i></button>
                                    <button class="btn btn-sm btn-outline-warning" title="Sửa" onclick='editBP(${JSON.stringify(item)})'><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" title="Xóa" onclick="deleteBP(${item.idBoPhan})"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>`;

                        let moTaHienThi = item.moTa ? `(${item.moTa})` : '';
                        checkboxHtml += `
                            <div class="form-check form-check-inline bp-item p-1 px-2 rounded border m-1">
                                <input class="form-check-input multi-bp-check" type="checkbox" value="${item.idBoPhan}" id="multi_bp_${item.idBoPhan}">
                                <label class="form-check-label small" for="multi_bp_${item.idBoPhan}">
                                    <span class="fw-bold text-dark">${item.tenBoPhan}</span> <span class="text-muted small">${moTaHienThi}</span>
                                </label>
                            </div>`;
                    });
                }
                $('#tbodyBoPhan').html(html);
                $('#listBPCheckbox').html(checkboxHtml);
                $('#selectAll').prop('checked', false);
                toggleDeleteBtn();

                if($('#selectMainUser').val()) {
                    $('#selectMainUser').trigger('change');
                }
            });
        }

        function openModalBP(id) {
            $('#txtIdBoPhan').val(id);
            $('#txtTenBoPhan').val('');
            $('#txtMoTa').val('');
            $('#modalTitleBP').text(id === 0 ? "Thêm bộ phận mới" : "Cập nhật bộ phận");
            $('#modalBP').modal('show');
        }

        function editBP(item) {
            $('#txtIdBoPhan').val(item.idBoPhan);
            $('#txtTenBoPhan').val(item.tenBoPhan);
            $('#txtMoTa').val(item.moTa);
            $('#modalTitleBP').text("Cập nhật bộ phận");
            $('#modalBP').modal('show');
        }

        function saveBoPhan() {
            let data = {
                IdBoPhan: parseInt($('#txtIdBoPhan').val()),
                TenBoPhan: $('#txtTenBoPhan').val().trim(),
                MoTa: $('#txtMoTa').val().trim()
            };
            if(!data.TenBoPhan || !data.MoTa) {
                Swal.fire("Thông báo", "Vui lòng nhập đủ Tên và Mô tả công ty!", "warning");
                return;
            }
            $.post('/QLBoPhanAamin/SaveBoPhan', data, function (res) {
                if (res.success) {
                    $('#modalBP').modal('hide');
                    loadBoPhan();
                    Swal.fire("Thành công", "Lưu dữ liệu bộ phận thành công!", "success");
                } else {
                    Swal.fire("Lỗi", res.msg, "error");
                }
            });
        }

        function deleteBP(id) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Dữ liệu bộ phận sẽ bị xóa vĩnh viễn!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLBoPhanAamin/DeleteBoPhan', { id: id }, function (res) {
                        if (res.success) {
                            loadBoPhan();
                            Swal.fire("Đã xóa", "Bộ phận đã được loại bỏ.", "success");
                        } else {
                            Swal.fire("Lỗi", res.msg, "error");
                        }
                    });
                }
            });
        }

        function deleteSelected() {
            let ids = [];
            $('.item-check:checked').each(function() { ids.push($(this).val()); });
            if (ids.length === 0) return;
            Swal.fire({
                title: 'Xóa hàng loạt?',
                text: `Bạn muốn xóa ${ids.length} bộ phận đã chọn?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Đồng ý'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLBoPhanAamin/DeleteSelected', { ids: ids }, function (res) {
                        Swal.fire("Kết quả", res.msg, "info");
                        loadBoPhan();
                    });
                }
            });
        }

        function syncFromUser() {
            Swal.fire({
                title: 'Đồng bộ dữ liệu?',
                text: "Hệ thống sẽ cập nhật bộ phận từ danh sách User.",
                icon: 'question',
                showCancelButton: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLBoPhanAamin/SyncFromUser', function (res) {
                        Swal.fire("Hoàn tất", res.msg, "success");
                        loadBoPhan();
                    });
                }
            });
        }

        var currentBP = 0;
        function openModalUser(id, name) {
            currentBP = id;
            $('#titleBP').text(name);
            $('#selectUser').val('').trigger('change');
            $('#txtLoai').val('');
            loadUsersInBP(id);
            $('#modalNhanSu').modal('show');
        }

        function loadUsersInBP(id) {
            $.get('/QLBoPhanAamin/GetUsersByBP', { idBoPhan: id }, function (res) {
                let html = '';
                if(res.data) {
                    res.data.forEach(u => {
                        html += `<tr>
                            <td>${u.hoTen}</td>
                            <td><code class="text-danger">${u.taiKhoan}</code></td>
                            <td><span class="badge bg-secondary">${u.loai || 'N/A'}</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-danger border-0" onclick="removeUser(${u.idNguoiDung})">
                                    <i class="fas fa-user-minus"></i>
                                </button>
                            </td>
                        </tr>`;
                    });
                }
                $('#tbodyUserInBP').html(html);
            });
        }

        function addUserToBP() {
            let idU = $('#selectUser').val();
            if(!idU) {
                Swal.fire("Lưu ý", "Vui lòng chọn nhân viên trước!", "warning");
                return;
            }
            $.post('/QLBoPhanAamin/AddUserToBP', { idUser: idU, idBP: currentBP, loai: $('#txtLoai').val() }, function(res) {
                if(res.success) {
                    loadUsersInBP(currentBP);
                    $('#selectUser').val('').trigger('change');
                } else {
                    Swal.fire("Lỗi", res.msg, "error");
                }
            });
        }

        function removeUser(idU) {
            Swal.fire({
                title: 'Gỡ nhân sự?',
                text: "Xóa nhân viên này khỏi bộ phận?",
                icon: 'warning',
                showCancelButton: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/QLBoPhanAamin/RemoveUserFromBP', { idUser: idU, idBP: currentBP }, function(res) {
                        if(res.success) loadUsersInBP(currentBP);
                    });
                }
            });
        }
    </script>
}