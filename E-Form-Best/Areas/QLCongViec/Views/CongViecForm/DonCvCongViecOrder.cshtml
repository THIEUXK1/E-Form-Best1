@model E_Form_Best.Models.ITForm.FormCongViec
@using System.Security.Claims

@{
    ViewData["Title"] = "Tạo đơn công việc chỉ định";
    Layout = "~/Areas/QLCongViec/Views/Shared/_Layout.cshtml";

    // --- Lấy thông tin từ User.Claims ---
    var tenNguoiNv = User.Identity?.Name ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = Model.TenCongTy ?? User.FindFirst("TenCongTy")?.Value ?? "Chưa xác định";

    // CHUẨN HÓA SẮC XANH CỎ NON MẠ NON CHỦ ĐẠO THỜI THƯỢNG (#65a30d)
    string colorPrimary = "#65a30d";
    string colorDark = "#2d4201";
    string colorLight = "#f7fee7";
    string colorBorder = "#bef264";

    string inputBase = $"width: 100%; padding: 12px; border-radius: 12px; border: 1px solid {colorBorder}; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; color: {colorDark}; transition: all 0.3s;";
    string labelBase = $"font-weight: 800; color: {colorDark}; font-size: 11px; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 0.8px;";
    string boxDetail = $"background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid {colorLight}; margin-bottom: 30px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);";
}

<style>
    /* CSS RESPONSIVE TRÊN MOBILE HOÀN TOÀN */
    @@media (max-width: 768px) {
        .main-container {
            padding: 20px 10px !important;
        }

        .form-wrapper {
            border-radius: 25px !important;
        }

        .header-section {
            padding: 35px 15px !important;
        }

            .header-section h2 {
                font-size: 20px !important;
            }

        .body-content {
            padding: 20px !important;
        }

        .grid-responsive-4, .grid-responsive-2 {
            grid-template-columns: 1fr !important;
            gap: 12px !important;
        }

        .box-detail-mobile {
            padding: 15px !important;
            border-radius: 20px !important;
        }

        #paste_area, .file-upload-box {
            height: 150px !important;
        }

        #btnSubmit {
            padding: 18px !important;
            font-size: 16px !important;
        }
    }

    /* Vòng bo sáng rực khi click chuột vào ô nhập liệu (Focus) */
    .input-hover:focus {
        border-color: @colorPrimary !important;
        box-shadow: 0 0 0 4px rgba(101, 163, 13, 0.15) !important;
    }

    /* ĐA CHỌN NHÂN SỰ MULTI-CHECKBOX DROPDOWN STYLE */
    .multiselect-container {
        position: relative;
        width: 100%;
    }

    .select-box {
        position: relative;
        cursor: pointer;
    }

    .checkboxes-dropdown {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background-color: #ffffff;
        border: 1px solid @colorBorder;
        border-radius: 12px;
        max-height: 260px;
        overflow-y: auto;
        z-index: 1000;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        margin-top: 4px;
        padding: 5px;
    }

        .checkboxes-dropdown label {
            display: flex !important;
            align-items: center;
            gap: 10px;
            padding: 10px;
            margin: 0;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
            text-transform: none !important;
            letter-spacing: normal !important;
            font-weight: 600 !important;
            color: @colorDark !important;
        }

            .checkboxes-dropdown label:hover {
                background-color: @colorLight;
            }

            .checkboxes-dropdown label.row-selected {
                background-color: @colorLight;
                box-shadow: inset 3px 0 0 @colorPrimary;
            }

        .checkboxes-dropdown input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: @colorPrimary;
            cursor: pointer;
        }

    /* CHỌN NGƯỜI THỰC HIỆN: khi ô đang mở dropdown thì bo góc dưới bằng 0 cho liền mạch */
    .select-box:focus-within .input-hover {
        border-color: @colorPrimary !important;
        box-shadow: 0 0 0 4px rgba(101, 163, 13, 0.15) !important;
    }
</style>

@* Nền trang chính chuyển sang dải màu xanh mạ tươi tắn mượt mà thiên hướng cỏ non *@
<div class="main-container" style="background: linear-gradient(135deg, #f7fee7 0%, #d9f99d 40%, #a3e635 100%); padding: 50px 20px; min-height: 100vh; font-family: 'Segoe UI', sans-serif;">

    <form id="workOrderSingleForm" method="post" enctype="multipart/form-data" action="/FormCongViec/DonCvCongViecOrder" class="form-wrapper"
          style="max-width: 950px; margin: 0 auto; background: #ffffff; border-radius: 35px; box-shadow: 0 25px 50px -12px rgba(45, 66, 1, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.7);">

        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger", style = "margin:10px 0;" })

        @* --- HEADER MÀU XANH TƯƠI SÁNG CHỦ ĐẠO --- *@
        <div class="header-section" style="background: linear-gradient(135deg, @colorDark 0%, #4d7c0f 100%); padding: 45px 20px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 20px; right: 30px; font-size: 10px; opacity: 0.8; font-weight: 700; letter-spacing: 2px;">TASK FLOW V2.0</div>
            <h2 style="margin: 0; font-size: 26px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">Phiếu giao việc công việc chỉ định</h2>
            <div style="margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; padding: 8px 20px; background: rgba(255,255,255,0.15); border-radius: 50px; font-size: 13px; backdrop-filter: blur(4px);">
                <span>📋 Trạng thái:</span>
                <span style="font-weight: 800; color: #bef264;">CHỈ ĐỊNH ĐIỀU PHỐI TRỰC TIẾP</span>
            </div>
        </div>

        <div class="body-content" style="padding: 40px;">

            @* --- PHẦN 1: THÔNG TIN HÀNH CHÍNH --- *@
            <div style="margin-bottom: 40px;">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 25px;">
                    <span style="background: @colorDark; color: white; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 900; box-shadow: 0 4px 10px rgba(45, 66, 1, 0.3);">1</span>
                    <h3 style="margin: 0; color: @colorDark; font-size: 16px; font-weight: 800; text-transform: uppercase;">Thông tin hành chính</h3>
                </div>

                <div class="grid-responsive-4" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;">
                    <div style="background: #f7fee7; padding: 15px; border-radius: 15px; border: 1px solid #d9f99d;">
                        <label style="@labelBase">Tài khoản/Email</label>
                        <div style="font-weight: 700; color: #1a2e05; font-size: 14px;">@soNhanVien</div>
                    </div>
                    <div style="background: #f7fee7; padding: 15px; border-radius: 15px; border: 1px solid #d9f99d;">
                        <label style="@labelBase">Người lập phiếu</label>
                        <div style="font-weight: 700; color: #1a2e05; font-size: 14px;">@tenNguoiNv</div>
                    </div>
                    <div style="background: #f7fee7; padding: 15px; border-radius: 15px; border: 1px solid #d9f99d;">
                        <label style="@labelBase">Bộ phận</label>
                        <div style="font-weight: 700; color: #1a2e05; font-size: 14px;">@phongBan</div>
                    </div>
                    <div style="background: #f7fee7; padding: 15px; border-radius: 15px; border: 1px solid #d9f99d;">
                        <label style="@labelBase">Công ty</label>
                        <div style="font-weight: 700; color: @colorPrimary; font-size: 14px;">@tenCongTy</div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 2: CHỈ ĐỊNH NHÂN SỰ VÀ TIẾN ĐỘ --- *@
            <div class="box-detail-mobile" style="@boxDetail">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 25px;">
                    <span style="background: @colorDark; color: white; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 900;">2</span>
                    <h3 style="margin: 0; color: @colorDark; font-size: 16px; font-weight: 800; text-transform: uppercase;">Nhân sự chịu trách nhiệm &amp; Tiến độ</h3>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                    <div>
                        <label style="@labelBase">Chọn người thực hiện công việc <span style="color:red">*</span></label>
                        <div class="multiselect-container">
                            <div class="select-box" onclick="openCheckboxes()">
                                <input type="text" id="searchStaffInput" autocomplete="off"
                                       class="input-hover" style="@inputBase cursor: text;"
                                       placeholder="🔍 Bấm vào đây, gõ tên/mã NV để tìm và chọn nhanh..."
                                       oninput="filterStaffFunction(event)" />
                            </div>
                            <div class="checkboxes-dropdown" id="checkboxesArea">
                                <div style="display: flex; gap: 8px; margin-bottom: 8px;">
                                    <button type="button" onclick="event.stopPropagation(); selectAllVisibleStaff(true)" style="flex: 1; padding: 8px; border-radius: 8px; border: 1px solid @colorBorder; background: @colorLight; color: @colorDark; font-size: 11px; font-weight: 800; cursor: pointer; text-transform: uppercase;">✔ Chọn tất cả</button>
                                    <button type="button" onclick="event.stopPropagation(); selectAllVisibleStaff(false)" style="flex: 1; padding: 8px; border-radius: 8px; border: 1px solid #e2e8f0; background: #f8fafc; color: #475569; font-size: 11px; font-weight: 800; cursor: pointer; text-transform: uppercase;">✖ Bỏ chọn</button>
                                </div>

                                @if (ViewBag.NguoiNhanViecList != null)
                                {
                                    foreach (var user in (IEnumerable<E_Form_Best.Models.ITForm.User>)ViewBag.NguoiNhanViecList)
                                    {
                                        <label for="user_@user.IdNguoiDung">
                                            <input type="checkbox" name="selectedNguoiLienQuanIds" id="user_@user.IdNguoiDung" value="@user.IdNguoiDung" onchange="updateDropdownText()" />
                                            <span>[@(user.MaNhanVien ?? "N/A")] @user.HoTen (@user.PhongBan)</span>
                                        </label>
                                    }
                                }
                            </div>
                        </div>

                        @* --- DANH SÁCH NHÂN SỰ ĐÃ CHỌN HIỂN THỊ DẠNG THẺ BÊN DƯỚI --- *@
                        <div id="selectedStaffChips" style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px;"></div>
                    </div>

                    <div>
                        <label style="@labelBase">Mức độ ưu tiên <span style="color:red">*</span></label>
                        <select name="cvOrder.MucDoUuTien" id="MucDoUuTien" class="input-hover" style="@inputBase cursor: pointer; appearance: none; background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%232d4201%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 15px top 50%; background-size: 12px auto;">
                            <option value="Thấp">Thấp</option>
                            <option value="Trung bình" selected>Trung bình</option>
                            <option value="Cao">Cao</option>
                            <option value="Khẩn cấp">Khẩn cấp</option>
                        </select>
                    </div>

                    <div>
                        <label style="@labelBase">Thời hạn hoàn thành (Deadline)</label>
                        <input type="datetime-local" name="cvOrder.ThoiHanHoanThanh" id="ThoiHanHoanThanh" class="input-hover" style="@inputBase" />
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: NỘI DUNG YÊU CẦU CHI TIẾT & FILE ĐÍNH KÈM SƠ ĐỒ --- *@
            <div class="box-detail-mobile" style="@boxDetail">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 25px;">
                    <span style="background: @colorDark; color: white; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 900;">3</span>
                    <h3 style="margin: 0; color: @colorDark; font-size: 16px; font-weight: 800; text-transform: uppercase;">Nội dung chi tiết hạng mục</h3>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="@labelBase">Tiêu đề công việc <span style="color:red">*</span></label>
                    <input type="text" name="cvOrder.Ten" id="TieuDe" required placeholder="Nhập tiêu đề hoặc tên hạng mục công việc chỉ định..." class="input-hover" style="@inputBase" />
                </div>

                <div style="margin-bottom: 25px;">
                    <label style="@labelBase">Nội dung yêu cầu cụ thể <span style="color:red">*</span></label>
                    <textarea name="cvOrder.GhiChu" id="GhiChu" required placeholder="Mô tả chi tiết yêu cầu, các mốc tiến độ hoặc kết quả đầu ra cần đạt được..."
                              class="input-hover"
                              style="@inputBase height: 120px; resize: none;"></textarea>
                </div>

                @* TÍCH HỢP LẠI: Vùng kéo thả file, đính kèm tài liệu và dán ảnh chụp màn hình thông minh gửi lên DonCongViec *@
                <div class="grid-responsive-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelBase">Hình ảnh mô tả / Sơ đồ kế hoạch (Ctrl+V)</label>
                        <div id="paste_area" tabindex="0"
                             style="width: 100%; border: 2px dashed @colorBorder; height: 160px; border-radius: 15px; display: flex; align-items: center; justify-content: center; background: @colorLight; color: @colorPrimary; cursor: pointer; overflow: hidden; font-size: 12px; font-weight: 700; transition: 0.3s; position: relative; outline: none;">
                            <div style="text-align:center;"><i style="font-size: 24px; margin-bottom:8px;" class="fa fa-image"></i><br>Dán hình ảnh minh họa tại đây</div>
                        </div>
                        <input type="file" id="file_Anh" name="Anh" hidden accept="image/*">
                    </div>
                    <div>
                        <label style="@labelBase">Tài liệu phương án đính kèm (File)</label>
                        <div class="file-upload-box" style="border: 2px dashed #cbd5e1; height: 160px; border-radius: 15px; padding: 20px; box-sizing: border-box; background: #ffffff; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                            <input type="file" id="file_TaiLieu" name="UploadFile" style="font-size: 12px; width: 100%;">
                            <p style="font-size: 11px; color: @colorDark; margin-top: 15px; text-align: center; font-weight: 600;">Đính kèm tài liệu liên quan (.doc, .xls, .pdf) nếu có.</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- NÚT SUBMIT BIỂU MẪU VIA AJAX --- *@
            <div style="display: flex; justify-content: center;">
                <button type="button" id="btnSubmit" onclick="xuLyLuuDonCV()"
                        style="width: 100%; padding: 22px; background: linear-gradient(to right, @colorDark, #4d7c0f); color: #ffffff; border: none; border-radius: 20px; font-weight: 900; font-size: 18px; cursor: pointer; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 10px 25px -5px rgba(101, 163, 13, 0.4); transition: 0.3s;">
                    PHÁT HÀNH VÀ BÀN GIAO CÔNG VIỆC
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // Mở danh sách nhân sự (bấm vào ô tìm kiếm là mở luôn, không cần bấm mũi tên nữa)
    function openCheckboxes() {
        document.getElementById("checkboxesArea").style.display = "block";
    }

    // Đóng danh sách nhân sự khi click chuột ra vùng ngoài
    document.addEventListener("click", function(event) {
        const container = document.querySelector(".multiselect-container");
        if (container && !container.contains(event.target)) {
            document.getElementById("checkboxesArea").style.display = "none";
        }
    });

    // TIÊU CHUẨN VÀNG 2026: Sử dụng Normalize NFD bóc tách dấu Tiếng Việt triệt để chính xác 100%
    function removeVietnameseTonesJS(str) {
        if (!str) return "";
        return str.normalize("NFD")
                  .replace(/[\u0300-\u036f]/g, "")
                  .replace(/đ/g, "d")
                  .replace(/Đ/g, "D");
    }

    // Hàm lọc nhân sự tức thì khi gõ hoặc xóa chữ (Kết hợp bóc dấu tiếng Việt chuẩn hóa)
    function filterStaffFunction(e) {
        e.stopPropagation();
        const input = document.getElementById("searchStaffInput");
        const filter = removeVietnameseTonesJS(input.value).toUpperCase();
        const div = document.getElementById("checkboxesArea");
        const labels = div.getElementsByTagName("label");

        for (let i = 0; i < labels.length; i++) {
            const txtValue = labels[i].textContent || labels[i].innerText;
            const txtValueNormalized = removeVietnameseTonesJS(txtValue).toUpperCase();

            if (txtValueNormalized.indexOf(filter) > -1) {
                labels[i].style.setProperty('display', 'flex', 'important');
            } else {
                labels[i].style.setProperty('display', 'none', 'important');
            }
        }
    }

    // Chọn nhanh/Bỏ chọn nhanh toàn bộ nhân sự đang hiển thị (theo bộ lọc tìm kiếm hiện tại)
    function selectAllVisibleStaff(checked) {
        const div = document.getElementById("checkboxesArea");
        const labels = div.getElementsByTagName("label");
        for (let i = 0; i < labels.length; i++) {
            if (labels[i].style.display !== "none") {
                const checkbox = labels[i].querySelector('input[type="checkbox"]');
                if (checkbox) checkbox.checked = checked;
            }
        }
        updateDropdownText();
    }

    // Tính toán số lượng nhân viên được chọn để hiển thị lên ô tìm kiếm (placeholder),
    // tô sáng các dòng đã chọn trong danh sách, và vẽ lại danh sách thẻ (chip) bên dưới
    function updateDropdownText() {
        const allBoxes = document.querySelectorAll('input[name="selectedNguoiLienQuanIds"]');
        const checkedBoxes = document.querySelectorAll('input[name="selectedNguoiLienQuanIds"]:checked');
        const searchInput = document.getElementById("searchStaffInput");
        searchInput.placeholder = checkedBoxes.length === 0
            ? "🔍 Bấm vào đây, gõ tên/mã NV để tìm và chọn nhanh..."
            : `✅ Đã chọn ${checkedBoxes.length} nhân sự — gõ để tìm và chọn thêm...`;

        allBoxes.forEach(function (cb) {
            const rowLabel = document.querySelector(`label[for="${cb.id}"]`);
            if (rowLabel) rowLabel.classList.toggle("row-selected", cb.checked);
        });

        const chipsContainer = document.getElementById("selectedStaffChips");
        chipsContainer.innerHTML = "";
        checkedBoxes.forEach(function (cb) {
            const labelSpan = document.querySelector(`label[for="${cb.id}"] span`);
            const name = labelSpan ? labelSpan.textContent : cb.value;

            const chip = document.createElement("div");
            chip.style.cssText = "display:flex; align-items:center; gap:6px; background:#f7fee7; border:1px solid #bef264; color:#2d4201; padding:6px 8px 6px 12px; border-radius:50px; font-size:12px; font-weight:700;";
            chip.innerHTML = `<span>${name}</span>`;

            const removeBtn = document.createElement("span");
            removeBtn.innerHTML = "&times;";
            removeBtn.title = "Bỏ chọn";
            removeBtn.style.cssText = "cursor:pointer; font-weight:900; color:#65a30d; font-size:16px; line-height:1; width:16px; height:16px; display:flex; align-items:center; justify-content:center;";
            removeBtn.onclick = function () {
                cb.checked = false;
                updateDropdownText();
            };

            chip.appendChild(removeBtn);
            chipsContainer.appendChild(chip);
        });
    }

    // Cơ chế dán ảnh thông minh bằng tổ hợp phím (Ctrl + V)
    document.getElementById("paste_area").addEventListener('paste', function(e) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                const blob = items[i].getAsFile();
                const reader = new FileReader();
                reader.onload = (event) => {
                    this.innerHTML = `<img src="${event.target.result}" style="height:100%; width:100%; object-fit:contain; border-radius:12px;">`;
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(blob);
                    document.getElementById("file_Anh").files = dataTransfer.files;
                };
                reader.readAsDataURL(blob);
            }
        }
    });

    // Gửi dữ liệu bằng AJAX đồng bộ không tải lại trang chuyên nghiệp
    function xuLyLuuDonCV() {
        const checkedBoxes = document.querySelectorAll('input[name="selectedNguoiLienQuanIds"]:checked');
        const mucDoUuTien = document.getElementById("MucDoUuTien").value;
        const tieuDe = document.getElementById("TieuDe").value;
        const ghiChu = document.getElementById("GhiChu").value;
        const btn = document.getElementById("btnSubmit");

        if (checkedBoxes.length === 0) {
            alert("⚠️ Vui lòng chọn ít nhất một nhân sự chịu trách nhiệm xử lý công việc!");
            return;
        }
        if (!tieuDe.trim()) {
            alert("⚠️ Vui lòng nhập tiêu đề cho công việc này!");
            return;
        }
        if (!ghiChu.trim()) {
            alert("⚠️ Bạn chưa điền nội dung mô tả công việc chi tiết!");
            return;
        }

        if (confirm("Xác nhận phát hành phiếu công việc chỉ định nhân sự này?")) {
            const originalBtnHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> ĐANG THIẾT LẬP TIẾN TRÌNH...';
            btn.style.opacity = '0.7';
            btn.style.pointerEvents = 'none';

            const formElement = document.getElementById("workOrderSingleForm");
            const formData = new FormData(formElement);

            fetch(formElement.action, {
                method: "POST",
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                btn.innerHTML = originalBtnHtml;
                btn.style.opacity = '1';
                btn.style.pointerEvents = 'auto';

                if (data.success) {
                    // Hiển thị thông báo thành công đẹp mắt bằng SweetAlert2 có sẵn từ Layout
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: data.message,
                            confirmButtonColor: '#65a30d'
                        });
                    } else {
                        alert("🎉 " + data.message);
                    }

                    // ĐÃ CẬP NHẬT THEO YÊU CẦU: Chỉ xóa duy nhất trường nội dung chi tiết (GhiChu) và làm sạch bộ nhớ tạm của tệp tin vừa tải lên
                    document.getElementById("GhiChu").value = "";
                    document.getElementById("paste_area").innerHTML = '<div style="text-align:center;"><i style="font-size: 24px; margin-bottom:8px;" class="fa fa-image"></i><br>Dán hình ảnh minh họa tại đây</div>';

                    // Giải phóng vùng lưu trữ Input File để tránh việc gửi lại file cũ ở đơn sau
                    document.getElementById("file_Anh").value = "";
                    document.getElementById("file_TaiLieu").value = "";

                    // GIỮ NGUYÊN: Không dùng formElement.reset(), giữ nguyên Tiêu đề (TieuDe) và danh sách Người thực hiện đã tích chọn
                } else {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'error',
                            title: 'Thất bại',
                            text: data.message,
                            confirmButtonColor: '#dc2626'
                        });
                    } else {
                        alert("❌ Thất bại: " + data.message);
                    }
                }
            })
            .catch(error => {
                btn.innerHTML = originalBtnHtml;
                btn.style.opacity = '1';
                btn.style.pointerEvents = 'auto';
                alert("❌ Đã xảy ra lỗi kết nối: " + error);
            });
        }
    }
</script>