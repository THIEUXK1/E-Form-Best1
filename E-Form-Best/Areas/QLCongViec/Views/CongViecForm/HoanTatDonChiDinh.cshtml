@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn Chỉ Định Công Việc";
    Layout = "~/Areas/QLCongViec/Views/Shared/_Layout.cshtml";

    // Lấy Role để hiển thị tag thông tin người dùng
    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    /* Style cho phân trang & hiệu ứng chung - CHỦ ĐỀ XANH LÁ CÂY TƯƠI #65a30d */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #65a30d;
            color: white;
            border-color: #65a30d;
            box-shadow: 0 4px 6px -1px rgba(101, 163, 13, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f7fee7;
            border-color: #cbd5e1;
        }

    /* Hiệu ứng hover cho bảng */
    #dataTable tbody tr {
        transition: all 0.2s;
    }

        #dataTable tbody tr:hover {
            background-color: #f7fee7;
            transform: scale(1.002);
        }

    /* Style cho các thành phần bộ lọc mới */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
        height: 38px;
    }

        .filter-input:focus {
            border-color: #65a30d;
            box-shadow: 0 0 0 2px rgba(101,163,13,0.1);
        }

    .btn-filter-action {
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
        height: 38px;
    }

    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* HỆ THỐNG DROPDOWN CHECKBOX (MULTI-SELECT) */
    .dropdown-combo-btn {
        text-align: left;
        background-color: #fff;
        border: 1px solid #cbd5e1;
        padding: 8px 28px 8px 12px;
        font-size: 13px;
        font-weight: 600;
        border-radius: 8px;
        color: #1e293b;
        position: relative;
        min-width: 160px;
        height: 38px;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

        .dropdown-combo-btn:after {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
        }

        .dropdown-combo-btn:focus {
            border-color: #65a30d;
            box-shadow: 0 0 0 2px rgba(101,163,13,0.1);
            outline: 0;
        }

    .dropdown-combo-menu {
        min-width: 220px;
        max-height: 280px;
        overflow-y: auto;
        padding: 8px 0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        z-index: 1050;
    }

    .dropdown-combo-item {
        display: flex;
        align-items: center;
        padding: 6px 16px;
        cursor: pointer;
        user-select: none;
        font-size: 13px;
        color: #334155;
        transition: background-color 0.15s ease;
    }

        .dropdown-combo-item:hover {
            background-color: #f1f5f9;
        }

        .dropdown-combo-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #65a30d;
            flex-shrink: 0;
        }

        .dropdown-combo-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    /* CSS RESPONSIVE CHO MOBILE (2026 STYLE) */
    @@media (max-width: 768px) {
        .main-padding {
            padding: 15px !important;
        }

        .header-mobile {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 20px !important;
        }

        .search-area-mobile {
            width: 100% !important;
            flex-direction: column !important;
            gap: 12px !important;
        }

            .search-area-mobile div, #searchInput {
                width: 100% !important;
                box-sizing: border-box;
            }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .dropdown-combo-btn {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }

        .stats-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }

        #dataTable thead {
            display: none;
        }

        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }

            #dataTable tr {
                margin-bottom: 20px;
                border: 1px solid #cbd5e1 !important;
                border-radius: 20px;
                padding: 15px;
                background: #ffffff;
                box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            }

            #dataTable td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 5px !important;
                border-bottom: 1px dashed #f1f5f9 !important;
                text-align: right !important;
            }

                #dataTable td:last-child {
                    border-bottom: none !important;
                    justify-content: center !important;
                    padding-top: 15px !important;
                    width: 100% !important;
                }

                #dataTable td::before {
                    content: attr(data-label);
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                    text-align: left;
                    flex-shrink: 0;
                }

        .mobile-td-content {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            width: 70%;
        }

        .pagination-mobile {
            flex-direction: column !important;
            gap: 20px;
            align-items: center !important;
        }
    }
</style>

<div class="main-padding" style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1500px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div class="header-mobile" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #65a30d; letter-spacing: -0.04em; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #65a30d; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(101, 163, 13, 0.3);">
                        <i class="fa fa-user-plus"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN CHỈ ĐỊNH CÔNG VIỆC
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #65a30d; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@currentUserRole</span>
                    <span style="background: #cbd5e1; color: #1e293b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">ĐƠN CÔNG VIỆC CHỈ ĐỊNH</span>
                </div>
            </div>

            <div class="search-area-mobile" style="display: flex; gap: 15px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 15px; border-radius: 15px; border: 2px solid #cbd5e1; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                    <span style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Dòng:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 1000; color: #65a30d; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="30" selected>30</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="handleSearch()" placeholder="Tìm tên, mã đơn..."
                           style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 300px; font-size: 14px; font-weight: 700; outline: none; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                </div>
            </div>
        </div>

        @* --- BỘ LỌC NÂNG CAO DROPDOWN CHECKBOX MULTI-SELECT --- *@
        <div class="advanced-filter">
            <div class="filter-group">
                <label>Từ ngày</label>
                <input type="date" id="txtFromDate" class="filter-input" onchange="handleSearch()" />
            </div>
            <div class="filter-group">
                <label>Đến ngày</label>
                <input type="date" id="txtToDate" class="filter-input" onchange="handleSearch()" />
            </div>

            <div class="filter-group">
                <label>Bộ phận yêu cầu</label>
                <div class="dropdown">
                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropDept" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        -- Tất cả --
                    </button>
                    <div class="dropdown-menu dropdown-combo-menu" id="menuDept" aria-labelledby="btnDropDept">
                    </div>
                </div>
            </div>

            <div class="filter-group">
                <label>Người thực hiện</label>
                <div class="dropdown">
                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropStaff" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        -- Tất cả --
                    </button>
                    <div class="dropdown-menu dropdown-combo-menu" id="menuStaff" aria-labelledby="btnDropStaff">
                    </div>
                </div>
            </div>

            <div class="filter-group">
                <label>Mức độ ưu tiên</label>
                <div class="dropdown">
                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropPriority" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        -- Tất cả --
                    </button>
                    <div class="dropdown-menu dropdown-combo-menu" id="menuPriority" aria-labelledby="btnDropPriority">
                        <label class="dropdown-combo-item">
                            <input type="checkbox" class="chk-priority" value="Khẩn cấp">
                            <span>Khẩn cấp</span>
                        </label>
                        <label class="dropdown-combo-item">
                            <input type="checkbox" class="chk-priority" value="Cao">
                            <span>Cao</span>
                        </label>
                        <label class="dropdown-combo-item">
                            <input type="checkbox" class="chk-priority" value="Trung bình">
                            <span>Trung bình</span>
                        </label>
                        <label class="dropdown-combo-item">
                            <input type="checkbox" class="chk-priority" value="Thấp">
                            <span>Thấp</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
                <button class="btn-filter-action btn-clear-filter" onclick="clearAllFilters()">
                    <i class="fa fa-refresh"></i> Làm mới
                </button>
            </div>
        </div>

        @* --- KHỐI CARD THỐNG KÊ ĐỒNG BỘ XANH LÁ MỚI --- *@
        <div class="stats-grid-mobile" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 30px;">
            <div class="stat-card-item active-stat" data-status="" onclick="filterByStatus('')" style="background: white; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #65a30d; letter-spacing: 1px; text-transform: uppercase;">TỔNG LƯU TRỮ</div>
                <div id="stat-total" style="font-size: 28px; font-weight: 1000; color: #65a30d; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Chờ QL Duyệt" onclick="filterByStatus('Chờ QL Duyệt')" style="background: #fff7ed; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #f59e0b; letter-spacing: 1px; text-transform: uppercase;">CHỜ QL DUYỆT</div>
                <div id="stat-waiting-manager" style="font-size: 28px; font-weight: 1000; color: #f59e0b; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Đang xử lý" onclick="filterByStatus('Đang xử lý')" style="background: #eff6ff; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #2563eb; letter-spacing: 1px; text-transform: uppercase;">ĐANG XỬ LÝ</div>
                <div id="stat-processing" style="font-size: 28px; font-weight: 1000; color: #2563eb; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Đơn quá hạn" onclick="filterByStatus('Đơn quá hạn')" style="background: #fff1f2; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #e11d48; letter-spacing: 1px; text-transform: uppercase;">⚠️ ĐƠN QUÁ HẠN</div>
                <div id="stat-overdue" style="font-size: 28px; font-weight: 1000; color: #e11d48; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Chờ đánh giá" onclick="filterByStatus('Chờ đánh giá')" style="background: #f5f3ff; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #7c3aed; letter-spacing: 1px; text-transform: uppercase;">CHỜ ĐÁNH GIÁ</div>
                <div id="stat-waiting-rate" style="font-size: 28px; font-weight: 1000; color: #7c3aed; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Hoàn tất" onclick="filterByStatus('Hoàn tất')" style="background: #f0fdf4; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #059669; letter-spacing: 1px; text-transform: uppercase;">ĐÃ HOÀN TẤT</div>
                <div id="stat-completed" style="font-size: 28px; font-weight: 1000; color: #059669; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Đã hủy" onclick="filterByStatus('Đã hủy')" style="background: #fef2f2; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #dc2626; letter-spacing: 1px; text-transform: uppercase;">ĐƠN ĐÃ HỦY</div>
                <div id="stat-cancelled" style="font-size: 28px; font-weight: 1000; color: #dc2626; margin-top: 8px;">0</div>
            </div>
        </div>

        @* --- BẢNG DANH SÁCH --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nhân viên yêu cầu</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Người thực hiện</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 130px;">Danh mục</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nhiệm vụ & Tiến trình</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 140px;">Mức ưu tiên</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 170px;">Hạn xử lý</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 140px;">Trạng thái</th>
                        <th style="padding: 20px; text-align: center; width: 120px;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr><td colspan="8" style="text-align: center; padding: 60px; color: #64748b;"><i class="fa fa-spinner fa-spin"></i> Đang tải dữ liệu lưu trữ công việc...</td></tr>
                </tbody>
            </table>

            <div id="emptyState" style="display: none; padding: 80px 20px; text-align: center; color: #94a3b8;">
                <i class="fa fa-folder-open-o" style="font-size: 54px; margin-bottom: 20px; display: block; opacity: 0.5;"></i>
                <div style="font-weight: 700; font-size: 16px;">Không tìm thấy kết quả phù hợp với bộ lọc</div>
            </div>
        </div>

        @* --- THANH PHÂN TRANG --- *@
        <div class="pagination-mobile" style="display: flex; justify-content: space-between; align-items: center; padding: 25px 10px;">
            <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: #65a30d;">1</span> / <span id="totalPagesNum">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                    Tổng bản ghi: <span id="totalVisibleCount">0</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let masterData = [];
    let filteredData = [];
    let currentPage = 1;
    let rowsPerPage = 30;
    let currentActiveStatusFilter = "";

    document.addEventListener("DOMContentLoaded", () => {
        // Khôi phục bộ nhớ cache Session Phân hệ Công việc tránh xung đột hệ thống IT
        const savedText = sessionStorage.getItem("savedChiDinhTextCV");
        if (savedText) document.getElementById("searchInput").value = savedText;

        const savedFrom = sessionStorage.getItem("savedFromDateChiDinhCV");
        if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

        const savedTo = sessionStorage.getItem("savedToDateChiDinhCV");
        if (savedTo) document.getElementById("txtToDate").value = savedTo;

        const savedStatus = sessionStorage.getItem("savedChiDinhStatusCV");
        if (savedStatus !== null) {
            currentActiveStatusFilter = savedStatus;
        }

        $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
            const $menu = $(this).closest('.dropdown-combo-menu');
            updateDropdownButtonLabel($menu);
            handleSearch();
        });

        loadDataFromAPI();
    });

    async function loadDataFromAPI() {
        try {
            const response = await fetch('/FormCongViec/GetHoanTatDonChiDinhData');
            if (!response.ok) throw new Error("API Failure");

            masterData = await response.json();
            filteredData = masterData;

            populateDropdowns(masterData);

            // Phục hồi trạng thái bộ lọc từ cache phân hệ Công việc
            const savedDeptStr = sessionStorage.getItem("savedDeptChiDinhCV");
            if (savedDeptStr) {
                try {
                    let arrDept = JSON.parse(savedDeptStr) || [];
                    arrDept.forEach(d => { $(`.chk-dept[value="${d}"]`).prop('checked', true); });
                    updateDropdownButtonLabel($('#menuDept'));
                } catch(e){}
            }

            const savedStaffStr = sessionStorage.getItem("savedStaffChiDinhCV");
            if (savedStaffStr) {
                try {
                    let arrStaff = JSON.parse(savedStaffStr) || [];
                    arrStaff.forEach(s => { $(`.chk-staff[value="${s}"]`).prop('checked', true); });
                    updateDropdownButtonLabel($('#menuStaff'));
                } catch(e){}
            }

            const savedPriorityStr = sessionStorage.getItem("savedPriorityChiDinhCV");
            if (savedPriorityStr) {
                try {
                    let arrPriority = JSON.parse(savedPriorityStr) || [];
                    arrPriority.forEach(p => { $(`.chk-priority[value="${p}"]`).prop('checked', true); });
                    updateDropdownButtonLabel($('#menuPriority'));
                } catch(e){}
            }

            calculateStats(masterData);
            updateVisualStatusCard(currentActiveStatusFilter);
            handleSearch();

        } catch (error) {
            console.error(error);
            document.getElementById('tableBody').innerHTML = '<tr><td colspan="8" style="text-align:center; padding: 50px; color: #ef4444; font-weight: 700;">Lỗi tải dữ liệu kho đơn chỉ định công việc!</td></tr>';
        }
    }

    function populateDropdowns(data) {
        const menuDept = document.getElementById("menuDept");
        const menuStaff = document.getElementById("menuStaff");

        const depts = [...new Set(data.map(x => x.boPhan).filter(Boolean))].sort();
        menuDept.innerHTML = '';
        depts.forEach(d => {
            menuDept.insertAdjacentHTML('beforeend', `
                <label class="dropdown-combo-item">
                    <input type="checkbox" class="chk-dept" value="${d}">
                    <span>${d}</span>
                </label>
            `);
        });

        const allStaff = [];
        data.forEach(item => {
            if (item.nguoiHoTros && item.nguoiHoTros.length > 0) {
                allStaff.push(...item.nguoiHoTros);
            }
        });
        const staffSet = [...new Set(allStaff.filter(name => name !== "N/A"))].sort();
        menuStaff.innerHTML = '';
        staffSet.forEach(s => {
            menuStaff.insertAdjacentHTML('beforeend', `
                <label class="dropdown-combo-item">
                    <input type="checkbox" class="chk-staff" value="${s}">
                    <span>${s}</span>
                </label>
            `);
        });
    }

    function updateDropdownButtonLabel($menu) {
        let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
        let $btn = $menu.siblings('.dropdown-combo-btn');

        if (totalChecked === 0) {
            $btn.text('-- Tất cả --');
        } else if (totalChecked === 1) {
            $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
        } else {
            $btn.text(`Đã chọn (${totalChecked})`);
        }
    }

    function calculateStats(data) {
        let completed = 0, processing = 0, cancelled = 0, waitingRate = 0, waitingManager = 0, overdue = 0;

        data.forEach(item => {
            let st = determineStatus(item).statusName;
            if (st === "Đã hủy") cancelled++;
            else if (st === "Hoàn tất") completed++;
            else if (st === "Chờ đánh giá") waitingRate++;
            else if (st === "Đang xử lý") processing++;
            else if (st === "Chờ QL Duyệt") waitingManager++;
            else if (st === "Đơn quá hạn") overdue++;
        });

        document.getElementById("stat-total").innerText = data.length;
        document.getElementById("stat-completed").innerText = completed;
        document.getElementById("stat-processing").innerText = processing;
        document.getElementById("stat-cancelled").innerText = cancelled;
        document.getElementById("stat-waiting-rate").innerText = waitingRate;
        document.getElementById("stat-waiting-manager").innerText = waitingManager;
        document.getElementById("stat-overdue").innerText = overdue;
    }

    function determineStatus(item) {
        let statusName = "";
        const isCancelled = (item.tenForm || "").includes("[ĐÃ HỦY]");

        if (isCancelled) statusName = "Đã hủy";
        else if (item.idNguoiDuyet == null) statusName = "Chờ QL Duyệt";
        else if (item.idAdmin == null) {
            if (item.thoiHanHoanThanh) {
                const deadline = new Date(item.thoiHanHoanThanh);
                const now = new Date();
                if (now > deadline) {
                    statusName = "Đơn quá hạn";
                } else {
                    statusName = "Đang xử lý";
                }
            } else {
                statusName = "Đang xử lý";
            }
        }
        else if (!item.daDanhGia) statusName = "Chờ đánh giá";
        else statusName = "Hoàn tất";

        let pWidth, pColor, stBg, stFg;
        switch(statusName) {
            case "Đã hủy": pWidth = "100%"; pColor = "#ef4444"; stBg = "#fee2e2"; stFg = "#dc2626"; break;
            case "Hoàn tất": pWidth = "100%"; pColor = "#10b981"; stBg = "#ecfdf5"; stFg = "#059669"; break;
            case "Chờ đánh giá": pWidth = "85%"; pColor = "#7c3aed"; stBg = "#f5f3ff"; stFg = "#6d28d9"; break;
            case "Đang xử lý": pWidth = "60%"; pColor = "#3b82f6"; stBg = "#eff6ff"; stFg = "#2563eb"; break;
            case "Chờ QL Duyệt": pWidth = "25%"; pColor = "#f59e0b"; stBg = "#fff7ed"; stFg = "#d97706"; break;
            case "Đơn quá hạn": pWidth = "60%"; pColor = "#f43f5e"; stBg = "#fff1f2"; stFg = "#e11d48"; break;
            default: pWidth = "10%"; pColor = "#94a3b8"; stBg = "#f8fafc"; stFg = "#64748b"; break;
        }

        return { statusName, pWidth, pColor, stBg, stFg };
    }

    function changePageSize() {
        rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
        currentPage = 1;
        renderTable();
    }

    function updateVisualStatusCard(status) {
        document.querySelectorAll('.stat-card-item').forEach(el => {
            el.style.boxShadow = "none"; el.style.border = "1px solid rgba(0,0,0,0.05)";
        });
        const targetCard = document.querySelector(`.stat-card-item[data-status="${status}"]`);
        if (targetCard) {
            targetCard.style.boxShadow = "0 0 0 3px rgba(101, 163, 13, 0.25)"; targetCard.style.border = "1px solid #65a30d";
        }
    }

    function filterByStatus(status) {
        currentActiveStatusFilter = status;
        sessionStorage.setItem("savedChiDinhStatusCV", status);
        updateVisualStatusCard(status);
        handleSearch();
    }

    function clearAllFilters() {
        document.getElementById("searchInput").value = "";
        document.getElementById("txtFromDate").value = "";
        document.getElementById("txtToDate").value = "";

        $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
        $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });

        sessionStorage.removeItem("savedChiDinhTextCV");
        sessionStorage.removeItem("savedFromDateChiDinhCV");
        sessionStorage.removeItem("savedToDateChiDinhCV");
        sessionStorage.removeItem("savedDeptChiDinhCV");
        sessionStorage.removeItem("savedStaffChiDinhCV");
        sessionStorage.removeItem("savedPriorityChiDinhCV");
        sessionStorage.removeItem("savedChiDinhStatusCV");

        filterByStatus("");
    }

    function handleSearch() {
        const textFilter = document.getElementById("searchInput").value.toUpperCase();
        const fromDateStr = document.getElementById("txtFromDate").value;
        const toDateStr = document.getElementById("txtToDate").value;

        const selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        const selectedStaffs = $('.chk-staff:checked').map(function() { return $(this).val(); }).get();
        const selectedPriorities = $('.chk-priority:checked').map(function() { return $(this).val(); }).get();

        sessionStorage.setItem("savedChiDinhTextCV", document.getElementById("searchInput").value);
        sessionStorage.setItem("savedFromDateChiDinhCV", fromDateStr);
        sessionStorage.setItem("savedToDateChiDinhCV", toDateStr);
        sessionStorage.setItem("savedDeptChiDinhCV", JSON.stringify(selectedDepts));
        sessionStorage.setItem("savedStaffChiDinhCV", JSON.stringify(selectedStaffs));
        sessionStorage.setItem("savedPriorityChiDinhCV", JSON.stringify(selectedPriorities));

        filteredData = masterData.filter(item => {
            const stInfo = determineStatus(item);
            const stName = stInfo.statusName;

            if (currentActiveStatusFilter && stName !== currentActiveStatusFilter) return false;

            if (selectedDepts.length > 0 && !selectedDepts.includes(item.boPhan)) return false;

            if (selectedStaffs.length > 0) {
                let itemNguoiHoTros = item.nguoiHoTros || [];
                let hasMatch = itemNguoiHoTros.some(staff => selectedStaffs.includes(staff));
                if (!hasMatch) return false;
            }

            if (selectedPriorities.length > 0 && !selectedPriorities.includes(item.mucDoUuTien)) return false;

            if (fromDateStr || toDateStr) {
                if (!item.timeNguoiTao) return false;
                const parts = item.timeNguoiTao.split('/');
                if (parts.length === 3) {
                    const itemDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
                    if (fromDateStr) {
                        const fromD = new Date(fromDateStr + "T00:00:00");
                        if (itemDate < fromD) return false;
                    }
                    if (toDateStr) {
                        const toD = new Date(toDateStr + "T23:59:59");
                        if (itemDate > toD) return false;
                    }
                }
            }

            if (textFilter) {
                const supportNames = (item.nguoiHoTros || []).join(" ").toUpperCase();
                const searchString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.danhmuc} ${item.tenForm} ${item.id} ${supportNames} ${stName} ${item.mucDoUuTien || ''}`.toUpperCase();
                if (!searchString.includes(textFilter)) return false;
            }

            return true;
        });

        currentPage = 1;
        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById("tableBody");
        const emptyState = document.getElementById("emptyState");
        const dataTable = document.getElementById("dataTable");

        tbody.innerHTML = "";
        const startIdx = (currentPage - 1) * rowsPerPage;
        const pageData = filteredData.slice(startIdx, startIdx + rowsPerPage);

        if (pageData.length === 0) {
            emptyState.style.display = "block"; dataTable.style.display = "none";
        } else {
            emptyState.style.display = "none"; dataTable.style.display = "table";

            pageData.forEach(item => {
                const s = determineStatus(item);
                const cleanTenForm = (item.tenForm || "").replace("[ĐÃ HỦY]", "").trim();

                let supportHtml = "";
                if (item.nguoiHoTros && item.nguoiHoTros.length > 0) {
                    supportHtml = `<div style="display: flex; flex-wrap: wrap; gap: 5px; justify-content: flex-start;">`;
                    item.nguoiHoTros.forEach(name => {
                        supportHtml += `<span style="background: #f7fee7; color: #4d7c0f; border: 1px solid #d9f99d; padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;"><i class="fa fa-user-circle-o"></i> ${name}</span>`;
                    });
                    supportHtml += `</div>`;
                } else {
                    supportHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa gán nhân sự</span>`;
                }

                let priorityColumnHtml = "";
                if (item.mucDoUuTien) {
                    let badgeColor = "#64748b";
                    let badgeBg = "#f8fafc";

                    if (item.mucDoUuTien === "Khẩn cấp") {
                        badgeColor = "#ef4444"; badgeBg = "#fef2f2";
                    } else if (item.mucDoUuTien === "Cao") {
                        badgeColor = "#f97316"; badgeBg = "#fff7ed";
                    } else if (item.mucDoUuTien === "Trung bình") {
                        badgeColor = "#3b82f6"; badgeBg = "#eff6ff";
                    }

                    priorityColumnHtml = `<span style="background: ${badgeBg}; color: ${badgeColor}; border: 1.5px solid ${badgeColor}; padding: 5px 12px; border-radius: 8px; font-size: 11px; font-weight: 900; display: inline-flex; align-items: center; gap: 5px; text-transform: uppercase;"><i class="fa fa-flag"></i> ${item.mucDoUuTien}</span>`;
                } else {
                    priorityColumnHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">--</span>`;
                }

                let deadlineColumnHtml = "";
                if (item.thoiHanHoanThanh) {
                    const d = new Date(item.thoiHanHoanThanh);
                    const formattedDeadline = `${String(d.getDate()).padStart(2, '0')}/${String(d.getMonth() + 1).padStart(2, '0')}/${d.getFullYear()} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
                    let colorTxt = (s.statusName === "Đơn quá hạn") ? "#ef4444" : "#475569";
                    deadlineColumnHtml = `<div style="font-size: 12px; color: ${colorTxt}; font-weight: 800;"><i class="fa fa-clock-o"></i> ${formattedDeadline}</div>`;
                } else {
                    deadlineColumnHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Không giới hạn</span>`;
                }

                const tr = document.createElement("tr");
                tr.className = "d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative";
                tr.innerHTML = `
                    <td data-label="Nhân viên" style="padding: 15px 20px;">
                        <div class="mobile-td-content">
                            <div style="font-weight: 900; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                            <div style="font-size: 11px; color: #64748b; margin-top: 4px; font-weight: 700;">
                                <i class="fa fa-id-badge"></i> #${item.id} • ${item.boPhan}
                            </div>
                        </div>
                    </td>
                    <td data-label="Hỗ trợ" style="padding: 15px 20px;">
                        <div class="mobile-td-content">${supportHtml}</div>
                    </td>
                    <td data-label="Danh mục" style="padding: 15px 20px;">
                        <span style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 800; border: 1px solid #e2e8f0; display: inline-block;">
                            ${item.danhmuc}
                        </span>
                    </td>
                    <td data-label="Dịch vụ" style="padding: 15px 20px;">
                        <div class="mobile-td-content">
                            <div style="font-weight: 800; color: #1e293b; font-size: 13px; margin-bottom: 6px;">
                                ${cleanTenForm}
                            </div>
                            <div style="display: flex; align-items: center; gap: 12px; width: 100%;">
                                <div style="flex-grow: 1; height: 5px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 120px;">
                                    <div style="width: ${s.pWidth}; height: 100%; background: ${s.pColor}; transition: width 0.6s;"></div>
                                </div>
                                <span style="font-size: 10px; font-weight: 800; color: #94a3b8;">${item.timeNguoiTao}</span>
                            </div>
                        </div>
                    </td>
                    <td data-label="Mức ưu tiên" style="padding: 15px 20px; text-align: center;">
                        <div class="mobile-td-content">${priorityColumnHtml}</div>
                    </td>
                    <td data-label="Hạn xử lý" style="padding: 15px 20px; text-align: center;">
                        <div class="mobile-td-content">${deadlineColumnHtml}</div>
                    </td>
                    <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                        <span style="background: ${s.stBg}; color: ${s.stFg}; border: 1.5px solid ${s.stFg}; padding: 6px 12px; border-radius: 10px; font-size: 10px; font-weight: 1000; display: inline-block; min-width: 110px; text-transform: uppercase;">${s.statusName}</span>
                    </td>
                    <td data-label="Hành động" style="padding: 15px 20px; text-align: right;">
                        <a href="/FormCongViec/ChiTiet/${item.id}"
                           style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.3s; background: #65a30d; color: #ffffff; width: 100%; text-align: center; box-sizing: border-box;"
                           onmouseover="this.style.background='#4d7c0f'" onmouseout="this.style.background='#65a30d'">
                            Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                        </a>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        const totalPages = Math.ceil(filteredData.length / rowsPerPage) || 1;
        renderPaginationButtons(totalPages);
        document.getElementById("totalVisibleCount").innerText = filteredData.length;
        document.getElementById("currentPageNum").innerText = currentPage;
        document.getElementById("totalPagesNum").innerText = totalPages;
    }

    function renderPaginationButtons(totalPages) {
        const container = document.getElementById("paginationButtons");
        container.innerHTML = ""; if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            if (totalPages > 6 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                if (i === 3 || i === totalPages - 2) {
                    const dot = document.createElement("span");
                    dot.innerText = "..."; dot.style.padding = "8px"; dot.style.color = "#94a3b8";
                    container.appendChild(dot);
                }
                continue;
            }
            const btn = document.createElement("button");
            btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
            btn.onclick = () => {
                currentPage = i; renderTable(); window.scrollTo({ top: 0, behavior: 'smooth' });
            };
            container.appendChild(btn);
        }
    }
</script>