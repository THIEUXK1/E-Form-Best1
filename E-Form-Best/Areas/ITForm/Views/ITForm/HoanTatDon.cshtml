@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn IT";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    // Lấy Role để hiển thị tag thông tin người dùng
    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    /* Style cho phân trang & hiệu ứng chung */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* Hiệu ứng hover cho bảng */
    #dataTable tbody tr {
        transition: all 0.2s;
    }

        #dataTable tbody tr:hover {
            background-color: #f8fafc;
            transform: scale(1.002);
        }

    /* Style cho các thành phần bộ lọc mới */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
    }

        .filter-input:focus {
            border-color: #1e40af;
            box-shadow: 0 0 0 2px rgba(30,64,175,0.1);
        }

    .btn-filter-action {
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-primary-filter {
        background: #1e40af;
        color: white;
    }

        .btn-primary-filter:hover {
            background: #1e3a8a;
        }

    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* ==========================================
           CSS RESPONSIVE CHO MOBILE (2026 STYLE)
           ========================================== */
    @@media (max-width: 768px) {
        .main-padding {
            padding: 15px !important;
        }

        .header-mobile {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 20px !important;
        }

        .search-area-mobile {
            width: 100% !important;
            flex-direction: column !important;
            gap: 12px !important;
        }

            .search-area-mobile div, #searchInput {
                width: 100% !important;
                box-sizing: border-box;
            }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }
        /* Thống kê: Lưới 2 cột */
        .stats-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }
        /* Chuyển Table thành Cards */
        #dataTable thead {
            display: none;
        }

        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }

            #dataTable tr {
                margin-bottom: 20px;
                border: 1px solid #cbd5e1 !important;
                border-radius: 20px;
                padding: 15px;
                background: #ffffff;
                box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            }

            #dataTable td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 5px !important;
                border-bottom: 1px dashed #f1f5f9 !important;
                text-align: right !important;
            }

                #dataTable td:last-child {
                    border-bottom: none !important;
                    justify-content: center !important;
                    padding-top: 15px !important;
                }

                #dataTable td::before {
                    content: attr(data-label);
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                    text-align: left;
                    flex-shrink: 0;
                }

        .mobile-td-content {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            width: 70%;
        }

        .pagination-mobile {
            flex-direction: column !important;
            gap: 20px;
            align-items: center !important;
        }
    }
</style>

<div class="main-padding" style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1500px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div class="header-mobile" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #1e40af; letter-spacing: -0.04em; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #1e40af; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(30, 64, 175, 0.3);">
                        <i class="fa fa-archive"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN IT
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e40af; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@currentUserRole</span>
                    <span style="background: #cbd5e1; color: #1e293b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">QUẢN TRỊ HỆ THỐNG</span>
                </div>
            </div>

            <div class="search-area-mobile" style="display: flex; gap: 15px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 15px; border-radius: 15px; border: 2px solid #cbd5e1; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                    <span style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Dòng:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 1000; color: #1e40af; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="30" selected>30</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="handleSearch()" placeholder="Tìm tên, mã đơn..."
                           style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 300px; font-size: 14px; font-weight: 700; outline: none; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                </div>
            </div>
        </div>

        @* --- BỘ LỌC NÂNG CAO --- *@
        <div class="advanced-filter">
            <div class="filter-group">
                <label>Từ ngày</label>
                <input type="date" id="txtFromDate" class="filter-input" onchange="handleSearch()" />
            </div>
            <div class="filter-group">
                <label>Đến ngày</label>
                <input type="date" id="txtToDate" class="filter-input" onchange="handleSearch()" />
            </div>
            <div class="filter-group">
                <label>Bộ phận</label>
                <select id="selDept" class="filter-input" onchange="handleSearch()">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>
            <div class="filter-group">
                <label>Người hỗ trợ</label>
                <select id="selStaff" class="filter-input" onchange="handleSearch()">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>
            <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
                <button class="btn-filter-action btn-clear-filter" onclick="clearAllFilters()">
                    <i class="fa fa-refresh"></i> Làm mới
                </button>
            </div>
        </div>

        @* --- THỐNG KÊ (Đã thêm data-status để dễ dàng xác định phần tử trên JS) --- *@
        <div class="stats-grid-mobile" style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 30px;">
            <div class="stat-card-item active-stat" data-status="" onclick="filterByStatus('')" style="background: white; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #1e40af; letter-spacing: 1px; text-transform: uppercase;">TỔNG LƯU TRỮ</div>
                <div id="stat-total" style="font-size: 28px; font-weight: 1000; color: #1e40af; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Chờ QL Duyệt" onclick="filterByStatus('Chờ QL Duyệt')" style="background: #fff7ed; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #f59e0b; letter-spacing: 1px; text-transform: uppercase;">CHỜ QL DUYỆT</div>
                <div id="stat-waiting-manager" style="font-size: 28px; font-weight: 1000; color: #f59e0b; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="IT Đang xử lý" onclick="filterByStatus('IT Đang xử lý')" style="background: #eff6ff; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #2563eb; letter-spacing: 1px; text-transform: uppercase;">IT ĐANG XỬ LÝ</div>
                <div id="stat-processing" style="font-size: 28px; font-weight: 1000; color: #2563eb; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Chờ đánh giá" onclick="filterByStatus('Chờ đánh giá')" style="background: #f5f3ff; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #7c3aed; letter-spacing: 1px; text-transform: uppercase;">CHỜ ĐÁNH GIÁ</div>
                <div id="stat-waiting-rate" style="font-size: 28px; font-weight: 1000; color: #7c3aed; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Hoàn tất" onclick="filterByStatus('Hoàn tất')" style="background: #f0fdf4; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #059669; letter-spacing: 1px; text-transform: uppercase;">ĐÃ HOÀN TẤT</div>
                <div id="stat-completed" style="font-size: 28px; font-weight: 1000; color: #059669; margin-top: 8px;">0</div>
            </div>
            <div class="stat-card-item" data-status="Đã hủy" onclick="filterByStatus('Đã hủy')" style="background: #fef2f2; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s;">
                <div style="font-size: 9px; font-weight: 900; color: #dc2626; letter-spacing: 1px; text-transform: uppercase;">ĐƠN ĐÃ HỦY</div>
                <div id="stat-cancelled" style="font-size: 28px; font-weight: 1000; color: #dc2626; margin-top: 8px;">0</div>
            </div>
        </div>

        @* --- BẢNG --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Nhân viên yêu cầu</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Người hỗ trợ</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 140px;">Danh mục</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Dịch vụ & Tiến độ</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 160px;">Trạng thái</th>
                        <th style="padding: 20px; text-align: center; width: 120px;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr><td colspan="6" style="text-align: center; padding: 60px; color: #64748b;"><i class="fa fa-spinner fa-spin"></i> Đang tải dữ liệu kho...</td></tr>
                </tbody>
            </table>

            <div id="emptyState" style="display: none; padding: 80px 20px; text-align: center; color: #94a3b8;">
                <i class="fa fa-folder-open-o" style="font-size: 54px; margin-bottom: 20px; display: block; opacity: 0.5;"></i>
                <div style="font-weight: 700; font-size: 16px;">Không tìm thấy kết quả phù hợp với bộ lọc</div>
            </div>
        </div>

        @* --- PHÂN TRANG --- *@
        <div class="pagination-mobile" style="display: flex; justify-content: space-between; align-items: center; padding: 25px 10px;">
            <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: #1e40af;">1</span> / <span id="totalPagesNum">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                    Tổng bản ghi: <span id="totalVisibleCount">0</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let masterData = [];
    let filteredData = [];
    let currentPage = 1;
    let rowsPerPage = 30;

    // Lưu lại trạng thái từ các thẻ màu phía trên
    let currentActiveStatusFilter = "";

    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. PHỤC HỒI TEXT SEARCH ---
        const savedText = sessionStorage.getItem("savedKhoLuuTruTextIT");
        if (savedText) document.getElementById("searchInput").value = savedText;

        // --- 2. PHỤC HỒI NGÀY THÁNG LỌC NÂNG CAO ---
        const savedFrom = sessionStorage.getItem("savedFromDateIT");
        if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

        const savedTo = sessionStorage.getItem("savedToDateIT");
        if (savedTo) document.getElementById("txtToDate").value = savedTo;

        // --- 3. PHỤC HỒI TRẠNG THÁI THẺ CARD ---
        const savedStatus = sessionStorage.getItem("savedKhoLuuTruStatusIT");
        if (savedStatus !== null) {
            currentActiveStatusFilter = savedStatus;
        }

        loadDataFromAPI();
    });

    async function loadDataFromAPI() {
        try {
            const response = await fetch('/FormIT/GetHoanTatDonData');
            if (!response.ok) throw new Error("API Failure");

            masterData = await response.json();
            filteredData = masterData;

            // Render giao diện lần đầu
            populateDropdowns(masterData);

            // --- 4. PHỤC HỒI COMBOBOX SAU KHI ĐỔ DỮ LIỆU ---
            const savedDept = sessionStorage.getItem("savedDeptIT");
            if (savedDept) document.getElementById("selDept").value = savedDept;

            const savedStaff = sessionStorage.getItem("savedStaffIT");
            if (savedStaff) document.getElementById("selStaff").value = savedStaff;

            // Tính toán tổng số trên thẻ
            calculateStats(masterData);

            // Bật hiệu ứng CSS thẻ Trạng Thái đã lưu
            updateVisualStatusCard(currentActiveStatusFilter);

            // Chạy hàm lọc tổng hợp
            handleSearch();
        } catch (error) {
            console.error(error);
            document.getElementById('tableBody').innerHTML = '<tr><td colspan="6" style="text-align:center; padding: 50px; color: #ef4444; font-weight: 700;">Lỗi tải dữ liệu. Vui lòng thử lại sau!</td></tr>';
        }
    }

    // Đổ dữ liệu vào Dropdown Bộ Phận và Người Hỗ Trợ
    function populateDropdowns(data) {
        const selDept = document.getElementById("selDept");
        const selStaff = document.getElementById("selStaff");

        // Lấy danh sách Bộ phận duy nhất
        const depts = [...new Set(data.map(x => x.boPhan).filter(Boolean))].sort();
        depts.forEach(d => {
            selDept.innerHTML += `<option value="${d}">${d}</option>`;
        });

        // Lấy danh sách Người hỗ trợ duy nhất
        const allStaff = [];
        data.forEach(item => {
            if (item.nguoiHoTros && item.nguoiHoTros.length > 0) {
                allStaff.push(...item.nguoiHoTros);
            }
        });
        const staffSet = [...new Set(allStaff.filter(name => name !== "N/A"))].sort();
        staffSet.forEach(s => {
            selStaff.innerHTML += `<option value="${s}">${s}</option>`;
        });
    }

    function calculateStats(data) {
        let completed = 0, processing = 0, cancelled = 0, waitingRate = 0, waitingManager = 0;

        data.forEach(item => {
            let st = determineStatus(item).statusName;
            if (st === "Đã hủy") cancelled++;
            else if (st === "Hoàn tất") completed++;
            else if (st === "Chờ đánh giá") waitingRate++;
            else if (st === "IT Đang xử lý") processing++;
            else if (st === "Chờ QL Duyệt") waitingManager++;
        });

        document.getElementById("stat-total").innerText = data.length;
        document.getElementById("stat-completed").innerText = completed;
        document.getElementById("stat-processing").innerText = processing;
        document.getElementById("stat-cancelled").innerText = cancelled;
        document.getElementById("stat-waiting-rate").innerText = waitingRate;
        document.getElementById("stat-waiting-manager").innerText = waitingManager;
    }

    function determineStatus(item) {
        let statusName = "";
        const isCancelled = (item.tenForm || "").includes("[ĐÃ HỦY]");

        if (isCancelled) statusName = "Đã hủy";
        else if (item.idNguoiDuyet == null) statusName = "Chờ QL Duyệt";
        else if (item.idAdmin == null) statusName = "IT Đang xử lý";
        else if (!item.daDanhGia) statusName = "Chờ đánh giá";
        else statusName = "Hoàn tất";

        let pWidth, pColor, stBg, stFg;
        switch(statusName) {
            case "Đã hủy": pWidth = "100%"; pColor = "#ef4444"; stBg = "#fee2e2"; stFg = "#dc2626"; break;
            case "Hoàn tất": pWidth = "100%"; pColor = "#10b981"; stBg = "#ecfdf5"; stFg = "#059669"; break;
            case "Chờ đánh giá": pWidth = "85%"; pColor = "#7c3aed"; stBg = "#f5f3ff"; stFg = "#6d28d9"; break;
            case "IT Đang xử lý": pWidth = "60%"; pColor = "#3b82f6"; stBg = "#eff6ff"; stFg = "#2563eb"; break;
            case "Chờ QL Duyệt": pWidth = "25%"; pColor = "#f59e0b"; stBg = "#fff7ed"; stFg = "#d97706"; break;
            default: pWidth = "10%"; pColor = "#94a3b8"; stBg = "#f8fafc"; stFg = "#64748b"; break;
        }

        return { statusName, pWidth, pColor, stBg, stFg };
    }

    function changePageSize() {
        rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
        currentPage = 1;
        renderTable();
    }

    // Hàm cập nhật CSS giao diện cho Thẻ Trạng thái
    function updateVisualStatusCard(status) {
        // Đưa tất cả thẻ về mặc định
        document.querySelectorAll('.stat-card-item').forEach(el => {
            el.style.boxShadow = "none";
            el.style.border = "1px solid rgba(0,0,0,0.05)";
        });

        // Bật viền xanh thẻ đang click
        const targetCard = document.querySelector(`.stat-card-item[data-status="${status}"]`);
        if (targetCard) {
            targetCard.style.boxShadow = "0 0 0 3px #1e40af40";
            targetCard.style.border = "1px solid #1e40af";
        }
    }

    // Nút bấm trên thẻ Thống kê màu mè
    function filterByStatus(status) {
        currentActiveStatusFilter = status;

        // Lưu trạng thái vào Session
        sessionStorage.setItem("savedKhoLuuTruStatusIT", status);

        updateVisualStatusCard(status);
        handleSearch();
    }

    function clearAllFilters() {
        document.getElementById("searchInput").value = "";
        document.getElementById("txtFromDate").value = "";
        document.getElementById("txtToDate").value = "";
        document.getElementById("selDept").value = "";
        document.getElementById("selStaff").value = "";

        // Xóa sạch Session Storage
        sessionStorage.removeItem("savedKhoLuuTruTextIT");
        sessionStorage.removeItem("savedFromDateIT");
        sessionStorage.removeItem("savedToDateIT");
        sessionStorage.removeItem("savedDeptIT");
        sessionStorage.removeItem("savedStaffIT");
        sessionStorage.removeItem("savedKhoLuuTruStatusIT");

        filterByStatus(""); // Trả về thẻ TỔNG LƯU TRỮ
    }

    // Hàm Lọc tổng hợp TẤT CẢ tiêu chí
    function handleSearch() {
        const textFilter = document.getElementById("searchInput").value.toUpperCase();
        const fromDateStr = document.getElementById("txtFromDate").value;
        const toDateStr = document.getElementById("txtToDate").value;
        const deptFilter = document.getElementById("selDept").value;
        const staffFilter = document.getElementById("selStaff").value;

        // Lưu thông số vào Session Storage để F5 không bị mất
        sessionStorage.setItem("savedKhoLuuTruTextIT", textFilter);
        sessionStorage.setItem("savedFromDateIT", fromDateStr);
        sessionStorage.setItem("savedToDateIT", toDateStr);
        sessionStorage.setItem("savedDeptIT", deptFilter);
        sessionStorage.setItem("savedStaffIT", staffFilter);

        filteredData = masterData.filter(item => {
            const stInfo = determineStatus(item);
            const stName = stInfo.statusName;

            // 1. Kiểm tra trạng thái từ Thẻ Card phía trên
            if (currentActiveStatusFilter && stName !== currentActiveStatusFilter) return false;

            // 2. Kiểm tra Bộ Phận
            if (deptFilter && item.boPhan !== deptFilter) return false;

            // 3. Kiểm tra Người Hỗ Trợ
            if (staffFilter && !(item.nguoiHoTros || []).includes(staffFilter)) return false;

            // 4. Kiểm tra Khoảng Thời Gian
            if (fromDateStr || toDateStr) {
                if (!item.timeNguoiTao) return false;

                // C# trả về chuỗi "dd/MM/yyyy", chuyển về object Date JS
                const parts = item.timeNguoiTao.split('/');
                if (parts.length === 3) {
                    const itemDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);

                    if (fromDateStr) {
                        const fromD = new Date(fromDateStr + "T00:00:00");
                        if (itemDate < fromD) return false;
                    }
                    if (toDateStr) {
                        const toD = new Date(toDateStr + "T23:59:59");
                        if (itemDate > toD) return false;
                    }
                }
            }

            // 5. Kiểm tra Chuỗi Text tìm kiếm tự do
            if (textFilter) {
                const supportNames = (item.nguoiHoTros || []).join(" ").toUpperCase();
                const searchString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.danhmuc} ${item.tenForm} ${item.id} ${supportNames} ${stName}`.toUpperCase();
                if (!searchString.includes(textFilter)) return false;
            }

            return true;
        });

        currentPage = 1;
        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById("tableBody");
        const emptyState = document.getElementById("emptyState");
        const dataTable = document.getElementById("dataTable");

        tbody.innerHTML = "";
        const startIdx = (currentPage - 1) * rowsPerPage;
        const pageData = filteredData.slice(startIdx, startIdx + rowsPerPage);

        if (pageData.length === 0) {
            emptyState.style.display = "block";
            dataTable.style.display = "none";
        } else {
            emptyState.style.display = "none";
            dataTable.style.display = "table";

            pageData.forEach(item => {
                const s = determineStatus(item);
                const cleanTenForm = (item.tenForm || "").replace("[ĐÃ HỦY]", "").trim();

                let supportHtml = "";
                if (item.nguoiHoTros && item.nguoiHoTros.length > 0) {
                    supportHtml = `<div style="display: flex; flex-wrap: wrap; gap: 5px; justify-content: flex-start;">`;
                    item.nguoiHoTros.forEach(name => {
                        supportHtml += `<span style="background: #eff6ff; color: #1e40af; border: 1px solid #dbeafe; padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;"><i class="fa fa-user-circle-o"></i> ${name}</span>`;
                    });
                    supportHtml += `</div>`;
                } else {
                    supportHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa có tiếp nhận</span>`;
                }

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td data-label="Nhân viên" style="padding: 15px 20px;">
                        <div class="mobile-td-content">
                            <div style="font-weight: 900; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                            <div style="font-size: 11px; color: #64748b; margin-top: 4px; font-weight: 700;">
                                <i class="fa fa-id-badge"></i> #${item.id} • ${item.boPhan}
                            </div>
                        </div>
                    </td>
                    <td data-label="Hỗ trợ" style="padding: 15px 20px;">
                        <div class="mobile-td-content">${supportHtml}</div>
                    </td>
                    <td data-label="Danh mục" style="padding: 15px 20px;">
                        <span style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 800; border: 1px solid #e2e8f0; display: inline-block;">
                            ${item.danhmuc}
                        </span>
                    </td>
                    <td data-label="Dịch vụ" style="padding: 15px 20px;">
                        <div class="mobile-td-content">
                            <div style="font-weight: 800; color: #1e293b; font-size: 13px; margin-bottom: 6px;">${cleanTenForm}</div>
                            <div style="display: flex; align-items: center; gap: 12px; width: 100%;">
                                <div style="flex-grow: 1; height: 5px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 120px;">
                                    <div style="width: ${s.pWidth}; height: 100%; background: ${s.pColor}; transition: width 0.6s;"></div>
                                </div>
                                <span style="font-size: 10px; font-weight: 800; color: #94a3b8;">${item.timeNguoiTao}</span>
                            </div>
                        </div>
                    </td>
                    <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                        <span style="background: ${s.stBg}; color: ${s.stFg}; border: 1.5px solid ${s.stFg}; padding: 6px 12px; border-radius: 10px; font-size: 10px; font-weight: 1000; display: inline-block; min-width: 110px; text-transform: uppercase;">${s.statusName}</span>
                    </td>
                    <td data-label="Hành động" style="padding: 15px 20px; text-align: right;">
                        <a href="/FormIT/ChiTiet/${item.id}"
                           style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.3s; background: #1e40af; color: #ffffff; width: 100%; text-align: center; box-sizing: border-box;"
                           onmouseover="this.style.background='#1e3a8a'" onmouseout="this.style.background='#1e40af'">
                           Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                        </a>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        const totalPages = Math.ceil(filteredData.length / rowsPerPage) || 1;
        renderPaginationButtons(totalPages);
        document.getElementById("totalVisibleCount").innerText = filteredData.length;
        document.getElementById("currentPageNum").innerText = currentPage;
        document.getElementById("totalPagesNum").innerText = totalPages;
    }

    function renderPaginationButtons(totalPages) {
        const container = document.getElementById("paginationButtons");
        container.innerHTML = "";
        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            if (totalPages > 6 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                if (i === 3 || i === totalPages - 2) {
                    const dot = document.createElement("span");
                    dot.innerText = "..."; dot.style.padding = "8px"; dot.style.color = "#94a3b8";
                    container.appendChild(dot);
                }
                continue;
            }
            const btn = document.createElement("button");
            btn.innerText = i;
            btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
            btn.onclick = () => {
                currentPage = i;
                renderTable();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            };
            container.appendChild(btn);
        }
    }
</script>