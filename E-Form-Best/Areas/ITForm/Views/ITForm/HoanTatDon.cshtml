@model IEnumerable<E_Form_Best.Models.ITForm.FormIt>
@using System.Security.Claims

@{
    ViewData["Title"] = "Đơn IT Hoàn Tất";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                          ?? User.FindFirst("UserRole")?.Value ?? "";

    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.IdAdmin != null && !(x.TenForm?.Contains("[ĐÃ HỦY]") ?? false)) ?? 0;
    var cancelled = Model?.Count(x => x.TenForm?.Contains("[ĐÃ HỦY]") ?? false) ?? 0;
    var processing = Model?.Count(x => x.IdNguoiDuyet != null && x.IdAdmin == null && !(x.TenForm?.Contains("[ĐÃ HỦY]") ?? false)) ?? 0;
}

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1400px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #1e40af; letter-spacing: -0.04em; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #1e40af; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(30, 64, 175, 0.3);">
                        <i class="fa fa-check-square-o"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN IT
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e40af; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@currentUserRole</span>
                    <span style="background: #cbd5e1; color: #1e293b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">HOÀN TẤT & HỦY</span>
                </div>
            </div>

            <div style="display: flex; gap: 15px;">
                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên, mã đơn, thiết bị..."
                           style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 350px; font-size: 14px; font-weight: 700; outline: none; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                </div>
            </div>
        </div>

        @* --- THỐNG KÊ NHANH (Giữ nguyên) --- *@
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px;">
            @{
                var stats = new[] {
                        new { Label = "TỔNG LƯU TRỮ", Value = total, Color = "#1e40af", Bg = "white", Filter = "" },
                        new { Label = "ĐÃ XỬ LÝ XONG", Value = completed, Color = "#059669", Bg = "#f0fdf4", Filter = "HOÀN TẤT" },
                        new { Label = "IT ĐANG XỬ LÝ", Value = processing, Color = "#2563eb", Bg = "#eff6ff", Filter = "CHỜ IT" },
                        new { Label = "ĐƠN ĐÃ HỦY", Value = cancelled, Color = "#dc2626", Bg = "#fef2f2", Filter = "ĐÃ HỦY" }
                        };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')"
                     style="background: @s.Bg; padding: 25px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                    <div style="font-size: 11px; font-weight: 900; color: @s.Color; letter-spacing: 1.5px; text-transform: uppercase; opacity: 0.8;">@s.Label</div>
                    <div style="font-size: 36px; font-weight: 1000; color: @s.Color; margin-top: 8px;">@s.Value</div>
                </div>
            }
        </div>

        @* --- BẢNG DỮ LIỆU --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 20%;">Nhân viên yêu cầu</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 20%;">Người hỗ trợ</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Loại dịch vụ & Tiến độ</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Ngày tạo</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 20px; text-align: center;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        bool isCancelled = item.TenForm?.Contains("[ĐÃ HỦY]") ?? false;
                        bool isFinished = item.IdAdmin != null;
                        bool isApprovedByManager = item.IdNguoiDuyet != null;

                        string pWidth = "10%"; string pColor = "#94a3b8"; string pText = "Gửi đơn";
                        if (isCancelled) { pWidth = "100%"; pColor = "#ef4444"; pText = "ĐÃ HỦY"; }
                        else if (isFinished) { pWidth = "100%"; pColor = "#10b981"; pText = "HOÀN TẤT"; }
                        else if (isApprovedByManager) { pWidth = "66%"; pColor = "#3b82f6"; pText = "CHỜ IT"; }
                        else { pWidth = "33%"; pColor = "#f59e0b"; pText = "CHỜ QL"; }

                        <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                            <td style="padding: 20px;">
                                <div style="font-weight: 900; color: #0f172a; font-size: 15px;">@item.TenNguoiNv</div>
                                <div style="font-size: 12px; color: #64748b; margin-top: 4px; font-weight: 700;">
                                    <i class="fa fa-id-badge"></i> #@item.Id • <i class="fa fa-briefcase"></i> @item.BoPhan
                                </div>
                            </td>

                            @* --- CỘT NGƯỜI HỖ TRỢ IT (BỔ SUNG MỚI) --- *@
                            <td style="padding: 20px;">
                                @if (item.ItCtNguoiHoTros != null && item.ItCtNguoiHoTros.Any())
                                {
                                    <div style="display: flex; flex-wrap: wrap; gap: 5px;">
                                        @foreach (var support in item.ItCtNguoiHoTros)
                                        {
                                            <span style="background: #eff6ff; color: #1e40af; border: 1px solid #dbeafe; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;">
                                                <i class="fa fa-user-circle"></i> @(support.IdItNguoiHoTroNavigation?.Ten ?? "N/A")
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa có người hỗ trợ</span>
                                }
                            </td>

                            <td style="padding: 20px;">
                                <div style="font-weight: 800; color: @(isCancelled ? "#ef4444" : "#1e40af"); font-size: 14px; margin-bottom: 10px;">
                                    @item.TenForm?.Replace("[ĐÃ HỦY]", "")
                                </div>
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <div style="flex-grow: 1; height: 10px; background: #e2e8f0; border-radius: 20px; overflow: hidden; max-width: 200px;">
                                        <div style="width: @pWidth; height: 100%; background: @pColor; border-radius: 20px; transition: width 0.5s ease;"></div>
                                    </div>
                                    <span style="font-size: 10px; font-weight: 1000; color: @pColor; text-transform: uppercase; letter-spacing: 0.5px;">@pText</span>
                                </div>
                            </td>
                            <td style="padding: 20px;">
                                <div style="font-size: 13px; font-weight: 800; color: #334155;">
                                    <i class="fa fa-calendar-o"></i> @(item.TimeNguoiTao?.ToString("dd/MM/yyyy") ?? "--/--")
                                </div>
                                <div style="font-size: 11px; color: #94a3b8; font-weight: 700; margin-top: 4px;">Lúc: @item.TimeNguoiTao?.ToString("HH:mm")</div>
                            </td>
                            <td style="padding: 20px; text-align: center;">
                                @{
                                    var (bg, fg, txt) = isCancelled ? ("#fee2e2", "#dc2626", "ĐÃ HỦY") :
                                    isFinished ? ("#d1fae5", "#059669", "HOÀN TẤT") :
                                    isApprovedByManager ? ("#dbeafe", "#2563eb", "CHỜ IT") : ("#fff7ed", "#d97706", "CHỜ QL");
                                }
                                <span style="background: @bg; color: @fg; border: 1.5px solid @fg; padding: 6px 14px; border-radius: 12px; font-size: 10px; font-weight: 1000; display: inline-block; min-width: 90px; letter-spacing: 0.5px;">
                                    @txt
                                </span>
                            </td>
                            <td style="padding: 20px; text-align: center;">
                                <a href="/FormIT/ChiTiet/@item.Id"
                                   style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: #f1f5f9; color: #1e40af; border-radius: 12px; text-decoration: none; font-size: 18px; transition: 0.3s;"
                                   onmouseover="this.style.background='#1e40af'; this.style.color='white'"
                                   onmouseout="this.style.background='#f1f5f9'; this.style.color='#1e40af'">
                                    <i class="fa fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div style="padding: 50px; text-align: center; color: #94a3b8;">
                    <i class="fa fa-folder-open-o" style="font-size: 48px; margin-bottom: 15px; display: block;"></i>
                    <span style="font-weight: 700;">Không có dữ liệu đơn nào trong kho lưu trữ</span>
                </div>
            }
        </div>

        <div style="text-align: left; padding: 25px 10px; color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase;">
            IT Support Management System v3.0
        </div>
    </div>
</div>

<script>
    // Hàm tìm kiếm tổng hợp (Giữ nguyên)
    function filterTable() {
        const input = document.getElementById("searchInput");
        const filter = input.value.toUpperCase();
        const tr = document.querySelectorAll("#dataTable tbody tr");

        tr.forEach(row => {
            const text = row.innerText.toUpperCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    }

    // Hàm lọc nhanh theo trạng thái từ thẻ thống kê (Giữ nguyên)
    function filterByStatus(status) {
        const input = document.getElementById("searchInput");
        input.value = status;
        filterTable();

        // Thêm hiệu ứng flash nhẹ để người dùng biết đã lọc
        const table = document.getElementById("dataTable");
        table.style.opacity = "0.5";
        setTimeout(() => { table.style.opacity = "1"; }, 150);
    }
</script>