@model IEnumerable<E_Form_Best.Models.ITForm.FormIt>
@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn IT";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    // Lấy Role để hiển thị tag thông tin người dùng
    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";

    // Thống kê dựa trên trường TrangThai đã được Controller gán logic tiếng Việt
    var total = Model?.Count() ?? 0;
    var completed = Model?.Count(x => x.TrangThai == "Hoàn tất") ?? 0;
    var processing = Model?.Count(x => x.TrangThai == "IT Đang xử lý") ?? 0;
    var cancelled = Model?.Count(x => x.TrangThai == "Đã hủy") ?? 0;
    var waitingRate = Model?.Count(x => x.TrangThai == "Chờ đánh giá") ?? 0;
    var waitingManager = Model?.Count(x => x.TrangThai == "Chờ QL Duyệt") ?? 0;
}

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1400px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #1e40af; letter-spacing: -0.04em; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #1e40af; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(30, 64, 175, 0.3);">
                        <i class="fa fa-archive"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN IT
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e40af; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@currentUserRole</span>
                    <span style="background: #cbd5e1; color: #1e293b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">DỮ LIỆU TỔNG HỢP</span>
                </div>
            </div>

            <div style="display: flex; gap: 15px;">
                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Tìm tên, mã đơn, trạng thái..."
                           style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 350px; font-size: 14px; font-weight: 700; outline: none; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                </div>
            </div>
        </div>

        @* --- THỐNG KÊ NHANH (6 ô trạng thái) --- *@
        <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 30px;">
            @{
                var stats = new[] {
                    new { Label = "TỔNG LƯU TRỮ", Value = total, Color = "#1e40af", Bg = "white", Filter = "" },
                    new { Label = "CHỜ QL DUYỆT", Value = waitingManager, Color = "#f59e0b", Bg = "#fff7ed", Filter = "Chờ QL Duyệt" },
                    new { Label = "IT ĐANG XỬ LÝ", Value = processing, Color = "#2563eb", Bg = "#eff6ff", Filter = "IT Đang xử lý" },
                    new { Label = "CHỜ ĐÁNH GIÁ", Value = waitingRate, Color = "#7c3aed", Bg = "#f5f3ff", Filter = "Chờ đánh giá" },
                    new { Label = "ĐÃ HOÀN TẤT", Value = completed, Color = "#059669", Bg = "#f0fdf4", Filter = "Hoàn tất" },
                    new { Label = "ĐƠN ĐÃ HỦY", Value = cancelled, Color = "#dc2626", Bg = "#fef2f2", Filter = "Đã hủy" }
                };
            }
            @foreach (var s in stats)
            {
                <div onclick="filterByStatus('@s.Filter')"
                     style="background: @s.Bg; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'"
                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                    <div style="font-size: 9px; font-weight: 900; color: @s.Color; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">@s.Label</div>
                    <div style="font-size: 28px; font-weight: 1000; color: @s.Color; margin-top: 8px;">@s.Value</div>
                </div>
            }
        </div>

        @* --- BẢNG DỮ LIỆU --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 20%;">Nhân viên yêu cầu</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 18%;">Người hỗ trợ</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 12%;">Danh mục</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Dịch vụ & Tiến độ</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 15%;">Trạng thái</th>
                        <th style="padding: 20px; text-align: center; width: 80px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        string pWidth, pColor, stBg, stFg;

                        // Logic màu sắc và thanh tiến độ dựa trên TrangThai đã gán ở Controller
                        switch (item.TrangThai)
                        {
                            case "Đã hủy":
                                pWidth = "100%"; pColor = "#ef4444"; stBg = "#fee2e2"; stFg = "#dc2626";
                                break;
                            case "Hoàn tất":
                                pWidth = "100%"; pColor = "#10b981"; stBg = "#d1fae5"; stFg = "#059669";
                                break;
                            case "Chờ đánh giá":
                                pWidth = "85%"; pColor = "#7c3aed"; stBg = "#f5f3ff"; stFg = "#7c3aed";
                                break;
                            case "IT Đang xử lý":
                                pWidth = "66%"; pColor = "#3b82f6"; stBg = "#dbeafe"; stFg = "#2563eb";
                                break;
                            case "Chờ QL Duyệt":
                                pWidth = "33%"; pColor = "#f59e0b"; stBg = "#fff7ed"; stFg = "#d97706";
                                break;
                            default:
                                pWidth = "10%"; pColor = "#94a3b8"; stBg = "#f1f5f9"; stFg = "#475569";
                                break;
                        }

                        <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                            @* 1. Thông tin người tạo *@
                            <td style="padding: 20px;">
                                <div style="font-weight: 900; color: #0f172a; font-size: 15px;">@item.TenNguoiNv</div>
                                <div style="font-size: 12px; color: #64748b; margin-top: 4px; font-weight: 700;">
                                    <i class="fa fa-id-badge"></i> #@item.Id • <i class="fa fa-briefcase"></i> @item.BoPhan
                                </div>
                            </td>

                            @* 2. Danh sách IT hỗ trợ (Eager Loading từ ItCtNguoiHoTros) *@
                            <td style="padding: 20px;">
                                @if (item.ItCtNguoiHoTros != null && item.ItCtNguoiHoTros.Any())
                                {
                                    <div style="display: flex; flex-wrap: wrap; gap: 5px;">
                                        @foreach (var support in item.ItCtNguoiHoTros)
                                        {
                                            <span style="background: #eff6ff; color: #1e40af; border: 1px solid #dbeafe; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;">
                                                <i class="fa fa-user-circle"></i> @(support.IdItNguoiHoTroNavigation?.Ten ?? "N/A")
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa có IT tiếp nhận</span>
                                }
                            </td>

                            @* 3. Danh mục *@
                            <td style="padding: 15px 20px;">
                                <span style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 800; border: 1px solid #e2e8f0;">
                                    <i class="fa fa-tag" style="margin-right: 4px;"></i>
                                    @(string.IsNullOrEmpty(item.Danhmuc) ? "Yêu cầu IT" : item.Danhmuc)
                                </span>
                            </td>

                            @* 4. Tên đơn & Thanh tiến độ *@
                            <td style="padding: 15px 20px;">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px; margin-bottom: 8px;">
                                    @(item.TenForm?.Replace("[ĐÃ HỦY]", "").Trim())
                                </div>
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <div style="flex-grow: 1; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 150px;">
                                        <div style="width: @pWidth; height: 100%; background: @pColor; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);"></div>
                                    </div>
                                    <span style="font-size: 10px; font-weight: 900; color: #64748b;">
                                        <i class="fa fa-clock-o"></i> @item.TimeNguoiTao?.ToString("dd/MM/yyyy")
                                    </span>
                                </div>
                            </td>

                            @* 5. Trạng thái *@
                            <td style="padding: 20px; text-align: center;">
                                <span style="background: @stBg; color: @stFg; border: 1.5px solid @stFg; padding: 6px 14px; border-radius: 12px; font-size: 10px; font-weight: 1000; display: inline-block; min-width: 115px; text-transform: uppercase; text-align: center;">
                                    @item.TrangThai
                                </span>
                            </td>

                            @* 6. Nút xem *@
                            <td style="padding: 20px; text-align: center;">
                                <a href="/FormIT/ChiTiet/@item.Id"
                                       title="Xem chi tiết đơn"
                                       style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: #f1f5f9; color: #1e40af; border-radius: 12px; text-decoration: none; font-size: 18px; transition: 0.3s;"
                                       onmouseover="this.style.background='#1e40af'; this.style.color='white'"
                                       onmouseout="this.style.background='#f1f5f9'; this.style.color='#1e40af'">
                                    <i class="fa fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* Hiển thị khi không có dữ liệu *@
            @if (!Model.Any())
            {
                <div style="padding: 80px 20px; text-align: center; color: #94a3b8;">
                    <i class="fa fa-folder-open-o" style="font-size: 54px; margin-bottom: 20px; display: block; opacity: 0.5;"></i>
                    <div style="font-weight: 700; font-size: 16px;">Không tìm thấy đơn nào</div>
                    <div style="font-size: 13px; margin-top: 5px;">Dữ liệu kho hiện đang trống hoặc không khớp từ khóa tìm kiếm</div>
                </div>
            }
        </div>

        @* --- FOOTER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 25px 10px;">
            <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase;">
                IT Support System v3.0
            </div>
            <div style="color: #64748b; font-size: 12px; font-weight: 700;">
                Tổng cộng: <span style="color: #1e40af;">@total</span> bản ghi
            </div>
        </div>
    </div>
</div>

<script>
    // Hàm tìm kiếm nhanh trên bảng
    function filterTable() {
        const input = document.getElementById("searchInput");
        const filter = input.value.toUpperCase();
        const tr = document.querySelectorAll("#dataTable tbody tr");

        tr.forEach(row => {
            const text = row.innerText.toUpperCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    }

    // Hàm lọc theo nút thống kê
    function filterByStatus(status) {
        const input = document.getElementById("searchInput");
        input.value = status;
        filterTable();

        // Hiệu ứng phản hồi nhẹ khi nhấn nút lọc
        const table = document.getElementById("dataTable");
        table.style.opacity = "0.4";
        setTimeout(() => {
            table.style.transition = "opacity 0.3s";
            table.style.opacity = "1";
        }, 100);
    }
</script>