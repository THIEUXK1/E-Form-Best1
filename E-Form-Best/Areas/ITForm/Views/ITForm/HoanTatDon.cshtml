@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn IT";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    // Lấy Role để hiển thị tag thông tin người dùng
    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* ==========================================
           CSS RESPONSIVE CHO MOBILE (2026 STYLE)
           ========================================== */
    @@media (max-width: 768px) {
        .main-padding {
            padding: 15px !important;
        }

        .header-mobile {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 20px !important;
        }

        .search-area-mobile {
            width: 100% !important;
            flex-direction: column !important;
            gap: 12px !important;
        }

            .search-area-mobile div, #searchInput {
                width: 100% !important;
            }
        /* Thống kê: Chuyển thành lưới 2 cột */
        .stats-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }
        /* Chuyển Table thành Cards */
        #dataTable, #dataTable thead, #dataTable tbody, #dataTable th, #dataTable td, #dataTable tr {
            display: block;
        }

            #dataTable thead {
                display: none; /* Ẩn tiêu đề bảng */
            }

            #dataTable tr {
                margin-bottom: 20px;
                border: 2px solid #e2e8f0 !important;
                border-radius: 20px;
                padding: 15px;
                background: #ffffff;
                box-shadow: 0 4px 10px rgba(0,0,0,0.03);
                position: relative;
            }

            #dataTable td {
                border: none !important;
                padding: 8px 0 !important;
                width: 100% !important;
                text-align: left !important;
            }
        /* Tùy chỉnh các khối thông tin trong Card */
        .td-support {
            border-top: 1px solid #f1f5f9 !important;
            border-bottom: 1px solid #f1f5f9 !important;
            padding: 12px 0 !important;
            margin: 10px 0;
        }

        .td-status {
            display: flex;
            justify-content: center;
            margin: 10px 0;
        }

        .td-action {
            text-align: right !important;
            margin-top: 5px;
        }

        .pagination-mobile {
            flex-direction: column !important;
            gap: 20px;
            align-items: center !important;
        }
    }
</style>

<div class="main-padding" style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Inter', sans-serif; color: #1e293b;">
    <div style="max-width: 1400px; margin: 0 auto;">

        @* --- HEADER --- *@
        <div class="header-mobile" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h2 style="margin: 0; font-size: 28px; font-weight: 1000; color: #1e40af; letter-spacing: -0.04em; display: flex; align-items: center; gap: 15px;">
                    <span style="background: #1e40af; color: white; width: 50px; height: 50px; border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 15px -3px rgba(30, 64, 175, 0.3);">
                        <i class="fa fa-archive"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN IT
                </h2>
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <span style="background: #1e40af; color: white; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900; text-transform: uppercase;">@currentUserRole</span>
                    <span style="background: #cbd5e1; color: #1e293b; padding: 5px 15px; border-radius: 8px; font-size: 11px; font-weight: 900;">DỮ LIỆU TỔNG HỢP</span>
                </div>
            </div>

            <div class="search-area-mobile" style="display: flex; gap: 15px; align-items: center;">
                @* --- CHỌN SỐ DÒNG HIỂN THỊ --- *@
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 15px; border-radius: 15px; border: 2px solid #cbd5e1; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                    <span style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase;">Hiển thị:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 1000; color: #1e40af; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="30" selected>30</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                @* --- TÌM KIẾM --- *@
                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #64748b; font-weight: 900;"></i>
                    <input type="text" id="searchInput" onkeyup="handleSearch()" placeholder="Tìm tên, mã đơn, trạng thái..."
                           style="padding: 14px 20px 14px 50px; border-radius: 15px; border: 2px solid #cbd5e1; width: 350px; font-size: 14px; font-weight: 700; outline: none; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                </div>
            </div>
        </div>

        @* --- THỐNG KÊ NHANH --- *@
        <div class="stats-grid-mobile" style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 30px;">
            <div onclick="filterByStatus('')" style="background: white; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                <div style="font-size: 9px; font-weight: 900; color: #1e40af; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">TỔNG LƯU TRỮ</div>
                <div id="stat-total" style="font-size: 28px; font-weight: 1000; color: #1e40af; margin-top: 8px;">0</div>
            </div>
            <div onclick="filterByStatus('Chờ QL Duyệt')" style="background: #fff7ed; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                <div style="font-size: 9px; font-weight: 900; color: #f59e0b; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">CHỜ QL DUYỆT</div>
                <div id="stat-waiting-manager" style="font-size: 28px; font-weight: 1000; color: #f59e0b; margin-top: 8px;">0</div>
            </div>
            <div onclick="filterByStatus('IT Đang xử lý')" style="background: #eff6ff; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                <div style="font-size: 9px; font-weight: 900; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">IT ĐANG XỬ LÝ</div>
                <div id="stat-processing" style="font-size: 28px; font-weight: 1000; color: #2563eb; margin-top: 8px;">0</div>
            </div>
            <div onclick="filterByStatus('Chờ đánh giá')" style="background: #f5f3ff; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                <div style="font-size: 9px; font-weight: 900; color: #7c3aed; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">CHỜ ĐÁNH GIÁ</div>
                <div id="stat-waiting-rate" style="font-size: 28px; font-weight: 1000; color: #7c3aed; margin-top: 8px;">0</div>
            </div>
            <div onclick="filterByStatus('Hoàn tất')" style="background: #f0fdf4; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                <div style="font-size: 9px; font-weight: 900; color: #059669; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">ĐÃ HOÀN TẤT</div>
                <div id="stat-completed" style="font-size: 28px; font-weight: 1000; color: #059669; margin-top: 8px;">0</div>
            </div>
            <div onclick="filterByStatus('Đã hủy')" style="background: #fef2f2; padding: 18px 15px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 20px 25px -5px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                <div style="font-size: 9px; font-weight: 900; color: #dc2626; letter-spacing: 1px; text-transform: uppercase; opacity: 0.8;">ĐƠN ĐÃ HỦY</div>
                <div id="stat-cancelled" style="font-size: 28px; font-weight: 1000; color: #dc2626; margin-top: 8px;">0</div>
            </div>
        </div>

        @* --- BẢNG DỮ LIỆU --- *@
        <div style="background: white; border-radius: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); overflow: hidden;">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 20%;">Nhân viên yêu cầu</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 18%;">Người hỗ trợ</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 12%;">Danh mục</th>
                        <th style="padding: 20px; text-align: left; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase;">Dịch vụ & Tiến độ</th>
                        <th style="padding: 20px; text-align: center; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; width: 15%;">Trạng thái</th>
                        <th style="padding: 20px; text-align: center; width: 80px;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr><td colspan="6" style="text-align: center; padding: 50px; color: #64748b; font-weight: 600;"><i class="fa fa-spinner fa-spin"></i> Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>

            <div id="emptyState" style="display: none; padding: 80px 20px; text-align: center; color: #94a3b8;">
                <i class="fa fa-folder-open-o" style="font-size: 54px; margin-bottom: 20px; display: block; opacity: 0.5;"></i>
                <div style="font-weight: 700; font-size: 16px;">Không tìm thấy đơn nào</div>
                <div style="font-size: 13px; margin-top: 5px;">Dữ liệu kho hiện đang trống hoặc không khớp từ khóa tìm kiếm</div>
            </div>
        </div>

        @* --- PHÂN TRANG VÀ FOOTER --- *@
        <div class="pagination-mobile" style="display: flex; justify-content: space-between; align-items: center; padding: 25px 10px;">
            <div id="paginationButtons" style="display: flex; gap: 8px;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 12px; font-weight: 700;">
                    Hiển thị trang <span id="currentPageNum" style="color: #1e40af;">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; margin-top: 5px;">
                    Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let masterData = [];
    let filteredData = [];
    let currentPage = 1;
    let rowsPerPage = 30;

    document.addEventListener("DOMContentLoaded", () => {
        const savedFilter = sessionStorage.getItem("savedKhoLuuTruFilter");
        if (savedFilter !== null) {
            document.getElementById("searchInput").value = savedFilter;
        }
        loadDataFromAPI();
    });

    async function loadDataFromAPI() {
        try {
            const response = await fetch('/FormIT/GetHoanTatDonData');
            if (!response.ok) throw new Error("Lỗi mạng khi tải dữ liệu");
            
            masterData = await response.json();
            filteredData = masterData;
            
            calculateStats(masterData);
            
            const savedFilter = document.getElementById("searchInput").value;
            if(savedFilter) {
                handleSearch();
            } else {
                renderTable();
            }
        } catch (error) {
            console.error(error);
            document.getElementById('tableBody').innerHTML = '<tr><td colspan="6" style="text-align:center; padding: 50px; color: red;">Đã xảy ra lỗi khi tải dữ liệu!</td></tr>';
        }
    }

    function calculateStats(data) {
        let total = data.length;
        let completed = 0, processing = 0, cancelled = 0, waitingRate = 0, waitingManager = 0;

        data.forEach(item => {
            let st = determineStatus(item).statusName;
            if (st === "Đã hủy") cancelled++;
            else if (st === "Hoàn tất") completed++;
            else if (st === "Chờ đánh giá") waitingRate++;
            else if (st === "IT Đang xử lý") processing++;
            else if (st === "Chờ QL Duyệt") waitingManager++;
        });

        document.getElementById("stat-total").innerText = total;
        document.getElementById("stat-completed").innerText = completed;
        document.getElementById("stat-processing").innerText = processing;
        document.getElementById("stat-cancelled").innerText = cancelled;
        document.getElementById("stat-waiting-rate").innerText = waitingRate;
        document.getElementById("stat-waiting-manager").innerText = waitingManager;
    }

    function determineStatus(item) {
        let statusName = "";
        let isCancelled = (item.tenForm || "").includes("[ĐÃ HỦY]");
        
        if (isCancelled) statusName = "Đã hủy";
        else if (item.idNguoiDuyet == null) statusName = "Chờ QL Duyệt";
        else if (item.idAdmin == null) statusName = "IT Đang xử lý";
        else if (!item.daDanhGia) statusName = "Chờ đánh giá";
        else statusName = "Hoàn tất";

        let pWidth, pColor, stBg, stFg;
        switch(statusName) {
            case "Đã hủy": pWidth = "100%"; pColor = "#ef4444"; stBg = "#fee2e2"; stFg = "#dc2626"; break;
            case "Hoàn tất": pWidth = "100%"; pColor = "#10b981"; stBg = "#d1fae5"; stFg = "#059669"; break;
            case "Chờ đánh giá": pWidth = "85%"; pColor = "#7c3aed"; stBg = "#f5f3ff"; stFg = "#7c3aed"; break;
            case "IT Đang xử lý": pWidth = "66%"; pColor = "#3b82f6"; stBg = "#dbeafe"; stFg = "#2563eb"; break;
            case "Chờ QL Duyệt": pWidth = "33%"; pColor = "#f59e0b"; stBg = "#fff7ed"; stFg = "#d97706"; break;
            default: pWidth = "10%"; pColor = "#94a3b8"; stBg = "#f1f5f9"; stFg = "#475569"; break;
        }

        return { statusName, pWidth, pColor, stBg, stFg };
    }

    function changePageSize() {
        const select = document.getElementById("pageSizeSelect");
        rowsPerPage = parseInt(select.value);
        currentPage = 1;
        renderTable();
    }

    function handleSearch() {
        const input = document.getElementById("searchInput");
        const filter = input.value.toUpperCase();
        sessionStorage.setItem("savedKhoLuuTruFilter", input.value);
        
        filteredData = masterData.filter(item => {
            const st = determineStatus(item).statusName.toUpperCase();
            const supportNames = (item.nguoiHoTros || []).join(" ").toUpperCase();
            const searchString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.danhmuc} ${item.tenForm} ${item.id} ${supportNames} ${st}`.toUpperCase();
            return searchString.includes(filter);
        });

        currentPage = 1;
        renderTable();
    }

    function filterByStatus(status) {
        document.getElementById("searchInput").value = status;
        handleSearch();
    }

    function renderTable() {
        const tbody = document.getElementById("tableBody");
        const emptyState = document.getElementById("emptyState");
        const dataTable = document.getElementById("dataTable");

        tbody.innerHTML = "";
        const startIdx = (currentPage - 1) * rowsPerPage;
        const pageData = filteredData.slice(startIdx, startIdx + rowsPerPage);

        if (pageData.length === 0) {
            emptyState.style.display = "block";
            dataTable.style.display = "none";
        } else {
            emptyState.style.display = "none";
            dataTable.style.display = "table";

            pageData.forEach(item => {
                const s = determineStatus(item);
                let cleanTenForm = (item.tenForm || "").replace("[ĐÃ HỦY]", "").trim();
                
                let supportHtml = "";
                if (item.nguoiHoTros && item.nguoiHoTros.length > 0) {
                    supportHtml = `<div style="display: flex; flex-wrap: wrap; gap: 5px;">`;
                    item.nguoiHoTros.forEach(name => {
                        supportHtml += `<span style="background: #eff6ff; color: #1e40af; border: 1px solid #dbeafe; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;"><i class="fa fa-user-circle"></i> ${name}</span>`;
                    });
                    supportHtml += `</div>`;
                } else {
                    supportHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa có IT tiếp nhận</span>`;
                }

                const tr = document.createElement("tr");
                tr.style.borderBottom = "1px solid #f1f5f9";
                tr.innerHTML = `
                    <td style="padding: 20px;">
                        <div style="font-weight: 900; color: #0f172a; font-size: 15px;">${item.tenNguoiNv}</div>
                        <div style="font-size: 12px; color: #64748b; margin-top: 4px; font-weight: 700;">
                            <i class="fa fa-id-badge"></i> #${item.id} • <i class="fa fa-briefcase"></i> ${item.boPhan}
                        </div>
                    </td>
                    <td class="td-support" style="padding: 20px;">
                        ${supportHtml}
                    </td>
                    <td style="padding: 15px 20px;">
                        <span style="background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 800; border: 1px solid #e2e8f0;">
                            <i class="fa fa-tag" style="margin-right: 4px;"></i> ${item.danhmuc}
                        </span>
                    </td>
                    <td style="padding: 15px 20px;">
                        <div style="font-weight: 800; color: #1e293b; font-size: 14px; margin-bottom: 8px;">${cleanTenForm}</div>
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <div style="flex-grow: 1; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; max-width: 150px;">
                                <div style="width: ${s.pWidth}; height: 100%; background: ${s.pColor}; transition: width 0.6s;"></div>
                            </div>
                            <span style="font-size: 10px; font-weight: 900; color: #64748b;"><i class="fa fa-clock-o"></i> ${item.timeNguoiTao}</span>
                        </div>
                    </td>
                    <td class="td-status" style="padding: 20px; text-align: center;">
                        <span style="background: ${s.stBg}; color: ${s.stFg}; border: 1.5px solid ${s.stFg}; padding: 6px 14px; border-radius: 12px; font-size: 10px; font-weight: 1000; display: inline-block; min-width: 115px; text-transform: uppercase;">${s.statusName}</span>
                    </td>
                    <td class="td-action" style="padding: 20px; text-align: center;">
                        <a href="/FormIT/ChiTiet/${item.id}" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: #f1f5f9; color: #1e40af; border-radius: 12px; text-decoration: none; font-size: 18px;"><i class="fa fa-eye"></i></a>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        renderPagination(filteredData.length);
        document.getElementById("totalVisibleCount").innerText = filteredData.length;
        document.getElementById("currentPageNum").innerText = currentPage;
    }

    function renderPagination(totalRows) {
        const totalPages = Math.ceil(totalRows / rowsPerPage);
        const container = document.getElementById("paginationButtons");
        container.innerHTML = "";
        if (totalPages > 1) {
            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 5 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i == 3 || i == totalPages - 2) {
                        const dot = document.createElement("span"); dot.innerText = "..."; dot.style.padding = "8px"; container.appendChild(dot);
                    }
                    continue;
                }
                const btn = document.createElement("button");
                btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => { currentPage = i; renderTable(); window.scrollTo({ top: 0, behavior: 'smooth' }); };
                container.appendChild(btn);
            }
        }
    }
</script>