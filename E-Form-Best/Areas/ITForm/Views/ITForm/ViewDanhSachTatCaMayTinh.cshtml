@{
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Danh sách tất cả thiết bị máy tính";
}

<style>
    :root {
        --tscn-navy: #0f172a;
        --tscn-blue: #1e40af;
        --tscn-accent: #2563eb;
        --tscn-accent-light: #60a5fa;
        --tscn-border: #e2e8f0;
        --tscn-bg-soft: #f8fafc;
    }

    .tscn-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

        .tscn-page-header h4 {
            margin: 0;
            font-weight: 800;
            color: var(--tscn-navy);
        }

        .tscn-page-header .tscn-subtitle {
            font-size: 13px;
            color: #64748b;
            margin-top: 2px;
        }

    .tscn-icon-badge {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--tscn-navy), var(--tscn-blue));
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .tscn-filter-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 10px rgba(15, 23, 42, 0.06);
    }

        .tscn-filter-card .card-body {
            background: #fff;
            border-radius: 16px;
        }

    .tscn-filter-label {
        font-size: 11.5px;
        font-weight: 700;
        letter-spacing: .03em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 6px;
        display: block;
    }

    .tscn-filter-card .form-control,
    .tscn-filter-card .form-select,
    .tscn-filter-card .dropdown-toggle {
        border-radius: 8px;
        border-color: var(--tscn-border);
    }

        .tscn-filter-card .form-control:focus,
        .tscn-filter-card .form-select:focus {
            border-color: var(--tscn-accent-light);
            box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .12);
        }

    .tscn-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        padding-top: 14px;
        margin-top: 14px;
        border-top: 1px dashed var(--tscn-border);
    }

        .tscn-toolbar .btn {
            border-radius: 8px;
            font-weight: 600;
            white-space: nowrap;
        }

    .tscn-toolbar-spacer {
        flex: 1 1 auto;
    }

    .grid-item-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid var(--tscn-border) !important;
    }

        .grid-item-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.12) !important;
        }

    .dropdown-menu-checkbox {
        max-height: 250px;
        overflow-y: auto;
        min-width: 240px;
        padding: 10px;
        border-radius: 10px;
        border-color: var(--tscn-border);
    }

        .dropdown-menu-checkbox .form-check {
            padding-top: 4px;
            padding-bottom: 4px;
            padding-left: 1.8em;
        }

            .dropdown-menu-checkbox .form-check:hover {
                background: var(--tscn-bg-soft);
                border-radius: 6px;
            }

    .tscn-main-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(15, 23, 42, 0.07);
        overflow: hidden;
    }

        .tscn-main-card .card-header {
            background: linear-gradient(135deg, var(--tscn-navy), var(--tscn-blue));
            border: none;
            padding: 16px 20px;
        }

            .tscn-main-card .card-header h5 {
                font-weight: 700;
                letter-spacing: .01em;
            }

    #tblTatCaMayTinh {
        font-size: 13.5px;
        margin-bottom: 0;
    }

        #tblTatCaMayTinh thead th {
            font-size: 11.5px;
            text-transform: uppercase;
            letter-spacing: .03em;
            font-weight: 700;
            color: #475569;
            background-color: #eef2f7;
            border-bottom: 2px solid var(--tscn-border);
            vertical-align: middle;
            padding: 10px 10px;
        }

        #tblTatCaMayTinh tbody td {
            vertical-align: middle;
            padding: 8px 10px;
        }

        #tblTatCaMayTinh tbody tr:hover {
            background-color: #eff6ff;
        }

    /* Ghim cột Hành động luôn hiển thị bên phải, không cần kéo ngang để thấy */
    #tblTatCaMayTinh th.cot-ghim,
    #tblTatCaMayTinh td.cot-ghim {
        position: sticky;
        right: 0;
        z-index: 5;
        background-color: #fff;
        box-shadow: -2px 0 4px rgba(0,0,0,0.08);
    }

    #tblTatCaMayTinh thead th.cot-ghim {
        z-index: 11;
        background-color: #eef2f7;
    }

    .tscn-empty-state {
        text-align: center;
        padding: 48px 16px;
        color: #94a3b8;
    }

        .tscn-empty-state i {
            font-size: 34px;
            margin-bottom: 10px;
            display: block;
            color: #cbd5e1;
        }

        .tscn-empty-state.text-danger i {
            color: #dc3545;
        }

    .tscn-card-footer {
        background: #fff;
        border-top: 1px solid var(--tscn-border);
        padding: 12px 20px;
    }

    #navPhanTrang .page-link {
        border-radius: 6px;
        margin: 0 2px;
        border-color: var(--tscn-border);
        color: var(--tscn-blue);
    }

    #navPhanTrang .page-item.active .page-link {
        background-color: var(--tscn-accent);
        border-color: var(--tscn-accent);
    }
</style>

<div class="container-fluid mt-4 text-dark">

    <div class="tscn-page-header">
        <div class="d-flex align-items-center gap-3">
            <div class="tscn-icon-badge"><i class="fa fa-server"></i></div>
            <div>
                <h4>Danh sách tất cả thiết bị máy tính</h4>
                <div class="tscn-subtitle">Quản lý, phân loại và đồng bộ toàn bộ máy tính đã kiểm kê trong hệ thống</div>
            </div>
        </div>
    </div>

    <div class="card tscn-filter-card mb-3">
        <div class="card-body py-3 px-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="tscn-filter-label">Tìm kiếm nhanh</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white text-secondary border-end-0"><i class="fa fa-search"></i></span>
                        <input type="text" id="txtTimKiemMay" class="form-control border-start-0 ps-0" placeholder="Tên máy, serial, nhân sự..." />
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="tscn-filter-label">Loại thiết bị</label>
                    <div class="dropdown w-100">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center bg-white" type="button" id="dropFilterLoai" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <span class="text-truncate" id="lblFilterLoaiText">Tất cả loại thiết bị</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-checkbox shadow" aria-labelledby="dropFilterLoai" id="divFilterLoaiOptions">
                        </div>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="tscn-filter-label">Bản quyền Win</label>
                    <div class="dropdown w-100">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center bg-white" type="button" id="dropFilterWin" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <span class="text-truncate" id="lblFilterWinText">Tất cả bản quyền Win</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-checkbox shadow" aria-labelledby="dropFilterWin" id="divFilterWinOptions">
                        </div>
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="tscn-filter-label">Bản quyền Office</label>
                    <div class="dropdown w-100">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center bg-white" type="button" id="dropFilterOffice" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <span class="text-truncate" id="lblFilterOfficeText">Tất cả bản quyền Office</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-checkbox shadow" aria-labelledby="dropFilterOffice" id="divFilterOfficeOptions">
                        </div>
                    </div>
                </div>

                <div class="col-md-2 col-6">
                    <label class="tscn-filter-label">Số dòng / trang</label>
                    <select id="ddlKichThuocTrang" class="form-select form-select-sm">
                        <option value="10">10 thiết bị</option>
                        <option value="25">25 thiết bị</option>
                        <option value="50">50 thiết bị</option>
                        <option value="100">100 thiết bị</option>
                        <option value="all">Hiển thị tất cả</option>
                    </select>
                </div>

                <div class="col-md-2 col-6">
                    <label class="tscn-filter-label">Kiểu hiển thị</label>
                    <div class="btn-group btn-group-sm w-100" role="group">
                        <button type="button" id="btnKieuList" class="btn btn-primary" title="Hiển thị dạng bảng danh sách">
                            <i class="fa fa-list"></i> Danh sách
                        </button>
                        <button type="button" id="btnKieuGrid" class="btn btn-outline-primary" title="Hiển thị dạng khối hình hộp">
                            <i class="fa fa-th-large"></i> Hình hộp
                        </button>
                    </div>
                </div>
            </div>

            <div class="tscn-toolbar">
                <button id="btnTaiLaiDanhSach" class="btn btn-sm btn-primary">
                    <i class="fa fa-refresh"></i> Tải lại
                </button>
                <button id="btnBoLoc" class="btn btn-sm btn-outline-danger" title="Xóa sạch bộ lọc quay về mặc định">
                    <i class="fa fa-filter"></i> Bỏ lọc
                </button>

                <span class="tscn-toolbar-spacer"></span>

                <button id="btnTuDongPhanLoai" class="btn btn-sm btn-warning" disabled title="Tích chọn thiết bị cần phân loại trước, sau đó bấm nút này để tự đoán Laptop/PC/MayAo/Server dựa vào Dòng máy">
                    <i class="fa fa-magic"></i> Tự động phân loại (<span id="lblSoLuongDaChonPhanLoai">0</span>)
                </button>
                <button id="btnDongBoThietBi" class="btn btn-sm btn-success" disabled>
                    <i class="fa fa-exchange"></i> Đồng bộ sang Thiết bị (<span id="lblSoLuongDaChon">0</span>)
                </button>
                <button id="btnDongBoChiNhanh" class="btn btn-sm btn-info text-white" title="Kéo dữ liệu máy tính mới từ SQL Server chi nhánh 10.0.55.3 về hệ thống này">
                    <i class="fa fa-cloud-download"></i> Đồng bộ từ chi nhánh
                </button>
            </div>
        </div>
    </div>

    <div class="card tscn-main-card">
        <div class="card-header text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="fa fa-desktop" style="margin-right: 8px;"></i>Danh Sách Quản Lý Tất Cả Thiết Bị Máy Tính
            </h5>
        </div>
        <div class="card-body p-0">
            <div id="alertTinNhan" class="alert alert-danger m-3" style="display: none;" role="alert"></div>

            <div id="vungKieuList" class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-bordered table-striped table-hover mb-0" id="tblTatCaMayTinh">
                    <thead class="table-secondary sticky-top" style="z-index: 10;">
                        <tr>
                            <th style="width: 3%;" class="text-center"><input type="checkbox" id="chkChonTatCaTrangHienTai" title="Chọn tất cả trong trang hiện tại" /></th>
                            <th style="white-space: nowrap; width: 5%;">Mã máy</th>
                            <th style="white-space: nowrap;">Số Serial Máy</th>
                            <th style="white-space: nowrap;">Dòng máy (Hãng sản xuất)</th>
                            <th style="white-space: nowrap;">Loại thiết bị</th>
                            <th style="white-space: nowrap;">Tên máy (Machine Name)</th>
                            <th style="white-space: nowrap;">Người dùng liên kết</th>
                            <th style="white-space: nowrap;">Phiên bản Office đang dùng</th>
                            <th style="white-space: nowrap;">Bản quyền Win</th>
                            <th style="white-space: nowrap;">Bản quyền Office</th>
                            <th style="white-space: nowrap; width: 8%;" class="text-center cot-ghim">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="11" class="text-center py-4 text-muted">
                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                <span class="ms-2">Đang nạp toàn bộ danh sách dữ liệu máy tính từ server...</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div id="vungKieuGrid" class="p-3" style="display: none; max-height: 70vh; overflow-y: auto;">
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3" id="divContainerGrid">
                </div>
            </div>
        </div>

        <div class="tscn-card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="text-dark small fw-bold" id="lblTongSoMay">Tổng số thiết bị: 0</span>
            <nav id="navPhanTrang" aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bundle.min.js"></script>
    <script>
        $(document).ready(function () {
        var danhSachGocCache = [];
        var danhSachDaLoc = [];

        // Các biến thiết lập trạng thái phân trang và view
        var trangHienTai = 1;
        var kichThuocTrang = 10;
        var kieuHienThi = "list"; // list hoặc grid

        // Tập hợp IdMay đang được tích chọn để đồng bộ (giữ nguyên khi chuyển trang/lọc)
        var danhSachDangChon = new Set();
        var trangDuLieuHienTai = []; // Dữ liệu đang render ở trang hiện tại (dùng cho Chọn tất cả)
        var demTienDoGiaLap = 0; // Đếm để tạo id duy nhất cho từng lần hiển thị thanh tiến trình

        // Mở popup có thanh tiến trình % mô phỏng (dùng cho các thao tác chỉ có 1 request, không chia lô được nên không có % thật)
        // Thanh sẽ tự chạy tăng dần tới tối đa 90%, chỉ nhảy lên 100% khi gọi hoanTat() lúc request thực sự xong
        function batDauTienDoGiaLap(tieuDe) {
        demTienDoGiaLap++;
        var idThanh = 'thanhTienDoGiaLap_' + demTienDoGiaLap;
        var phanTramHienTai = 0;

        Swal.fire({
        title: tieuDe,
        html: '<div class="progress" style="height: 24px;">' +
        '<div id="' + idThanh + '" class="progress-bar bg-primary" role="progressbar" style="width: 0%;">0%</div>' +
        '</div>',
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false
        });

        var idBoDemThoiGian = setInterval(function () {
        // Tăng nhanh lúc đầu, chậm dần khi gần tới 90% để không tạo cảm giác "giả" quá lộ liễu
        var buocTang = phanTramHienTai < 50 ? 9 : (phanTramHienTai < 80 ? 4 : 1);
        phanTramHienTai = Math.min(phanTramHienTai + buocTang, 90);
        $("#" + idThanh).css('width', phanTramHienTai + '%').text(phanTramHienTai + '%');
        }, 250);

        return {
        // Gọi khi request thực sự đã có kết quả: nhảy thanh lên 100%, đổi màu theo kết quả rồi mới chạy tiếp (vd: mở Swal kết quả)
        hoanTat: function (thanhCong, sauKhiHoanTat) {
        clearInterval(idBoDemThoiGian);
        $("#" + idThanh).css('width', '100%').text('100%')
        .removeClass('bg-primary').addClass(thanhCong === false ? 'bg-danger' : 'bg-success');
        setTimeout(function () {
        if (sauKhiHoanTat) sauKhiHoanTat(); else Swal.close();
        }, 400);
        }
        };
        }

        // ĐỌC TRẠNG THÁI BỘ LỌC ĐÃ LƯU TỪ LOCALSTORAGE KHI LOAD TRANG
        docTrangThaiBoLocTuLocalStorage();

        loadGoiTinTatCaMayTinh();

        $("#btnTaiLaiDanhSach").click(function () {
        if ($(this).prop("disabled")) return;
        $(this).prop("disabled", true);
        var tienDo = batDauTienDoGiaLap('Đang tải lại danh sách thiết bị...');
        loadGoiTinTatCaMayTinh(function (thanhCong) {
        $("#btnTaiLaiDanhSach").prop("disabled", false);
        tienDo.hoanTat(thanhCong);
        });
        });

        // Nhấn nút "Đồng bộ từ chi nhánh": kéo các máy mới (Serial chưa từng có ở local) từ SQL Server chi nhánh 10.0.55.3 về
        $("#btnDongBoChiNhanh").click(function () {
        Swal.fire({
        title: 'Đồng bộ máy tính từ chi nhánh?',
        html: 'Hệ thống sẽ kết nối đến SQL Server chi nhánh (10.0.55.3) và thêm mới các máy tính <b>chưa từng có</b> ở đây (đối chiếu theo Số Serial).<br/>Máy đã tồn tại sẽ được <b>bỏ qua</b>, không ghi đè dữ liệu đã kiểm kê.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Đồng bộ ngay',
        cancelButtonText: 'Hủy',
        confirmButtonColor: '#0dcaf0'
        }).then(function (result) {
        if (!result.isConfirmed) return;

        $("#btnDongBoChiNhanh").prop("disabled", true).html('<i class="fa fa-spinner fa-spin"></i> Đang đồng bộ...');
        var tienDo = batDauTienDoGiaLap('Đang đồng bộ thiết bị từ chi nhánh...');
        $.ajax({
        url: '/QLKiemKe/DongBoTuChiNhanh',
        type: 'POST',
        dataType: 'json',
        success: function (res) {
        $("#btnDongBoChiNhanh").prop("disabled", false).html('<i class="fa fa-cloud-download"></i> Đồng bộ từ chi nhánh');
        tienDo.hoanTat(res.success, function () {
        if (res.success) {
        var dsTen = (res.chiTiet || []).map(function (x) { return x.tenMay + (x.seriMay ? ' (' + x.seriMay + ')' : ''); }).join('<br/>');
        Swal.fire({
        icon: 'success',
        title: 'Đồng bộ hoàn tất!',
        html: 'Đã thêm mới: <b>' + res.soDaThem + '</b> máy.<br/>Đã bỏ qua (trùng Serial): <b>' + res.soBoQuaTrungSeri + '</b> máy.' + (dsTen ? '<hr/><div style="text-align:left; max-height:200px; overflow-y:auto; font-size:13px;">' + dsTen + '</div>' : '')
        });
        loadGoiTinTatCaMayTinh();
        } else {
        Swal.fire('Lỗi', res.message || 'Không thể đồng bộ từ chi nhánh.', 'error');
        }
        });
        },
        error: function () {
        $("#btnDongBoChiNhanh").prop("disabled", false).html('<i class="fa fa-cloud-download"></i> Đồng bộ từ chi nhánh');
        tienDo.hoanTat(false, function () {
        Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ để đồng bộ.', 'error');
        });
        }
        });
        });
        });

        // Sự kiện khi nhấn nút Bỏ lọc để khôi phục cấu hình mặc định
        $("#btnBoLoc").click(function () {
        localStorage.removeItem("Tscn_BoLocGiaoDien");
        $("#txtTimKiemMay").val("");
        $("#ddlKichThuocTrang").val("10");
        kichThuocTrang = 10;
        trangHienTai = 1;
        kieuHienThi = "list";

        capNhatGiaoDienNutBamView();
        $(".chk-filter-win, .chk-filter-office, .chk-filter-loai").prop("checked", true);
        thucThiBoLocDuLieu();
        });

        // Sửa trực tiếp Loại thiết bị ngay trên bảng, tự lưu xuống server khi đổi giá trị
        $("#tblTatCaMayTinh tbody").on("change", ".select-loai-thiet-bi", function () {
        var $sel = $(this);
        var idMay = parseInt($sel.data("id"));
        var loaiMoi = $sel.val();

        $sel.prop("disabled", true);
        $.ajax({
        url: '/QLKiemKe/CapNhatLoaiThietBiMay',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ idMay: idMay, loaiThietBi: loaiMoi }),
        dataType: 'json',
        success: function (res) {
        $sel.prop("disabled", false);
        if (res.success) {
        $sel.attr("class", "form-select form-select-sm select-loai-thiet-bi fw-bold " + layMauLoaiThietBi(loaiMoi));
        // Đồng bộ lại cache gốc để lọc/tìm kiếm và badge Hình hộp phản ánh đúng giá trị mới
        var itemCache = danhSachGocCache.find(function (x) { return x.idMay === idMay; });
        if (itemCache) itemCache.loaiThietBi = loaiMoi;
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã cập nhật loại thiết bị', showConfirmButton: false, timer: 1500 });
        } else {
        Swal.fire('Lỗi', res.message || 'Không thể cập nhật loại thiết bị.', 'error');
        }
        },
        error: function () {
        $sel.prop("disabled", false);
        Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ để cập nhật.', 'error');
        }
        });
        });

        // Tích/bỏ tích 1 dòng máy tính (ủy quyền sự kiện vì bảng render lại liên tục)
        $("#tblTatCaMayTinh tbody").on("change", ".chk-chon-may", function () {
        var idMay = parseInt($(this).data("id"));
        if ($(this).is(":checked")) danhSachDangChon.add(idMay);
        else danhSachDangChon.delete(idMay);
        capNhatTrangThaiChonTatCa();
        capNhatNutDongBo();
        });

        // Chọn/bỏ chọn tất cả các dòng đang hiển thị trên trang hiện tại
        $("#chkChonTatCaTrangHienTai").change(function () {
        var dangChon = $(this).is(":checked");
        trangDuLieuHienTai.forEach(function (item) {
        if (dangChon) danhSachDangChon.add(item.idMay);
        else danhSachDangChon.delete(item.idMay);
        });
        $(".chk-chon-may").prop("checked", dangChon);
        capNhatNutDongBo();
        });

        // Cập nhật trạng thái checkbox "Chọn tất cả" dựa theo các dòng đang hiển thị ở trang hiện tại
        function capNhatTrangThaiChonTatCa() {
        var tongTrang = trangDuLieuHienTai.length;
        var soDaChonTrongTrang = trangDuLieuHienTai.filter(function (item) { return danhSachDangChon.has(item.idMay); }).length;
        $("#chkChonTatCaTrangHienTai").prop("checked", tongTrang > 0 && soDaChonTrongTrang === tongTrang);
        $("#chkChonTatCaTrangHienTai").prop("indeterminate", soDaChonTrongTrang > 0 && soDaChonTrongTrang < tongTrang);
        }

        // Cập nhật số lượng hiển thị trên nút Đồng bộ / Tự động phân loại và bật/tắt các nút theo số lượng đang tích chọn
        function capNhatNutDongBo() {
        $("#lblSoLuongDaChon").text(danhSachDangChon.size);
        $("#btnDongBoThietBi").prop("disabled", danhSachDangChon.size === 0);
        $("#lblSoLuongDaChonPhanLoai").text(danhSachDangChon.size);
        $("#btnTuDongPhanLoai").prop("disabled", danhSachDangChon.size === 0);
        }

        // Nhấn nút "Tự động phân loại": chỉ áp dụng cho các thiết bị ĐANG TÍCH CHỌN, đoán Laptop/PC/MayAo/Server dựa vào Dòng máy (ghi đè cả khi đã có sẵn giá trị)
        $("#btnTuDongPhanLoai").click(function () {
        if (danhSachDangChon.size === 0) return;

        Swal.fire({
        title: 'Tự động phân loại ' + danhSachDangChon.size + ' thiết bị đã chọn?',
        html: 'Hệ thống sẽ dựa vào <b>Dòng máy</b> để tự đoán Laptop/PC/MayAo/Server cho các thiết bị đang tích chọn (ghi đè cả Loại thiết bị đã chọn trước đó nếu đoán được).<br/>Thiết bị không đủ dấu hiệu nhận diện sẽ vẫn giữ nguyên/để trống, cần chọn tay.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Thực hiện',
        cancelButtonText: 'Hủy',
        confirmButtonColor: '#ffc107'
        }).then(function (result) {
        if (!result.isConfirmed) return;

        $("#btnTuDongPhanLoai").prop("disabled", true);
        var tienDo = batDauTienDoGiaLap('Đang tự động phân loại ' + danhSachDangChon.size + ' thiết bị...');
        $.ajax({
        url: '/QLKiemKe/TuDongPhanLoaiThietBiChuaPhanLoai',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ danhSachIdMay: Array.from(danhSachDangChon) }),
        dataType: 'json',
        success: function (res) {
        $("#btnTuDongPhanLoai").prop("disabled", danhSachDangChon.size === 0);
        tienDo.hoanTat(res.success, function () {
        if (res.success) {
        var ghiChuConLai = res.soKhongXacDinh > 0 ? ('<br/><span class="text-warning">Còn ' + res.soKhongXacDinh + ' thiết bị không đủ dấu hiệu nhận diện, cần chọn tay ở cột Loại thiết bị.</span>') : '';
        Swal.fire({ icon: 'success', title: 'Đã tự động phân loại xong!', html: 'Đã phân loại: <b>' + res.soDaPhanLoai + '</b> thiết bị.' + ghiChuConLai });
        loadGoiTinTatCaMayTinh();
        } else {
        Swal.fire('Lỗi', res.message || 'Không thể tự động phân loại.', 'error');
        }
        });
        },
        error: function () {
        $("#btnTuDongPhanLoai").prop("disabled", danhSachDangChon.size === 0);
        tienDo.hoanTat(false, function () {
        Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ để tự động phân loại.', 'error');
        });
        }
        });
        });
        });

        // Nhấn nút Đồng bộ sang Thiết bị: hỏi Trạng thái (tùy chọn) rồi gửi danh sách IdMay đã chọn lên server
        $("#btnDongBoThietBi").click(function () {
        if (danhSachDangChon.size === 0) return;

        $.get('/QLKiemKe/GetKkTrangThais', function (res) {
        var tuyChonTrangThai = '<option value="">-- Không gán trạng thái --</option>';
        if (res && res.success && res.data) {
        res.data.forEach(function (tt) {
        // Mặc định chọn sẵn "Đang hoạt động" cho thiết bị mới thêm (vẫn có thể đổi trước khi xác nhận)
        var macDinh = tt.tenTrangThai === 'Đang hoạt động' ? ' selected' : '';
        tuyChonTrangThai += '<option value="' + tt.idTrangThai + '"' + macDinh + '>' + tt.tenTrangThai + '</option>';
        });
        }

        Swal.fire({
        title: 'Đồng bộ ' + danhSachDangChon.size + ' máy tính sang Thiết bị',
        html: '<p class="text-start small text-muted mb-2">Trùng Tên máy + Loại thiết bị sẽ được cập nhật, không trùng sẽ thêm mới. Vị trí đặt máy sẽ để trống, cần bổ sung sau.</p>' +
        '<label class="form-label small fw-bold text-start d-block">Gán trạng thái cho các thiết bị này (tùy chọn)</label>' +
        '<select id="swalIdTrangThai" class="form-select form-select-sm">' + tuyChonTrangThai + '</select>',
        showCancelButton: true,
        confirmButtonText: 'Xác nhận đồng bộ',
        cancelButtonText: 'Hủy',
        confirmButtonColor: '#198754',
        preConfirm: function () {
        return $("#swalIdTrangThai").val();
        }
        }).then(function (result) {
        if (!result.isConfirmed) return;

        var idTrangThai = result.value ? parseInt(result.value) : null;

        // Chia nhỏ danh sách thành từng lô để gửi tuần tự, nhờ đó hiển thị được % tiến trình thay vì phải chờ 1 request duy nhất xử lý hết
        var KICH_THUOC_LO_DONG_BO = 20;
        var dsIdMayDongBo = Array.from(danhSachDangChon);
        var tongSoMay = dsIdMayDongBo.length;
        var soLo = Math.ceil(tongSoMay / KICH_THUOC_LO_DONG_BO);
        var loHienTai = 0;
        var tongThemMoi = 0, tongCapNhat = 0, dsBoQuaGop = [];

        Swal.fire({
        title: 'Đang đồng bộ...',
        html: '<div class="progress" style="height: 24px;">' +
        '<div id="thanhTienDoDongBo" class="progress-bar bg-success" role="progressbar" style="width: 0%;">0%</div>' +
        '</div>' +
        '<div id="ghiChuTienDoDongBo" class="small text-muted mt-2">Đang xử lý 0/' + tongSoMay + ' máy...</div>',
        allowOutsideClick: false,
        allowEscapeKey: false,
        showConfirmButton: false,
        didOpen: function () { guiLoDongBoTiepTheo(); }
        });

        function guiLoDongBoTiepTheo() {
        var viTriBatDau = loHienTai * KICH_THUOC_LO_DONG_BO;
        var dsIdLo = dsIdMayDongBo.slice(viTriBatDau, viTriBatDau + KICH_THUOC_LO_DONG_BO);

        $.ajax({
        url: '/QLKiemKe/DongBoMayTinhSangThietBi',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ danhSachIdMay: dsIdLo, idTrangThai: idTrangThai }),
        dataType: 'json',
        success: function (res) {
        if (res.success) {
        tongThemMoi += res.themMoi;
        tongCapNhat += res.capNhat;
        if (res.boQua && res.boQua.length > 0) dsBoQuaGop = dsBoQuaGop.concat(res.boQua);
        }
        loHienTai++;
        capNhatThanhTienDoDongBo();
        },
        error: function () {
        loHienTai++;
        capNhatThanhTienDoDongBo();
        }
        });
        }

        function capNhatThanhTienDoDongBo() {
        var soDaXuLy = Math.min(loHienTai * KICH_THUOC_LO_DONG_BO, tongSoMay);
        var phanTram = Math.round((loHienTai / soLo) * 100);
        $("#thanhTienDoDongBo").css('width', phanTram + '%').text(phanTram + '%');
        $("#ghiChuTienDoDongBo").text('Đang xử lý ' + soDaXuLy + '/' + tongSoMay + ' máy...');

        if (loHienTai < soLo) {
        guiLoDongBoTiepTheo();
        } else {
        var thongBaoBoQua = dsBoQuaGop.length > 0 ? ('<br/><span class="text-warning">Bỏ qua ' + dsBoQuaGop.length + ' máy (thiếu Tên máy/Loại thiết bị).</span>') : '';
        Swal.fire({
        icon: 'success',
        title: 'Đồng bộ thành công!',
        html: 'Thêm mới: <b>' + tongThemMoi + '</b> &nbsp;|&nbsp; Cập nhật: <b>' + tongCapNhat + '</b>' + thongBaoBoQua
        });
        danhSachDangChon.clear();
        capNhatNutDongBo();
        loadGoiTinTatCaMayTinh();
        }
        }
        });
        });
        });

        // Thay đổi số lượng phần tử trên một trang
        $("#ddlKichThuocTrang").change(function () {
        var val = $(this).val();
        kichThuocTrang = val === "all" ? danhSachDaLoc.length : parseInt(val);
        trangHienTai = 1;
        thucThiBoLocDuLieu();
        });

        // Chuyển sang hiển thị giao diện dạng Bảng Danh Sách
        $("#btnKieuList").click(function () {
        kieuHienThi = "list";
        capNhatGiaoDienNutBamView();
        thucThiBoLocDuLieu();
        });

        // Chuyển sang hiển thị giao diện dạng Khối Hình Hộp
        $("#btnKieuGrid").click(function () {
        kieuHienThi = "grid";
        capNhatGiaoDienNutBamView();
        thucThiBoLocDuLieu();
        });

        function capNhatGiaoDienNutBamView() {
        if (kieuHienThi === "list") {
        $("#btnKieuList").removeClass("btn-outline-primary").addClass("btn-primary");
        $("#btnKieuGrid").removeClass("btn-primary").addClass("btn-outline-primary");
        $("#vungKieuList").show();
        $("#vungKieuGrid").hide();
        } else {
        $("#btnKieuGrid").removeClass("btn-outline-primary").addClass("btn-primary");
        $("#btnKieuList").removeClass("btn-primary").addClass("btn-outline-primary");
        $("#vungKieuGrid").show();
        $("#vungKieuList").hide();
        }
        }

        function loadGoiTinTatCaMayTinh(khiHoanTat) {
        $("#alertTinNhan").hide();
        $.ajax({
        url: '/QLKiemKe/DanhSachTatCaMayTinh',
        type: 'GET',
        dataType: 'json',
        success: function (res) {
        if (res.success && res.data) {
        danhSachGocCache = res.data;

        // SẮP XẾP MÃ MÁY (IDMAY) GIẢM DẦN - CÁI NÀO MỚI HƠN SẼ ĐƯỢC LÊN ĐẦU
        danhSachGocCache.sort(function (a, b) {
        return b.idMay - a.idMay;
        });

        // Đổ danh sách Checkbox điều kiện động dựa trên tập dữ liệu thực tế nhận từ server
        khoiTaoBoLocDropdownMulti();

        // Tiến hành lọc và render dữ liệu lên màn hình
        thucThiBoLocDuLieu();
        if (khiHoanTat) khiHoanTat(true);
        } else {
        hienThiLoiHeThong(res.message || "Dữ liệu trả về bị rỗng.");
        if (khiHoanTat) khiHoanTat(false);
        }
        },
        error: function (xhr, status, error) {
        hienThiLoiHeThong("Không thể kết nối đến máy chủ Web API để lấy danh sách máy.");
        if (khiHoanTat) khiHoanTat(false);
        }
        });
        }

        // Tạo ra các thẻ Checkbox động bên trong dropdown
        function khoiTaoBoLocDropdownMulti() {
        var mangWin = [];
        var mangOffice = [];
        var mangLoai = [];
        var coChuaPhanLoai = false;

        $.each(danhSachGocCache, function (i, item) {
        var w = item.banQuyenWin || "N/A";
        var o = item.banQuyenOffice || "N/A";
        if ($.inArray(w, mangWin) === -1) mangWin.push(w);
        if ($.inArray(o, mangOffice) === -1) mangOffice.push(o);

        if (item.loaiThietBi) {
        if ($.inArray(item.loaiThietBi, mangLoai) === -1) mangLoai.push(item.loaiThietBi);
        } else {
        coChuaPhanLoai = true;
        }
        });
        // Luôn xếp "Chưa phân loại" lên đầu danh sách để dễ tìm thấy nhất
        if (coChuaPhanLoai) mangLoai.unshift("");

        // Đọc lại cache cấu hình cũ nếu có để gán trạng thái checked chính xác
        var cacheBoLoc = JSON.parse(localStorage.getItem("Tscn_BoLocGiaoDien"));

        // Chèn danh sách Checkbox Loại thiết bị (dùng value rỗng "" đại diện cho nhóm "Chưa phân loại")
        var htmlLoai = "";
        $.each(mangLoai, function (i, v) {
        var isChecked = "checked";
        if (cacheBoLoc && cacheBoLoc.selectedLoais) {
        isChecked = $.inArray(v, cacheBoLoc.selectedLoais) !== -1 ? "checked" : "";
        }
        var nhan = v === "" ? '<span class="text-danger fw-bold">⚠ Chưa phân loại</span>' : v;
        htmlLoai += '<div class="form-check">' +
        '<input class="form-check-input chk-filter-loai" type="checkbox" value="' + v + '" id="chkLoai_' + i + '" ' + isChecked + '>' +
        '<label class="form-check-label small text-dark" for="chkLoai_' + i + '">' + nhan + '</label>' +
        '</div>';
        });
        $("#divFilterLoaiOptions").html(htmlLoai);

        // Chèn danh sách Checkbox Windows
        var htmlWin = "";
        $.each(mangWin, function (i, v) {
        var isChecked = "checked";
        if (cacheBoLoc && cacheBoLoc.selectedWins) {
        isChecked = $.inArray(v, cacheBoLoc.selectedWins) !== -1 ? "checked" : "";
        }
        htmlWin += '<div class="form-check">' +
        '<input class="form-check-input chk-filter-win" type="checkbox" value="' + v + '" id="chkWin_' + i + '" ' + isChecked + '>' +
        '<label class="form-check-label small text-dark" for="chkWin_' + i + '">' + v + '</label>' +
        '</div>';
        });
        $("#divFilterWinOptions").html(htmlWin);

        // Chèn danh sách Checkbox Office
        var htmlOffice = "";
        $.each(mangOffice, function (i, v) {
        var isChecked = "checked";
        if (cacheBoLoc && cacheBoLoc.selectedOffices) {
        isChecked = $.inArray(v, cacheBoLoc.selectedOffices) !== -1 ? "checked" : "";
        }
        htmlOffice += '<div class="form-check">' +
        '<input class="form-check-input chk-filter-office" type="checkbox" value="' + v + '" id="chkOffice_' + i + '" ' + isChecked + '>' +
        '<label class="form-check-label small text-dark" for="chkOffice_' + i + '">' + v + '</label>' +
        '</div>';
        });
        $("#divFilterOfficeOptions").html(htmlOffice);

        // Gán sự kiện quét lọc khi click thay đổi trạng thái Checkbox
        $(".chk-filter-win, .chk-filter-office, .chk-filter-loai").on("change", function () {
        trangHienTai = 1;
        thucThiBoLocDuLieu();
        });
        }

        // Tổ hợp quét đồng thời bộ lọc text phẳng và các ô Checkbox tùy chọn bản quyền công ty
        function thucThiBoLocDuLieu() {
        var tuKhoa = $("#txtTimKiemMay").val().toLowerCase().trim();

        var selectedWins = [];
        $(".chk-filter-win:checked").each(function () { selectedWins.push($(this).val()); });

        var selectedOffices = [];
        $(".chk-filter-office:checked").each(function () { selectedOffices.push($(this).val()); });

        var selectedLoais = [];
        $(".chk-filter-loai:checked").each(function () { selectedLoais.push($(this).val()); });

        // Thay đổi text tiêu đề hiển thị trên nút Dropdown linh hoạt
        var totalLoaiOpts = $(".chk-filter-loai").length;
        if (totalLoaiOpts > 0) {
        if (selectedLoais.length === totalLoaiOpts) $("#lblFilterLoaiText").text("Tất cả loại thiết bị");
        else if (selectedLoais.length === 0) $("#lblFilterLoaiText").text("Đang ẩn tất cả loại");
        else $("#lblFilterLoaiText").text("Đã chọn loại (" + selectedLoais.length + ")");
        }

        // Thay đổi text tiêu đề hiển thị trên nút Dropdown linh hoạt
        var totalWinOpts = $(".chk-filter-win").length;
        if (totalWinOpts > 0) {
        if (selectedWins.length === totalWinOpts) $("#lblFilterWinText").text("Tất cả bản quyền Win");
        else if (selectedWins.length === 0) $("#lblFilterWinText").text("Đang ẩn tất cả Win");
        else $("#lblFilterWinText").text("Đã chọn Win (" + selectedWins.length + ")");
        }

        var totalOfficeOpts = $(".chk-filter-office").length;
        if (totalOfficeOpts > 0) {
        if (selectedOffices.length === totalOfficeOpts) $("#lblFilterOfficeText").text("Tất cả bản quyền Office");
        else if (selectedOffices.length === 0) $("#lblFilterOfficeText").text("Đang ẩn tất cả Office");
        else $("#lblFilterOfficeText").text("Đã chọn Office (" + selectedOffices.length + ")");
        }

        // Lọc dữ liệu mảng thông qua hàm grep mở rộng
        danhSachDaLoc = $.grep(danhSachGocCache, function (item) {
        var matchText = true;
        if (tuKhoa !== "") {
        matchText = (item.tenMay && item.tenMay.toLowerCase().indexOf(tuKhoa) !== -1) ||
        (item.seriMay && item.seriMay.toLowerCase().indexOf(tuKhoa) !== -1) ||
        (item.dongMay && item.dongMay.toLowerCase().indexOf(tuKhoa) !== -1) ||
        (item.hoTenNguoiSoHuu && item.hoTenNguoiSoHuu.toLowerCase().indexOf(tuKhoa) !== -1) ||
        (item.maNhanVienSoHuu && item.maNhanVienSoHuu.toLowerCase().indexOf(tuKhoa) !== -1);
        }

        var vWin = item.banQuyenWin || "N/A";
        var vOffice = item.banQuyenOffice || "N/A";
        var vLoai = item.loaiThietBi || "";

        var matchWin = $(".chk-filter-win").length === 0 ? true : $.inArray(vWin, selectedWins) !== -1;
        var matchOffice = $(".chk-filter-office").length === 0 ? true : $.inArray(vOffice, selectedOffices) !== -1;
        var matchLoai = $(".chk-filter-loai").length === 0 ? true : $.inArray(vLoai, selectedLoais) !== -1;

        return matchText && matchWin && matchOffice && matchLoai;
        });

        // Nếu người dùng chọn hiển thị tất cả, gán lại giá trị kích thước phân trang bằng tổng độ dài mảng
        if ($("#ddlKichThuocTrang").val() === "all") {
        kichThuocTrang = danhSachDaLoc.length > 0 ? danhSachDaLoc.length : 10;
        }

        // TIẾN HÀNH ĐỒNG BỘ LƯU TRẠNG THÁI BỘ LỌC VÀO LOCALSTORAGE
        var configBoLoc = {
        tuKhoa: $("#txtTimKiemMay").val(),
        selectedWins: selectedWins,
        selectedOffices: selectedOffices,
        selectedLoais: selectedLoais,
        kichThuocTrang: $("#ddlKichThuocTrang").val(),
        kieuHienThi: kieuHienThi,
        trangHienTai: trangHienTai
        };
        localStorage.setItem("Tscn_BoLocGiaoDien", JSON.stringify(configBoLoc));

        thucThiRenderTheoTrang();
        }

        // Hàm khôi phục lại cấu hình bộ lọc từ localStorage khi vừa load trang
        function docTrangThaiBoLocTuLocalStorage() {
        var cache = localStorage.getItem("Tscn_BoLocGiaoDien");
        if (cache) {
        var obj = JSON.parse(cache);
        $("#txtTimKiemMay").val(obj.tuKhoa || "");
        $("#ddlKichThuocTrang").val(obj.kichThuocTrang || "10");

        kieuHienThi = obj.kieuHienThi || "list";
        trangHienTai = obj.trangHienTai || 1;

        var valTrang = $("#ddlKichThuocTrang").val();
        kichThuocTrang = valTrang === "all" ? 999999 : parseInt(valTrang);

        capNhatGiaoDienNutBamView();
        }
        }

        // Lắng nghe sự kiện bàn phím tại ô nhập thông tin tìm kiếm
        $("#txtTimKiemMay").on("keyup", function () {
        trangHienTai = 1;
        thucThiBoLocDuLieu();
        });

        // Thực hiện lát cắt mảng dữ liệu (Slice Array) dựa trên số trang đang đứng để hiển thị
        function thucThiRenderTheoTrang() {
        $("#lblTongSoMay").text("Tổng số thiết bị: " + danhSachDaLoc.length);

        // Đảm bảo trang hiện tại an toàn sau khi mảng thay đổi độ dài do bộ lọc thay đổi
        var maxTrang = Math.ceil(danhSachDaLoc.length / kichThuocTrang) || 1;
        if (trangHienTai > maxTrang) {
        trangHienTai = maxTrang;
        }

        if (danhSachDaLoc.length === 0) {
        $("#tblTatCaMayTinh tbody").html('<tr><td colspan="11"><div class="tscn-empty-state"><i class="fa fa-inbox"></i>Không tìm thấy bản ghi thiết bị máy tính nào hợp lệ.</div></td></tr>');
        $("#divContainerGrid").html('<div class="col-12"><div class="tscn-empty-state"><i class="fa fa-inbox"></i>Không tìm thấy bản ghi thiết bị máy tính nào hợp lệ.</div></div>');
        $("#navPhanTrang .pagination").empty();
        trangDuLieuHienTai = [];
        capNhatTrangThaiChonTatCa();
        return;
        }

        var startIdx = (trangHienTai - 1) * kichThuocTrang;
        var endIdx = startIdx + kichThuocTrang;
        var phânĐoạnDữLiệuTrang = danhSachDaLoc.slice(startIdx, endIdx);
        trangDuLieuHienTai = phânĐoạnDữLiệuTrang;

        if (kieuHienThi === "list") {
        renderKieuBangDanhSach(phânĐoạnDữLiệuTrang);
        } else {
        renderKieuHinhHopGrid(phânĐoạnDữLiệuTrang);
        }

        capNhatTrangThaiChonTatCa();

        // Tiến hành dựng các nút bấm thanh điều hướng trang
        buildThanhPhanTrang(danhSachDaLoc.length);
        }

        // Trả về class màu Bootstrap tương ứng với từng loại thiết bị (Laptop/PC/Máy ảo/Server)
        function layMauLoaiThietBi(loai) {
        if (loai === "Laptop") return "bg-primary";
        if (loai === "PC") return "bg-success";
        if (loai === "MayAo") return "bg-warning text-dark";
        if (loai === "Server") return "bg-danger";
        return "bg-secondary";
        }

        // Trả về HTML dropdown cho phép sửa trực tiếp Loại thiết bị ngay trên bảng, tự lưu khi đổi giá trị
        function layHtmlSuaLoaiThietBi(idMay, loaiHienTai) {
        var dsLoai = ["Laptop", "PC", "MayAo", "Server"];
        var html = '<select class="form-select form-select-sm select-loai-thiet-bi fw-bold ' + layMauLoaiThietBi(loaiHienTai) + '" data-id="' + idMay + '" style="min-width: 110px;">';
        html += '<option value=""' + (!loaiHienTai ? ' selected' : '') + '>-- Chưa rõ --</option>';
        dsLoai.forEach(function (l) {
        html += '<option value="' + l + '"' + (loaiHienTai === l ? ' selected' : '') + '>' + l + '</option>';
        });
        html += '</select>';
        return html;
        }

        // Trả về HTML badge màu tương ứng với từng loại thiết bị (Laptop/PC/Máy ảo/Server) - dùng cho chế độ Hình hộp
        function layHtmlBadgeLoaiThietBi(loai) {
        var lop = layMauLoaiThietBi(loai);
        var giaTri = loai || "Chưa xác định";
        return '<span class="badge ' + lop + '">' + giaTri + '</span>';
        }

        // PHƯƠNG THỨC RENDER 1: GIAO DIỆN BẢNG DANH SÁCH (TABLE ROW)
        function renderKieuBangDanhSach(dataList) {
        var html = "";
        $.each(dataList, function (index, item) {
        // Định dạng chuỗi hiển thị thông tin người dùng liên kết kèm mã nhân viên
        var userInfo = "Chưa liên kết";
        if (item.hoTenNguoiSoHuu && item.hoTenNguoiSoHuu !== "Chưa bàn giao") {
        userInfo = item.hoTenNguoiSoHuu + " (" + (item.maNhanVienSoHuu || "Không có mã") + ")";
        }

        html += '<tr>' +
        '<td class="text-center"><input type="checkbox" class="chk-chon-may" data-id="' + item.idMay + '"' + (danhSachDangChon.has(item.idMay) ? ' checked' : '') + '></td>' +
        '<td>' + item.idMay + '</td>' +
        '<td class="text-danger fw-bold" style="white-space: nowrap;">' + (item.seriMay || "N/A") + '</td>' +
        '<td style="white-space: nowrap;">' + (item.dongMay || "N/A") + '</td>' +
        '<td style="white-space: nowrap;">' + layHtmlSuaLoaiThietBi(item.idMay, item.loaiThietBi) + '</td>' +
        '<td class="fw-bold text-dark" style="white-space: nowrap;">' + (item.tenMay || "N/A") + '</td>' +
        '<td class="fw-bold text-primary">' + userInfo + '</td>' +
        '<td>' + (item.thongTinOffice || "N/A") + '</td>' +
        '<td class="text-info fw-bold">' + (item.banQuyenWin || "N/A") + '</td>' +
        '<td class="text-warning fw-bold">' + (item.banQuyenOffice || "N/A") + '</td>' +
        '<td class="text-center cot-ghim">' +
        '   <a href="/QLKiemKe/ViewChiTietMayTinh?idMay=' + item.idMay + '" class="btn btn-xs btn-outline-primary py-0 px-2" style="font-size: 11px;">' +
        '       <i class="fa fa-eye"></i> Chi tiết' +
        '   </a>' +
        '</td>' +
        '</tr>';
        });
        $("#tblTatCaMayTinh tbody").html(html);
        }

        // PHƯƠNG THỨC RENDER 2: GIAO DIỆN HÌNH HỘP KHỐI (GRID CARD CELL)
        function renderKieuHinhHopGrid(dataList) {
        var html = "";
        $.each(dataList, function (index, item) {
        var userInfo = "Chưa liên kết";
        if (item.hoTenNguoiSoHuu && item.hoTenNguoiSoHuu !== "Chưa bàn giao") {
        userInfo = item.hoTenNguoiSoHuu + " (" + (item.maNhanVienSoHuu || "N/A") + ")";
        }

        html += '<div class="col">' +
        '   <div class="card h-100 shadow-sm border grid-item-card bg-white">' +
        '       <div class="card-header bg-secondary text-white py-2 d-flex justify-content-between align-items-center">' +
        '           <span class="badge bg-dark">ID: ' + item.idMay + '</span>' +
        '           ' + layHtmlBadgeLoaiThietBi(item.loaiThietBi) +
        '       </div>' +
        '       <div class="card-body p-3 text-dark" style="font-size: 12px;">' +
        '           <h6 class="text-primary fw-bold mb-2 text-truncate" title="' + item.tenMay + '"><i class="fa fa-desktop me-1"></i>' + (item.tenMay || "N/A") + '</h6>' +
        '           <p class="mb-1 text-muted text-truncate"><b>Dòng máy:</b> ' + (item.dongMay || "N/A") + '</p>' +
        '           <p class="mb-1"><b>Serial:</b> <span class="text-danger fw-bold">' + (item.seriMay || "N/A") + '</span></p>' +
        '           <p class="mb-1 text-truncate text-primary"><b>Nhân sự:</b> ' + userInfo + '</p>' +
        '           <p class="mb-1 text-muted text-truncate"><b>Bản Office:</b> ' + (item.thongTinOffice || "N/A") + '</p>' +
        '           <div class="border-top my-2 pt-2" style="font-size: 11px;">' +
        '               <div class="d-flex justify-content-between mb-1"><span><i class="fa fa-windows text-info me-1"></i>Win:</span><span class="fw-bold text-info text-truncate" style="max-width:110px;">' + (item.banQuyenWin || "N/A") + '</span></div>' +
        '               <div class="d-flex justify-content-between"><span><i class="fa fa-key text-warning me-1"></i>Office:</span><span class="fw-bold text-warning text-truncate" style="max-width:110px;">' + (item.banQuyenOffice || "N/A") + '</span></div>' +
        '           </div>' +
        '       </div>' +
        '       <div class="card-footer bg-light p-2 text-center border-top">' +
        '           <a href="/QLKiemKe/ViewChiTietMayTinh?idMay=' + item.idMay + '" class="btn btn-xs btn-primary w-100 py-1" style="font-size: 11px;">' +
        '               <i class="fa fa-eye"></i> Xem chi tiết' +
        '           </a>' +
        '       </div>' +
        '   </div>' +
        '</div>';
        });
        $("#divContainerGrid").html(html);
        }

        // Xây dựng giao diện thanh bấm chuyển số trang cơ động
        function buildThanhPhanTrang(tongSoBanGhi) {
        var tongSoTrang = Math.ceil(tongSoBanGhi / kichThuocTrang);
        var htmlPhanTrang = "";

        if (tongSoTrang <= 1) {
        $("#navPhanTrang .pagination").empty();
        return;
        }

        // Nút điều hướng trang trước (Previous)
        var activePrev = trangHienTai === 1 ? "disabled" : "";
        htmlPhanTrang += '<li class="page-item ' + activePrev + '"><a class="page-link link-phan-trang" href="#" data-page="' + (trangHienTai - 1) + '">&laquo;</a></li>';

        // Khởi tạo vòng lặp dựng các ô số trang tương ứng
        for (var i = 1; i <= tongSoTrang; i++) {
        var activeClass = trangHienTai === i ? "active" : "";
        htmlPhanTrang += '<li class="page-item ' + activeClass + '"><a class="page-link link-phan-trang" href="#" data-page="' + i + '">' + i + '</a></li>';
        }

        // Nút điều hướng trang sau (Next)
        var activeNext = trangHienTai === tongSoTrang ? "disabled" : "";
        htmlPhanTrang += '<li class="page-item ' + activeNext + '"><a class="page-link link-phan-trang" href="#" data-page="' + (trangHienTai + 1) + '">&raquo;</a></li>';

        $("#navPhanTrang .pagination").html(htmlPhanTrang);

        // Đăng ký bắt sự kiện click cho các thẻ phân trang vừa dựng xong
        $(".link-phan-trang").off("click").on("click", function (e) {
        e.preventDefault();
        var mucTieuTrang = parseInt($(this).data("page"));
        if (mucTieuTrang >= 1 && mucTieuTrang <= tongSoTrang) {
        trangHienTai = mucTieuTrang;

        // Cập nhật lại chỉ số số trang hiện tại vào bộ nhớ cache local
        var cacheBoLoc = JSON.parse(localStorage.getItem("Tscn_BoLocGiaoDien")) || {};
        cacheBoLoc.trangHienTai = trangHienTai;
        localStorage.setItem("Tscn_BoLocGiaoDien", JSON.stringify(cacheBoLoc));

        thucThiRenderTheoTrang();
        }
        });
        }

        function hienThiLoiHeThong(msg) {
        $("#tblTatCaMayTinh tbody").html('<tr><td colspan="11"><div class="tscn-empty-state text-danger"><i class="fa fa-exclamation-triangle"></i>Lỗi: ' + msg + '</div></td></tr>');
        $("#divContainerGrid").html('<div class="col-12"><div class="tscn-empty-state text-danger"><i class="fa fa-exclamation-triangle"></i>Lỗi: ' + msg + '</div></div>');
        $("#alertTinNhan").text(msg).fadeIn();
        $("#lblTongSoMay").text("Tổng số thiết bị: 0");
        $("#navPhanTrang .pagination").empty();
        }
        });
    </script>
}