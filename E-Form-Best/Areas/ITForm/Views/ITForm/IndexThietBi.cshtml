        if (selectedTrangThais.length > 0) filtered = filtered.filter(x => selectedTrangThais.includes(x.tenTrangThai));

        if (fTuNgay || fDenNgay || fTìnhTrangCheck) {
        filtered = filtered.filter(x => {
