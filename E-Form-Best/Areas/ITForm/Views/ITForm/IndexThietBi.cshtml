<div class="modal fade" id="modalXacNhanCheckEvidence" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-success text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-clipboard-check me-2"></i> Xác nhận kiểm kê thiết bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="closeEvidenceCamera()"></button>
            </div>
            <div class="modal-body p-3">
                <input type="hidden" id="evidence_IdThietBi" value="0" />

                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Ghi chú kiểm kê (Nếu có)</label>
                    <input type="text" id="evidence_GhiChu" class="form-control rounded-3" placeholder="Ví dụ: Hoạt động tốt, tem còn nguyên vẹn..." style="font-size:13px;" />
                </div>

                <label class="form-label fw-bold small text-muted"><i class="fas fa-image me-1"></i> Hình ảnh bằng chứng thực tế (Tùy chọn)</label>
                <div class="drag-drop-zone text-center mb-2" id="dropZoneEvidence" style="border: 2px dashed #10b981; background: #f0fdf4;" title="Kéo thả tệp, hoặc click chọn ảnh, hoặc click vào vùng này rồi nhấn Ctrl + V để dán bằng chứng">
                    <div class="py-2 text-muted" id="txtEvidenceZoneHint">
                        <i class="fas fa-camera-retro fa-2x mb-2 text-success"></i>
                        <p class="mb-1 small fw-semibold">Chọn ảnh từ máy / Kéo thả ảnh / Nhấp vào đây rồi nhấn <b>Ctrl + V</b> để dán</p>
                    </div>
                    <div class="d-flex gap-2 justify-content-center mt-2">
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="$('#evidence_AnhFile').click(); event.stopPropagation();">
                            <i class="fas fa-file-image"></i> Chọn file ảnh
                        </button>
                        <button type="button" class="btn btn-sm btn-success" onclick="openEvidenceCamera(); event.stopPropagation();">
                            <i class="fas fa-video"></i> Mở Camera
                        </button>
                    </div>
                </div>

                <input type="file" id="evidence_AnhFile" accept="image/*" class="d-none" onchange="previewEvidenceImage(this)" />

                <div id="boxEvidenceCamera" style="display: none;" class="mt-2 text-center border rounded p-2 bg-light shadow-sm">
                    <video id="videoEvidenceCamera" autoplay playsinline style="width: 100%; max-height: 240px; border-radius: 10px; background: #000; object-fit: cover;"></video>
                    <div class="mt-2 mb-1">
                        <button type="button" class="btn btn-danger rounded-pill px-3" onclick="takeEvidenceSnapshot()">
                            <i class="fas fa-dot-circle me-1"></i> Chụp hình bằng chứng
                        </button>
                        <button type="button" class="btn btn-secondary rounded-pill px-2 ms-2" onclick="closeEvidenceCamera()">
                            <i class="fas fa-times"></i> Đóng cam
                        </button>
                    </div>
                    <canvas id="canvasEvidenceCamera" style="display: none;"></canvas>
                </div>

                <div class="mt-3 text-center" id="boxPreviewEvidenceImg" style="display: none;">
                    <div class="position-relative d-inline-block">
                        <img id="imgEvidencePreview" src="" alt="Bằng chứng kiểm kê" class="shadow-sm" style="max-height: 180px; max-width: 100%; border-radius: 10px; border: 2px dashed #10b981; padding: 3px;" />
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="clearEvidenceImage()" style="width: 24px; height: 24px; padding: 0; line-height: 1;">
                            <i class="fas fa-times" style="font-size:11px;"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light d-flex justify-content-between">
                <button type="button" class="btn btn-sm btn-link text-secondary text-decoration-none" data-bs-dismiss="modal" onclick="closeEvidenceCamera()">Hủy bỏ</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary px-3 rounded-pill" onclick="executeSubmitXacNhanCheck(true)">
                        Xác nhận nhanh (Không ảnh)
                    </button>
                    <button type="button" class="btn btn-sm btn-success px-4 rounded-pill" onclick="executeSubmitXacNhanCheck(false)">
                        <i class="fas fa-check-double me-1"></i> Hoàn tất kiểm tra
                    </button>
                </div>
            </div>
        </div>
