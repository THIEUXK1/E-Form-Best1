        let video = document.getElementById('videoQuickCamera');
        let canvas = document.getElementById('canvasQuickCamera');
        let context = canvas.getContext('2d');
        let idThietBi = $('#quickCam_IdThietBi').val();

        let maxDim = 1280;
        let w = video.videoWidth;
        let h = video.videoHeight;
        if (w > maxDim || h > maxDim) {
        if (w > h) {
        h = Math.round((h * maxDim) / w);
        w = maxDim;
        } else {
        w = Math.round((w * maxDim) / h);
        h = maxDim;
        }
        }

        canvas.width = w;
        canvas.height = h;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        canvas.toBlob(function(blob) {
        if(!blob) return;

        $('#modalQuickCamMobile').modal('hide');
        closeQuickCamera();

        Swal.fire({ title: 'Đang tải ảnh lên...', text: 'Vui lòng chờ', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

        let currentItem = allThietBiCache.find(x => x.idThietBi == idThietBi);

        var formData = new FormData();
        formData.append("IdThietBi", parseInt(idThietBi));
        formData.append("AnhThietBi", blob, "quick_mobile_photo.jpg");

        if(currentItem) {
        formData.append("LoaiThietBi", currentItem.loaiThietBi || "");
        formData.append("IdTrangThai", currentItem.idTrangThai || 0);
        formData.append("TenViTri", currentItem.tenViTri || "");
        formData.append("TenMayTinh", currentItem.tenMayTinh || "");
        formData.append("TenDangNhap", currentItem.tenDangNhap || "");
        formData.append("GhiChu", currentItem.ghiChu || "");
        formData.append("QuyCach", currentItem.quyCach || "");
        formData.append("Seribacode", currentItem.seribacode || "");
        formData.append("HanBaoHanh", currentItem.hanBaoHanh || "");
        formData.append("WinLicense", currentItem.winLicense || "");
        formData.append("OfficeLicense", currentItem.officeLicense || "");
        if(currentItem.idNguoiDung) formData.append("IdNguoiDung", currentItem.idNguoiDung);
        if(currentItem.idcongTy) formData.append("IdcongTy", currentItem.idcongTy);
        if(currentItem.idboPhan) formData.append("IdboPhan", currentItem.idboPhan);
        }

        $.ajax({
        url: '/QLKiemKe/SaveKkThietBi', type: 'POST', data: formData, processData: false, contentType: false,
        success: function(res) {
        Swal.close();
        if(res.success) {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã lưu ảnh mới!', showConfirmButton: false, timer: 2500 });
        loadThietBi();
        } else Swal.fire("Lỗi", res.message, "error");
        },
        error: function() { Swal.close(); Swal.fire("Lỗi", "Không thể kết nối đến máy chủ!", "error"); }
        });
        }, 'image/jpeg', 0.75);
        }

        // Hiển thị TOÀN BỘ các trường của thiết bị trong 1 modal ngay tại trang này (không điều hướng sang trang khác)
        function xemChiTietThietBi(item) {
        function dong(nhan, giaTri, icon) {
        let hienThi = (giaTri === null || giaTri === undefined || giaTri === '') ? '<span class="text-muted fst-italic">Chưa có</span>' : giaTri;
        return `<div class="col-md-6 mb-3">
        <div class="small text-muted text-uppercase fw-bold" style="font-size:11px;"><i class="fas ${icon} me-1"></i>${nhan}</div>
        <div class="fw-semibold text-dark">${hienThi}</div>
        </div>`;
        }

        let ngayTao = item.ngayTao ? new Date(item.ngayTao).toLocaleString('vi-VN') : '';
        let ngayCapNhat = item.ngayCapNhat ? new Date(item.ngayCapNhat).toLocaleString('vi-VN') : '';
        let thoiGianCheck = item.thoiGianCheck ? new Date(item.thoiGianCheck).toLocaleString('vi-VN') : '';
        let hanBaoHanh = item.hanBaoHanh ? new Date(item.hanBaoHanh).toLocaleDateString('vi-VN') : '';

        let html = '<div class="row">';
        html += dong('ID', '#' + item.idThietBi, 'fa-hashtag');
        html += dong('Loại thiết bị', item.loaiThietBi, 'fa-tag');
        html += dong('Hostname', item.tenMayTinh, 'fa-desktop');
        html += dong('IP', item.ip, 'fa-network-wired');
        html += dong('Model / Quy cách', item.quyCach, 'fa-microchip');
        html += dong('Version', item.version, 'fa-code-branch');
        html += dong('Serial', item.seribacode, 'fa-barcode');
        html += dong('Error', item.error, 'fa-triangle-exclamation');
        html += dong('Vị trí', item.tenViTri, 'fa-map-marker-alt');
        html += dong('Người dùng', item.tenNguoiDung, 'fa-user');
        html += dong('Account', item.tk || item.tenDangNhap, 'fa-id-badge');
        html += dong('Công ty', item.tenCongTy, 'fa-building');
        html += dong('Bộ phận', item.tenBoPhan, 'fa-sitemap');
        html += dong('Trạng thái', item.tenTrangThai, 'fa-toggle-on');
        html += dong('Bản quyền Windows', item.winLicense, 'fa-windows');
        html += dong('Bản quyền Office', item.officeLicense, 'fa-file-word');
        html += dong('Hạn bảo hành', hanBaoHanh, 'fa-shield-alt');
        html += dong('Thời gian Check gần nhất', thoiGianCheck, 'fa-clock');
        html += dong('Ngày tạo', ngayTao, 'fa-calendar-plus');
        html += dong('Ngày cập nhật', ngayCapNhat, 'fa-calendar-check');
        html += `<div class="col-12 mb-3">
        <div class="small text-muted text-uppercase fw-bold" style="font-size:11px;"><i class="fas fa-sticky-note me-1"></i>Ghi chú</div>
        <div class="fw-semibold text-dark">${item.ghiChu ? item.ghiChu : '<span class="text-muted fst-italic">Chưa có</span>'}</div>
        </div>`;
        html += '</div>';

        $('#bodyXemChiTietThietBi').html(html);

        if (item.duongDanAnh) {
        $('#imgXemChiTietThietBi').attr('src', '/QLKiemKe/GetImage?fileName=' + encodeURIComponent(item.duongDanAnh)).show();
        } else {
        $('#imgXemChiTietThietBi').hide();
        }

        $('#modalXemChiTietThietBi').modal('show');
        }

        function editThietBi(item) {
        $('#tb_Id').val(item.idThietBi);
        $('#btnSaveAsNew').show();
        fillSelectTrangThai('#tb_IdTrangThai', item.idTrangThai || '');
        fillSelectCongTy('#tb_IdCongTy', item.idcongTy || '');

        if (item.idcongTy) {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        let filtered = listBoPhanCache.filter(b => b.idcongTy == item.idcongTy);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        $('#tb_IdBoPhan').html(html).val(item.idboPhan || '');
        } else {
        fillSelectBoPhan('#tb_IdBoPhan', item.idboPhan || '');
        }

        $('#tb_LoaiThietBi').val(item.loaiThietBi);
        $('#tb_QuyCach').val(item.quyCach || '');
        $('#tb_TenViTri').val(item.tenViTri);
        $('#tb_TenMayTinh').val(item.tenMayTinh || '');
        $('#tb_TenDangNhap').val(item.tenDangNhap || '');
        $('#tb_GhiChu').val(item.ghiChu || '');

        $('#tb_Seribacode').val(item.seribacode || '');
        $('#tb_WinLicense').val(item.winLicense || '');
        $('#tb_OfficeLicense').val(item.officeLicense || '');

        if (item.hanBaoHanh) {
        $('#tb_HanBaoHanh').val(item.hanBaoHanh);
        } else {
        $('#tb_HanBaoHanh').val('');
        }

        clearImage();
        if (item.duongDanAnh) {
        $('#imgThietBi').attr('src', '/QLKiemKe/GetImage?fileName=' + encodeURIComponent(item.duongDanAnh));
        $('#boxPreviewImg').show();
        }

        $('#tb_IdNguoiDung').val(item.idNguoiDung || '').trigger('change');
        $('#titleModalThietBi').text("Cập nhật Thiết bị");
        $('#modalThietBi').modal('show');
        }

        function saveThietBi(saveAsNew = false) {
        let isAddMode = parseInt($('#tb_Id').val()) === 0 || saveAsNew;
        let loaiThietBi = $('#tb_LoaiThietBi').val();
        let idTrangThai = $('#tb_IdTrangThai').val();
        let textTenViTri = $('#tb_TenViTri').val().trim();

        if(!loaiThietBi || !idTrangThai || !textTenViTri) return Swal.fire("Lỗi", "Vui lòng chọn loại thiết bị, trạng thái và điền tên vị trí!", "warning");

        var formData = new FormData();
        formData.append("IdThietBi", parseInt($('#tb_Id').val()));
        formData.append("LoaiThietBi", loaiThietBi);
        formData.append("QuyCach", $('#tb_QuyCach').val().trim());
        formData.append("IdTrangThai", parseInt(idTrangThai));
        formData.append("TenViTri", textTenViTri.toUpperCase());
        formData.append("TenMayTinh", $('#tb_TenMayTinh').val().trim().toUpperCase());
        formData.append("TenDangNhap", $('#tb_TenDangNhap').val().trim().toUpperCase());
        formData.append("GhiChu", $('#tb_GhiChu').val().trim());
        formData.append("saveAsNew", saveAsNew);

        formData.append("Seribacode", $('#tb_Seribacode').val().trim());
        formData.append("HanBaoHanh", $('#tb_HanBaoHanh').val());
        formData.append("WinLicense", $('#tb_WinLicense').val());
        formData.append("OfficeLicense", $('#tb_OfficeLicense').val());

        if($('#tb_IdNguoiDung').val()) formData.append("IdNguoiDung", parseInt($('#tb_IdNguoiDung').val()));
        if($('#tb_IdCongTy').val()) formData.append("IdcongTy", parseInt($('#tb_IdCongTy').val()));
        if($('#tb_IdBoPhan').val()) formData.append("IdboPhan", parseInt($('#tb_IdBoPhan').val()));

        if (capturedPhotoBlob) {
        formData.append("AnhThietBi", capturedPhotoBlob, "camera_photo.jpg");
        } else {
        var fileInput = $('#tb_Anh')[0].files;
        if(fileInput.length > 0) { formData.append("AnhThietBi", fileInput[0]); }
        }

        $.ajax({
        url: '/QLKiemKe/SaveKkThietBi', type: 'POST', data: formData, processData: false, contentType: false,
        success: function(res) {
        if(res.success) {
        loadThietBi();
        if(isAddMode) {
        xoaCacheFormAdd();
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: saveAsNew ? 'Nhân bản sao thiết bị thành công!' : 'Thêm thiết bị thành công!', showConfirmButton: false, timer: 2000 });
        $('#tb_Id').val('0');
        clearImage();
        $('#tb_TenViTri').select().focus();
        $('#btnSaveAsNew').hide();
        } else {
        $('#modalThietBi').modal('hide');
        Swal.fire("Thành công", res.message, "success");
        }
        } else Swal.fire("Lỗi", res.message, "error");
        },
        error: function() { Swal.fire("Lỗi", "Không thể kết nối đến máy chủ!", "error"); }
        });
        }

        function xoaCacheFormAdd() {
        localStorage.removeItem('add_form_tb_LoaiThietBi');
        localStorage.removeItem('add_form_tb_IdTrangThai');
        localStorage.removeItem('add_form_tb_TenViTri');
        localStorage.removeItem('add_form_tb_QuyCach');
        localStorage.removeItem('add_form_tb_TenMayTinh');
        localStorage.removeItem('add_form_tb_TenDangNhap');
        localStorage.removeItem('add_form_tb_GhiChu');
        localStorage.removeItem('add_form_tb_IdCongTy');
        localStorage.removeItem('add_form_tb_IdBoPhan');
        localStorage.removeItem('add_form_tb_IdNguoiDung');
        localStorage.removeItem('add_form_tb_Seribacode');
        localStorage.removeItem('add_form_tb_HanBaoHanh');
        localStorage.removeItem('add_form_tb_WinLicense');
        localStorage.removeItem('add_form_tb_OfficeLicense');
        }

        function xacNhanCheckThietBi(id) {
        $('#evidence_IdThietBi').val(id);
        $('#evidence_GhiChu').val('');

        $('#evidence_AnhFile').val('');
        evidencePhotoBlob = null;
        $('#imgEvidencePreview').attr('src', '');
        $('#boxPreviewEvidenceImg').hide();
        $('#boxEvidenceCamera').hide();
        if (evidenceCamStream) {
        evidenceCamStream.getTracks().forEach(t => t.stop());
        evidenceCamStream = null;
        }

        $('#modalXacNhanCheckEvidence').modal('show');

        setTimeout(() => {
        initEvidenceZoneEvents();
        }, 250);
        }

        function initEvidenceZoneEvents() {
        let zone = document.getElementById('dropZoneEvidence');
        if(!zone) return;

        zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.style.background = "#d1fae5"; });
        zone.addEventListener('dragleave', () => { zone.style.background = "#f0fdf4"; });
        zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.style.background = "#f0fdf4";
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        let file = e.dataTransfer.files[0];
        if (file.type.startsWith('image/')) {
        evidencePhotoBlob = null;
        $('#evidence_AnhFile')[0].files = e.dataTransfer.files;
        let r = new FileReader();
        r.onload = (evt) => { $('#imgEvidencePreview').attr('src', evt.target.result); $('#boxPreviewEvidenceImg').show(); };
        r.readAsDataURL(file);
        }
        }
        });

        let modalEv = document.getElementById('modalXacNhanCheckEvidence');
        modalEv.addEventListener('paste', (e) => {
        if (e.clipboardData && e.clipboardData.items) {
        for (let i = 0; i < e.clipboardData.items.length; i++) {
        let item = e.clipboardData.items[i];
        if (item.type.indexOf('image') !== -1) {
        let blob = item.getAsFile();
        evidencePhotoBlob = blob;
        $('#evidence_AnhFile').val('');
        let r = new FileReader();
        r.onload = (evt) => { $('#imgEvidencePreview').attr('src', evt.target.result); $('#boxPreviewEvidenceImg').show(); };
        r.readAsDataURL(blob);
        break;
        }
        }
        }
        });
        }

        function openEvidenceCamera() {
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
        navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'environment', width: { ideal: 1920 }, height: { ideal: 1080 } }
        })
        .then(function(stream) {
        evidenceCamStream = stream;
        let video = document.getElementById('videoEvidenceCamera');
        video.srcObject = stream;
        video.play();
        $('#boxEvidenceCamera').slideDown();
        $('#boxPreviewEvidenceImg').hide();
        })
        .catch(function(err) { Swal.fire("Lỗi Camera", "Không thể truy cập camera phụ: " + err.message, "error"); });
        }
        }

        function closeEvidenceCamera() {
        if (evidenceCamStream) { evidenceCamStream.getTracks().forEach(t => t.stop()); evidenceCamStream = null; }
        $('#boxEvidenceCamera').slideUp();
        }

        function takeEvidenceSnapshot() {
        let video = document.getElementById('videoEvidenceCamera');
        let canvas = document.getElementById('canvasEvidenceCamera');
        let ctx = canvas.getContext('2d');

        let maxDim = 1024;
        let w = video.videoWidth;
        let h = video.videoHeight;
        if (w > maxDim || h > maxDim) {
        if (w > h) {
        h = Math.round((h * maxDim) / w);
        w = maxDim;
        } else {
        w = Math.round((w * maxDim) / h);
        h = maxDim;
        }
        }

        canvas.width = w;
        canvas.height = h;
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

        let dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        $('#imgEvidencePreview').attr('src', dataUrl);
        $('#boxPreviewEvidenceImg').show();

        canvas.toBlob(function(b) { evidencePhotoBlob = b; $('#evidence_AnhFile').val(''); }, 'image/jpeg', 0.8);
        closeEvidenceCamera();
        }

        function clearEvidenceImage() {
        $('#evidence_AnhFile').val('');
        evidencePhotoBlob = null;
        $('#imgEvidencePreview').attr('src', '');
        $('#boxPreviewEvidenceImg').hide();
        }

        function previewEvidenceImage(input) {
        if (input.files && input.files[0]) {
        evidencePhotoBlob = null;
        var reader = new FileReader();
        reader.onload = function(e) { $('#imgEvidencePreview').attr('src', e.target.result); $('#boxPreviewEvidenceImg').show(); }
        reader.readAsDataURL(input.files[0]);
        } else { clearEvidenceImage(); }
        }

        function openLichSuCheckThietBi(idThietBi, tenMayTinh, tenViTri) {
        $('#lblInfoThietBiLichSu').html(`<i class="fas fa-laptop me-1"></i> Máy tính: ${tenMayTinh || 'N/A'} | Vị trí: ${tenViTri || 'N/A'}`);
        $('#boxTimelineCheckResult').html(`<div class="text-center text-muted py-3"><i class="fas fa-spinner fa-spin"></i> Đang tải nhật ký...</div>`);
        $('#modalLichSuCheckThietBi').modal('show');

        $.get('/QLKiemKe/GetKkBangChungChecks', { idThietBi: idThietBi }, function (res) {
        if (res && res.success) {
        let logs = res.data || [];
        if (logs.length === 0) {
        $('#boxTimelineCheckResult').html(`<div class="text-center text-muted py-4 small"><i class="fas fa-info-circle opacity-50 mb-1 d-block fs-4"></i> Thiết bị này chưa có lịch sử xác nhận kiểm kê kèm bằng chứng.</div>`);
        return;
        }

        let timelineHtml = '';
        logs.forEach(log => {
        let dateStr = new Date(log.thoiGianCheck).toLocaleString('vi-VN');
        let imgHtml = '';

        if (log.duongDanAnh) {
        let fullImgUrl = `/QLKiemKe/GetEvidenceImage?fileName=${encodeURIComponent(log.duongDanAnh)}`;
        imgHtml = `
        <div class="mt-2">
        <img src="${fullImgUrl}" class="rounded shadow-sm border border-light" style="width: 100px; height: 75px; object-fit: cover; cursor: pointer;" onclick="phongToAnh('${fullImgUrl}', '${tenViTri}')" title="Bấm để xem ảnh lớn bằng chứng" />
        </div>`;
        }

        timelineHtml += `
        <div class="timeline-check-item">
        <div class="fw-bold text-dark small mb-1"><i class="fas fa-clock me-1 text-secondary"></i> ${dateStr}</div>
        <div class="text-secondary small bg-light p-2 rounded border border-light shadow-none" style="font-size:12.5px;">
        <b>Ghi chú:</b> ${log.ghiChu || 'Xác nhận kiểm kê'}
        ${imgHtml}
        </div>
        </div>`;
        });
        $('#boxTimelineCheckResult').html(timelineHtml);
        } else {
        $('#boxTimelineCheckResult').html(`<div class="text-danger small">Lỗi tải nhật ký: ${res.message}</div>`);
        }
        }).fail(function () {
        $('#boxTimelineCheckResult').html(`<div class="text-danger small">Không thể kết nối tới máy chủ.</div>`);
        });
        }

        function executeSubmitXacNhanCheck(isQuickMode) {
        let id = $('#evidence_IdThietBi').val();
        let note = $('#evidence_GhiChu').val();

        var formData = new FormData();
        formData.append("idThietBi", parseInt(id));
        formData.append("ghiChuCheck", note);

        if (!isQuickMode) {
        if (evidencePhotoBlob) {
        formData.append("AnhBangChung", evidencePhotoBlob, "evidence_photo.jpg");
        } else {
        let files = $('#evidence_AnhFile')[0].files;
        if (files.length > 0) { formData.append("AnhBangChung", files[0]); }
        }
        }

        $('#modalXacNhanCheckEvidence').modal('hide');
        closeEvidenceCamera();

        Swal.fire({ title: 'Đang xác nhận kiểm kê...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

        $.ajax({
        url: '/QLKiemKe/XacNhanCheck', type: 'POST', data: formData, processData: false, contentType: false,
        success: function(res) {
        Swal.close();
        if(res.success) {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã hoàn tất lưu bằng chứng kiểm tra!', showConfirmButton: false, timer: 2000 });
        loadThietBi();
        } else Swal.fire("Thất bại", res.message, "error");
        },
        error: function() { Swal.close(); Swal.fire("Lỗi kết nối", "Không thể liên lạc với máy chủ!", "error"); }
        });
        }

        function deleteThietBi(id) {
        Swal.fire({
        title: 'Chuyển vào Thùng Rác?', text: "Thiết bị sẽ được chuyển sang Tab Đã Xóa. Nhập lý do:",
        input: 'text', icon: 'warning', showCancelButton: true, confirmButtonText: 'Đồng ý', cancelButtonText: 'Hủy',
        inputValidator: (value) => { if (!value) { return 'Bạn phải nhập lý do xóa!' } }
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkThietBi', { id: id, lyDo: r.value }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Đã chuyển", res.message, "success"); }
        else Swal.fire("Lỗi", res.message, "error");
        });
        }
        });
        }

        function restoreThietBi(id) {
        Swal.fire({
        title: 'Khôi phục thiết bị?', text: "Thiết bị sẽ được khôi phục về trạng thái hoạt động cũ.",
        icon: 'question', showCancelButton: true, confirmButtonText: 'Khôi phục', cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/RestoreKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Thành công", res.message, "success"); }
        else Swal.fire("Lỗi", res.message, "error");
        });
        }
        });
        }

        function hardDeleteThietBi(id) {
        Swal.fire({
        title: 'Xóa vĩnh viễn?', text: "Hành động xóa vĩnh viễn khỏi cơ sở dữ liệu sẽ không thể khôi phục lại!",
        icon: 'error', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Xóa vĩnh vễn', cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/HardDeleteKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Đã xóa!", res.message, "success"); }
        else Swal.fire("Lỗi", res.message, "error");
        });
        }
        });
        }

        function phongToAnh(imgUrl, title) {
        Swal.fire({
        title: title ? `Vị trí: ${title}` : 'Ảnh Thiết Bị', imageUrl: imgUrl, imageAlt: 'Ảnh thiết bị chi tiết',
        showCloseButton: true, showConfirmButton: false, width: 'auto', padding: '1em', backdrop: `rgba(0,0,0,0.85)`,
        customClass: { image: 'img-fluid rounded shadow-lg', popup: 'bg-white rounded-4' }
        });
        }
    </script>
}