<div class="modal fade" id="modalXacNhanCheckEvidence" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-success text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-clipboard-check me-2"></i> Xác nhận kiểm kê thiết bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="closeEvidenceCamera()"></button>
            </div>
            <div class="modal-body p-3">
                <input type="hidden" id="evidence_IdThietBi" value="0" />

                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted">Ghi chú kiểm kê (Nếu có)</label>
                    <input type="text" id="evidence_GhiChu" class="form-control rounded-3" placeholder="Ví dụ: Hoạt động tốt, tem còn nguyên vẹn..." style="font-size:13px;" />
                </div>

                <label class="form-label fw-bold small text-muted"><i class="fas fa-image me-1"></i> Hình ảnh bằng chứng thực tế (Tùy chọn)</label>
                <div class="drag-drop-zone text-center mb-2" id="dropZoneEvidence" style="border: 2px dashed #10b981; background: #f0fdf4;" title="Kéo thả tệp, hoặc click chọn ảnh, hoặc click vào vùng này rồi nhấn Ctrl + V để dán bằng chứng">
                    <div class="py-2 text-muted" id="txtEvidenceZoneHint">
                        <i class="fas fa-camera-retro fa-2x mb-2 text-success"></i>
                        <p class="mb-1 small fw-semibold">Chọn ảnh từ máy / Kéo thả ảnh / Nhấp vào đây rồi nhấn <b>Ctrl + V</b> để dán</p>
                    </div>
                    <div class="d-flex gap-2 justify-content-center mt-2">
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="$('#evidence_AnhFile').click(); event.stopPropagation();">
                            <i class="fas fa-file-image"></i> Chọn file ảnh
                        </button>
                        <button type="button" class="btn btn-sm btn-success" onclick="openEvidenceCamera(); event.stopPropagation();">
                            <i class="fas fa-video"></i> Mở Camera
                        </button>
                    </div>
                </div>

                <input type="file" id="evidence_AnhFile" accept="image/*" class="d-none" onchange="previewEvidenceImage(this)" />

                <div id="boxEvidenceCamera" style="display: none;" class="mt-2 text-center border rounded p-2 bg-light shadow-sm">
                    <video id="videoEvidenceCamera" autoplay playsinline style="width: 100%; max-height: 240px; border-radius: 10px; background: #000; object-fit: cover;"></video>
                    <div class="mt-2 mb-1">
                        <button type="button" class="btn btn-danger rounded-pill px-3" onclick="takeEvidenceSnapshot()">
                            <i class="fas fa-dot-circle me-1"></i> Chụp hình bằng chứng
                        </button>
                        <button type="button" class="btn btn-secondary rounded-pill px-2 ms-2" onclick="closeEvidenceCamera()">
                            <i class="fas fa-times"></i> Đóng cam
                        </button>
                    </div>
                    <canvas id="canvasEvidenceCamera" style="display: none;"></canvas>
                </div>

                <div class="mt-3 text-center" id="boxPreviewEvidenceImg" style="display: none;">
                    <div class="position-relative d-inline-block">
                        <img id="imgEvidencePreview" src="" alt="Bằng chứng kiểm kê" class="shadow-sm" style="max-height: 180px; max-width: 100%; border-radius: 10px; border: 2px dashed #10b981; padding: 3px;" />
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="clearEvidenceImage()" style="width: 24px; height: 24px; padding: 0; line-height: 1;">
                            <i class="fas fa-times" style="font-size:11px;"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light d-flex justify-content-between">
                <button type="button" class="btn btn-sm btn-link text-secondary text-decoration-none" data-bs-dismiss="modal" onclick="closeEvidenceCamera()">Hủy bỏ</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary px-3 rounded-pill" onclick="executeSubmitXacNhanCheck(true)">
                        Xác nhận nhanh (Không ảnh)
                    </button>
                    <button type="button" class="btn btn-sm btn-success px-4 rounded-pill" onclick="executeSubmitXacNhanCheck(false)">
                        <i class="fas fa-check-double me-1"></i> Hoàn tất kiểm tra
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLichSuCheckThietBi" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-info text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-history me-2"></i> Nhật ký kiểm kê thiết bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="lblInfoThietBiLichSu" class="mb-3 p-2 bg-light rounded border fw-bold small text-secondary"></div>
                <div class="timeline-check" id="boxTimelineCheckResult"></div>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-sm btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        var currentTab = 'Thiết bị';

        let listCongTyCache = [];
        let listBoPhanCache = [];
        let listTrangThaiCache = [];
        let listLoaiThietBiCache = [];
        let allThietBiCache = [];

        let chartLoai = null;
        let chartTT = null;

        let currentStream = null;
        let capturedPhotoBlob = null;
        let quickCamStream = null;

        let evidencePhotoBlob = null;
        let evidenceCamStream = null;

        $(document).ready(function () {
        if($.fn.select2) {
        $('.select2-modal').select2({
        dropdownParent: $('#modalThietBi .modal-content'),
        placeholder: "-- Chọn người dùng --",
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0
        });

        $(document).on('select2:open', () => {
        let isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (!isMobile) {
        let searchField = document.querySelector('.select2-search__field');
        if (searchField) { setTimeout(() => { searchField.focus(); }, 10); }
        }
        });

        $('#modalThietBi').on('scroll', function() {
        let isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (isMobile) { $('.select2-modal').select2("close"); }
        });

        setTimeout(() => {
        $('.select2-modal').next('.select2-container').find('.select2-selection--single').css({
        'height': '45px', 'display': 'flex', 'align-items': 'center',
        'border': '1px solid #e2e8f0', 'border-radius': '0.5rem'
        });
        }, 200);
        }

        let savedLimit = localStorage.getItem('kk_filterLimit') || '100';
        $('#filterLimit').val(savedLimit);
        let savedText = localStorage.getItem('kk_filterText') || '';
        $('#filterText').val(savedText);
        let savedSort = localStorage.getItem('kk_filterSort') || '';
        $('#filterSort').val(savedSort);
        let savedTuNgay = localStorage.getItem('kk_filterTuNgay') || '';
        $('#filterTuNgay').val(savedTuNgay);
        let savedDenNgay = localStorage.getItem('kk_filterDenNgay') || '';
        $('#filterDenNgay').val(savedDenNgay);
        let savedTìnhTrangCheck = localStorage.getItem('kk_filterTìnhTrangCheck') || '';
        $('#filterTìnhTrangCheck').val(savedTìnhTrangCheck);

        // Khôi phục chế độ Loại trừ Công ty/Bộ phận
        excludeCongTyMode = localStorage.getItem('kk_excludeCongTyMode') === 'true';
        excludeBoPhanMode = localStorage.getItem('kk_excludeBoPhanMode') === 'true';
        $('#chkExcludeCongTy').prop('checked', excludeCongTyMode);
        $('#chkExcludeBoPhan').prop('checked', excludeBoPhanMode);

        $('#chkExcludeCongTy').on('change', function () {
        excludeCongTyMode = $(this).is(':checked');
        localStorage.setItem('kk_excludeCongTyMode', excludeCongTyMode);
        updateDropdownButtonLabel($('#menuCongTy'));
        applyFilters();
        });
        $('#chkExcludeBoPhan').on('change', function () {
        excludeBoPhanMode = $(this).is(':checked');
        localStorage.setItem('kk_excludeBoPhanMode', excludeBoPhanMode);
        updateDropdownButtonLabel($('#menuBoPhan'));
        applyFilters();
        });

        // PHẦN LOGIC GHI NHỚ TRẠNG THÁI ẨN / HIỆN BỘ LỌC NÂNG CAO KHI LOAD LẠI TRANG
        let savedFilterState = localStorage.getItem('kk_toggleAdvancedFilter') || 'hide';
        if(savedFilterState === 'show') {
        $('#advancedFilterArea').show();
        $('#textToggleFilter').text('Thu gọn bộ lọc');
        $('#btnToggleAdvancedFilter').removeClass('btn-primary').addClass('btn-secondary').css({'background-color': '#64748b', 'border-color': '#64748b'});
        } else {
        $('#advancedFilterArea').hide();
        $('#textToggleFilter').text('Bộ lọc nâng cao');
        $('#btnToggleAdvancedFilter').removeClass('btn-secondary').addClass('btn-primary').css({'background-color': '#4f46e5', 'border-color': '#4f46e5'});
        }

        $('#filterLimit, #filterSort, #filterTuNgay, #filterDenNgay, #filterTìnhTrangCheck').on('change', function() { applyFilters(); });
        $('#filterText').on('keyup input', function() { applyFilters(); });

        $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
        let $menu = $(this).closest('.dropdown-combo-menu');
        updateDropdownButtonLabel($menu);

        if ($(this).hasClass('chk-company')) {
        renderFilterBoPhan();
        }
        applyFilters();
        });

        $('#tb_LoaiThietBi, #tb_IdTrangThai, #tb_IdCongTy, #tb_IdBoPhan, #tb_IdNguoiDung, #tb_WinLicense, #tb_OfficeLicense').on('change', function() {
        if (parseInt($('#tb_Id').val()) === 0) { localStorage.setItem('add_form_' + this.id, $(this).val() || ''); }
        });
        $('#tb_TenViTri, #tb_QuyCach, #tb_TenMayTinh, #tb_TenDangNhap, #tb_GhiChu, #tb_Seribacode, #tb_HanBaoHanh').on('keyup input change', function() {
        if (parseInt($('#tb_Id').val()) === 0) { localStorage.setItem('add_form_' + this.id, $(this).val().trim()); }
        });

        $('#modalThietBi').on('keydown', 'input, select', function (e) {
        if (e.key === 'Enter' || e.keyCode === 13) {
        if ($(e.target).hasClass('select2-search__field')) return;
        e.preventDefault();
        saveThietBi(false);
        }
        });

        $('.select2-modal').on('select2:select', function (e) {
        setTimeout(() => { saveThietBi(false); }, 50);
        });

        $('.modal').on('hidden.bs.modal', function () {
        if (this.id === 'modalQuickCamMobile' || this.id === 'modalXacNhanCheckEvidence' || this.id === 'modalLichSuCheckThietBi') return;
        $(this).find('input[type="text"], input[type="date"], textarea').val('');
        $(this).find('input[type="hidden"]').val('0');
        $(this).find('select').val('').trigger('change');
        closeCamera();
        closeCamera();
        clearImage();
        khoiPhucDuLieuFormAdd();
        $('#btnSaveAsNew').hide();
        });

        $('#tb_IdCongTy').on('change', function() {
        let idCT = $(this).val();
        let html = '<option value="">-- Chọn bộ phận --</option>';
        if(idCT) {
        let filtered = listBoPhanCache.filter(b => b.idcongTy == idCT);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        } else {
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        }
        $('#tb_IdBoPhan').html(html);

        if (parseInt($('#tb_Id').val()) === 0) {
        let savedBP = localStorage.getItem('add_form_tb_IdBoPhan') || '';
        if ($(html).filter(`[value="${savedBP}"]`).length > 0) { $('#tb_IdBoPhan').val(savedBP); }
        }
        });

        let dropZone = document.getElementById('dropZoneThietBi');
        if (dropZone) {
        dropZone.addEventListener('click', () => $('#tb_Anh').click());

        dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        let file = e.dataTransfer.files[0];
        if (file.type.startsWith('image/')) {
        capturedPhotoBlob = null;
        $('#tb_Anh')[0].files = e.dataTransfer.files;
        let reader = new FileReader();
        reader.onload = (evt) => {
        $('#imgThietBi').attr('src', evt.target.result);
        $('#boxPreviewImg').show();
        };
        reader.readAsDataURL(file);
        }
        }
        });
        }

        document.getElementById('modalThietBi').addEventListener('paste', (e) => {
        if (e.clipboardData && e.clipboardData.items) {
        for (let i = 0; i < e.clipboardData.items.length; i++) {
        let item = e.clipboardData.items[i];
        if (item.type.indexOf('image') !== -1) {
        let blob = item.getAsFile();
        capturedPhotoBlob = blob;
        $('#tb_Anh').val('');

        let reader = new FileReader();
        reader.onload = (evt) => {
        $('#imgThietBi').attr('src', evt.target.result);
        $('#boxPreviewImg').show();
        };
        reader.readAsDataURL(blob);
        break;
        }
        }
        }
        });

        loadMasterData();
        });

        // HÀM XỬ LÝ ĐÓNG MỞ EVENT CHO NÚT BỘ LỌC NÂNG CAO
        function toggleAdvancedFilter() {
        let $filterArea = $('#advancedFilterArea');
        if($filterArea.is(':visible')) {
        $filterArea.slideUp(200);
        $('#textToggleFilter').text('Bộ lọc nâng cao');
        $('#btnToggleAdvancedFilter').removeClass('btn-secondary').addClass('btn-primary').css({'background-color': '#4f46e5', 'border-color': '#4f46e5'});
        localStorage.setItem('kk_toggleAdvancedFilter', 'hide');
        } else {
        $filterArea.slideDown(200);
        $('#textToggleFilter').text('Thu gọn bộ lọc');
        $('#btnToggleAdvancedFilter').removeClass('btn-primary').addClass('btn-secondary').css({'background-color': '#64748b', 'border-color': '#64748b'});
        localStorage.setItem('kk_toggleAdvancedFilter', 'show');
        }
        }

        // HÀM KHỞI TẠO VÀ RENDER DROPDOWN CHECKBOX CHO WINDOWS LICENSE & OFFICE LICENSE MỚI THÊM
        function renderFilterLicenses() {
        let winList = ["Windows Pro", "Windows Home", "Windows Enterprise", "Windows Education", "Windows Server", "Có (Chưa rõ phiên bản)", "Chưa có", "Trống / Chưa rõ"];
        let officeList = ["Office Professional Plus", "Office Standard", "Office Home & Business", "Office Home & Student", "Microsoft 365 Apps", "Có (Chưa rõ phiên bản)", "Chưa có", "Trống / Chưa rõ"];

        let savedWin = [];
        let savedOffice = [];
        try { savedWin = JSON.parse(localStorage.getItem('kk_filterWinLicense')) || []; } catch(e){}
        try { savedOffice = JSON.parse(localStorage.getItem('kk_filterOfficeLicense')) || []; } catch(e){}

        let $itemsWin = $('#menuWinLicense .dropdown-combo-items').empty();
        winList.forEach(w => {
        let isChecked = savedWin.includes(w) ? 'checked' : '';
        $itemsWin.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-win" value="${w}" ${isChecked}>
        <span>${w}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuWinLicense'));

        let $itemsOffice = $('#menuOfficeLicense .dropdown-combo-items').empty();
        officeList.forEach(o => {
        let isChecked = savedOffice.includes(o) ? 'checked' : '';
        $itemsOffice.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-office" value="${o}" ${isChecked}>
        <span>${o}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuOfficeLicense'));
        }

        // Chế độ lọc Công ty/Bộ phận: false = chỉ lấy các mục đã chọn, true = lấy tất cả TRỪ các mục đã chọn
        let excludeCongTyMode = false;
        let excludeBoPhanMode = false;

        function updateDropdownButtonLabel($menu) {
        let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
        let $btn = $menu.siblings('.dropdown-combo-btn');
        let menuId = $menu.attr('id');
        let isExcludeMode = (menuId === 'menuCongTy' && excludeCongTyMode) || (menuId === 'menuBoPhan' && excludeBoPhanMode);

        if (totalChecked === 0) {
        $btn.text('-- Tất cả --');
        } else if (isExcludeMode) {
        $btn.text(`Tất cả, trừ ${totalChecked} mục`);
        } else if (totalChecked === 1) {
        $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
        } else {
        $btn.text(`Đã chọn (${totalChecked})`);
        }
        }

        // ===== TÌM KIẾM + CHỌN NHANH CHO CÁC DROPDOWN CHECKBOX BỘ LỌC (giống ô chọn người thực hiện ở DonCvCongViecOrder) =====
        function removeVietnameseTonesJS(str) {
        if (!str) return "";
        let s = str.normalize("NFD");
        let result = "";
        for (let i = 0; i < s.length; i++) {
        let code = s.charCodeAt(i);
        if (code >= 768 && code <= 879) continue; // Bỏ các dấu kết hợp Unicode (U+0300-U+036F)
        result += s[i];
        }
        return result.replace(/đ/g, "d").replace(/Đ/g, "D");
        }

        // Gõ để lọc tức thì các mục trong dropdown đang mở (không phân biệt dấu tiếng Việt)
        $(document).on('input', '.dropdown-combo-search', function (e) {
        e.stopPropagation();
        let filter = removeVietnameseTonesJS($(this).val()).toUpperCase();
        $(this).closest('.dropdown-combo-menu').find('.dropdown-combo-items .dropdown-combo-item').each(function () {
        let txt = removeVietnameseTonesJS($(this).text()).toUpperCase();
        $(this).toggle(txt.indexOf(filter) > -1);
        });
        });

        $(document).on('click', '.dropdown-combo-search', function (e) { e.stopPropagation(); });

        // Chọn tất cả / Bỏ chọn: chỉ áp dụng cho các mục đang hiển thị theo bộ lọc tìm kiếm hiện tại
        $(document).on('click', '.dropdown-combo-selectall, .dropdown-combo-clearall', function (e) {
        e.stopPropagation();
        let checked = $(this).hasClass('dropdown-combo-selectall');
        let $menu = $(this).closest('.dropdown-combo-menu');
        $menu.find('.dropdown-combo-items .dropdown-combo-item:visible input[type="checkbox"]').prop('checked', checked);
        updateDropdownButtonLabel($menu);
        if ($menu.attr('id') === 'menuCongTy') { renderFilterBoPhan(); }
        applyFilters();
        });

        function khoiPhucDuLieuFormAdd() {
        if (parseInt($('#tb_Id').val()) !== 0) return;
        $('#tb_LoaiThietBi').val(localStorage.getItem('add_form_tb_LoaiThietBi') || '');
        $('#tb_IdTrangThai').val(localStorage.getItem('add_form_tb_IdTrangThai') || '');
        $('#tb_TenViTri').val(localStorage.getItem('add_form_tb_TenViTri') || '');
        $('#tb_QuyCach').val(localStorage.getItem('add_form_tb_QuyCach') || '');
        $('#tb_TenMayTinh').val(localStorage.getItem('add_form_tb_TenMayTinh') || '');
        $('#tb_TenDangNhap').val(localStorage.getItem('add_form_tb_TenDangNhap') || '');
        $('#tb_GhiChu').val(localStorage.getItem('add_form_tb_GhiChu') || '');
        $('#tb_Seribacode').val(localStorage.getItem('add_form_tb_Seribacode') || '');
        $('#tb_HanBaoHanh').val(localStorage.getItem('add_form_tb_HanBaoHanh') || '');
        $('#tb_WinLicense').val(localStorage.getItem('add_form_tb_WinLicense') || '');
        $('#tb_OfficeLicense').val(localStorage.getItem('add_form_tb_OfficeLicense') || '');

        let savedCT = localStorage.getItem('add_form_tb_IdCongTy') || '';
        $('#tb_IdCongTy').val(savedCT).trigger('change');

        let savedBP = localStorage.getItem('add_form_tb_IdBoPhan') || '';
        if(savedBP) { setTimeout(() => { $('#tb_IdBoPhan').val(savedBP); }, 50); }

        let savedND = localStorage.getItem('add_form_tb_IdNguoiDung') || '';
        $('#tb_IdNguoiDung').val(savedND).trigger('change.select2');
        }

        function xoaCacheFormAdd() {
        localStorage.removeItem('add_form_tb_LoaiThietBi');
        localStorage.removeItem('add_form_tb_IdTrangThai');
        localStorage.removeItem('add_form_tb_TenViTri');
        localStorage.removeItem('add_form_tb_QuyCach');
        localStorage.removeItem('add_form_tb_TenMayTinh');
        localStorage.removeItem('add_form_tb_TenDangNhap');
        localStorage.removeItem('add_form_tb_GhiChu');
        localStorage.removeItem('add_form_tb_IdCongTy');
        localStorage.removeItem('add_form_tb_IdBoPhan');
        localStorage.removeItem('add_form_tb_IdNguoiDung');
        localStorage.removeItem('add_form_tb_Seribacode');
        localStorage.removeItem('add_form_tb_HanBaoHanh');
        localStorage.removeItem('add_form_tb_WinLicense');
        localStorage.removeItem('add_form_tb_OfficeLicense');
        }

        function changeTab(tabName, element) {
        currentTab = tabName;
        if(tabName === 'Đã xóa' || tabName === 'Tổng quan') {
        $('#btnMasterThemMoi').parent().hide();
        } else {
        $('#btnMasterThemMoi').parent().show();
        }

        if(tabName === 'Tổng quan') {
        $('#filterBar').hide();
        } else {
        $('#filterBar').show();
        if(tabName === 'Đã xóa') { $('#boxFilterTrangThai').hide(); }
        else { $('#boxFilterTrangThai').show(); }
        }

        $('.nav-link').removeClass('active').addClass('text-muted').css({'border-bottom': 'none', 'color': '#64748b'});
        $(element).addClass('active').removeClass('text-muted').css({'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5'});
        }

        function openModalCurrentTab() {
        if (currentTab === 'Thiết bị') {
        $('#tb_Id').val('0');
        $('#btnSaveAsNew').hide();
        $('#titleModalThietBi').text("Thêm Thiết bị mới");
        fillSelectCongTy('#tb_IdCongTy');
        fillSelectBoPhan('#tb_IdBoPhan');
        fillSelectTrangThai('#tb_IdTrangThai');
        khoiPhucDuLieuFormAdd();
        $('#modalThietBi').modal('show');
        }
        }

        function clearFilters() {
        localStorage.removeItem('kk_filterCT');
        localStorage.removeItem('kk_filterBP');
        localStorage.removeItem('kk_filterLoai');
        localStorage.removeItem('kk_filterTT');
        localStorage.removeItem('kk_filterWinLicense');
        localStorage.removeItem('kk_filterOfficeLicense');
        localStorage.setItem('kk_filterLimit', '100');
        localStorage.removeItem('kk_filterText');
        localStorage.removeItem('kk_filterSort');
        localStorage.removeItem('kk_filterTuNgay');
        localStorage.removeItem('kk_filterDenNgay');
        localStorage.removeItem('kk_filterTìnhTrangCheck');
        localStorage.removeItem('kk_excludeCongTyMode');
        localStorage.removeItem('kk_excludeBoPhanMode');

        excludeCongTyMode = false;
        excludeBoPhanMode = false;
        $('#chkExcludeCongTy').prop('checked', false);
        $('#chkExcludeBoPhan').prop('checked', false);

        $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
        $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });

        renderFilterBoPhan();
        renderFilterLicenses();
        $('#filterSort, #filterTuNgay, #filterDenNgay, #filterTìnhTrangCheck').val('');
        $('#filterLimit').val('100');
        $('#filterText').val('');

        applyFilters();
        }

        function applyFilters() {
        let selectedCT = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedBP = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoai = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();
        let selectedTT = $('.chk-status:checked').map(function() { return $(this).data('id'); }).get();
        let selectedWin = $('.chk-win:checked').map(function() { return $(this).val(); }).get();
        let selectedOffice = $('.chk-office:checked').map(function() { return $(this).val(); }).get();

        localStorage.setItem('kk_filterCT', JSON.stringify(selectedCT));
        localStorage.setItem('kk_filterBP', JSON.stringify(selectedBP));
        localStorage.setItem('kk_filterLoai', JSON.stringify(selectedLoai));
        localStorage.setItem('kk_filterTT', JSON.stringify(selectedTT));
        localStorage.setItem('kk_filterWinLicense', JSON.stringify(selectedWin));
        localStorage.setItem('kk_filterOfficeLicense', JSON.stringify(selectedOffice));

        localStorage.setItem('kk_filterLimit', $('#filterLimit').val());
        localStorage.setItem('kk_filterText', $('#filterText').val().trim());
        localStorage.setItem('kk_filterSort', $('#filterSort').val() || '');
        localStorage.setItem('kk_filterTuNgay', $('#filterTuNgay').val() || '');
        localStorage.setItem('kk_filterDenNgay', $('#filterDenNgay').val() || '');
        localStorage.setItem('kk_filterTìnhTrangCheck', $('#filterTìnhTrangCheck').val() || '');

        renderUIThietBi();
        renderUIDaXoa();
        }

        // Tải cấu hình Master Data và danh sách thiết bị ban đầu từ api server của bạn
        function loadMasterData() {
        $.get('/QLKiemKe/GetKkTrangThais', function(res) { if(res.success) { listTrangThaiCache = res.data; renderFilterTrangThai(); } });
        $.get('/QLKiemKe/GetKkLoaiThietBis', function(res) { if(res.success) { listLoaiThietBiCache = res.data; renderFilterLoaiThietBi(); } });
        $.get('/QLKiemKe/GetKkCongTys', function(res) { if(res.success) { listCongTyCache = res.data; renderFilterCongTy(); } });
        $.get('/QLKiemKe/GetKkBoPhans', function(res) { if(res.success) { listBoPhanCache = res.data; renderFilterBoPhan(); } });
        napGoiYBanQuyen();
        renderFilterLicenses();
        loadThietBi();
        }

        // Bổ sung thêm gợi ý (datalist) Bản quyền Windows/Office dựa trên các giá trị THỰC TẾ đã từng nhập trong hệ thống,
        // gộp cùng vài mẫu chuẩn có sẵn (giữ nguyên, không xóa) để gợi ý luôn bám sát dữ liệu đang dùng thật.
        function napGoiYBanQuyen() {
        $.get('/QLKiemKe/GetGoiYBanQuyen', function (res) {
        if (!res || !res.success) return;

        (res.dsWin || []).forEach(function (v) {
        if ($("#dlWinLicense option[value='" + v.replace(/'/g, "\\'") + "']").length === 0) {
        $("#dlWinLicense").append($('<option>').val(v));
        }
        });

        (res.dsOffice || []).forEach(function (v) {
        if ($("#dlOfficeLicense option[value='" + v.replace(/'/g, "\\'") + "']").length === 0) {
        $("#dlOfficeLicense").append($('<option>').val(v));
        }
        });
        });
        }

        function loadThietBi() {
        $.get('/QLKiemKe/GetKkThietBis', function (res) {
        if (res && res.success) {
        allThietBiCache = res.data || [];
        renderThongKe();
        renderUIThietBi();
        renderUIDaXoa();
        capNhatGoiYTenViTri();
        } else {
        $('#tbodyThietBi').html(`<tr><td colspan="7" class="text-center text-danger py-4">Lỗi tải dữ liệu từ Server: ${res.message}</td></tr>`);
        }
        }).fail(function() {
        $('#tbodyThietBi').html(`<tr><td colspan="7" class="text-center text-danger py-4">Không thể kết nối đến API /QLKiemKe/GetKkThietBis</td></tr>`);
        });
        }

        // Gửi file Excel lên Server để nhập nhanh tình trạng Key Office (Cột A: Tên máy, Cột B: Activated / Not Activated)
        function submitImportOfficeLicense() {
        var fileInput = document.getElementById('fileImportOfficeLicense');
        if (!fileInput.files || fileInput.files.length === 0) {
        Swal.fire('Thông báo', 'Vui lòng chọn file Excel trước khi tải lên.', 'warning');
        return;
        }

        var formData = new FormData();
        formData.append('file', fileInput.files[0]);

        var $btn = $('#btnSubmitImportOfficeLicense');
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Đang xử lý...');
        $('#ketQuaImportOfficeLicense').hide().empty();

        $.ajax({
        url: '/QLKiemKe/ImportOfficeLicenseExcel',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function (res) {
        $btn.prop('disabled', false).html('<i class="fas fa-upload me-1"></i> Tải lên & Cập nhật');
        if (res.success) {
        var html = `<div class="alert alert-success mb-2"><i class="fas fa-check-circle me-1"></i> Đã cập nhật <b>${res.soDaCapNhat}</b> thiết bị (Máy tính/Laptop). Bỏ qua <b>${res.soBoQuaTrong}</b> dòng trống tình trạng.</div>`;
        if (res.dsKhongTimThay && res.dsKhongTimThay.length > 0) {
        html += `<div class="alert alert-warning mb-2"><i class="fas fa-exclamation-triangle me-1"></i> Không tìm thấy <b>${res.dsKhongTimThay.length}</b> tên máy trong hệ thống:<br/><small>${res.dsKhongTimThay.join(', ')}</small></div>`;
        }
        if (res.dsBoQuaKhacLoai && res.dsBoQuaKhacLoai.length > 0) {
        html += `<div class="alert alert-secondary mb-0"><i class="fas fa-info-circle me-1"></i> Bỏ qua <b>${res.dsBoQuaKhacLoai.length}</b> tên máy trùng nhưng thiết bị không phải Máy tính/Laptop:<br/><small>${res.dsBoQuaKhacLoai.join(', ')}</small></div>`;
        }
        $('#ketQuaImportOfficeLicense').html(html).show();
        fileInput.value = '';
        loadThietBi();
        } else {
        $('#ketQuaImportOfficeLicense').html(`<div class="alert alert-danger mb-0"><i class="fas fa-times-circle me-1"></i> ${res.message}</div>`).show();
        }
        },
        error: function () {
        $btn.prop('disabled', false).html('<i class="fas fa-upload me-1"></i> Tải lên & Cập nhật');
        $('#ketQuaImportOfficeLicense').html('<div class="alert alert-danger mb-0">Lỗi kết nối đến Server khi tải file lên.</div>').show();
        }
        });
        }

        // Reset lại trạng thái preview mỗi khi người dùng chọn file khác
        function resetPreviewSwitchExcel() {
        $('#wrapBangPreviewSwitchExcel').hide();
        $('#tbodyPreviewSwitchExcel').empty();
        $('#ketQuaPreviewSwitchExcel').hide().empty();
        $('#ketQuaImportSwitchExcel').hide().empty();
        $('#btnSubmitImportSwitchExcel').prop('disabled', true);
        }

        // Đọc thử file (không lưu DB) để hiển thị bảng xem trước trước khi xác nhận đẩy dữ liệu
        function previewImportSwitchExcel() {
        var fileInput = document.getElementById('fileImportSwitchExcel');
        if (!fileInput.files || fileInput.files.length === 0) {
        Swal.fire('Thông báo', 'Vui lòng chọn file trước khi xem trước.', 'warning');
        return;
        }

        var formData = new FormData();
        formData.append('file', fileInput.files[0]);

        var $btn = $('#btnPreviewSwitchExcel');
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Đang đọc...');
        resetPreviewSwitchExcel();

        $.ajax({
        url: '/QLKiemKe/PreviewSwitchExcel',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        success: function (res) {
        $btn.prop('disabled', false).html('<i class="fas fa-eye me-1"></i> Xem trước');
        if (res.success) {
        var html = `<div class="alert alert-info mb-0"><i class="fas fa-info-circle me-1"></i> Đọc được <b>${res.rows.length}</b> dòng: <b>${res.soHopLe}</b> hợp lệ sẽ được đẩy, <b>${res.soBoQuaThieuThongTin}</b> dòng sẽ bị bỏ qua (thiếu Serial/IP).</div>`;
        $('#ketQuaPreviewSwitchExcel').html(html).show();

        var rowsHtml = '';
        res.rows.forEach(function (r) {
        var badge = !r.hopLe ? 'secondary' : (r.trangThai === 'Cập nhật' ? 'warning text-dark' : 'success');
        var trClass = r.hopLe ? '' : 'table-secondary text-muted';
        rowsHtml += `<tr class="${trClass}">
        <td>${$('<div>').text(r.ip).html()}</td>
        <td>${$('<div>').text(r.hostname).html()}</td>
        <td>${$('<div>').text(r.model).html()}</td>
        <td>${$('<div>').text(r.version).html()}</td>
        <td>${$('<div>').text(r.serial).html()}</td>
        <td>${$('<div>').text(r.error).html()}</td>
        <td><span class="badge bg-${badge}">${r.trangThai}</span></td>
        </tr>`;
        });
        $('#tbodyPreviewSwitchExcel').html(rowsHtml);
        $('#wrapBangPreviewSwitchExcel').show();
        $('#btnSubmitImportSwitchExcel').prop('disabled', res.soHopLe === 0);
        } else {
        $('#ketQuaPreviewSwitchExcel').html(`<div class="alert alert-danger mb-0"><i class="fas fa-times-circle me-1"></i> ${res.message}</div>`).show();
        }
        },
        error: function () {
        $btn.prop('disabled', false).html('<i class="fas fa-eye me-1"></i> Xem trước');
        $('#ketQuaPreviewSwitchExcel').html('<div class="alert alert-danger mb-0">Lỗi kết nối đến Server khi đọc file.</div>').show();
        }
        });
        }

        // Gửi file lên Server để đẩy dữ liệu Switch thật sự, chỉ dùng sau khi đã Xem trước
        function submitImportSwitchExcel() {
        var fileInput = document.getElementById('fileImportSwitchExcel');
