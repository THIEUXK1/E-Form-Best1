<div class="modal fade" id="modalThietBi" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-dark text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalThietBi">Thông tin Thiết bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3 p-md-4">
                <input type="hidden" id="tb_Id" value="0" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Loại thiết bị <span class="text-danger">*</span></label>
                        <select id="tb_LoaiThietBi" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chọn loại --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Tên Vị Trí <span class="text-danger">*</span></label>
                        <input type="text" id="tb_TenViTri" list="suggestTenViTri" class="form-control rounded-3" placeholder="VD: PHÒNG IT, SẢN XUẤT..." style="border: 1px solid #e2e8f0; height: 45px; text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" />
                        <datalist id="suggestTenViTri"></datalist>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold" style="color: #8b5cf6;">Trạng thái <span class="text-danger">*</span></label>
                        <select id="tb_IdTrangThai" class="form-select rounded-3" style="border: 1px solid #8b5cf6; height: 45px;">
                            <option value="">-- Chọn trạng thái --</option>
                        </select>
                    </div>

                    <div class="col-md-8">
                        <label class="form-label fw-bold" style="color: #2563eb;">Quy cách (Cấu hình chi tiết)</label>
                        <input type="text" id="tb_QuyCach" class="form-control rounded-3" placeholder="VD: Core i7 13700H, RAM 16GB, SSD 512GB..." style="border: 1px solid #2563eb; height: 45px;" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Số Serial / Barcode</label>
                        <input type="text" id="tb_Seribacode" class="form-control rounded-3" placeholder="Nhập Serial hoặc Barcode..." style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Tên máy tính (Hostname)</label>
                        <input type="text" id="tb_TenMayTinh" class="form-control rounded-3" placeholder="VD: DESKTOP-123" style="border: 1px solid #e2e8f0; height: 45px; text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Tên đăng nhập (Account)</label>
                        <input type="text" id="tb_TenDangNhap" class="form-control rounded-3" placeholder="VD: ADMIN_LOCAL" style="border: 1px solid #e2e8f0; height: 45px; text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Hạn bảo hành</label>
                        <input type="date" id="tb_HanBaoHanh" class="form-control rounded-3" style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold"><i class="fab fa-windows text-primary me-1"></i> Bản quyền Windows</label>
                        <input type="text" id="tb_WinLicense" class="form-control rounded-3" list="dlWinLicense" placeholder="VD: Professional - Có bản quyền" style="border: 1px solid #e2e8f0; height: 45px;" />
                        <datalist id="dlWinLicense">
                            <option value="Home - Có bản quyền"></option>
                            <option value="Professional - Có bản quyền"></option>
                            <option value="Enterprise - Có bản quyền"></option>
                            <option value="Education - Có bản quyền"></option>
                            <option value="Chưa có bản quyền"></option>
                            <option value="Không xác định"></option>
                        </datalist>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold"><i class="fas fa-file-word text-success me-1"></i> Bản quyền Office</label>
                        <input type="text" id="tb_OfficeLicense" class="form-control rounded-3" list="dlOfficeLicense" placeholder="VD: Có bản quyền" style="border: 1px solid #e2e8f0; height: 45px;" />
                        <datalist id="dlOfficeLicense">
                            <option value="Có bản quyền"></option>
                            <option value="Không có bản quyền"></option>
                            <option value="Không xác định"></option>
                        </datalist>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Ghi chú (Cấu hình, thông tin...)</label>
                        <input type="text" id="tb_GhiChu" class="form-control rounded-3" placeholder="Thông tin tự thêm..." style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-12 mt-4 mb-2"><div style="border-top: 1px dashed #cbd5e1;"></div></div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold" style="color: #4f46e5;">Gán người sử dụng</label>
                        <select id="tb_IdNguoiDung" class="form-control select2-modal w-100">
                            <option value="">-- Chưa cấp phát --</option>
                            @if (ViewBag.Users != null)
                            {
                                foreach (var item in ViewBag.Users)
                                {
                                    <option value="@item.IdNguoiDung">@item.HoTen (@item.Tk)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gán Công ty</label>
                        <select id="tb_IdCongTy" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chọn công ty --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gán Bộ phận</label>
                        <select id="tb_IdBoPhan" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chọn bộ phận --</option>
                        </select>
                    </div>

                    <div class="col-12 mt-4 mb-2"><div style="border-top: 1px dashed #cbd5e1;"></div></div>

                    <div class="col-md-12 mt-2">
                        <label class="form-label fw-bold"><i class="fas fa-camera text-secondary me-1"></i> Ảnh thiết bị đính kèm</label>
                        <div class="drag-drop-zone text-center mb-2" id="dropZoneThietBi" title="Click để tải, hoặc Kéo thả ảnh vào đây, hoặc nhấn vào modal rồi Ctrl + V để dán ảnh">
                            <div class="py-2 text-muted" id="txtDropZoneHint">
                                <i class="fas fa-cloud-upload-alt fa-2x mb-2 text-primary"></i>
                                <p class="mb-1 small fw-semibold">Click tải lên / Kéo thả ảnh / Bấm vào đây rồi nhấn <b>Ctrl + V</b> để dán ảnh</p>
                            </div>
                            <div class="d-flex gap-2 justify-content-center mt-2">
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="$('#tb_Anh').click(); event.stopPropagation();">
                                    <i class="fas fa-upload"></i> Chọn File
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-success" onclick="openCamera(); event.stopPropagation();">
                                    <i class="fas fa-camera"></i> Chụp trực tiếp
                                </button>
                            </div>
                        </div>

                        <input type="file" id="tb_Anh" accept="image/*" class="d-none" onchange="previewImage(this)" />

                        <div id="boxCamera" style="display: none;" class="mt-2 text-center border rounded p-2 bg-light shadow-sm">
                            <video id="videoCamera" autoplay playsinline style="width: 100%; max-height: 300px; border-radius: 10px; background: #000; object-fit: cover;"></video>
                            <div class="mt-3 mb-2">
                                <button type="button" class="btn btn-danger rounded-pill px-4" onclick="takeSnapshot()">
                                    <i class="fas fa-dot-circle me-1"></i> Chụp ngay
                                </button>
                                <button type="button" class="btn btn-secondary rounded-pill px-3 ms-2" onclick="closeCamera()">
                                    <i class="fas fa-times me-1"></i> Đóng Camera
                                </button>
                            </div>
                            <canvas id="canvasCamera" style="display: none;"></canvas>
                        </div>

                        <div class="mt-3 text-center" id="boxPreviewImg" style="display: none;">
                            <div class="position-relative d-inline-block">
                                <img id="imgThietBi" src="" alt="Ảnh thiết bị" class="shadow-sm" style="max-height: 250px; max-width: 100%; border-radius: 10px; border: 2px dashed #cbd5e1; padding: 5px;" />
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="clearImage()" style="width: 28px; height: 28px; padding: 0; line-height: 1;">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light d-flex justify-content-between" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-warning px-3 rounded-pill" id="btnSaveAsNew" style="display: none;" onclick="saveThietBi(true)">
                        <i class="fas fa-copy"></i> Lưu thành bản sao mới
                    </button>
                    <button type="button" class="btn btn-dark px-4 rounded-pill" onclick="saveThietBi(false)">Lưu dữ liệu</button>
                </div>
            </div>
        </div>
    </div>
</div>

