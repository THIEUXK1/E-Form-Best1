        function initEvidenceZoneEvents() {
        let zone = document.getElementById('dropZoneEvidence');
        if(!zone) return;

        zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.style.background = "#d1fae5"; });
        zone.addEventListener('dragleave', () => { zone.style.background = "#f0fdf4"; });
        zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.style.background = "#f0fdf4";
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        let file = e.dataTransfer.files[0];
        if (file.type.startsWith('image/')) {
        evidencePhotoBlob = null;
        $('#evidence_AnhFile')[0].files = e.dataTransfer.files;
        let r = new FileReader();
        r.onload = (evt) => { $('#imgEvidencePreview').attr('src', evt.target.result); $('#boxPreviewEvidenceImg').show(); };
        r.readAsDataURL(file);
        }
        }
        });

        let modalEv = document.getElementById('modalXacNhanCheckEvidence');
        modalEv.addEventListener('paste', (e) => {
        if (e.clipboardData && e.clipboardData.items) {
        for (let i = 0; i < e.clipboardData.items.length; i++) {
        let item = e.clipboardData.items[i];
        if (item.type.indexOf('image') !== -1) {
        let blob = item.getAsFile();
        evidencePhotoBlob = blob;
        $('#evidence_AnhFile').val('');
        let r = new FileReader();
        r.onload = (evt) => { $('#imgEvidencePreview').attr('src', evt.target.result); $('#boxPreviewEvidenceImg').show(); };
        r.readAsDataURL(blob);
        break;
        }
        }
        }
        });
        }

