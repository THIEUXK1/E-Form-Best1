        if (res.soBoQuaThieuThongTin > 0) {
        html += `<div class="alert alert-warning mb-0"><i class="fas fa-exclamation-triangle me-1"></i> Bỏ qua <b>${res.soBoQuaThieuThongTin}</b> dòng thiếu Serial hoặc IP.</div>`;
        }
        $('#ketQuaImportSwitchExcel').html(html).show();
