        function deleteThietBi(id) {
        Swal.fire({
        title: 'Chuyển vào Thùng Rác?', text: "Thiết bị sẽ được chuyển sang Tab Đã Xóa. Nhập lý do:",
        input: 'text', icon: 'warning', showCancelButton: true, confirmButtonText: 'Đồng ý', cancelButtonText: 'Hủy',
        inputValidator: (value) => { if (!value) { return 'Bạn phải nhập lý do xóa!' } }
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkThietBi', { id: id, lyDo: r.value }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Đã chuyển", res.msg, "success"); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function restoreThietBi(id) {
        Swal.fire({
        title: 'Khôi phục thiết bị?', text: "Thiết bị sẽ được khôi phục về trạng thái hoạt động cũ.",
        icon: 'question', showCancelButton: true, confirmButtonText: 'Khôi phục', cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/RestoreKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Thành công", res.msg, "success"); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function hardDeleteThietBi(id) {
        Swal.fire({
        title: 'Xóa vĩnh viễn?', text: "Hành động xóa vĩnh viễn khỏi cơ sở dữ liệu sẽ không thể khôi phục lại!",
        icon: 'error', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Xóa vĩnh vễn', cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/HardDeleteKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Đã xóa!", res.msg, "success"); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function phongToAnh(imgUrl, title) {
        Swal.fire({
        title: title ? `Vị trí: ${title}` : 'Ảnh Thiết Bị', imageUrl: imgUrl, imageAlt: 'Ảnh thiết bị chi tiết',
        showCloseButton: true, showConfirmButton: false, width: 'auto', padding: '1em', backdrop: `rgba(0,0,0,0.85)`,
        customClass: { image: 'img-fluid rounded shadow-lg', popup: 'bg-white rounded-4' }
        });
        }
    </script>
}