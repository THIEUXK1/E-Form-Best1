        }
        },
        error: function () {
        $btn.prop('disabled', false).html('<i class="fas fa-upload me-1"></i> Xác nhận & Đẩy dữ liệu');
        $('#ketQuaImportSwitchExcel').html('<div class="alert alert-danger mb-0">Lỗi kết nối đến Server khi tải file lên.</div>').show();
