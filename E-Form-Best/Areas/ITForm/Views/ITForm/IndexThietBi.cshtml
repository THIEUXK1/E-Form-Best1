@{
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý Thiết bị";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="content-header py-3">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6 col-12 mb-2 mb-md-0">
                <h4 class="m-0 fw-bold" style="color: #1e293b; letter-spacing: -0.5px;">
                    <i class="fas fa-laptop me-2" style="color: #4f46e5;"></i> Quản lý Thiết bị
                </h4>
            </div>
            <div class="col-md-6 col-12 text-md-end text-start">
                <button class="btn btn-sm rounded-pill px-3 shadow-sm text-white w-100 w-md-auto" style="background-color: #4f46e5; border-color: #4f46e5; padding-top: 8px; padding-bottom: 8px;" onclick="openModalCurrentTab()" id="btnMasterThemMoi">
                    <i class="fas fa-plus me-1"></i> Thêm mới <span id="txtBtnThemMoi">Thiết bị</span>
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card border-0 shadow-sm bg-white" style="border-radius: 15px;">
            <div class="card-header bg-white pt-3 pb-0 border-0" style="border-radius: 15px 15px 0 0;">
                <ul class="nav nav-tabs border-bottom flex-nowrap overflow-x-auto" id="myTab" role="tablist" style="border-color: #e2e8f0; white-space: nowrap; -webkit-overflow-scrolling: touch;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="thongke-tab" data-bs-toggle="tab" data-bs-target="#thongke" type="button" role="tab" onclick="changeTab('Tổng quan', this)">
                            <i class="fas fa-chart-pie me-1"></i> Tổng quan
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent; border-bottom: 3px solid #4f46e5; color: #4f46e5;" id="thietbi-tab" data-bs-toggle="tab" data-bs-target="#thietbi" type="button" role="tab" onclick="changeTab('Thiết bị', this)">
                            <i class="fas fa-laptop me-1"></i> Thiết bị
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="daxoa-tab" data-bs-toggle="tab" data-bs-target="#daxoa" type="button" role="tab" onclick="changeTab('Đã xóa', this)">
                            <i class="fas fa-trash-alt me-1"></i> Thùng rác
                        </button>
                    </li>
                </ul>
            </div>

            <div class="card-body p-2 p-md-3">
                <div class="row mb-3 pb-3 border-bottom align-items-end" id="filterBar" style="background: #f8fafc; padding: 15px; border-radius: 10px; margin: 0 5px;">
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-2">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-building"></i> Công ty</label>
                        <select id="filterCongTy" class="form-select select2-filter rounded-3 border-0 shadow-sm">
                            <option value="">-- Tất cả --</option>
                        </select>
                    </div>
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-2">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-sitemap"></i> Bộ phận</label>
                        <select id="filterBoPhan" class="form-select select2-filter rounded-3 border-0 shadow-sm">
                            <option value="">-- Tất cả --</option>
                        </select>
                    </div>
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-2">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-tags"></i> Loại thiết bị</label>
                        <select id="filterLoai" class="form-select rounded-3 border-0 shadow-sm" style="height: 38px;">
                            <option value="">-- Tất cả --</option>
                        </select>
                    </div>
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-2" id="boxFilterTrangThai">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-info-circle"></i> Trạng thái</label>
                        <select id="filterTrangThai" class="form-select rounded-3 border-0 shadow-sm" style="height: 38px;">
                            <option value="">-- Tất cả --</option>
                        </select>
                    </div>

                    <div class="col-xl-2 col-lg-4 col-md-4 col-sm-6 mb-2">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-search text-primary"></i> Tìm kiếm nhanh</label>
                        <input type="text" id="filterText" class="form-control rounded-3 border-0 shadow-sm" placeholder="S/N, Hostname, Account, Note..." style="height: 38px;">
                    </div>

                    <div class="col-xl-1 col-lg-2 col-md-3 col-sm-6 mb-2">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-sort-alpha-down"></i> Sắp xếp</label>
                        <select id="filterSort" class="form-select rounded-3 border-0 shadow-sm" style="height: 38px;">
                            <option value="">Mặc định</option>
                            <option value="name_asc">Tên TB (A-Z)</option>
                            <option value="name_desc">Tên TB (Z-A)</option>
                            <option value="host_asc">Hostname (A-Z)</option>
                            <option value="host_desc">Hostname (Z-A)</option>
                        </select>
                    </div>

                    <div class="col-xl-1 col-lg-2 col-md-3 col-sm-6 mb-2">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-list-ol"></i> Hiển thị</label>
                        <select id="filterLimit" class="form-select rounded-3 border-0 shadow-sm" style="height: 38px;">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="all">Tất cả</option>
                        </select>
                    </div>
                    <div class="col-xl-1 col-lg-2 col-md-12 mb-2 d-flex justify-content-end">
                        <button class="btn btn-outline-secondary rounded-pill px-3 shadow-sm w-100" onclick="clearFilters()" style="height: 38px;"><i class="fas fa-sync-alt"></i> Bỏ lọc</button>
                    </div>
                </div>

                <div class="tab-content" id="myTabContent">

                    <div class="tab-pane fade" id="thongke" role="tabpanel">
                        <div class="row g-3 mb-4" id="boxThongKeCards"></div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                                    <div class="card-header bg-white border-0 fw-bold pt-3 pb-0"><i class="fas fa-chart-bar text-primary me-1"></i> Số lượng theo Loại thiết bị</div>
                                    <div class="card-body">
                                        <canvas id="chartLoaiThietBi" style="max-height: 300px;"></canvas>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                                    <div class="card-header bg-white border-0 fw-bold pt-3 pb-0"><i class="fas fa-chart-pie text-success me-1"></i> Tỷ lệ theo Trạng thái</div>
                                    <div class="card-body d-flex justify-content-center">
                                        <canvas id="chartTrangThai" style="max-height: 300px;"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade show active" id="thietbi" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="60">ID</th>
                                        <th width="100" class="text-center">Hình ảnh</th>
                                        <th>Thông tin máy tính</th>
                                        <th>Người dùng, Vị trí & Mã TB</th>
                                        <th>Trạng thái & Kiểm tra</th>
                                        <th width="140" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyThietBi"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="daxoa" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Thông tin máy</th>
                                        <th>Vị trí cũ</th>
                                        <th>Ngày Xóa</th>
                                        <th>Lý do xóa</th>
                                        <th width="180" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyDaXoa"></tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="modalThietBi" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-dark text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalThietBi">Thông tin Thiết bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3 p-md-4">
                <input type="hidden" id="tb_Id" value="0" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Loại thiết bị <span class="text-danger">*</span></label>
                        <select id="tb_LoaiThietBi" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chọn loại --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Tên thiết bị (Mã/Serial)</label>
                        <input type="text" id="tb_TenThietBi" class="form-control rounded-3" placeholder="VD: LAPTOP DELL XPS..." style="border: 1px solid #e2e8f0; height: 45px; text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold" style="color: #8b5cf6;">Trạng thái <span class="text-danger">*</span></label>
                        <select id="tb_IdTrangThai" class="form-select rounded-3" style="border: 1px solid #8b5cf6; height: 45px;">
                            <option value="">-- Chọn trạng thái --</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên máy tính (Hostname)</label>
                        <input type="text" id="tb_TenMayTinh" class="form-control rounded-3" placeholder="VD: DESKTOP-123" style="border: 1px solid #e2e8f0; height: 45px; text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên đăng nhập (Account)</label>
                        <input type="text" id="tb_TenDangNhap" class="form-control rounded-3" placeholder="VD: ADMIN_LOCAL" style="border: 1px solid #e2e8f0; height: 45px; text-transform: uppercase;" oninput="this.value = this.value.toUpperCase()" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Ghi chú (Cấu hình, thông tin...)</label>
                        <input type="text" id="tb_GhiChu" class="form-control rounded-3" placeholder="Thông tự thêm..." style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-12 mt-4 mb-2"><div style="border-top: 1px dashed #cbd5e1;"></div></div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold" style="color: #4f46e5;">Gán người sử dụng</label>
                        <select id="tb_IdNguoiDung" class="form-control select2-modal w-100">
                            <option value="">-- Chưa cấp phát --</option>
                            @if (ViewBag.Users != null)
                            {
                                foreach (var item in ViewBag.Users)
                                {
                                    <option value="@item.IdNguoiDung">@item.HoTen (@item.Tk)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gán Công ty</label>
                        <select id="tb_IdCongTy" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chưa rõ --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gán Bộ phận</label>
                        <select id="tb_IdBoPhan" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chưa rõ --</option>
                        </select>
                    </div>

                    <div class="col-12 mt-4 mb-2"><div style="border-top: 1px dashed #cbd5e1;"></div></div>

                    <div class="col-md-12 mt-2">
                        <label class="form-label fw-bold"><i class="fas fa-camera text-secondary me-1"></i> Ảnh thiết bị đính kèm</label>
                        <div class="d-flex gap-2 mb-2">
                            <button type="button" class="btn btn-outline-primary flex-fill" onclick="$('#tb_Anh').click()">
                                <i class="fas fa-upload"></i> Tải ảnh lên
                            </button>
                            <button type="button" class="btn btn-outline-success flex-fill" onclick="openCamera()">
                                <i class="fas fa-camera"></i> Chụp trực tiếp
                            </button>
                        </div>

                        <input type="file" id="tb_Anh" accept="image/*" class="d-none" onchange="previewImage(this)" />

                        <div id="boxCamera" style="display: none;" class="mt-2 text-center border rounded p-2 bg-light shadow-sm">
                            <video id="videoCamera" autoplay playsinline style="width: 100%; max-height: 300px; border-radius: 10px; background: #000; object-fit: cover;"></video>
                            <div class="mt-3 mb-2">
                                <button type="button" class="btn btn-danger rounded-pill px-4" onclick="takeSnapshot()">
                                    <i class="fas fa-dot-circle me-1"></i> Chụp ngay
                                </button>
                                <button type="button" class="btn btn-secondary rounded-pill px-3 ms-2" onclick="closeCamera()">
                                    <i class="fas fa-times me-1"></i> Đóng Camera
                                </button>
                            </div>
                            <canvas id="canvasCamera" style="display: none;"></canvas>
                        </div>

                        <div class="mt-3 text-center" id="boxPreviewImg" style="display: none;">
                            <div class="position-relative d-inline-block">
                                <img id="imgThietBi" src="" alt="Ảnh thiết bị" class="shadow-sm" style="max-height: 250px; max-width: 100%; border-radius: 10px; border: 2px dashed #cbd5e1; padding: 5px;" />
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="clearImage()" style="width: 28px; height: 28px; padding: 0; line-height: 1;">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-dark px-4 rounded-pill w-100 w-md-auto" onclick="saveThietBi()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        var currentTab = 'Thiết bị';

        let listCongTyCache = [];
        let listBoPhanCache = [];
        let listTrangThaiCache = [];
        let listLoaiThietBiCache = [];
        let allThietBiCache = [];

        let chartLoai = null;
        let chartTT = null;

        let currentStream = null;
        let capturedPhotoBlob = null;

        $(document).ready(function () {
        if($.fn.select2) {
        $('.select2-filter').select2({ width: '100%', minimumResultsForSearch: 0 });

        $('.select2-modal').select2({
        dropdownParent: $('#modalThietBi .modal-content'),
        placeholder: "-- Chọn người dùng --",
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0
        });

        $(document).on('select2:open', () => {
        let isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (!isMobile) {
        let searchField = document.querySelector('.select2-search__field');
        if (searchField) { setTimeout(() => { searchField.focus(); }, 10); }
        }
        });

        $('#modalThietBi').on('scroll', function() {
        let isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (isMobile) {
        $('.select2-modal').select2("close");
        }
        });

        setTimeout(() => {
        $('.select2-selection--single').css({
        'height': '38px', 'display': 'flex', 'align-items': 'center',
        'border': '1px solid #e2e8f0', 'border-radius': '0.5rem'
        });
        $('.select2-modal').next('.select2-container').find('.select2-selection--single').css('height', '45px');
        }, 200);
        }

        let savedLimit = localStorage.getItem('kk_filterLimit') || '50';
        $('#filterLimit').val(savedLimit);

        let savedLoai = localStorage.getItem('kk_filterLoai') || '';
        $('#filterLoai').val(savedLoai);

        let savedText = localStorage.getItem('kk_filterText') || '';
        $('#filterText').val(savedText);

        let savedSort = localStorage.getItem('kk_filterSort') || '';
        $('#filterSort').val(savedSort);

        $('#filterCongTy').on('change', function() { renderFilterBoPhan(); applyFilters(); });
        $('#filterBoPhan, #filterLimit, #filterLoai, #filterTrangThai, #filterSort').on('change', function() { applyFilters(); });

        $('#filterText').on('keyup input', function() { applyFilters(); });

        $('.modal').on('hidden.bs.modal', function () {
        $(this).find('input[type="text"], textarea').val('');
        $(this).find('input[type="hidden"]').val('0');
        $(this).find('select').val('').trigger('change');
        closeCamera();
        clearImage();
        });

        $('#tb_IdCongTy').on('change', function() {
        let idCT = $(this).val();
        let html = '<option value="">-- Chọn bộ phận --</option>';
        if(idCT) {
        let filtered = listBoPhanCache.filter(b => b.idcongTy == idCT);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        } else {
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        }
        $('#tb_IdBoPhan').html(html);
        });

        loadMasterData();
        });

        // ==========================================
        // UI TABS & FILTERS
        // ==========================================
        function changeTab(tabName, element) {
        currentTab = tabName;

        if(tabName === 'Đã xóa' || tabName === 'Tổng quan') {
        $('#btnMasterThemMoi').parent().hide();
        } else {
        $('#btnMasterThemMoi').parent().show();
        $('#txtBtnThemMoi').text(tabName);
        }

        if(tabName === 'Tổng quan') {
        $('#filterBar').hide();
        } else {
        $('#filterBar').show();
        if(tabName === 'Đã xóa') {
        $('#boxFilterTrangThai').hide();
        } else {
        $('#boxFilterTrangThai').show();
        }
        }

        $('.nav-link').removeClass('active').addClass('text-muted').css({'border-bottom': 'none', 'color': '#64748b'});
        $(element).addClass('active').removeClass('text-muted').css({'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5'});
        }

        function openModalCurrentTab() {
        if (currentTab === 'Thiết bị') {
        $('#titleModalThietBi').text("Thêm Thiết bị mới");
        fillSelectCongTy('#tb_IdCongTy');
        fillSelectBoPhan('#tb_IdBoPhan');
        fillSelectTrangThai('#tb_IdTrangThai');
        $('#modalThietBi').modal('show');
        }
        }

        function clearFilters() {
        localStorage.removeItem('kk_filterCT');
        localStorage.removeItem('kk_filterBP');
        localStorage.removeItem('kk_filterLoai');
        localStorage.removeItem('kk_filterTT');
        localStorage.setItem('kk_filterLimit', '50');
        localStorage.removeItem('kk_filterText');
        localStorage.removeItem('kk_filterSort');

        $('#filterCongTy').val('').trigger('change.select2');
        renderFilterBoPhan();
        $('#filterBoPhan').val('').trigger('change.select2');
        $('#filterLoai, #filterTrangThai, #filterSort').val('');
        $('#filterLimit').val('50');
        $('#filterText').val('');

        applyFilters();
        }

        function applyFilters() {
        localStorage.setItem('kk_filterCT', $('#filterCongTy').val() || '');
        localStorage.setItem('kk_filterBP', $('#filterBoPhan').val() || '');
        localStorage.setItem('kk_filterLoai', $('#filterLoai').val() || '');
        localStorage.setItem('kk_filterTT', $('#filterTrangThai').val() || '');
        localStorage.setItem('kk_filterLimit', $('#filterLimit').val());
        localStorage.setItem('kk_filterText', $('#filterText').val().trim());
        localStorage.setItem('kk_filterSort', $('#filterSort').val() || '');

        renderUIThietBi();
        renderUIDaXoa();
        }

        // ==========================================
        // FETCH DATA - SỬA LỖI ĐỒNG BỘ PROMISE (Bỏ $.when cũ gây sập luồng)
        // ==========================================
        function loadMasterData() {
        $.get('/QLKiemKe/GetKkTrangThais', function(res) { if(res.success) { listTrangThaiCache = res.data; renderFilterTrangThai(); } });
        $.get('/QLKiemKe/GetKkLoaiThietBis', function(res) { if(res.success) { listLoaiThietBiCache = res.data; renderFilterLoaiThietBi(); } });
        $.get('/QLKiemKe/GetKkCongTys', function(res) { if(res.success) { listCongTyCache = res.data; renderFilterCongTy(); } });
        $.get('/QLKiemKe/GetKkBoPhans', function(res) { if(res.success) { listBoPhanCache = res.data; renderFilterBoPhan(); } });

        loadThietBi();
        }

        function loadThietBi() {
        $.get('/QLKiemKe/GetKkThietBis', function (res) {
        if (res && res.success) {
        allThietBiCache = res.data || [];
        renderThongKe();
        renderUIThietBi();
        renderUIDaXoa();
