        function capNhatGoiYTenViTri() {
        if (!allThietBiCache || allThietBiCache.length === 0) return;
        let uniqueNames = [];
        allThietBiCache.forEach(item => {
        if (item.tenViTri && item.tenViTri.trim() !== "") {
        let nameUpper = item.tenViTri.trim().toUpperCase();
        if (!uniqueNames.includes(nameUpper)) { uniqueNames.push(nameUpper); }
        }
        });
        uniqueNames.sort();
        let htmlOptions = '';
        uniqueNames.forEach(name => { htmlOptions += `<option value="${name}"></option>`; });
        $('#suggestTenViTri').html(htmlOptions);
        }

        function renderFilterTrangThai() {
        let savedTT = [];
        try { savedTT = JSON.parse(localStorage.getItem('kk_filterTT')) || []; } catch(e){}

        let $itemsTT = $('#menuTrangThai .dropdown-combo-items').empty();
        listTrangThaiCache.forEach(c => {
        let isChecked = savedTT.includes(c.idTrangThai) || savedTT.includes(String(c.idTrangThai)) ? 'checked' : '';
        $itemsTT.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-status" data-id="${c.idTrangThai}" value="${c.tenTrangThai}" ${isChecked}>
        <span>${c.tenTrangThai}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuTrangThai'));
        }

        function renderFilterLoaiThietBi() {
        let savedLoai = [];
        try { savedLoai = JSON.parse(localStorage.getItem('kk_filterLoai')) || []; } catch(e){}

        let htmlForm = '<option value="">-- Chọn loại --</option>';
        let $itemsLoai = $('#menuLoai .dropdown-combo-items').empty();

        listLoaiThietBiCache.forEach(c => {
        let isChecked = savedLoai.includes(c.tenLoai) ? 'checked' : '';
        $itemsLoai.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-loai" value="${c.tenLoai}" ${isChecked}>
        <span>${c.tenLoai}</span>
        </label>
        `);
        htmlForm += `<option value="${c.tenLoai}">${c.tenLoai}</option>';`;
        });
        updateDropdownButtonLabel($('#menuLoai'));
        $('#tb_LoaiThietBi').html(htmlForm);
        }

        function renderFilterCongTy() {
        let savedCT = [];
        try { savedCT = JSON.parse(localStorage.getItem('kk_filterCT')) || []; } catch(e){}

        let $itemsCT = $('#menuCongTy .dropdown-combo-items').empty();

        // Luôn hiện sẵn tùy chọn "Chưa xác định công ty" để lọc ra các thiết bị chưa được gán Công ty,
        // tránh bị bỏ sót khi kiểm kê (thiết bị này sẽ mất hút nếu chỉ lọc theo tên công ty thực tế).
        let isCheckedChuaXacDinhCT = savedCT.includes('__CHUA_XAC_DINH__') ? 'checked' : '';
        $itemsCT.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-company" value="__CHUA_XAC_DINH__" ${isCheckedChuaXacDinhCT}>
        <span class="text-danger fw-bold">⚠ Chưa xác định công ty</span>
        </label>
        <div class="dropdown-divider"></div>
        `);

        listCongTyCache.forEach(c => {
        let isChecked = savedCT.includes(String(c.idcongTy)) || savedCT.includes(c.tenCongTy) ? 'checked' : '';
        $itemsCT.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-company" value="${c.tenCongTy}" data-id="${c.idcongTy}" ${isChecked}>
        <span>${c.tenCongTy}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuCongTy'));
        }

        function renderFilterBoPhan() {
        let savedBP = [];
        try { savedBP = JSON.parse(localStorage.getItem('kk_filterBP')) || []; } catch(e){}

        let selectedCompanyIds = $('.chk-company:checked').map(function() { return $(this).data('id'); }).get();

        let filteredBPs = listBoPhanCache;
        if (selectedCompanyIds.length > 0) {
        filteredBPs = listBoPhanCache.filter(b => selectedCompanyIds.includes(b.idcongTy) || selectedCompanyIds.includes(String(b.idcongTy)));
        }

        let $itemsBP = $('#menuBoPhan .dropdown-combo-items').empty();

        // Luôn hiện sẵn tùy chọn "Chưa xác định bộ phận" để lọc ra các thiết bị chưa được gán Bộ phận
        let isCheckedChuaXacDinhBP = savedBP.includes('__CHUA_XAC_DINH__') ? 'checked' : '';
        $itemsBP.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-dept" value="__CHUA_XAC_DINH__" ${isCheckedChuaXacDinhBP}>
        <span class="text-danger fw-bold">⚠ Chưa xác định bộ phận</span>
        </label>
        <div class="dropdown-divider"></div>
        `);

        filteredBPs.forEach(b => {
        let extendName = (selectedCompanyIds.length === 0 && b.tenCongTy) ? ` (${b.tenCongTy})` : '';
        let isChecked = savedBP.includes(b.tenBoPhan) ? 'checked' : '';
        $itemsBP.append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-dept" value="${b.tenBoPhan}" ${isChecked}>
        <span>${b.tenBoPhan}${extendName}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuBoPhan'));
        }

        function fillSelectCongTy(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn công ty --</option>';
        listCongTyCache.forEach(c => { html += `<option value="${c.idcongTy}">${c.tenCongTy}</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        function fillSelectBoPhan(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        function fillSelectTrangThai(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn trạng thái --</option>';
        listTrangThaiCache.forEach(c => { html += `<option value="${c.idTrangThai}">${c.tenTrangThai}</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        // Màu trạng thái dùng chung cho badge trong bảng và biểu đồ, để 1 trạng thái luôn có đúng 1 màu trên toàn trang
        function getStatusColor(tenTrangThai) {
        let t = (tenTrangThai || '').toLowerCase();
        if (t.includes('hoạt động')) return '#1baf7a';
        if (t.includes('hỏng')) return '#e34948';
        if (t.includes('bảo trì')) return '#eda100';
        return '#64748b';
        }

        function renderThongKe() {
        let activeDevices = allThietBiCache.filter(x => !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));

        let total = activeDevices.length;
        let dangHoatDong = activeDevices.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('hoạt động')).length;
        let hongHoc = activeDevices.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('hỏng')).length;
        let chuaCapPhat = activeDevices.filter(x => !x.idNguoiDung).length;

        $('#boxThongKeCards').html(`
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-primary text-white border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-boxes fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${total}</h3><div class="small">Tổng Thiết Bị (Thực tế)</div></div>
        </div>
        </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-success text-white border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-check-circle fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${dangHoatDong}</h3><div class="small">Đang Hoạt Động</div></div>
        </div>
        </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-danger text-white border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-tools fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${hongHoc}</h3><div class="small">Hỏng / Cần sửa</div></div>
        </div>
        </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-warning text-dark border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-user-slash fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${chuaCapPhat}</h3><div class="small">Chưa Cấp Phát N.Dùng</div></div>
        </div>
        </div>
        </div>
        `);

        let countLoai = {};
        activeDevices.forEach(d => { let loai = d.loaiThietBi || 'Chưa rõ'; countLoai[loai] = (countLoai[loai] || 0) + 1; });

        if(chartLoai) chartLoai.destroy();
        let chartElementLoai = document.getElementById('chartLoaiThietBi');
        if(chartElementLoai) {
        chartLoai = new Chart(chartElementLoai.getContext('2d'), {
        type: 'bar',
        data: {
        labels: Object.keys(countLoai),
        datasets: [{ label: 'Số lượng thiết bị', data: Object.values(countLoai), backgroundColor: '#2a78d6', borderRadius: 5 }]
        },
        options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, grid: { color: '#e1e0d9' }, ticks: { color: '#898781' } }, x: { grid: { display: false }, ticks: { color: '#52514e' } } }
        }
        });
        }

        let countTT = {};
        activeDevices.forEach(d => { let tt = d.tenTrangThai || 'Chưa rõ'; countTT[tt] = (countTT[tt] || 0) + 1; });

        if(chartTT) chartTT.destroy();
        let chartElementTT = document.getElementById('chartTrangThai');
        if(chartElementTT) {
        chartTT = new Chart(chartElementTT.getContext('2d'), {
        type: 'doughnut',
        data: {
        labels: Object.keys(countTT),
        datasets: [{ data: Object.values(countTT), backgroundColor: Object.keys(countTT).map(getStatusColor), borderColor: '#fff', borderWidth: 2 }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { labels: { color: '#475569', font: { weight: '600' } } } } }
        });
        }
        }

        function renderUIThietBi() {
        let selectedCompanies = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoais = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();
        let selectedTrangThais = $('.chk-status:checked').map(function() { return $(this).val(); }).get();

        // Lấy thêm mảng giá trị của bộ lọc Windows và Office
        let selectedWins = $('.chk-win:checked').map(function() { return $(this).val(); }).get();
        let selectedOffices = $('.chk-office:checked').map(function() { return $(this).val(); }).get();

