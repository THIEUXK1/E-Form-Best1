@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        var currentTab = 'Thiết bị';

        let listCongTyCache = [];
        let listBoPhanCache = [];
        let listTrangThaiCache = [];
        let listLoaiThietBiCache = [];
        let allThietBiCache = [];

        let chartLoai = null;
        let chartTT = null;

        let currentStream = null;
        let capturedPhotoBlob = null;
        let quickCamStream = null;

        let evidencePhotoBlob = null;
        let evidenceCamStream = null;

        $(document).ready(function () {
        if($.fn.select2) {
        $('.select2-modal').select2({
        dropdownParent: $('#modalThietBi .modal-content'),
        placeholder: "-- Chọn người dùng --",
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0
        });

        $(document).on('select2:open', () => {
        let isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (!isMobile) {
        let searchField = document.querySelector('.select2-search__field');
        if (searchField) { setTimeout(() => { searchField.focus(); }, 10); }
        }
        });

        $('#modalThietBi').on('scroll', function() {
        let isMobile = window.matchMedia("(max-width: 767px)").matches;
        if (isMobile) { $('.select2-modal').select2("close"); }
        });

        setTimeout(() => {
        $('.select2-modal').next('.select2-container').find('.select2-selection--single').css({
        'height': '45px', 'display': 'flex', 'align-items': 'center',
        'border': '1px solid #e2e8f0', 'border-radius': '0.5rem'
        });
        }, 200);
        }

        let savedLimit = localStorage.getItem('kk_filterLimit') || '50';
        $('#filterLimit').val(savedLimit);
        let savedText = localStorage.getItem('kk_filterText') || '';
        $('#filterText').val(savedText);
        let savedSort = localStorage.getItem('kk_filterSort') || '';
        $('#filterSort').val(savedSort);
        let savedTuNgay = localStorage.getItem('kk_filterTuNgay') || '';
        $('#filterTuNgay').val(savedTuNgay);
        let savedDenNgay = localStorage.getItem('kk_filterDenNgay') || '';
        $('#filterDenNgay').val(savedDenNgay);
        let savedTìnhTrangCheck = localStorage.getItem('kk_filterTìnhTrangCheck') || '';
        $('#filterTìnhTrangCheck').val(savedTìnhTrangCheck);

        $('#filterLimit, #filterSort, #filterTuNgay, #filterDenNgay, #filterTìnhTrangCheck').on('change', function() { applyFilters(); });
        $('#filterText').on('keyup input', function() { applyFilters(); });

        $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
        let $menu = $(this).closest('.dropdown-combo-menu');
        updateDropdownButtonLabel($menu);

        if ($(this).hasClass('chk-company')) {
        renderFilterBoPhan();
        }
        applyFilters();
        });

        $('#tb_LoaiThietBi, #tb_IdTrangThai, #tb_IdCongTy, #tb_IdBoPhan, #tb_IdNguoiDung, #tb_WinLicense, #tb_OfficeLicense').on('change', function() {
        if (parseInt($('#tb_Id').val()) === 0) { localStorage.setItem('add_form_' + this.id, $(this).val() || ''); }
        });
        $('#tb_TenViTri, #tb_QuyCach, #tb_TenMayTinh, #tb_TenDangNhap, #tb_GhiChu, #tb_Seribacode, #tb_HanBaoHanh').on('keyup input change', function() {
        if (parseInt($('#tb_Id').val()) === 0) { localStorage.setItem('add_form_' + this.id, $(this).val().trim()); }
        });

        $('#modalThietBi').on('keydown', 'input, select', function (e) {
        if (e.key === 'Enter' || e.keyCode === 13) {
        if ($(e.target).hasClass('select2-search__field')) return;
        e.preventDefault();
        saveThietBi(false);
        }
        });

        $('.select2-modal').on('select2:select', function (e) {
        setTimeout(() => { saveThietBi(false); }, 50);
        });

        $('.modal').on('hidden.bs.modal', function () {
        if (this.id === 'modalQuickCamMobile' || this.id === 'modalXacNhanCheckEvidence' || this.id === 'modalLichSuCheckThietBi') return;
        $(this).find('input[type="text"], input[type="date"], textarea').val('');
        $(this).find('input[type="hidden"]').val('0');
        $(this).find('select').val('').trigger('change');
        closeCamera();
        closeCamera();
        clearImage();
        khoiPhucDuLieuFormAdd();
        $('#btnSaveAsNew').hide();
        });

        $('#tb_IdCongTy').on('change', function() {
        let idCT = $(this).val();
        let html = '<option value="">-- Chọn bộ phận --</option>';
        if(idCT) {
        let filtered = listBoPhanCache.filter(b => b.idcongTy == idCT);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        } else {
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        }
        $('#tb_IdBoPhan').html(html);

        if (parseInt($('#tb_Id').val()) === 0) {
        let savedBP = localStorage.getItem('add_form_tb_IdBoPhan') || '';
        if ($(html).filter(`[value="${savedBP}"]`).length > 0) { $('#tb_IdBoPhan').val(savedBP); }
        }
        });

        let dropZone = document.getElementById('dropZoneThietBi');
        if (dropZone) {
        dropZone.addEventListener('click', () => $('#tb_Anh').click());

        dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        let file = e.dataTransfer.files[0];
        if (file.type.startsWith('image/')) {
        capturedPhotoBlob = null;
        $('#tb_Anh')[0].files = e.dataTransfer.files;
        let reader = new FileReader();
        reader.onload = (evt) => {
        $('#imgThietBi').attr('src', evt.target.result);
        $('#boxPreviewImg').show();
        };
        reader.readAsDataURL(file);
        }
        }
        });
        }

        document.getElementById('modalThietBi').addEventListener('paste', (e) => {
        if (e.clipboardData && e.clipboardData.items) {
        for (let i = 0; i < e.clipboardData.items.length; i++) {
        let item = e.clipboardData.items[i];
        if (item.type.indexOf('image') !== -1) {
        let blob = item.getAsFile();
        capturedPhotoBlob = blob;
        $('#tb_Anh').val('');

        let reader = new FileReader();
        reader.onload = (evt) => {
        $('#imgThietBi').attr('src', evt.target.result);
        $('#boxPreviewImg').show();
        };
        reader.readAsDataURL(blob);
        break;
        }
        }
        }
        });

        loadMasterData();
        });

        function updateDropdownButtonLabel($menu) {
        let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
        let $btn = $menu.siblings('.dropdown-combo-btn');

        if (totalChecked === 0) {
        $btn.text('-- Tất cả --');
        } else if (totalChecked === 1) {
        $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
        } else {
        $btn.text(`Đã chọn (${totalChecked})`);
        }
        }

        function khoiPhucDuLieuFormAdd() {
        if (parseInt($('#tb_Id').val()) !== 0) return;
        $('#tb_LoaiThietBi').val(localStorage.getItem('add_form_tb_LoaiThietBi') || '');
        $('#tb_IdTrangThai').val(localStorage.getItem('add_form_tb_IdTrangThai') || '');
        $('#tb_TenViTri').val(localStorage.getItem('add_form_tb_TenViTri') || '');
        $('#tb_QuyCach').val(localStorage.getItem('add_form_tb_QuyCach') || '');
        $('#tb_TenMayTinh').val(localStorage.getItem('add_form_tb_TenMayTinh') || '');
        $('#tb_TenDangNhap').val(localStorage.getItem('add_form_tb_TenDangNhap') || '');
        $('#tb_GhiChu').val(localStorage.getItem('add_form_tb_GhiChu') || '');
        $('#tb_Seribacode').val(localStorage.getItem('add_form_tb_Seribacode') || '');
        $('#tb_HanBaoHanh').val(localStorage.getItem('add_form_tb_HanBaoHanh') || '');
        $('#tb_WinLicense').val(localStorage.getItem('add_form_tb_WinLicense') || '');
        $('#tb_OfficeLicense').val(localStorage.getItem('add_form_tb_OfficeLicense') || '');

        let savedCT = localStorage.getItem('add_form_tb_IdCongTy') || '';
        $('#tb_IdCongTy').val(savedCT).trigger('change');

        let savedBP = localStorage.getItem('add_form_tb_IdBoPhan') || '';
        if(savedBP) { setTimeout(() => { $('#tb_IdBoPhan').val(savedBP); }, 50); }

        let savedND = localStorage.getItem('add_form_tb_IdNguoiDung') || '';
        $('#tb_IdNguoiDung').val(savedND).trigger('change.select2');
        }

        function xoaCacheFormAdd() {
        localStorage.removeItem('add_form_tb_LoaiThietBi');
        localStorage.removeItem('add_form_tb_IdTrangThai');
        localStorage.removeItem('add_form_tb_TenViTri');
        localStorage.removeItem('add_form_tb_QuyCach');
        localStorage.removeItem('add_form_tb_TenMayTinh');
        localStorage.removeItem('add_form_tb_TenDangNhap');
        localStorage.removeItem('add_form_tb_GhiChu');
        localStorage.removeItem('add_form_tb_IdCongTy');
        localStorage.removeItem('add_form_tb_IdBoPhan');
        localStorage.removeItem('add_form_tb_IdNguoiDung');
        localStorage.removeItem('add_form_tb_Seribacode');
        localStorage.removeItem('add_form_tb_HanBaoHanh');
        localStorage.removeItem('add_form_tb_WinLicense');
        localStorage.removeItem('add_form_tb_OfficeLicense');
        }

        function changeTab(tabName, element) {
        currentTab = tabName;
        if(tabName === 'Đã xóa' || tabName === 'Tổng quan') {
        $('#btnMasterThemMoi').parent().hide();
        } else {
        $('#btnMasterThemMoi').parent().show();
        $('#txtBtnThemMoi').text(tabName);
        }

        if(tabName === 'Tổng quan') {
        $('#filterBar').hide();
        } else {
        $('#filterBar').show();
        if(tabName === 'Đã xóa') { $('#boxFilterTrangThai').hide(); }
        else { $('#boxFilterTrangThai').show(); }
        }

        $('.nav-link').removeClass('active').addClass('text-muted').css({'border-bottom': 'none', 'color': '#64748b'});
        $(element).addClass('active').removeClass('text-muted').css({'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5'});
        }

        function openModalCurrentTab() {
        if (currentTab === 'Thiết bị') {
        $('#tb_Id').val('0');
        $('#btnSaveAsNew').hide();
        $('#titleModalThietBi').text("Thêm Thiết bị mới");
        fillSelectCongTy('#tb_IdCongTy');
        fillSelectBoPhan('#tb_IdBoPhan');
        fillSelectTrangThai('#tb_IdTrangThai');
        khoiPhucDuLieuFormAdd();
        $('#modalThietBi').modal('show');
        }
        }

        function clearFilters() {
        localStorage.removeItem('kk_filterCT');
        localStorage.removeItem('kk_filterBP');
        localStorage.removeItem('kk_filterLoai');
        localStorage.removeItem('kk_filterTT');
        localStorage.setItem('kk_filterLimit', '50');
        localStorage.removeItem('kk_filterText');
        localStorage.removeItem('kk_filterSort');
        localStorage.removeItem('kk_filterTuNgay');
        localStorage.removeItem('kk_filterDenNgay');
        localStorage.removeItem('kk_filterTìnhTrangCheck');

        $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
        $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });

        renderFilterBoPhan();
        $('#filterSort, #filterTuNgay, #filterDenNgay, #filterTìnhTrangCheck').val('');
        $('#filterLimit').val('50');
        $('#filterText').val('');

        applyFilters();
        }

        function applyFilters() {
        let selectedCT = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedBP = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoai = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();
        let selectedTT = $('.chk-status:checked').map(function() { return $(this).data('id'); }).get();

        localStorage.setItem('kk_filterCT', JSON.stringify(selectedCT));
        localStorage.setItem('kk_filterBP', JSON.stringify(selectedBP));
        localStorage.setItem('kk_filterLoai', JSON.stringify(selectedLoai));
        localStorage.setItem('kk_filterTT', JSON.stringify(selectedTT));

        localStorage.setItem('kk_filterLimit', $('#filterLimit').val());
        localStorage.setItem('kk_filterText', $('#filterText').val().trim());
        localStorage.setItem('kk_filterSort', $('#filterSort').val() || '');
        localStorage.setItem('kk_filterTuNgay', $('#filterTuNgay').val() || '');
        localStorage.setItem('kk_filterDenNgay', $('#filterDenNgay').val() || '');
        localStorage.setItem('kk_filterTìnhTrangCheck', $('#filterTìnhTrangCheck').val() || '');

        renderUIThietBi();
        renderUIDaXoa();
        }

        function loadMasterData() {
        $.get('/QLKiemKe/GetKkTrangThais', function(res) { if(res.success) { listTrangThaiCache = res.data; renderFilterTrangThai(); } });
        $.get('/QLKiemKe/GetKkLoaiThietBis', function(res) { if(res.success) { listLoaiThietBiCache = res.data; renderFilterLoaiThietBi(); } });
        $.get('/QLKiemKe/GetKkCongTys', function(res) { if(res.success) { listCongTyCache = res.data; renderFilterCongTy(); } });
        $.get('/QLKiemKe/GetKkBoPhans', function(res) { if(res.success) { listBoPhanCache = res.data; renderFilterBoPhan(); } });
        loadThietBi();
        }

        function loadThietBi() {
        $.get('/QLKiemKe/GetKkThietBis', function (res) {
        if (res && res.success) {
        allThietBiCache = res.data || [];
        renderThongKe();
        renderUIThietBi();
        renderUIDaXoa();
        capNhatGoiYTenViTri();
        } else {
        $('#tbodyThietBi').html(`<tr><td colspan="7" class="text-center text-danger py-4">Lỗi tải dữ liệu từ Server: ${res.msg}</td></tr>`);
        }
        }).fail(function() {
        $('#tbodyThietBi').html(`<tr><td colspan="7" class="text-center text-danger py-4">Không thể kết nối đến API /QLKiemKe/GetKkThietBis</td></tr>`);
        });
        }

        function capNhatGoiYTenViTri() {
        if (!allThietBiCache || allThietBiCache.length === 0) return;
        let uniqueNames = [];
        allThietBiCache.forEach(item => {
        if (item.tenViTri && item.tenViTri.trim() !== "") {
        let nameUpper = item.tenViTri.trim().toUpperCase();
        if (!uniqueNames.includes(nameUpper)) { uniqueNames.push(nameUpper); }
        }
        });
        uniqueNames.sort();
        let htmlOptions = '';
        uniqueNames.forEach(name => { htmlOptions += `<option value="${name}"></option>`; });
        $('#suggestTenViTri').html(htmlOptions);
        }

        function renderFilterTrangThai() {
        let savedTT = [];
        try { savedTT = JSON.parse(localStorage.getItem('kk_filterTT')) || []; } catch(e){}

        $('#menuTrangThai').empty();
        listTrangThaiCache.forEach(c => {
        let isChecked = savedTT.includes(c.idTrangThai) || savedTT.includes(String(c.idTrangThai)) ? 'checked' : '';
        $('#menuTrangThai').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-status" data-id="${c.idTrangThai}" value="${c.tenTrangThai}" ${isChecked}>
        <span>${c.tenTrangThai}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuTrangThai'));
        }

        function renderFilterLoaiThietBi() {
        let savedLoai = [];
        try { savedLoai = JSON.parse(localStorage.getItem('kk_filterLoai')) || []; } catch(e){}

        let htmlForm = '<option value="">-- Chọn loại --</option>';
        $('#menuLoai').empty();

        listLoaiThietBiCache.forEach(c => {
        let isChecked = savedLoai.includes(c.tenLoai) ? 'checked' : '';
        $('#menuLoai').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-loai" value="${c.tenLoai}" ${isChecked}>
        <span>${c.tenLoai}</span>
        </label>
        `);
        htmlForm += `<option value="${c.tenLoai}">${c.tenLoai}</option>`;
        });
        updateDropdownButtonLabel($('#menuLoai'));
        $('#tb_LoaiThietBi').html(htmlForm);
        }

        function renderFilterCongTy() {
        let savedCT = [];
        try { savedCT = JSON.parse(localStorage.getItem('kk_filterCT')) || []; } catch(e){}

        $('#menuCongTy').empty();
        listCongTyCache.forEach(c => {
        let isChecked = savedCT.includes(String(c.idcongTy)) || savedCT.includes(c.tenCongTy) ? 'checked' : '';
        $('#menuCongTy').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-company" value="${c.tenCongTy}" data-id="${c.idcongTy}" ${isChecked}>
        <span>${c.tenCongTy}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuCongTy'));
        }

        function renderFilterBoPhan() {
        let savedBP = [];
        try { savedBP = JSON.parse(localStorage.getItem('kk_filterBP')) || []; } catch(e){}

        let selectedCompanyIds = $('.chk-company:checked').map(function() { return $(this).data('id'); }).get();

        let filteredBPs = listBoPhanCache;
        if (selectedCompanyIds.length > 0) {
        filteredBPs = listBoPhanCache.filter(b => selectedCompanyIds.includes(b.idcongTy) || selectedCompanyIds.includes(String(b.idcongTy)));
        }

        $('#menuBoPhan').empty();
        filteredBPs.forEach(b => {
        let extendName = (selectedCompanyIds.length === 0 && b.tenCongTy) ? ` (${b.tenCongTy})` : '';
        let isChecked = savedBP.includes(b.tenBoPhan) ? 'checked' : '';
        $('#menuBoPhan').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-dept" value="${b.tenBoPhan}" ${isChecked}>
        <span>${b.tenBoPhan}${extendName}</span>
        </label>
        `);
        });
        updateDropdownButtonLabel($('#menuBoPhan'));
        }

        function fillSelectCongTy(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn công ty --</option>';
        listCongTyCache.forEach(c => { html += `<option value="${c.idcongTy}">${c.tenCongTy}</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        function fillSelectBoPhan(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        function fillSelectTrangThai(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn trạng thái --</option>';
        listTrangThaiCache.forEach(c => { html += `<option value="${c.idTrangThai}">${c.tenTrangThai}</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        function renderThongKe() {
        let activeDevices = allThietBiCache.filter(x => !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));

        let total = activeDevices.length;
        let dangHoatDong = activeDevices.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('hoạt động')).length;
        let hongHoc = activeDevices.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('hỏng')).length;
        let chuaCapPhat = activeDevices.filter(x => !x.idNguoiDung).length;

        $('#boxThongKeCards').html(`
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-primary text-white border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-boxes fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${total}</h3><div class="small">Tổng Thiết Bị (Thực tế)</div></div>
        </div>
        </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-success text-white border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-check-circle fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${dangHoatDong}</h3><div class="small">Đang Hoạt Động</div></div>
        </div>
        </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-danger text-white border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-tools fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${hongHoc}</h3><div class="small">Hỏng / Cần sửa</div></div>
        </div>
        </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
        <div class="card bg-warning text-dark border-0 shadow-sm h-100" style="border-radius:15px">
        <div class="card-body d-flex align-items-center">
        <div class="me-3"><i class="fas fa-user-slash fa-3x" style="opacity: 0.7;"></i></div>
        <div><h3 class="mb-0 fw-bold">${chuaCapPhat}</h3><div class="small">Chưa Cấp Phát N.Dùng</div></div>
        </div>
        </div>
        </div>
        `);

        let countLoai = {};
        activeDevices.forEach(d => { let loai = d.loaiThietBi || 'Chưa rõ'; countLoai[loai] = (countLoai[loai] || 0) + 1; });

        if(chartLoai) chartLoai.destroy();
        let chartElementLoai = document.getElementById('chartLoaiThietBi');
        if(chartElementLoai) {
        chartLoai = new Chart(chartElementLoai.getContext('2d'), {
        type: 'bar',
        data: {
        labels: Object.keys(countLoai),
        datasets: [{ label: 'Số lượng thiết bị', data: Object.values(countLoai), backgroundColor: '#3b82f6', borderRadius: 5 }]
        },
        options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });
        }

        let countTT = {};
        activeDevices.forEach(d => { let tt = d.tenTrangThai || 'Chưa rõ'; countTT[tt] = (countTT[tt] || 0) + 1; });

        if(chartTT) chartTT.destroy();
        let chartElementTT = document.getElementById('chartTrangThai');
        if(chartElementTT) {
        chartTT = new Chart(chartElementTT.getContext('2d'), {
        type: 'doughnut',
        data: {
        labels: Object.keys(countTT),
        datasets: [{ data: Object.values(countTT), backgroundColor: ['#10b981', '#ef4444', '#f59e0b', '#8b5cf6', '#06b6d4', '#64748b'] }]
        },
        options: { responsive: true, maintainAspectRatio: false }
        });
        }
        }

        function renderUIThietBi() {
        let selectedCompanies = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoais = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();
        let selectedTrangThais = $('.chk-status:checked').map(function() { return $(this).val(); }).get();

        let fLimit = $('#filterLimit').val();
        let fText = $('#filterText').val() ? $('#filterText').val().toLowerCase().trim() : '';
        let fSort = $('#filterSort').val();
        let fTuNgay = $('#filterTuNgay').val();
        let fDenNgay = $('#filterDenNgay').val();
        let fTìnhTrangCheck = $('#filterTìnhTrangCheck').val();

        let filtered = allThietBiCache.filter(x => !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));

        if (selectedCompanies.length > 0) filtered = filtered.filter(x => selectedCompanies.includes(x.tenCongTy));
        if (selectedDepts.length > 0) filtered = filtered.filter(x => selectedDepts.includes(x.tenBoPhan));
        if (selectedLoais.length > 0) filtered = filtered.filter(x => selectedLoais.includes(x.loaiThietBi));
        if (selectedTrangThais.length > 0) filtered = filtered.filter(x => selectedTrangThais.includes(x.tenTrangThai));

        if (fTuNgay || fDenNgay || fTìnhTrangCheck) {
        filtered = filtered.filter(x => {
        let hasChecked = !!x.thoiGianCheck;
        let itemCheckDateChuỗi = "";

        if (hasChecked) {
        let d = new Date(x.thoiGianCheck);
        itemCheckDateChuỗi = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        }

        if (fTìnhTrangCheck === 'chua_check') {
        if (!hasChecked) return true;
        if (fTuNgay && itemCheckDateChuỗi < fTuNgay) return true;
        if (fDenNgay && itemCheckDateChuỗi > fDenNgay) return true;
        return false;
        }

        if (fTìnhTrangCheck === 'da_check' || (!fTìnhTrangCheck && (fTuNgay || fDenNgay))) {
        if (!hasChecked) return false;
        if (fTuNgay && itemCheckDateChuỗi < fTuNgay) return false;
        if (fDenNgay && itemCheckDateChuỗi > fDenNgay) return false;
        return true;
        }
        return true;
        });
        }

        if (fText) {
        filtered = filtered.filter(x =>
        (x.tenMayTinh && x.tenMayTinh.toLowerCase().includes(fText)) ||
        (x.tenViTri && x.tenViTri.toLowerCase().includes(fText)) ||
        (x.tenDangNhap && x.tenDangNhap.toLowerCase().includes(fText)) ||
        (x.tenNguoiDung && x.tenNguoiDung.toLowerCase().includes(fText)) ||
        (x.tk && x.tk.toLowerCase().includes(fText)) ||
        (x.quyCach && x.quyCach.toLowerCase().includes(fText)) ||
        (x.seribacode && x.seribacode.toLowerCase().includes(fText)) ||
        (x.ghiChu && x.ghiChu.toLowerCase().includes(fText))
        );
        }

        if (fSort) {
        filtered.sort((a, b) => {
        let valA = '', valB = '';
        if (fSort.startsWith('name')) {
        valA = (a.tenViTri || '').toLowerCase().trim(); valB = (b.tenViTri || '').toLowerCase().trim();
        } else if (fSort.startsWith('host')) {
        valA = (a.tenMayTinh || '').toLowerCase().trim(); valB = (b.tenMayTinh || '').toLowerCase().trim();
        }
        return fSort.endsWith('asc') ? valA.localeCompare(valB, 'vi') : valB.localeCompare(valA, 'vi');
        });
        } else {
        filtered.sort((a, b) => {
        let nameA = (a.tenViTri || '').toLowerCase().trim();
        let nameB = (b.tenViTri || '').toLowerCase().trim();

        let compareName = nameA.localeCompare(nameB, 'vi');
        if (compareName !== 0) {
        return compareName;
        }
        return b.idThietBi - a.idThietBi;
        });
        }

        if (fLimit !== 'all') filtered = filtered.slice(0, parseInt(fLimit));

        let html = '';
        filtered.forEach(item => {
        let userStr = item.tenNguoiDung
        ? `<span class="text-success fw-bold"><i class="fas fa-user me-1"></i>${item.tenNguoiDung} <span class="text-danger fw-normal">(${item.tk || 'N/A'})</span></span>`
        : `<span class="text-muted fst-italic">Chưa cấp phát</span>`;

        let locStr = [item.tenCongTy, item.tenBoPhan].filter(Boolean).join(' - ') || "Chưa gắn";
        let ttName = item.tenTrangThai || "Chưa gắn";
        let badgeClass = ttName.toLowerCase().includes("hoạt động") ? "success" : "warning text-dark";

        let imgHtml = item.duongDanAnh
        ? `<div class="position-relative d-inline-block">
        <img src="/QLKiemKe/GetImage?fileName=${encodeURIComponent(item.duongDanAnh)}" class="shadow-sm img-thumbnail-hover" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid #cbd5e1; cursor: pointer;" alt="Ảnh TB" onclick="phongToAnh('/QLKiemKe/GetImage?fileName=${encodeURIComponent(item.duongDanAnh)}', '${item.tenViTri || 'Vị trí'}')" title="Nhấn để phóng to ảnh" />
        <div class="mobile-quick-cam-wrap"><button class="btn btn-sm btn-success btn-quick-cam" onclick="openQuickCameraMobile(${item.idThietBi}, event)"><i class="fas fa-camera" style="font-size:11px;"></i></button></div>
        </div>`
        : `<div class="position-relative d-inline-block">
        <div class="bg-light d-flex align-items-center justify-content-center text-muted shadow-sm" style="width: 80px; height: 80px; border-radius: 8px; border: 1px dashed #cbd5e1;"><i class="fas fa-laptop fs-3"></i></div>
        <div class="mobile-quick-cam-wrap"><button class="btn btn-sm btn-success btn-quick-cam" onclick="openQuickCameraMobile(${item.idThietBi}, event)"><i class="fas fa-camera" style="font-size:11px;"></i></button></div>
        </div>`;

        let checkTimeStr = item.thoiGianCheck ? new Date(item.thoiGianCheck).toLocaleString('vi-VN') : '<span class="text-danger fst-italic">Chưa Check</span>';

        let hostName = item.tenMayTinh
        ? `<a href="/QLKiemKe/ChiTietThietBi/${item.idThietBi}" class="fw-bold text-decoration-none text-primary mb-1 d-block" style="font-size:16px;" target="_blank"><i class="fas fa-desktop me-1"></i> ${item.tenMayTinh}</a>`
        : '<i class="text-muted d-block mb-1">Chưa có Hostname</i>';

        let accountName = item.tenDangNhap ? item.tenDangNhap : '<i class="text-muted">Chưa có Account</i>';
        let quyCachLine = item.quyCach ? `<div class="small text-dark text-truncate" style="max-width:200px" title="${item.quyCach}"><b>Quy cách:</b> ${item.quyCach}</div>` : '';
        let serialLine = item.seribacode ? `<div class="small text-secondary text-truncate" style="max-width:200px"><b>S/N:</b> ${item.seribacode}</div>` : '';

        html += `
        <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative">
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2 align-middle">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px;">ID:</span> #${item.idThietBi}
        </td>
        <td class="d-block d-md-table-cell text-center border-0 py-2 align-middle">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px;">Hình ảnh:</span>
        ${imgHtml}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2 align-middle fw-bold text-dark">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px;">Loại thiết bị:</span>
        <span class="badge bg-secondary px-2 py-1">${item.loaiThietBi || 'Chưa rõ'}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2 align-middle">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px;">Thông tin máy:</span>
        ${hostName}
        <div class="fw-semibold text-dark mb-1"><i class="fas fa-user-circle me-1"></i> ${accountName}</div>
        ${quyCachLine}
        ${serialLine}
        <div class="small text-muted mt-1 text-truncate d-inline-block" style="max-width:200px"><b>Note:</b> ${item.ghiChu || ''}</div>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2 align-middle">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px;">Người dùng & Vị trí:</span>
        ${userStr}<br/>
        <span class="small text-muted"><i class="fas fa-map-marker-alt mt-1"></i> ${locStr}</span><br/>
        <span class="badge bg-dark mt-1 text-white"><i class="fas fa-map-pin"></i> Vị trí: ${item.tenViTri}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2 align-middle">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px;">Trạng thái:</span>
        <span class="badge bg-${badgeClass} mb-1">${ttName}</span><br/>
        <span class="small" style="color: #64748b;"><i class="fas fa-clock"></i> Check: <b>${checkTimeStr}</b></span>
        </td>
        <td class="d-block d-md-table-cell text-center border-0 py-3 py-md-2 mt-2 mt-md-0 align-middle">
        <div class="d-flex flex-column gap-1">
        <button class="btn btn-sm btn-success w-100 shadow-sm" onclick="xacNhanCheckThietBi(${item.idThietBi})"><i class="fas fa-check-circle"></i> Xác nhận Check</button>
        <div class="btn-group w-100 shadow-sm">
        <button class="btn btn-sm btn-outline-info text-info" onclick="openLichSuCheckThietBi(${item.idThietBi}, '${item.tenMayTinh || ''}', '${item.tenViTri || ''}')" title="Xem lịch sử & bằng chứng check"><i class="fas fa-history"></i></button>
        <button class="btn btn-sm btn-outline-dark flex-fill" onclick='editThietBi(${JSON.stringify(item).replace(/'/g, "&#39;")})'><i class="fas fa-edit"></i> Sửa</button>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteThietBi(${item.idThietBi})"><i class="fas fa-trash"></i></button>
        </div>
        </div>
        </td>
        </tr>`;
        });

        if (filtered.length === 0) {
        html = `<tr><td colspan="7" class="text-center text-muted py-5"><i class="fas fa-search fs-2 mb-2 d-block opacity-50"></i> Không tìm thấy thiết bị nào phù hợp</td></tr>`;
        }
        $('#tbodyThietBi').html(html);
        }

        function renderUIDaXoa() {
        let selectedCompanies = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoais = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();

        let fLimit = $('#filterLimit').val();
        let fText = $('#filterText').val() ? $('#filterText').val().toLowerCase().trim() : '';

        let filtered = allThietBiCache.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa'));

        if (selectedCompanies.length > 0) filtered = filtered.filter(x => selectedCompanies.includes(x.tenCongTy));
        if (selectedDepts.length > 0) filtered = filtered.filter(x => selectedDepts.includes(x.tenBoPhan));
        if (selectedLoais.length > 0) filtered = filtered.filter(x => selectedLoais.includes(x.loaiThietBi));

        if (fText) {
        filtered = filtered.filter(x =>
        (x.tenMayTinh && x.tenMayTinh.toLowerCase().includes(fText)) ||
        (x.tenViTri && x.tenViTri.toLowerCase().includes(fText)) ||
        (x.lyDoXoa && x.lyDoXoa.toLowerCase().includes(fText))
