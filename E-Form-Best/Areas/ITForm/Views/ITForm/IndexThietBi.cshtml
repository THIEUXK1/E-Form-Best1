        function openCamera() {
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
        navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'environment', width: { ideal: 1920 }, height: { ideal: 1080 } }
        })
        .then(function(stream) {
        currentStream = stream;
        let video = document.getElementById('videoCamera');
        video.srcObject = stream;
        video.play();
        $('#boxCamera').slideDown();
        $('#boxPreviewImg').hide();
        })
        .catch(function(err) { Swal.fire("Lỗi Camera", "Không thể truy cập camera: " + err.message, "error"); });
        } else {
        Swal.fire("Không hỗ trợ", "Trình duyệt không hỗ trợ tính năng chụp trực tiếp.", "warning");
        }
        }

        function closeCamera() {
        if (currentStream) { currentStream.getTracks().forEach(track => track.stop()); currentStream = null; }
        $('#boxCamera').slideUp();
        }

        function takeSnapshot() {
        let video = document.getElementById('videoCamera');
        let canvas = document.getElementById('canvasCamera');
        let context = canvas.getContext('2d');

        let maxDim = 1280;
        let w = video.videoWidth;
        let h = video.videoHeight;
        if (w > maxDim || h > maxDim) {
        if (w > h) {
        h = Math.round((h * maxDim) / w);
        w = maxDim;
        } else {
        w = Math.round((w * maxDim) / h);
        h = maxDim;
        }
        }

        canvas.width = w;
        canvas.height = h;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        let dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        $('#imgThietBi').attr('src', dataUrl);
        $('#boxPreviewImg').show();

        canvas.toBlob(function(blob) {
        capturedPhotoBlob = blob;
        $('#tb_Anh').val('');
        }, 'image/jpeg', 0.8);

        closeCamera();
        }

        function clearImage() {
        $('#tb_Anh').val('');
        capturedPhotoBlob = null;
        $('#imgThietBi').attr('src', '');
        $('#boxPreviewImg').hide();
        }

        function previewImage(input) {
        if (input.files && input.files[0]) {
        capturedPhotoBlob = null;
        var reader = new FileReader();
        reader.onload = function(e) {
        $('#imgThietBi').attr('src', e.target.result);
        $('#boxPreviewImg').show();
        }
        reader.readAsDataURL(input.files[0]);
        } else {
        clearImage();
        }
        }

