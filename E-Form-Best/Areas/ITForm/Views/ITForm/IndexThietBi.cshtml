        // ==========================================
        // CAMERA VÀ XỬ LÝ ẢNH TRÊN FORM MODAL CHÍNH
        // ==========================================
        function openCamera() {
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
        .then(function(stream) {
        currentStream = stream;
        let video = document.getElementById('videoCamera');
        video.srcObject = stream;
        video.play();
        $('#boxCamera').slideDown();
        $('#boxPreviewImg').hide();
        })
        .catch(function(err) { Swal.fire("Lỗi Camera", "Không thể truy cập camera: " + err.message, "error"); });
        } else {
        Swal.fire("Không hỗ trợ", "Trình duyệt của thiết bị không hỗ trợ tính năng chụp trực tiếp.", "warning");
        }
        }

        function closeCamera() {
        if (currentStream) { currentStream.getTracks().forEach(track => track.stop()); currentStream = null; }
        $('#boxCamera').slideUp();
        }

        function takeSnapshot() {
        let video = document.getElementById('videoCamera');
        let canvas = document.getElementById('canvasCamera');
        let context = canvas.getContext('2d');

        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        let dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        $('#imgThietBi').attr('src', dataUrl);
        $('#boxPreviewImg').show();

        canvas.toBlob(function(blob) {
        capturedPhotoBlob = blob;
        $('#tb_Anh').val('');
        }, 'image/jpeg', 0.8);

        closeCamera();
        }

        function clearImage() {
        $('#tb_Anh').val('');
        capturedPhotoBlob = null;
        $('#imgThietBi').attr('src', '');
        $('#boxPreviewImg').hide();
        }

        @* Giữ nguyên logic xử lý xem trước ảnh tải từ máy tính của người dùng *@
        function previewImage(input) {
        if (input.files && input.files[0]) {
        capturedPhotoBlob = null;
        var reader = new FileReader();
        reader.onload = function(e) {
        $('#imgThietBi').attr('src', e.target.result);
        $('#boxPreviewImg').show();
        }
        reader.readAsDataURL(input.files[0]);
        } else {
        clearImage();
        }
        }

        // ==========================================
        // XỬ LÝ CHỨC NĂNG THAY ĐỔI ẢNH NHANH MOBILE
        // ==========================================
        function openQuickCameraMobile(idThietBi, event) {
        if(event) { event.stopPropagation(); event.preventDefault(); }
        $('#quickCam_IdThietBi').val(idThietBi);

        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
        .then(function(stream) {
        quickCamStream = stream;
        let video = document.getElementById('videoQuickCamera');
        video.srcObject = stream;
        video.play();
        $('#modalQuickCamMobile').modal('show');
        })
        .catch(function(err) { Swal.fire("Lỗi Camera", "Không thể truy cập camera: " + err.message, "error"); });
        } else {
        Swal.fire("Không hỗ trợ", "Trình duyệt thiết bị không hỗ trợ chụp trực tiếp.", "warning");
        }
        }

        function closeQuickCamera() {
        if (quickCamStream) { quickCamStream.getTracks().forEach(track => track.stop()); quickCamStream = null; }
        }

        function captureAndUploadQuickPhoto() {
        let video = document.getElementById('videoQuickCamera');
        let canvas = document.getElementById('canvasQuickCamera');
        let context = canvas.getContext('2d');
        let idThietBi = $('#quickCam_IdThietBi').val();

        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        canvas.toBlob(function(blob) {
        if(!blob) return;

        $('#modalQuickCamMobile').modal('hide');
        closeQuickCamera();

        Swal.fire({ title: 'Đang tải ảnh lên...', text: 'Vui lòng chờ', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

        let currentItem = allThietBiCache.find(x => x.idThietBi == idThietBi);

        var formData = new FormData();
        formData.append("IdThietBi", parseInt(idThietBi));
        formData.append("AnhThietBi", blob, "quick_mobile_photo.jpg");

        if(currentItem) {
        formData.append("LoaiThietBi", currentItem.loaiThietBi || "");
        formData.append("IdTrangThai", currentItem.idTrangThai || 0);
        formData.append("TenThietBi", currentItem.tenThietBi || "");
        formData.append("TenMayTinh", currentItem.tenMayTinh || "");
        formData.append("TenDangNhap", currentItem.tenDangNhap || "");
        formData.append("GhiChu", currentItem.ghiChu || "");
        formData.append("QuyCach", currentItem.quyCach || "");
        if(currentItem.idNguoiDung) formData.append("IdNguoiDung", currentItem.idNguoiDung);
        if(currentItem.idcongTy) formData.append("IdcongTy", currentItem.idcongTy);
        if(currentItem.idboPhan) formData.append("IdboPhan", currentItem.idboPhan);
        }

        $.ajax({
        url: '/QLKiemKe/SaveKkThietBi', type: 'POST', data: formData, processData: false, contentType: false,
        success: function(res) {
        Swal.close();
        if(res.success) {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã lưu ảnh mới!', showConfirmButton: false, timer: 2500 });
        loadThietBi();
        } else Swal.fire("Lỗi", res.msg, "error");
        },
        error: function() { Swal.close(); Swal.fire("Lỗi", "Không thể kết nối đến máy chủ!", "error"); }
        });
        }, 'image/jpeg', 0.8);
        }

        // ==========================================
        // THÊM / SỬA / XÓA / CHECK THIẾT BỊ
        // ==========================================
        function editThietBi(item) {
        $('#tb_Id').val(item.idThietBi);
        fillSelectTrangThai('#tb_IdTrangThai', item.idTrangThai || '');
        fillSelectCongTy('#tb_IdCongTy', item.idcongTy || '');

        if (item.idcongTy) {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        let filtered = listBoPhanCache.filter(b => b.idcongTy == item.idcongTy);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        $('#tb_IdBoPhan').html(html).val(item.idboPhan || '');
        } else {
        fillSelectBoPhan('#tb_IdBoPhan', item.idboPhan || '');
        }

        $('#tb_LoaiThietBi').val(item.loaiThietBi);
        $('#tb_QuyCach').val(item.quyCach || '');
        $('#tb_TenThietBi').val(item.tenThietBi);
        $('#tb_TenMayTinh').val(item.tenMayTinh || '');
        $('#tb_TenDangNhap').val(item.tenDangNhap || '');
        $('#tb_GhiChu').val(item.ghiChu || '');

        clearImage();
        if (item.duongDanAnh) {
        $('#imgThietBi').attr('src', '/QLKiemKe/GetImage?fileName=' + encodeURIComponent(item.duongDanAnh));
        $('#boxPreviewImg').show();
        }

        $('#tb_IdNguoiDung').val(item.idNguoiDung || '').trigger('change');
        $('#titleModalThietBi').text("Cập nhật Thiết bị");
        $('#modalThietBi').modal('show');
        }

        function saveThietBi() {
        let isAddMode = parseInt($('#tb_Id').val()) === 0;
        let loaiThietBi = $('#tb_LoaiThietBi').val();
        let idTrangThai = $('#tb_IdTrangThai').val();

        if(!loaiThietBi || !idTrangThai) return Swal.fire("Lỗi", "Vui lòng chọn loại thiết bị và Trạng thái!", "warning");

        var formData = new FormData();
        formData.append("IdThietBi", parseInt($('#tb_Id').val()));
        formData.append("LoaiThietBi", loaiThietBi);
        formData.append("QuyCach", $('#tb_QuyCach').val().trim());
        formData.append("IdTrangThai", parseInt(idTrangThai));
        formData.append("TenThietBi", $('#tb_TenThietBi').val().trim().toUpperCase());
        formData.append("TenMayTinh", $('#tb_TenMayTinh').val().trim().toUpperCase());
        formData.append("TenDangNhap", $('#tb_TenDangNhap').val().trim().toUpperCase());
        formData.append("GhiChu", $('#tb_GhiChu').val().trim());

        if($('#tb_IdNguoiDung').val()) formData.append("IdNguoiDung", parseInt($('#tb_IdNguoiDung').val()));
        if($('#tb_IdCongTy').val()) formData.append("IdcongTy", parseInt($('#tb_IdCongTy').val()));
        if($('#tb_IdBoPhan').val()) formData.append("IdboPhan", parseInt($('#tb_IdBoPhan').val()));

        if (capturedPhotoBlob) {
        formData.append("AnhThietBi", capturedPhotoBlob, "camera_photo.jpg");
        } else {
        var fileInput = $('#tb_Anh')[0].files;
        if(fileInput.length > 0) { formData.append("AnhThietBi", fileInput[0]); }
        }

        $.ajax({
        url: '/QLKiemKe/SaveKkThietBi', type: 'POST', data: formData, processData: false, contentType: false,
        success: function(res) {
        if(res.success) {
        loadThietBi();
        if(isAddMode) {
        xoaCacheFormAdd();
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Thêm thiết bị thành công!', showConfirmButton: false, timer: 2000 });
        $('#tb_Id').val('0');
        clearImage();
        $('#tb_TenThietBi').select().focus();
        } else {
        $('#modalThietBi').modal('hide');
        Swal.fire("Thành công", res.msg, "success");
        }
        } else Swal.fire("Lỗi", res.msg, "error");
        },
        error: function() { Swal.fire("Lỗi", "Không thể kết nối đến máy chủ!", "error"); }
        });
        }

        function xacNhanCheckThietBi(id) {
        $.post('/QLKiemKe/XacNhanCheck', { idThietBi: id }, function(res) {
        if(res.success) {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã cập nhật thời gian Check!', showConfirmButton: false, timer: 2000 });
        loadThietBi();
        } else Swal.fire("Lỗi", res.msg || "Không thể cập nhật thời gian check", "error");
        }).fail(function() { Swal.fire("Lỗi", "Không thể kết nối đến máy chủ!", "error"); });
        }

        function deleteThietBi(id) {
        Swal.fire({
        title: 'Chuyển vào Thùng Rác?', text: "Thiết bị sẽ được chuyển sang Tab Đã Xóa. Nhập lý do:",
        input: 'text', icon: 'warning', showCancelButton: true, confirmButtonText: 'Đồng ý', cancelButtonText: 'Hủy',
        inputValidator: (value) => { if (!value) { return 'Bạn phải nhập lý do xóa!' } }
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkThietBi', { id: id, lyDo: r.value }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Đã chuyển", res.msg, "success"); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function restoreThietBi(id) {
        Swal.fire({
        title: 'Khôi phục thiết bị?', text: "Thiết bị sẽ được khôi phục về trạng thái hoạt động cũ.",
        icon: 'question', showCancelButton: true, confirmButtonText: 'Khôi phục', cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/RestoreKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Thành công", res.msg, "success"); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function hardDeleteThietBi(id) {
        Swal.fire({
        title: 'Xóa vĩnh viễn?', text: "Hành động xóa vĩnh viễn khỏi cơ sở dữ liệu sẽ không thể khôi phục lại!",
        icon: 'error', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Xóa vĩnh viễn', cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/HardDeleteKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); Swal.fire("Đã xóa!", res.msg, "success"); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function phongToAnh(imgUrl, title) {
        Swal.fire({
        title: title ? `Mã TB: ${title}` : 'Ảnh Thiết Bị', imageUrl: imgUrl, imageAlt: 'Ảnh thiết bị chi tiết',
        showCloseButton: true, showConfirmButton: false, width: 'auto', padding: '1em', backdrop: `rgba(0,0,0,0.85)`,
        customClass: { image: 'img-fluid rounded shadow-lg', popup: 'bg-white rounded-4' }
        });
        }
    </script>
}