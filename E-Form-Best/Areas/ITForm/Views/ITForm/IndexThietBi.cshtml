        }

        if (fTìnhTrangCheck === 'chua_check') {
        if (!hasChecked) return true;
        if (fTuNgay && itemCheckDateChuỗi < fTuNgay) return true;
        if (fDenNgay && itemCheckDateChuỗi > fDenNgay) return true;
        return false;
        }

        if (fTìnhTrangCheck === 'da_check' || (!fTìnhTrangCheck && (fTuNgay || fDenNgay))) {
