        function takeSnapshot() {
        let video = document.getElementById('videoCamera');
        let canvas = document.getElementById('canvasCamera');
        let context = canvas.getContext('2d');

        // Tính toán downscale độ phân giải tối đa 1280px để lưu nhanh hơn
        let maxDim = 1280;
        let w = video.videoWidth;
        let h = video.videoHeight;
        if (w > maxDim || h > maxDim) {
        if (w > h) {
        h = Math.round((h * maxDim) / w);
        w = maxDim;
        } else {
        w = Math.round((w * maxDim) / h);
        h = maxDim;
        }
        }

        canvas.width = w;
        canvas.height = h;
        context.drawImage(video, 0, 0, canvas.width, canvas.height);

        // Nén chất lượng xuống 0.8 (80%) để giảm dung lượng file đáng kể
        let dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        $('#imgThietBi').attr('src', dataUrl);
        $('#boxPreviewImg').show();

        canvas.toBlob(function(blob) {
        capturedPhotoBlob = blob;
        $('#tb_Anh').val('');
        }, 'image/jpeg', 0.8);

        closeCamera();
        }

