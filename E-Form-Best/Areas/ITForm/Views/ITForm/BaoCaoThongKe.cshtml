@model IEnumerable<E_Form_Best.Models.ITForm.FormIt>

@{
    ViewData["Title"] = "Thống kê & Báo cáo IT";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --status-cancel: #e34948;
        --status-wait: #eda100;
        --status-processing: #2a78d6;
        --status-review: #4a3aa7;
        --status-done: #1baf7a;
        --ink-primary: #0f172a;
        --ink-secondary: #52514e;
        --ink-muted: #898781;
        --border-hairline: #e5e7eb;
        --page-plane: #f4f6f8;
    }

    body {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--page-plane);
        color: var(--ink-primary);
    }

    .stat-card {
        background: white;
        padding: 18px 20px;
        border-radius: 14px;
        border: 1px solid var(--border-hairline);
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px -4px rgba(15, 23, 42, 0.12);
        }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .card-title {
        font-size: 11.5px;
        font-weight: 700;
        color: var(--ink-secondary);
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .card-value {
        font-size: 24px;
        font-weight: 800;
        margin-top: 2px;
        display: block;
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.4px;
    }

    .chart-container {
        background: white;
        padding: 20px;
        border-radius: 14px;
        border: 1px solid var(--border-hairline);
        margin-bottom: 20px;
        position: relative;
    }

    .chart-header {
        font-weight: 700;
        color: var(--ink-primary);
        margin-bottom: 16px;
        font-size: 15.5px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 13px;
        border-bottom: 1px solid var(--border-hairline);
    }

    .table-scroll {
        max-height: 560px;
        overflow-y: auto;
        overflow-x: auto;
        border: 1px solid var(--border-hairline);
        border-radius: 10px;
        -webkit-overflow-scrolling: touch;
    }

    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-top: 0;
        font-size: 14px;
    }

        .custom-table th {
            position: sticky;
            top: 0;
            z-index: 2;
            background-color: #f8fafc;
            color: var(--ink-secondary);
            text-align: left;
            padding: 12px 16px;
            border-bottom: 2px solid var(--border-hairline);
            font-weight: 700;
            font-size: 12.5px;
        }

        .custom-table td {
            padding: 13px 16px;
            border-bottom: 1px solid #f1f5f9;
            color: var(--ink-primary);
        }

        .custom-table tbody tr:nth-child(even) {
            background-color: #fafbfc;
        }

        .custom-table tbody tr:hover {
            background-color: #eef6fd;
        }

    .badge-count {
        background: #e8f0fc;
        color: #1d5aa8;
        padding: 3px 11px;
        border-radius: 20px;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        display: inline-block;
    }

    .badge-time {
        color: var(--ink-primary);
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        font-variant-numeric: tabular-nums;
    }

    .filter-wrapper {
        display: flex;
        gap: 14px;
        align-items: flex-end;
        flex-wrap: wrap;
        background: white;
        padding: 16px 20px;
        border-radius: 14px;
        border: 1px solid var(--border-hairline);
        margin-bottom: 20px;
    }

    .filter-input {
        border: 1px solid #cbd5e1;
        padding: 7px 12px;
        border-radius: 8px;
        font-size: 13.5px;
        color: #334155;
        outline: none;
        height: 38px;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .filter-input:focus {
            border-color: #2a78d6;
            box-shadow: 0 0 0 3px rgba(42, 120, 214, 0.15);
        }

    .btn-filter {
        background: #2a78d6;
        color: white;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 13.5px;
        font-weight: 700;
        cursor: pointer;
        height: 38px;
        transition: background 0.2s;
    }

        .btn-filter:hover {
            background: #1d5aa8;
        }

        .btn-filter:active {
            transform: translateY(1px);
        }

    .loading-text {
        font-size: 13px;
        color: #2a78d6;
        font-weight: 600;
        margin-bottom: 10px;
        display: none;
    }

    .chart-empty-state {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--ink-muted);
        font-size: 13px;
        font-weight: 500;
        text-align: center;
        width: 100%;
        padding: 20px;
    }

        .chart-empty-state i {
            font-size: 28px;
            margin-bottom: 8px;
            color: #cbd5e1;
        }

    .filter-badge {
        display: none;
        background: #e6f7f0;
        border: 1px solid #b7e9d3;
        color: #0f7a52;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 10px;
        width: fit-content;
        align-items: center;
        gap: 8px;
    }

    .error-banner {
        display: none;
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #b91c1c;
        padding: 12px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 13px;
        font-weight: 600;
        align-items: center;
        gap: 10px;
    }

    /* ========================================================
        CSS NÂNG CẤP THÊM GIỐNG TRANG DASHBOARD: DROPDOWN CHECKBOX
        ======================================================== */
    .dropdown-combo-btn {
        width: 180px;
        text-align: left;
        background-color: #fff;
        border: 1px solid #cbd5e1;
        padding: 7px 24px 7px 12px;
        font-size: 13.5px;
        font-weight: 500;
        border-radius: 8px;
        color: #334155;
        position: relative;
        height: 38px;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .dropdown-combo-btn:after {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
        }

        .dropdown-combo-btn:focus {
            border-color: #2a78d6;
            outline: 0;
            box-shadow: 0 0 0 3px rgba(42, 120, 214, 0.15);
        }

    .dropdown-combo-menu {
        min-width: 220px;
        max-height: 280px;
        overflow-y: auto;
        padding: 8px 0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        z-index: 1050;
    }

    .dropdown-combo-item {
        display: flex;
        align-items: center;
        padding: 7px 16px;
        cursor: pointer;
        user-select: none;
        font-size: 13.5px;
        color: #334155;
        transition: background-color 0.15s ease;
    }

        .dropdown-combo-item:hover {
            background-color: #eef6fd;
        }

        .dropdown-combo-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #2a78d6;
            flex-shrink: 0;
        }

        .dropdown-combo-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    @@media (max-width: 768px) {
        .dashboard-container {
            padding: 0 10px !important;
            margin-top: 10px !important;
        }

        .header-section h2 {
            font-size: 18px !important;
        }

        .stat-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }

        .chart-row-mobile {
            grid-template-columns: 1fr !important;
            gap: 15px !important;
        }

        .chart-container {
            padding: 15px !important;
        }

        .canvas-wrapper-mobile {
            height: 250px !important;
        }

        .staff-chart-wrapper {
            height: 350px !important;
        }

        .filter-wrapper {
            flex-direction: column;
            align-items: stretch;
            gap: 10px;
        }

        .dropdown-combo-btn {
            width: 100%;
        }

        .loading-text {
            margin-left: 0;
            text-align: center;
        }
    }
</style>

<div class="dashboard-container" style="max-width: 1400px; margin: 20px auto; padding: 0 20px;">

    @* --- HEADER --- *@
    <div class="header-section" style="margin-bottom: 20px;">
        <h2 style="font-weight: 800; color: var(--ink-primary); margin: 0; font-size: 22px; display: flex; align-items: center; gap: 10px;">
            <i class="fa fa-dashboard" style="color: #2a78d6;"></i> Hệ Thống Quản Trị Báo Cáo IT
        </h2>
        <p style="margin: 6px 0 0; color: var(--ink-secondary); font-size: 13.5px;">Tổng quan tình trạng xử lý và hiệu suất hỗ trợ theo khoảng thời gian</p>
    </div>

    @* --- BANNER HIỂN THỊ LỖI --- *@
    <div id="lblError" class="error-banner">
        <i class="fa fa-exclamation-triangle" style="font-size: 16px;"></i>
        <span id="lblErrorText">Không thể kết nối đến hệ thống máy chủ. Vui lòng kiểm tra lại đường truyền hoặc thử lại sau!</span>
    </div>

    @* --- BỘ LỌC THỜI GIAN VÀ DROPDOWN CHECKBOX NGƯỜI HỖ TRỢ --- *@
    <div class="filter-wrapper">
        <div style="display: flex; flex-direction: column; gap: 4px;">
            <label style="font-size: 12px; font-weight: 700; color: #475569;">Từ ngày:</label>
            <input type="date" id="txtFromDate" class="filter-input" />
        </div>
        <div style="display: flex; flex-direction: column; gap: 4px;">
            <label style="font-size: 12px; font-weight: 700; color: #475569;">Đến ngày:</label>
            <input type="date" id="txtToDate" class="filter-input" />
        </div>

        @* THAY THẾ SELECT THƯỜNG THÀNH DROPDOWN CHECKBOX ĐA CHỌN *@
        <div style="display: flex; flex-direction: column; gap: 4px;">
            <label style="font-size: 12px; font-weight: 700; color: #475569;">Người hỗ trợ:</label>
            <div class="dropdown">
                <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropStaff" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    -- Tất cả --
                </button>
                <div class="dropdown-menu dropdown-combo-menu" id="menuStaff" aria-labelledby="btnDropStaff">
                </div>
            </div>
        </div>

        <button type="button" class="btn-filter" onclick="initStats()"><i class="fa fa-filter"></i> Lọc dữ liệu</button>
        <span id="lblLoading" class="loading-text"><i class="fa fa-spinner fa-spin"></i> Đang tải dữ liệu mới...</span>
    </div>

    @* --- HÀNG CON SỐ TỔNG QUAN --- *@
    <div class="stat-grid-mobile" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px;">
        <div class="stat-card" style="border-top: 3px solid #64748b;">
            <div class="stat-icon" style="background: #f1f5f9; color: #64748b;"><i class="fa fa-inbox"></i></div>
            <div><span class="card-title">Tổng số đơn</span><span class="card-value" id="lblTotal" style="color: #64748b;">0</span></div>
        </div>
        <div class="stat-card" style="border-top: 3px solid var(--status-wait);">
            <div class="stat-icon" style="background: #fdf3e0; color: var(--status-wait);"><i class="fa fa-clock-o"></i></div>
            <div><span class="card-title">Chờ QL duyệt</span><span class="card-value" id="lblWaitQL" style="color: var(--status-wait);">0</span></div>
        </div>
        <div class="stat-card" style="border-top: 3px solid var(--status-processing);">
            <div class="stat-icon" style="background: #e8f0fc; color: var(--status-processing);"><i class="fa fa-cog"></i></div>
            <div><span class="card-title">IT đang xử lý</span><span class="card-value" id="lblProcessing" style="color: var(--status-processing);">0</span></div>
        </div>
        <div class="stat-card" style="border-top: 3px solid var(--status-review);">
            <div class="stat-icon" style="background: #ece9f9; color: var(--status-review);"><i class="fa fa-star-o"></i></div>
            <div><span class="card-title">Chờ đánh giá</span><span class="card-value" id="lblWaitRate" style="color: var(--status-review);">0</span></div>
        </div>
        <div class="stat-card" style="border-top: 3px solid var(--status-done);">
            <div class="stat-icon" style="background: #e6f7f0; color: var(--status-done);"><i class="fa fa-check-circle"></i></div>
            <div><span class="card-title">Đã hoàn tất</span><span class="card-value" id="lblDone" style="color: var(--status-done);">0</span></div>
        </div>
    </div>

    @* --- HÀNG BIỂU ĐỒ 1 --- *@
    <div class="chart-row-mobile" style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-bottom: 20px;">
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-tasks" style="color: var(--status-processing);"></i> Tỉ lệ Trạng thái</div>
            <div class="canvas-wrapper-mobile" id="wrapStatus" style="height: 300px;"><canvas id="chartStatus"></canvas></div>
            <div class="chart-empty-state" id="emptyStatus"><i class="fa fa-pie-chart"></i>Không có dữ liệu trạng thái</div>
        </div>
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-building" style="color: var(--status-processing);"></i> Yêu cầu theo Bộ phận</div>
            <div class="canvas-wrapper-mobile" id="wrapDept" style="height: 300px;"><canvas id="chartDept"></canvas></div>
            <div class="chart-empty-state" id="emptyDept"><i class="fa fa-bar-chart"></i>Không có dữ liệu bộ phận</div>
        </div>
    </div>

    @* --- HÀNG BIỂU ĐỒ 2 --- *@
    <div class="chart-container">
        <div class="chart-header"><i class="fa fa-users" style="color: var(--status-processing);"></i> Hiệu suất theo Nhân viên hỗ trợ (Chi tiết trạng thái đơn) <span style="font-size:11.5px; color:var(--ink-muted); font-weight:normal;">(Bấm vào cột để lọc bảng chi tiết)</span></div>
        <div class="staff-chart-wrapper" id="wrapStaff" style="height: 400px;"><canvas id="chartStaff"></canvas></div>
        <div class="chart-empty-state" id="emptyStaff"><i class="fa fa-user-times"></i>Không có dữ liệu nhân viên hỗ trợ</div>
    </div>

    @* --- HÀNG BIỂU ĐỒ 3 --- *@
    <div class="chart-row-mobile" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-tags" style="color: var(--status-done);"></i> Thống kê theo Danh mục</div>
            <div class="canvas-wrapper-mobile" id="wrapCategory" style="height: 350px;"><canvas id="chartCategory"></canvas></div>
            <div class="chart-empty-state" id="emptyCategory"><i class="fa fa-tags"></i>Không có dữ liệu danh mục</div>
        </div>
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-file-code-o" style="color: var(--status-review);"></i> Thống kê theo Mã Form (IdForm)</div>
            <div class="canvas-wrapper-mobile" id="wrapIdForm" style="height: 350px;"><canvas id="chartIdForm"></canvas></div>
            <div class="chart-empty-state" id="emptyIdForm"><i class="fa fa-code"></i>Không có dữ liệu mã form</div>
        </div>
    </div>

    @* --- HÀNG CUỐI: BẢNG CHI TIẾT --- *@
    <div class="chart-container">
        <div class="chart-header"><i class="fa fa-list-alt" style="color: var(--status-processing);"></i> Báo cáo chi tiết theo Người hỗ trợ &amp; Danh mục</div>
        <div id="tableFilterBadge" class="filter-badge"></div>
        <div class="table-scroll">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Người Hỗ Trợ</th>
                        <th>Danh Mục</th>
                        <th style="text-align: center;">Số Đơn</th>
                        <th style="text-align: center;">TG Xử Lý Trung Bình</th>
                    </tr>
                </thead>
                <tbody id="tblStaffBody"></tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
    Chart.register(ChartDataLabels);

    let chartStatusInstance = null;
    let chartDeptInstance = null;
    let chartStaffInstance = null;
    let chartCategoryInstance = null;
    let chartIdFormInstance = null;

    let cachedDataChung = [];
    let cachedDataStaff = [];

    // Đã thay đổi thành Mảng chứa danh sách các nhân viên đang được chọn
    let selectedStaffFilter = [];

    // Bảng màu trạng thái cố định - dùng chung cho mọi biểu đồ để 1 trạng thái luôn giữ 1 màu
    const STATUS_COLORS = {
    "HỦY": "#e34948",
    "CHỜ QL": "#eda100",
    "ĐANG XỬ LÝ": "#2a78d6",
    "ĐÁNH GIÁ": "#4a3aa7",
    "HOÀN TẤT": "#1baf7a"
    };
    // Vàng và xanh lá nhạt cần chữ tối để đủ tương phản, còn lại dùng chữ trắng
    const STATUS_LABEL_INK = {
    "HỦY": "#fff",
    "CHỜ QL": "#3a2a00",
    "ĐANG XỬ LÝ": "#fff",
    "ĐÁNH GIÁ": "#fff",
    "HOÀN TẤT": "#053d29"
    };

    const commonLabelOptions = {
    color: '#fff',
    font: { weight: 'bold', family: 'Inter', size: 11 },
    formatter: (value) => value > 0 ? value : '',
    anchor: 'center',
    align: 'center'
    };

    function formatDuration(totalMinutes) {
    if (!totalMinutes || totalMinutes <= 0) return "-";
    const days = Math.floor(totalMinutes / 1440);
    const hours = Math.floor((totalMinutes % 1440) / 60);
    const mins = Math.round(totalMinutes % 60);

    let result = "";
    if (days > 0) {
    result += days + " ngày ";
    if (hours > 0) result += hours + " giờ";
    }
    else if (hours > 0) {
    result += hours + " giờ ";
    if (mins > 0) result += mins + " phút";
    }
    else {
    result += mins + " phút";
    }
    return result.trim();
    }

    function handleEmptyState(hasData, wrapperId, emptyId) {
    const wrapper = document.getElementById(wrapperId);
    const emptyElement = document.getElementById(emptyId);
    if (wrapper && emptyElement) {
    if (hasData) {
    wrapper.style.display = 'block';
    emptyElement.style.display = 'none';
    } else {
    wrapper.style.display = 'none';
    emptyElement.style.display = 'flex';
    }
    }
    }

    // Nâng cấp hàm nạp checkbox động vào Dropdown Menu Người hỗ trợ
    function populateStaffDropdown(dataStaff) {
    const menuStaff = document.getElementById('menuStaff');
    const staffs = [...new Set(dataStaff.map(item => item.tenNguoiHoTro).filter(n => n && n !== "Chưa xác định"))].sort();

    menuStaff.innerHTML = '';

    staffs.forEach(staff => {
    const isChecked = selectedStaffFilter.includes(staff) ? 'checked' : '';
    const labelItem = `
    <label class="dropdown-combo-item">
    <input type="checkbox" class="chk-staff" value="${staff}" ${isChecked}>
    <span>${staff}</span>
    </label>
    `;
    menuStaff.insertAdjacentHTML('beforeend', labelItem);
    });

    updateDropdownButtonLabel();
    }

    // Hàm cập nhật nhãn cho nút Dropdown dựa trên số lượng ô tích chọn
    function updateDropdownButtonLabel() {
    const totalChecked = $('.chk-staff:checked').length;
    const $btn = $('#btnDropStaff');

    if (totalChecked === 0) {
    $btn.text('-- Tất cả --');
    } else if (totalChecked === 1) {
    $btn.text($('.chk-staff:checked').first().val());
    } else {
    $btn.text(`Đã chọn (${totalChecked})`);
    }
    }

    // Hàm xử lý lọc đồng bộ TOÀN BỘ Dashboard theo mảng nhiều nhân viên được chọn cùng lúc
    function applyStaffFilter() {
    let displayDataStaff = cachedDataStaff;
    let displayDataChung = cachedDataChung;

    if (selectedStaffFilter.length > 0) {
    // 1. Lọc bảng nhân viên hỗ trợ theo danh sách mảng được chọn
    displayDataStaff = cachedDataStaff.filter(x => selectedStaffFilter.includes(x.tenNguoiHoTro));

    // 2. Lấy ra mảng các ID đơn liên kết
    const validFormIds = displayDataStaff.map(x => x.idFormIt);

    // 3. Lọc lại cục dữ liệu tổng quan
    displayDataChung = cachedDataChung.filter(x => validFormIds.includes(x.id));
    }

    // Cập nhật các con số đếm
    const statusResults = processStatusLogic(displayDataChung);
    updateCounters(statusResults);

    const hasDataChung = displayDataChung && displayDataChung.length > 0;
    handleEmptyState(hasDataChung, 'wrapStatus', 'emptyStatus');
    handleEmptyState(hasDataChung, 'wrapDept', 'emptyDept');
    handleEmptyState(hasDataChung, 'wrapCategory', 'emptyCategory');
    handleEmptyState(hasDataChung, 'wrapIdForm', 'emptyIdForm');

    if (hasDataChung) {
    drawStatusChart(statusResults);
    drawDeptChart(displayDataChung);
    drawCategoryChart(displayDataChung);
    drawIdFormChart(displayDataChung);
    }

    const hasDataStaff = displayDataStaff && displayDataStaff.length > 0;
    handleEmptyState(hasDataStaff, 'wrapStaff', 'emptyStaff');
    if (hasDataStaff) {
    drawStaffChart(cachedDataStaff); // Vẽ biểu đồ nhân viên gốc để hiển thị so sánh tổng quan trực quan
    }

    renderTable(cachedDataStaff);
    }

    async function initStats() {
    const fromDate = document.getElementById('txtFromDate').value;
    const toDate = document.getElementById('txtToDate').value;
    const lblLoading = document.getElementById('lblLoading');
    const lblError = document.getElementById('lblError');

    try {
    lblError.style.display = 'none';
    lblLoading.style.display = 'inline-block';

    const urlParams = `?fromDate=${fromDate}&toDate=${toDate}`;

    const [resChung, resStaff] = await Promise.all([
    fetch('/FormIT/GetDataThongKe' + urlParams),
    fetch('/FormIT/GetDataNguoiHoTro' + urlParams)
    ]);

    if (!resChung.ok || !resStaff.ok) {
    throw new Error("Lỗi API từ phía Server");
    }

    const dataChung = await resChung.json();
    const dataStaff = await resStaff.json();

    cachedDataChung = dataChung;
    cachedDataStaff = dataStaff;

    populateStaffDropdown(dataStaff);
    applyStaffFilter();

    } catch (e) {
    console.error("Lỗi tải dữ liệu:", e);
    lblError.style.display = 'flex';
    } finally {
    lblLoading.style.display = 'none';
    }
    }

    function renderTable(data) {
    let displayData = data;
    const badge = document.getElementById('tableFilterBadge');

    if (selectedStaffFilter.length > 0) {
    displayData = data.filter(x => selectedStaffFilter.includes(x.tenNguoiHoTro));
    badge.innerHTML = `<i class="fa fa-filter"></i> Đang lọc theo nhóm (<b class="text-danger">${selectedStaffFilter.length}</b>) nhân viên <span style="margin-left:8px; color:#dc2626; cursor:pointer; font-weight:bold;" onclick="clearTableFilter()">[Xóa bộ lọc]</span>`;
    badge.style.display = 'flex';
    } else {
    badge.style.display = 'none';
    }

    const summary = displayData.reduce((acc, curr) => {
    const key = `${curr.tenNguoiHoTro}|${curr.danhMuc}`;
    if (!acc[key]) {
    acc[key] = { name: curr.tenNguoiHoTro, cat: curr.danhMuc, count: 0, totalMin: 0, timeCount: 0 };
    }
    acc[key].count++;
    if (curr.phutXuLy !== null) {
    acc[key].totalMin += curr.phutXuLy;
    acc[key].timeCount++;
    }
    return acc;
    }, {});

    const tbody = document.getElementById('tblStaffBody');

    if (Object.keys(summary).length === 0) {
    tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; color:#94a3b8; padding:20px;">Không có dữ liệu hiển thị</td></tr>`;
    return;
    }

    tbody.innerHTML = Object.values(summary)
    .sort((a, b) => b.count - a.count)
    .map(item => `
    <tr>
    <td style="font-weight: 600;">${item.name}</td>
    <td style="color: #64748b;">${item.cat}</td>
    <td style="text-align: center;"><span class="badge-count">${item.count}</span></td>
    <td style="text-align: center;" class="badge-time">
    ${item.timeCount > 0 ? formatDuration(item.totalMin / item.timeCount) : '-'}
    </td>
    </tr>
    `).join('');
    }

    function clearTableFilter() {
    selectedStaffFilter = [];
    $('.chk-staff').prop('checked', false);
    updateDropdownButtonLabel();
    applyStaffFilter();
    }

    function processStatusLogic(data) {
    let stats = { "HỦY": 0, "CHỜ QL": 0, "ĐANG XỬ LÝ": 0, "ĐÁNH GIÁ": 0, "HOÀN TẤT": 0 };
    data.forEach(item => {
    const isCancelled = (item.tenForm || "").includes("[ĐÃ HỦY]");
    if (isCancelled) stats["HỦY"]++;
    else if (item.idAdmin && item.isRated) stats["HOÀN TẤT"]++;
    else if (item.idAdmin && !item.isRated) stats["ĐÁNH GIÁ"]++;
    else if (item.idNguoiDuyet) stats["ĐANG XỬ LÝ"]++;
    else stats["CHỜ QL"]++;
    });
    return stats;
    }

    function updateCounters(s) {
    document.getElementById('lblTotal').innerText = Object.values(s).reduce((a, b) => a + b, 0);
    document.getElementById('lblWaitQL').innerText = s["CHỜ QL"];
    document.getElementById('lblProcessing').innerText = s["ĐANG XỬ LÝ"];
    document.getElementById('lblWaitRate').innerText = s["ĐÁNH GIÁ"];
    document.getElementById('lblDone').innerText = s["HOÀN TẤT"];
    }

    function drawStatusChart(s) {
    if (chartStatusInstance) { chartStatusInstance.destroy(); }
    const labels = Object.keys(s);
    chartStatusInstance = new Chart(document.getElementById('chartStatus'), {
    type: 'doughnut',
    data: {
    labels: labels,
    datasets: [{
    data: Object.values(s),
    backgroundColor: labels.map(k => STATUS_COLORS[k]),
    borderColor: '#ffffff',
    borderWidth: 2
    }]
    },
    options: {
    maintainAspectRatio: false,
    cutout: '62%',
    plugins: {
    legend: { position: 'bottom', labels: { boxWidth: 10, color: '#52514e', font: { size: 11, weight: '600' } } },
    datalabels: { ...commonLabelOptions, color: (ctx) => STATUS_LABEL_INK[labels[ctx.dataIndex]] }
    }
    }
    });
    }

    function drawDeptChart(data) {
    if (chartDeptInstance) { chartDeptInstance.destroy(); }
    const group = groupData(data, 'boPhan');
    chartDeptInstance = new Chart(document.getElementById('chartDept'), {
    type: 'bar',
    data: {
    labels: Object.keys(group),
    datasets: [{ label: 'Đơn', data: Object.values(group), backgroundColor: '#2a78d6', borderRadius: 4, maxBarThickness: 40 }]
    },
    options: {
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, datalabels: { ...commonLabelOptions, anchor: 'end', align: 'top', color: '#52514e' } },
    scales: { x: { grid: { display: false }, ticks: { color: '#52514e' } }, y: { beginAtZero: true, grid: { color: '#e1e0d9' }, ticks: { color: '#898781' } } }
    }
    });
    }

    function drawStaffChart(dataStaff) {
    if (chartStaffInstance) { chartStaffInstance.destroy(); }

    const staffs = [...new Set(dataStaff.map(item => item.tenNguoiHoTro))].sort();
    const statuses = ["CHỜ QL", "ĐANG XỬ LÝ", "ĐÁNH GIÁ", "HOÀN TẤT"];

    const datasets = statuses.map((status) => ({
    label: status,
    data: staffs.map(staff => dataStaff.filter(x => x.tenNguoiHoTro === staff && x.trangThai === status).length),
    backgroundColor: STATUS_COLORS[status],
    stack: 'Stack 0'
    }));

    chartStaffInstance = new Chart(document.getElementById('chartStaff'), {
    type: 'bar',
    data: { labels: staffs, datasets: datasets },
    options: {
    maintainAspectRatio: false,
    onHover: (event, chartElement) => {
    event.native.target.style.cursor = chartElement.length ? 'pointer' : 'default';
    },
    onClick: (event, elements, chart) => {
    if (elements && elements.length > 0) {
    const firstElement = elements[0];
    const clickedStaffName = chart.data.labels[firstElement.index];

    // Khi bấm vào cột của biểu đồ, tự động tích chọn checkbox và kích hoạt bộ lọc đa vùng
    $('.chk-staff').prop('checked', false);
    $(`.chk-staff[value="${clickedStaffName}"]`).prop('checked', true);

    selectedStaffFilter = [clickedStaffName];
    updateDropdownButtonLabel();
    applyStaffFilter();
    }
    },
    plugins: {
    legend: { position: 'top', labels: { boxWidth: 10, color: '#52514e', font: { size: 11, weight: '600' } } },
    datalabels: { ...commonLabelOptions, color: (ctx) => STATUS_LABEL_INK[statuses[ctx.datasetIndex]] }
    },
    scales: {
    x: { stacked: true, grid: { display: false }, ticks: { color: '#52514e' } },
    y: { stacked: true, beginAtZero: true, grid: { color: '#e1e0d9' }, ticks: { color: '#898781' } }
    }
    }
    });
    }

    function drawCategoryChart(data) {
    if (chartCategoryInstance) { chartCategoryInstance.destroy(); }
    const group = groupData(data, 'danhmuc');
    chartCategoryInstance = new Chart(document.getElementById('chartCategory'), {
    type: 'bar',
    data: {
    labels: Object.keys(group),
    datasets: [{ label: 'Đơn', data: Object.values(group), backgroundColor: '#1baf7a', borderRadius: 4, maxBarThickness: 40 }]
    },
    options: {
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, datalabels: { ...commonLabelOptions, anchor: 'end', align: 'top', color: '#52514e' } },
    scales: { x: { grid: { display: false }, ticks: { color: '#52514e' } }, y: { beginAtZero: true, grid: { color: '#e1e0d9' }, ticks: { color: '#898781' } } }
    }
    });
    }

    function drawIdFormChart(data) {
    if (chartIdFormInstance) { chartIdFormInstance.destroy(); }
    const group = groupData(data, 'idForm');
    chartIdFormInstance = new Chart(document.getElementById('chartIdForm'), {
    type: 'bar',
    data: {
    labels: Object.keys(group),
    datasets: [{ label: 'Đơn', data: Object.values(group), backgroundColor: '#4a3aa7', borderRadius: 4, maxBarThickness: 24 }]
    },
    options: {
    indexAxis: 'y',
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, datalabels: { ...commonLabelOptions, anchor: 'end', align: 'right', color: '#52514e' } },
    scales: { x: { beginAtZero: true, grid: { color: '#e1e0d9' }, ticks: { color: '#898781' } }, y: { grid: { display: false }, ticks: { color: '#52514e' } } }
    }
    });
    }

    function groupData(data, key) {
    return data.reduce((acc, x) => {
    let val = x[key] || "N/A";
    acc[val] = (acc[val] || 0) + 1;
    return acc;
    }, {});
    }

    document.addEventListener('DOMContentLoaded', () => {
    // Ủy quyền sự kiện thay đổi trạng thái Checkbox của Menu người hỗ trợ mới
    $(document).on('change', '#menuStaff input[type="checkbox"]', function() {
    selectedStaffFilter = $('.chk-staff:checked').map(function() { return $(this).val(); }).get();
    updateDropdownButtonLabel();
    applyStaffFilter();
    });

    initStats();
    });
</script>