@model IEnumerable<E_Form_Best.Models.ITForm.FormIt>

@{
    ViewData["Title"] = "Thống kê & Báo cáo IT";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    var statusCounts = ViewBag.StatusCounts as List<int> ?? new List<int> { 0, 0, 0 };
    var hoanTat = statusCounts[0];
    var dangCho = statusCounts[1];
    var daHuy = statusCounts[2];
    var total = Model?.Count() ?? 0;
    string colorPrimary = "#10b981";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

<div style="font-family: 'Inter', sans-serif; max-width: 1400px; margin: auto; padding: 25px; background: #f8fafc;">

    @* Header *@
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;">
        <div>
            <h2 style="margin:0; color:#064e3b; font-size: 1.85rem; font-weight: 800;"><i class="fa fa-chart-pie" style="color:@colorPrimary; margin-right:10px;"></i>BÁO CÁO HỆ THỐNG IT</h2>
            <p style="margin:8px 0 0 0; color:#64748b;">Thống kê Email, Wifi, Sửa chữa và Điện thoại bàn</p>
        </div>
        <button onclick="location.reload()" style="padding: 10px 18px; background: @colorPrimary; color: #fff; border: none; border-radius: 10px; font-weight: 700; cursor: pointer;">Làm mới</button>
    </div>

    @* Cards *@
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 35px;">
        <div class="report-card">
            <span class="card-title">TỔNG PHIẾU</span>
            <div class="card-value">@total</div>
            <div class="progress-container"><div class="progress-bar" style="width: 100%; background: #3b82f6;"></div></div>
        </div>
        <div class="report-card">
            <span class="card-title" style="color: @colorPrimary;">HOÀN TẤT</span>
            <div class="card-value" style="color: @colorPrimary;">@hoanTat</div>
            <div class="progress-container"><div class="progress-bar" style="width: @(total > 0 ? (hoanTat * 100 / total) : 0)%; background: @colorPrimary;"></div></div>
        </div>
        <div class="report-card">
            <span class="card-title" style="color: #f59e0b;">ĐANG CHỜ</span>
            <div class="card-value" style="color: #f59e0b;">@dangCho</div>
            <div class="progress-container"><div class="progress-bar" style="width: @(total > 0 ? (dangCho * 100 / total) : 0)%; background: #f59e0b;"></div></div>
        </div>
        <div class="report-card">
            <span class="card-title" style="color: #ef4444;">ĐÃ HỦY</span>
            <div class="card-value" style="color: #ef4444;">@daHuy</div>
            <div class="progress-container"><div class="progress-bar" style="width: @(total > 0 ? (daHuy * 100 / total) : 0)%; background: #ef4444;"></div></div>
        </div>
    </div>

    @* Biểu đồ *@
    <div style="display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 25px; margin-bottom: 35px;">
        <div class="chart-box">
            <h3 class="chart-title">SỐ LƯỢNG THEO LOẠI FORM</h3>
            <canvas id="itTypeChart" height="110"></canvas>
        </div>
        <div class="chart-box">
            <h3 class="chart-title">TỶ LỆ PHÊ DUYỆT (%)</h3>
            <div style="height: 300px;"><canvas id="itStatusChart"></canvas></div>
        </div>
    </div>

    @* Table *@
    <div class="table-container">
        <div class="table-header"><h3 style="margin: 0; font-size: 1.1rem; font-weight: 800;">20 ĐƠN MỚI NHẤT</h3></div>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="text-align: left; background: #f8fafc;">
                        <th class="th-style">Mã Đơn</th>
                        <th class="th-style">Người Tạo</th>
                        <th class="th-style">Loại Form</th>
                        <th class="th-style">Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Take(20))
                    {
                        bool isCancelled = (item.TenForm ?? "").Contains("[ĐÃ HỦY]") || item.TrangThai == "TuChoi";
                        bool isApproved = item.IdAdmin != null && !isCancelled;
                        <tr>
                            <td style="padding: 15px 20px; font-weight: 700; color: @colorPrimary;">#@item.Id</td>
                            <td style="padding: 15px 20px;">@item.TenNguoiTao</td>
                            <td style="padding: 15px 20px;"><span class="form-tag">@item.TenForm?.Replace("[ĐÃ HỦY]", "")</span></td>
                            <td style="padding: 15px 20px;">
                                @if (isCancelled)
                                {
                                    <span class="status-badge badge-red">ĐÃ HỦY</span>
                                }
                                else if (isApproved)
                                {

                                    <span class="status-badge badge-green">HOÀN TẤT</span>
                                }
                                else
                                {

                                    <span class="status-badge badge-orange">CHỜ DUYỆT</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .report-card {
        background: white;
        padding: 25px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .card-title {
        font-size: 0.7rem;
        font-weight: 800;
        color: #64748b;
    }

    .card-value {
        font-size: 2.3rem;
        font-weight: 800;
        margin: 12px 0;
    }

    .progress-container {
        height: 6px;
        background: #f1f5f9;
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        transition: 0.8s;
    }

    .chart-box {
        background: white;
        padding: 25px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
    }

    .chart-title {
        margin: 0 0 25px 0;
        font-size: 0.95rem;
        font-weight: 800;
        border-left: 4px solid @colorPrimary;
        padding-left: 12px;
    }

    .table-container {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    .th-style {
        padding: 15px 20px;
        font-size: 11px;
        color: #94a3b8;
        text-transform: uppercase;
    }

    .form-tag {
        background: #f1f5f9;
        color: #475569;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-badge {
        font-size: 10px;
        font-weight: 800;
        padding: 5px 12px;
        border-radius: 50px;
    }

    .badge-green {
        background: #ecfdf5;
        color: #10b981;
    }

    .badge-red {
        background: #fef2f2;
        color: #ef4444;
    }

    .badge-orange {
        background: #fffbeb;
        color: #f59e0b;
    }
</style>

<script>
    Chart.register(ChartDataLabels);

    // Biểu đồ Cột
    new Chart(document.getElementById('itTypeChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.TypeLabels)),
            datasets: [{
                label: 'Số lượng',
                data: @Html.Raw(Json.Serialize(ViewBag.TypeCounts)),
                backgroundColor: '@colorPrimary',
                borderRadius: 8
            }]
        },
        options: { plugins: { datalabels: { display: false }, legend: { display: false } } }
    });

    // Biểu đồ Tròn hiển thị %
    new Chart(document.getElementById('itStatusChart'), {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.StatusLabels)),
            datasets: [{
                data: @Html.Raw(Json.Serialize(ViewBag.StatusCounts)),
                backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                borderWidth: 5,
                borderColor: '#ffffff'
            }]
        },
        options: {
            cutout: '65%',
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, font: { weight: '700' } } },
                datalabels: {
                    color: '#fff',
                    font: { weight: 'bold', size: 13 },
                    formatter: (value, ctx) => {
                        let sum = 0;
                        let dataArr = ctx.chart.data.datasets[0].data;
                        dataArr.map(data => { sum += data; });
                        let percentage = (value * 100 / sum).toFixed(1) + "%";
                        return value > 0 ? percentage : null;
                    }
                }
            }
        }
    });
</script>