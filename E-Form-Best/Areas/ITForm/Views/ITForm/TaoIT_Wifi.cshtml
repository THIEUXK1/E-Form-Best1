@model E_Form_Best.Models.ITForm.FormIt
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký sử dụng Wifi - IT System";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    var tenNguoiNv = User.Identity?.Name ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // --- CẤU HÌNH TÔNG MÀU XANH LÁ TƯƠI VÀ RỰC RỠ HƠN ---
    string colorPrimary = "#22c55e"; // Xanh lá tươi rực rỡ (Green 500)
    string colorDark = "#14532d";    // Xanh lá đậm quý phái (Green 900)
    string colorLight = "#f0fdf4";   // Xanh lá nền dịu nhẹ (Green 50)
    string colorBorder = "#86efac";  // Xanh lá viền sáng (Green 300)

    string inputBase = $"width: 100%; padding: 12px; border-radius: 12px; border: 1px solid {colorBorder}; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; color: {colorDark}; transition: all 0.3s;";
    string labelBase = $"font-weight: 800; color: {colorDark}; font-size: 11px; margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 0.8px;";
    string boxDetail = $"background: #ffffff; padding: 25px; border-radius: 24px; border: 1px solid {colorLight}; margin-bottom: 30px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);";
}

<style>
    /* HIỆU ỨNG DESKTOP HIỆN CÓ */
    .input-hover:focus {
        border-color: @colorPrimary !important;
        box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.15) !important;
    }

    #paste_AnhWifi:hover, #paste_AnhWifi:focus {
        border-color: @colorDark !important;
        background: #f0fdf4 !important;
    }

    .btn-add-item {
        background: @colorLight;
        color: @colorDark;
        border: 1px dashed @colorPrimary;
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-add-item:hover {
            background: @colorPrimary;
            color: white;
        }

    .btn-remove-item {
        color: #ef4444;
        background: #fef2f2;
        border: none;
        padding: 6px 12px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        font-size: 12px;
    }

    .wifi-item {
        background: #f9fefc;
        border: 1px solid #d1fae5;
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 20px;
        position: relative;
    }

    /* CSS RADIO GROUP GIỐNG ĐƠN MAIL - MÀU XANH LÁ TƯƠI */
    .radio-group label {
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 15px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        transition: 0.2s;
        font-weight: 700;
        color: @colorDark;
        background: #ffffff;
    }

        .radio-group label:hover {
            border-color: @colorPrimary;
            background-color: #f0fdf4;
        }

    .radio-group input[type="radio"]:checked + span {
        color: @colorPrimary;
    }

    /* ĐỊNH DẠNG HÀNG ĐỘNG 2 Ô TRÊN CÙNG 1 DÒNG THẲNG HÀNG VỚI NÚT */
    .dynamic-wifi-row {
        display: grid;
        grid-template-columns: 1fr 1fr 45px;
        gap: 12px;
        align-items: center;
        margin-bottom: 12px;
    }

    /* ==========================================
                           CSS RESPONSIVE CHO MOBILE (2026 STYLE)
                           ========================================== */
    @@media (max-width: 768px) {
        .main-page-container {
            padding: 20px 10px !important;
        }

        .form-card {
            border-radius: 25px !important;
        }

        .form-header {
            padding: 35px 15px !important;
        }

            .form-header h2 {
                font-size: 19px !important;
            }

        .form-body {
            padding: 20px 15px !important;
        }
        /* Chuyển Grid 4 cột và 2 cột thành 1 cột */
        .grid-responsive {
            grid-template-columns: 1fr !important;
            gap: 12px !important;
        }
        /* Khung nhập liệu động chuyển đổi linh hoạt trên mobile */
        .dynamic-wifi-row {
            grid-template-columns: 1fr !important;
            gap: 10px !important;
        }

            .dynamic-wifi-row button {
                height: 42px !important;
                width: 100% !important;
            }
        /* Chuyển phần tiêu đề có nút bấm thành hàng dọc */
        .flex-header-mobile {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 15px !important;
        }

            .flex-header-mobile .text-right {
                text-align: left !important;
                width: 100%;
            }

        .btn-add-item {
            width: 100%;
            justify-content: center;
            padding: 14px;
        }

        .box-detail-mobile {
            padding: 15px !important;
            border-radius: 20px !important;
        }

        #paste_AnhWifi, .file-input-box {
            height: 140px !important;
        }

        #btnSubmit {
            padding: 18px !important;
            font-size: 16px !important;
        }
        /* Radio mobile giống đơn mail */
        .radio-group {
            flex-direction: column;
            display: flex;
            gap: 10px;
        }

            .radio-group label {
                width: 100%;
            }
    }
</style>

<div class="main-page-container" style="background: linear-gradient(135deg, #f0fdf4 0%, #bbf7d0 100%); padding: 50px 20px; min-height: 100vh; font-family: 'Segoe UI', sans-serif;">

    <form id="itWifiForm" method="post" enctype="multipart/form-data" asp-action="TaoIT_Wifi" asp-controller="FormIT" asp-area="ITForm" class="form-card"
          style="max-width: 900px; margin: 0 auto; background: #ffffff; border-radius: 35px; box-shadow: 0 25px 50px -12px rgba(20, 83, 45, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div class="form-header" style="background: linear-gradient(135deg, @colorPrimary 0%, @colorDark 100%); padding: 45px 20px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 20px; right: 30px; font-size: 10px; opacity: 0.8; font-weight: 700; letter-spacing: 2px;">NETWORK ACCESS V3.0</div>
            <h2 style="margin: 0; font-size: 26px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px; text-shadow: 0 2px 4px rgba(0,0,0,0.15);">Phiếu đăng ký sử dụng Wifi</h2>
            <div style="margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; padding: 8px 20px; background: rgba(255,255,255,0.25); border-radius: 50px; font-size: 13px; backdrop-filter: blur(4px);">
                <span style="color: #ffffff;">📅 Ngày yêu cầu:</span>
                <span style="font-weight: 800; color: #ffffff;">@ngayHienThi</span>
            </div>
        </div>

        <div class="form-body" style="padding: 40px;">

            @* --- PHẦN 1: THÔNG TIN NHÂN VIÊN --- *@
            <div style="margin-bottom: 40px;">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 25px;">
                    <span style="background: @colorPrimary; color: white; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 900; box-shadow: 0 4px 10px rgba(34, 197, 94, 0.3);">1</span>
                    <h3 style="margin: 0; color: @colorDark; font-size: 16px; font-weight: 800; text-transform: uppercase;">Thông tin chủ sở hữu</h3>
                </div>

                <div class="grid-responsive" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;">
                    <div style="background: #f0fdf4; padding: 15px; border-radius: 15px; border: 1px solid #dcfce7;">
                        <label style="@labelBase">Mã nhân viên</label>
                        <div style="font-weight: 700; color: #14532d; font-size: 14px;">@soNhanVien</div>
                    </div>
                    <div style="background: #f0fdf4; padding: 15px; border-radius: 15px; border: 1px solid #dcfce7;">
                        <label style="@labelBase">Họ tên</label>
                        <div style="font-weight: 700; color: #14532d; font-size: 14px;">@tenNguoiNv</div>
                    </div>
                    <div style="background: #f0fdf4; padding: 15px; border-radius: 15px; border: 1px solid #dcfce7;">
                        <label style="@labelBase">Bộ phận</label>
                        <div style="font-weight: 700; color: #14532d; font-size: 14px;">@phongBan</div>
                    </div>
                    <div style="background: #ecfdf5; padding: 15px; border-radius: 15px; border: 1px solid @colorBorder;">
                        <label style="@labelBase">Công ty</label>
                        <div style="font-weight: 800; color: @colorPrimary; font-size: 14px;">@tenCongTy</div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT WIFI --- *@
            <div class="box-detail-mobile" style="@boxDetail">
                <div class="flex-header-mobile" style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 25px; gap: 20px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="background: @colorDark; color: white; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 900;">2</span>
                        <h3 style="margin: 0; color: @colorDark; font-size: 16px; font-weight: 800; text-transform: uppercase;">Thông số thiết bị & Thời gian</h3>
                    </div>
                    <div class="text-right" style="display: none;">
                        <button type="button" class="btn-add-item" onclick="themThietBi()">
                            <i class="fa fa-plus"></i> Thêm người/thiết bị
                        </button>
                    </div>
                </div>

                <div id="danhSachWifi">
                    <div class="wifi-item" style="padding: 0; background: transparent; border: none; margin: 0;">

                        <div class="grid-responsive" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                            <div>
                                <label style="@labelBase">Loại đơn <span style="color:red">*</span></label>
                                <div class="radio-group" style="display: flex; gap: 15px; flex-wrap: wrap;">
                                    <label>
                                        <input type="radio" name="chiTiet.LoaiDon" value="Đăng ký mới" checked required style="width: 18px; height: 18px; accent-color: @colorPrimary;">
                                        <span>Đăng ký mới</span>
                                    </label>
                                    <label>
                                        <input type="radio" name="chiTiet.LoaiDon" value="Hủy đăng ký của thiết bị" required style="width: 18px; height: 18px; accent-color: @colorPrimary;">
                                        <span>Hủy đăng ký</span>
                                    </label>
                                </div>
                            </div>
                            <div>
                                <label style="@labelBase">Loại thiết bị <span style="color:red">*</span></label>
                                <input type="text" name="chiTiet.LoaiThietBi" placeholder="Ví dụ: Laptop, Phone..." required class="input-hover" style="@inputBase">
                            </div>
                        </div>

                        <div style="margin-bottom: 20px; padding: 20px; border-radius: 16px; background: #fdfefd; border: 1px dashed @colorPrimary;">
                            <div class="grid-responsive" style="display: grid; grid-template-columns: 1fr 1fr 45px; gap: 12px; margin-bottom: 8px;">
                                <label style="@labelBase; margin-bottom: 0;">Mã thiết bị / Định danh <span style="color:red">*</span></label>
                                <label style="@labelBase; margin-bottom: 0;">Địa chỉ MAC <span style="color:red">*</span></label>
                                <div></div>
                            </div>

                            <div id="dynamicWifiWrapper">
                                <div class="dynamic-wifi-row">
                                    <input type="text" name="arrMaThietBi" placeholder="BoPhan_MaNV_HoTen (viết liền không dấu)" required class="input-hover" style="@inputBase">
                                    <input type="text" name="arrMacTb" maxlength="17" placeholder="00:00:00:00:00:00" required class="input-hover mac-input" style="@inputBase">
                                    <button type="button" onclick="addWifiRow()" style="background: @colorPrimary; color: white; border: none; border-radius: 10px; height: 42px; font-size: 20px; font-weight: 900; cursor: pointer; transition: 0.2s; width: 100%; display: flex; align-items: center; justify-content: center;">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="grid-responsive" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                            <div>
                                <label style="@labelBase">Từ ngày</label>
                                <input type="datetime-local" name="chiTiet.ThoiGianBatDau" class="input-hover" style="@inputBase">
                            </div>
                            <div>
                                <label style="@labelBase">Đến ngày</label>
                                <input type="datetime-local" name="chiTiet.ThoiGianKetThuc" class="input-hover" style="@inputBase">
                            </div>
                        </div>

                        <div style="margin-bottom: 20px;">
                            <label style="@labelBase">Lý do sử dụng</label>
                            <textarea name="chiTiet.LyDo" placeholder="Nhập mục đích truy cập..." class="input-hover" style="@inputBase height: 60px; resize: none;"></textarea>
                        </div>
                    </div>
                </div>

                <hr style="border: 0; border-top: 1px dashed @colorBorder; margin: 30px 0;" />

                <div class="grid-responsive" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelBase">Ảnh minh họa MAC Address chung (Ctrl+V)</label>
                        <div id="paste_AnhWifi" tabindex="0"
                             style="width: 100%; border: 2px dashed @colorBorder; height: 160px; border-radius: 15px; display: flex; align-items: center; justify-content: center; background: #f9fefc; color: @colorPrimary; cursor: pointer; overflow: hidden; transition: 0.3s; outline: none;">
                            <div style="text-align:center;"><i style="font-size: 20px; margin-bottom:8px;" class="fa fa-wifi"></i><br><span style="font-size: 11px; font-weight: 700;">Bấm vào đây rồi Ctrl+V</span></div>
                        </div>
                        <input type="file" id="input_Anh" name="Anh" hidden accept="image/*">
                    </div>

                    <div>
                        <label style="@labelBase">File đính kèm chung (PDF/Excel...)</label>
                        <div class="file-input-box" style="border: 2px dashed #cbd5e1; height: 160px; border-radius: 15px; padding: 20px; box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; background: #ffffff;">
                            <input type="file" name="UploadFile" style="font-size: 12px; width: 100%;">
                            <p style="font-size: 11px; color: #64748b; margin-top: 15px; line-height: 1.4;">Hỗ trợ hồ sơ xác nhận bộ phận</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CHỌN CÔNG VIỆC --- *@
            <div class="box-detail-mobile" style="@boxDetail">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 25px;">
                    <span style="background: @colorPrimary; color: white; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 900;">3</span>
                    <h3 style="margin: 0; color: @colorDark; font-size: 16px; font-weight: 800; text-transform: uppercase;">Loại yêu cầu hỗ trợ</h3>
                </div>

                <label style="@labelBase">Vui lòng chọn vấn đề bạn đang gặp <span style="color:red">*</span></label>
                <select name="selectedCongViecId" id="selectedCongViecId" required class="input-hover" style="@inputBase cursor: pointer;">
                    <option value="">-- Click để chọn loại công việc --</option>
                    @if (ViewBag.CongViecList != null)
                    {
                        foreach (var cv in (IEnumerable<E_Form_Best.Models.ITForm.CongViecIt>)ViewBag.CongViecList)
                        {
                            <option value="@cv.Id">@cv.Ten</option>
                        }
                    }
                </select>
            </div>

            @* --- PHẦN 4: BẢN CAM KẾT --- *@
            <div class="box-detail-mobile" style="margin-bottom: 30px; background: #f0fdf4; border: 1px dashed @colorBorder; border-radius: 24px; padding: 25px;">
                <h3 style="margin: 0 0 15px 0; color: @colorDark; font-size: 15px; font-weight: 900; text-align: center; text-transform: uppercase; letter-spacing: 1px;">
                    CAM KẾT BẢO MẬT & SỬ DỤNG MẠNG
                </h3>
                <label style="cursor: pointer; display: flex; align-items: flex-start; gap: 12px; background: #ffffff; padding: 15px; border-radius: 15px; border: 1px solid @colorBorder;">
                    <input type="checkbox" id="chkCamKet" style="width: 20px; height: 20px; margin-top: 3px; accent-color: @colorPrimary;">
                    <span style="font-size: 13px; font-weight: 800; color: @colorDark; line-height: 1.4;">
                        Tôi đã đọc, hiểu và cam kết sử dụng mạng đúng mục đích, không gây hại cho hệ thống công ty.
                    </span>
                </label>
            </div>

            <button type="button" id="btnSubmit" onclick="xuLyLuuWifi()" class="btn-grad"
                    style="width: 100%; padding: 22px; background: linear-gradient(to right, @colorPrimary, @colorDark); color: #ffffff; border: none; border-radius: 20px; font-weight: 900; font-size: 18px; cursor: pointer; text-transform: uppercase; letter-spacing: 2px; box-shadow: 0 10px 25px -5px rgba(34, 197, 94, 0.4); transition: 0.3s;">
                Xác nhận gửi đơn
            </button>
        </div>
    </form>
</div>

<script>
    // Hàm format MAC Address dùng chung
    function applyMacFormat(input) {
        input.addEventListener('input', function(e) {
            let value = e.target.value.toUpperCase().replace(/[^0-9A-F]/g, '');
            let formatted = "";
            for (let i = 0; i < value.length && i < 12; i++) {
                if (i > 0 && i % 2 === 0) formatted += ":";
                formatted += value[i];
            }
            e.target.value = formatted;
        });
    }

    // Khởi tạo format cho input MAC đầu tiên
    applyMacFormat(document.querySelector(".mac-input"));

    // Xử lý dán ảnh từ Clipboard
    document.getElementById("paste_AnhWifi").addEventListener('paste', function(e) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf("image") !== -1) {
                const blob = items[i].getAsFile();
                const reader = new FileReader();
                reader.onload = (event) => {
                    this.innerHTML = `<img src="${event.target.result}" style="height:100%; width:100%; object-fit:contain; border-radius:12px;">`;
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(blob);
                    document.getElementById("input_Anh").files = dataTransfer.files;
                };
                reader.readAsDataURL(blob);
            }
        }
    });

    // --- HÀM THÊM Ô ĐIỀN MÃ THIẾT BỊ VÀ ĐỊA CHỈ MAC TRÊN CÙNG 1 DÒNG CHUẨN ĐẸP Y HỆT Ô ĐẦU ---
    function addWifiRow() {
        const wrapper = document.getElementById('dynamicWifiWrapper');
        const row = document.createElement('div');
        row.className = 'dynamic-wifi-row';
        row.innerHTML = `
            <input type="text" name="arrMaThietBi" placeholder="BoPhan_MaNV_HoTen (viết liền không dấu)" required class="input-hover" style="@inputBase">
            <input type="text" name="arrMacTb" maxlength="17" placeholder="00:00:00:00:00:00" required class="input-hover mac-input" style="@inputBase">
            <button type="button" onclick="this.parentElement.remove()" style="background: #ef4444; color: white; border: none; border-radius: 10px; height: 42px; font-size: 20px; font-weight: 900; cursor: pointer; transition: 0.2s; width: 100%; display: flex; align-items: center; justify-content: center;">-</button>
        `;
        // Áp dụng định dạng MAC cho ô nhập liệu vừa được sinh ra để giữ tính đồng bộ mượt mà
        applyMacFormat(row.querySelector(".mac-input"));
        wrapper.appendChild(row);
    }

    // Giữ lại định nghĩa hàm trống để tránh lỗi kịch bản nếu layout có gọi
    function themThietBi() {}
    function xoaThietBi(btn) {}
    function capNhatNutXoa() {}

    // --- LOGIC KIỂM TRA VÀ GỬI DỮ LIỆU ĐƠN ---
    function xuLyLuuWifi() {
        const arrMa = document.getElementsByName('arrMaThietBi');
        const arrMac = document.getElementsByName('arrMacTb');
        const congViec = document.getElementById("selectedCongViecId").value;
        const chk = document.getElementById("chkCamKet");

        // Kiểm tra vòng lặp toàn bộ các dòng động được tạo ra
        for (let i = 0; i < arrMa.length; i++) {
            if (!arrMa[i].value.trim()) {
                alert(`⚠️ Dòng số ${i + 1}: Vui lòng nhập Mã thiết bị / Định danh!`);
                arrMa[i].focus();
                return;
            }
            if (arrMac[i].value.length < 17) {
                alert(`⚠️ Dòng số ${i + 1}: Địa chỉ MAC Address không hợp lệ hoặc không đủ 17 ký tự!`);
                arrMac[i].focus();
                return;
            }
        }

        if (!congViec) { alert("⚠️ Vui lòng chọn loại công việc!"); return; }
        if (!chk.checked) { alert("⚠️ Bạn phải xác nhận cam kết!"); return; }

        if (confirm(`Xác nhận gửi đơn đăng ký sử dụng mạng Wifi công ty?`)) {
            const btn = document.getElementById("btnSubmit");
            btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> ĐANG XỬ LÝ...';
            btn.style.pointerEvents = 'none';
            document.getElementById("itWifiForm").submit();
        }
    }
</script>