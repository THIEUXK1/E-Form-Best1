@{
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cấu hình Danh mục Kiểm kê";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="content-header py-3">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6 col-12 mb-2 mb-md-0">
                <h4 class="m-0 fw-bold" style="color: #1e293b; letter-spacing: -0.5px;">
                    <i class="fas fa-cogs me-2" style="color: #4f46e5;"></i> Cấu hình Danh mục Kiểm kê
                </h4>
            </div>
            <div class="col-md-6 col-12 text-md-end text-start">
                <button class="btn btn-sm rounded-pill px-3 shadow-sm text-white w-100 w-md-auto" style="background-color: #4f46e5; border-color: #4f46e5; padding-top: 8px; padding-bottom: 8px;" onclick="openModalCurrentTab()" id="btnMasterThemMoi">
                    <i class="fas fa-plus me-1"></i> Thêm mới <span id="txtBtnThemMoi">Công ty</span>
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card border-0 shadow-sm bg-white" style="border-radius: 15px;">
            <div class="card-header bg-white pt-3 pb-0 border-0" style="border-radius: 15px 15px 0 0;">
                <ul class="nav nav-tabs border-bottom flex-nowrap overflow-x-auto" id="myTab" role="tablist" style="border-color: #e2e8f0; white-space: nowrap; -webkit-overflow-scrolling: touch;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent; border-bottom: 3px solid #4f46e5; color: #4f46e5;" id="congty-tab" data-bs-toggle="tab" data-bs-target="#congty" type="button" role="tab" onclick="changeTab('Công ty', this)">
                            <i class="fas fa-building me-1"></i> Công ty
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="bophan-tab" data-bs-toggle="tab" data-bs-target="#bophan" type="button" role="tab" onclick="changeTab('Bộ phận', this)">
                            <i class="fas fa-sitemap me-1"></i> Bộ phận
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="loaithietbi-tab" data-bs-toggle="tab" data-bs-target="#loaithietbi" type="button" role="tab" onclick="changeTab('Loại thiết bị', this)">
                            <i class="fas fa-tags me-1"></i> Loại thiết bị
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="trangthai-tab" data-bs-toggle="tab" data-bs-target="#trangthai" type="button" role="tab" onclick="changeTab('Trạng thái', this)">
                            <i class="fas fa-info-circle me-1"></i> Trạng thái
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="lichsu-tab" data-bs-toggle="tab" data-bs-target="#lichsu" type="button" role="tab" onclick="changeTab('Lịch sử', this)">
                            <i class="fas fa-history me-1"></i> Lịch sử
                        </button>
                    </li>
                </ul>
            </div>

            <div class="card-body p-2 p-md-3">
                <div class="row mb-3 pb-3 border-bottom align-items-center" id="filterBar" style="background: #f8fafc; padding: 15px; border-radius: 10px; margin: 0 5px;">
                    <div class="col-md-3 col-sm-6 mb-2 mb-md-0">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-list-ol"></i> Hiển thị</label>
                        <select id="filterLimit" class="form-select rounded-3 border-0 shadow-sm" style="height: 38px;">
                            <option value="10">10 dòng</option>
                            <option value="20">20 dòng</option>
                            <option value="50">50 dòng</option>
                            <option value="100">100 dòng</option>
                            <option value="all">Tất cả</option>
                        </select>
                    </div>
                </div>

                <div class="tab-content" id="myTabContent">
                    <!-- TAB CÔNG TY -->
                    <div class="tab-pane fade show active" id="congty" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Công Ty</th>
                                        <th>Ghi chú</th>
                                        <th width="120">Ngày tạo</th>
                                        <th width="100">Trạng thái</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyCongTy"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB BỘ PHẬN -->
                    <div class="tab-pane fade" id="bophan" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Bộ Phận</th>
                                        <th>Thuộc Công Ty</th>
                                        <th>Ghi chú</th>
                                        <th width="100">Trạng thái</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyBoPhan"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB LOẠI THIẾT BỊ -->
                    <div class="tab-pane fade" id="loaithietbi" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Loại Thiết Bị</th>
                                        <th>Ghi chú</th>
                                        <th width="150">Ngày tạo</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyLoaiThietBi"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB TRẠNG THÁI -->
                    <div class="tab-pane fade" id="trangthai" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Trạng Thái</th>
                                        <th>Mô tả / Ghi chú</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyTrangThai"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB LỊCH SỬ THAO TÁC -->
                    <div class="tab-pane fade" id="lichsu" role="tabpanel">
                        <div class="d-flex justify-content-end mb-3">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="loadLichSu(true)"><i class="fas fa-sync-alt me-1"></i>Làm mới</button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="160">Thời gian</th>
                                        <th width="150">Người thao tác</th>
                                        <th width="120">Hành động</th>
                                        <th width="150">Đối tượng</th>
                                        <th>Chi tiết</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyLichSu"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL CÔNG TY -->
<div class="modal fade" id="modalCongTy" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header text-white border-0" style="background-color: #4f46e5; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalCongTy">Thông tin Công ty</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="ct_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên công ty <span class="text-danger">*</span></label>
                    <input type="text" id="ct_Ten" class="form-control rounded-3" placeholder="Nhập tên..." style="border: 1px solid #e2e8f0; padding: 10px 15px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <textarea id="ct_GhiChu" class="form-control rounded-3" rows="2" style="border: 1px solid #e2e8f0; padding: 10px 15px;"></textarea>
                </div>
                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" id="ct_TrangThai" checked style="cursor: pointer; transform: scale(1.2); margin-top: 0.3rem;">
                    <label class="form-check-label ms-2" for="ct_TrangThai">Đang hoạt động</label>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn text-white px-4 rounded-pill" style="background-color: #4f46e5;" onclick="saveCongTy()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL BỘ PHẬN -->
<div class="modal fade" id="modalBoPhan" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header text-white border-0" style="background-color: #06b6d4; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalBoPhan">Thông tin Bộ phận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="bp_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên bộ phận <span class="text-danger">*</span></label>
                    <input type="text" id="bp_Ten" class="form-control rounded-3" placeholder="Nhập tên..." style="border: 1px solid #e2e8f0; padding: 10px 15px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Thuộc công ty</label>
                    <select id="bp_IdCongTy" class="form-select rounded-3" style="border: 1px solid #e2e8f0; padding: 10px 15px;">
                        <option value="">-- Chọn công ty --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <textarea id="bp_GhiChu" class="form-control rounded-3" rows="2" style="border: 1px solid #e2e8f0; padding: 10px 15px;"></textarea>
                </div>
                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" id="bp_TrangThai" checked style="cursor: pointer; transform: scale(1.2); margin-top: 0.3rem;">
                    <label class="form-check-label ms-2" for="bp_TrangThai">Đang hoạt động</label>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn text-white px-4 rounded-pill" style="background-color: #06b6d4;" onclick="saveBoPhan()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL LOẠI THIẾT BỊ -->
<div class="modal fade" id="modalLoaiThietBi" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header text-white border-0" style="background-color: #ec4899; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalLoaiThietBi">Thông tin Loại Thiết Bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="ltb_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên loại <span class="text-danger">*</span></label>
                    <input type="text" id="ltb_Ten" class="form-control rounded-3" placeholder="Ví dụ: Máy tính, Máy in..." style="border: 1px solid #e2e8f0; padding: 10px 15px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <textarea id="ltb_GhiChu" class="form-control rounded-3" rows="2" style="border: 1px solid #e2e8f0; padding: 10px 15px;"></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn text-white px-4 rounded-pill" style="background-color: #ec4899;" onclick="saveLoaiThietBi()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL TRẠNG THÁI -->
<div class="modal fade" id="modalTrangThai" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header text-white border-0" style="background-color: #8b5cf6; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalTrangThai">Thông tin Trạng thái</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="tt_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên trạng thái <span class="text-danger">*</span></label>
                    <input type="text" id="tt_Ten" class="form-control rounded-3" placeholder="Ví dụ: Đang hoạt động, Hỏng..." style="border: 1px solid #e2e8f0; padding: 10px 15px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả / Ghi chú</label>
                    <textarea id="tt_GhiChu" class="form-control rounded-3" rows="2" style="border: 1px solid #e2e8f0; padding: 10px 15px;"></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn text-white px-4 rounded-pill" style="background-color: #8b5cf6;" onclick="saveTrangThai()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        var currentTab = 'Công ty';

        let listCongTyCache = [];
        let listBoPhanCache = [];
        let listTrangThaiCache = [];
        let listLoaiThietBiCache = [];
        let allLichSuCache = [];

        $(document).ready(function () {
        let savedLimit = localStorage.getItem('kk_filterLimit') || '50';
        $('#filterLimit').val(savedLimit);
        $('#filterLimit').on('change', function() { applyFilters(); });

        $('.modal').on('hidden.bs.modal', function () {
        $(this).find('input[type="text"], textarea').val('');
        $(this).find('input[type="hidden"]').val('0');
        $(this).find('select').val('').trigger('change');
        $(this).find('input[type="checkbox"]').prop('checked', true);
        });

        loadTrangThai();

        var savedTabId = localStorage.getItem('kk_activeTab');
        if (savedTabId) {
        var savedTabEl = document.getElementById(savedTabId);
        if (savedTabEl) { savedTabEl.click(); }
        }
        });

        function changeTab(tabName, element) {
        currentTab = tabName;
        localStorage.setItem('kk_activeTab', element.id);
        if(tabName === 'Lịch sử') {
        $('#btnMasterThemMoi').parent().hide();
        } else {
        $('#btnMasterThemMoi').parent().show();
        $('#txtBtnThemMoi').text(tabName);
        }

        $('.nav-link').removeClass('active').addClass('text-muted').css({'border-bottom': 'none', 'color': '#64748b'});
        $(element).addClass('active').removeClass('text-muted').css({'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5'});
        }

        function openModalCurrentTab() {
        if (currentTab === 'Công ty') {
        $('#titleModalCongTy').text("Thêm Công ty mới");
        $('#modalCongTy').modal('show');
        } else if (currentTab === 'Bộ phận') {
        $('#titleModalBoPhan').text("Thêm Bộ phận mới");
        fillSelectCongTy('#bp_IdCongTy');
        $('#modalBoPhan').modal('show');
        } else if (currentTab === 'Trạng thái') {
        $('#titleModalTrangThai').text("Thêm Trạng thái mới");
        $('#modalTrangThai').modal('show');
        } else if (currentTab === 'Loại thiết bị') {
        $('#titleModalLoaiThietBi').text("Thêm Loại Thiết Bị mới");
        $('#ltb_Id').val('0');
        $('#ltb_Ten').val('');
        $('#ltb_GhiChu').val('');
        $('#modalLoaiThietBi').modal('show');
        }
        }

        function applyFilters() {
        localStorage.setItem('kk_filterLimit', $('#filterLimit').val());
        renderUICongTy();
        renderUIBoPhan();
        renderUITrangThai();
        renderUILoaiThietBi();
        renderUILichSu();
        }

        // LOAD DATA
        function loadTrangThai() {
        $.get('/QLKiemKe/GetKkTrangThais', function (res) {
        if (res && res.success) { listTrangThaiCache = res.data || []; renderUITrangThai(); }
        loadLoaiThietBi();
        }).fail(function() { loadLoaiThietBi(); });
        }

        function loadLoaiThietBi() {
        $.get('/QLKiemKe/GetKkLoaiThietBis', function (res) {
        if (res && res.success) { listLoaiThietBiCache = res.data || []; renderUILoaiThietBi(); }
        loadCongTy();
        }).fail(function() { loadCongTy(); });
        }

        function loadCongTy() {
        $.get('/QLKiemKe/GetKkCongTys', function (res) {
        if (res && res.success) { listCongTyCache = res.data || []; renderUICongTy(); }
        loadBoPhan();
        }).fail(function() { loadBoPhan(); });
        }

        function loadBoPhan() {
        $.get('/QLKiemKe/GetKkBoPhans', function (res) {
        if (res && res.success) { listBoPhanCache = res.data || []; renderUIBoPhan(); }
        loadLichSu();
        }).fail(function() { loadLichSu(); });
        }

        function loadLichSu(forceReload = false) {
        if(forceReload || allLichSuCache.length === 0) {
        $.get('/QLKiemKe/GetLichSu', function (res) {
        if (res && res.success) { allLichSuCache = res.data || []; renderUILichSu(); }
        });
        } else { renderUILichSu(); }
        }

        function fillSelectCongTy(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn công ty --</option>';
        listCongTyCache.forEach(c => { html += `<option value="${c.idcongTy}">${c.tenCongTy}</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        // RENDERS
        function renderUICongTy() {
        let fLimit = $('#filterLimit').val();
        let filtered = listCongTyCache;
        if (fLimit !== 'all') filtered = filtered.slice(0, parseInt(fLimit));

        let html = '';
        filtered.forEach(item => {
        let status = item.trangThai ? `<span class="badge bg-success">Hoạt động</span>` : `<span class="badge bg-danger">Khóa</span>`;
        let date = item.ngayTao ? new Date(item.ngayTao).toLocaleDateString('vi-VN') : '';
        html += `
        <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative" style="border-color: #f1f5f9 !important;">
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">ID:</span> ${item.idcongTy}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Tên Công Ty:</span>
        <span class="fw-bold" style="color:#4f46e5; font-size:15px;">${item.tenCongTy}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Ghi chú:</span> ${item.ghiChu || ''}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Ngày tạo:</span> ${date}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
