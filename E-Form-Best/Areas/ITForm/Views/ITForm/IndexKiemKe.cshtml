        html += `
        <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative" style="border-color: #f1f5f9 !important;">
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">ID:</span>
        ${item.idThietBi}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Tên TB:</span>
        <div class="fw-bold text-dark" style="font-size:15px;">${item.tenThietBi}</div>
        <div class="small text-muted mt-1">Loại: <span class="badge bg-secondary">${item.loaiThietBi || 'N/A'}</span></div>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Thông tin máy:</span>
        <div class="small mb-1"><b>Host:</b> ${item.tenMayTinh || 'N/A'}</div>
        <div class="small text-truncate d-inline-block text-end text-md-start" style="max-width:200px" title="${item.ghiChu || ''}"><b>Note:</b> ${item.ghiChu || ''}</div>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Người dùng:</span>
        ${userStr}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Vị trí:</span>
        ${locStr}
        </td>
        <td class="d-block d-md-table-cell text-center border-0 py-3 py-md-2 mt-2 mt-md-0">
        <div class="btn-group d-flex d-md-inline-flex w-100 w-md-auto">
        <button class="btn btn-sm btn-outline-dark flex-fill flex-md-grow-0" onclick='editThietBi(${JSON.stringify(item).replace(/'/g, "&#39;")})'><i class="fas fa-edit"></i> Sửa</button>
        <button class="btn btn-sm btn-outline-danger flex-fill flex-md-grow-0" onclick="deleteThietBi(${item.idThietBi})"><i class="fas fa-trash"></i> Xóa</button>
        </div>
        </td>
        </tr>`;
        });
        }
        $('#tbodyThietBi').html(html);
        });
        }

        // ======================= CÔNG TY =======================
        function loadCongTy() {
        $.get('/QLKiemKe/GetKkCongTys', function (res) {
        listCongTyCache = res.data;
        let html = '';
        if(res.data) {
        res.data.forEach(item => {
        let status = item.trangThai ? `<span class="badge bg-success">Hoạt động</span>` : `<span class="badge bg-danger">Khóa</span>`;
        let date = item.ngayTao ? new Date(item.ngayTao).toLocaleDateString('vi-VN') : '';
                        
        html += `
        <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative" style="border-color: #f1f5f9 !important;">
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">ID:</span>
        ${item.idcongTy}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Tên Công Ty:</span>
        <span class="fw-bold" style="color:#4f46e5; font-size:15px;">${item.tenCongTy}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Ghi chú:</span>
        ${item.ghiChu || ''}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Ngày tạo:</span>
        ${date}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Trạng thái:</span>
        ${status}
        </td>
        <td class="d-block d-md-table-cell text-center border-0 py-3 py-md-2 mt-2 mt-md-0">
        <div class="btn-group d-flex d-md-inline-flex w-100 w-md-auto">
        <button class="btn btn-sm btn-outline-warning flex-fill flex-md-grow-0" onclick='editCongTy(${JSON.stringify(item)})'><i class="fas fa-edit"></i> Sửa</button>
        <button class="btn btn-sm btn-outline-danger flex-fill flex-md-grow-0" onclick="deleteCongTy(${item.idcongTy})"><i class="fas fa-trash"></i> Xóa</button>
        </div>
        </td>
        </tr>`;
        });
        }
        $('#tbodyCongTy').html(html);
        });
        }

        // ======================= BỘ PHẬN =======================
        function loadBoPhan() {
        $.get('/QLKiemKe/GetKkBoPhans', function (res) {
        listBoPhanCache = res.data;
        let html = '';
        if(res.data) {
        res.data.forEach(item => {
        let status = item.trangThai ? `<span class="badge bg-success">Hoạt động</span>` : `<span class="badge bg-danger">Khóa</span>`;
                        
        html += `
        <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative" style="border-color: #f1f5f9 !important;">
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">ID:</span>
        ${item.idboPhan}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Tên Bộ Phận:</span>
        <span class="fw-bold" style="color:#06b6d4; font-size:15px;">${item.tenBoPhan}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Thuộc CT:</span>
        <b>${item.tenCongTy || 'N/A'}</b>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Ghi chú:</span>
        ${item.ghiChu || ''}
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Trạng thái:</span>
        ${status}
        </td>
        <td class="d-block d-md-table-cell text-center border-0 py-3 py-md-2 mt-2 mt-md-0">
        <div class="btn-group d-flex d-md-inline-flex w-100 w-md-auto">
        <button class="btn btn-sm btn-outline-warning flex-fill flex-md-grow-0" onclick='editBoPhan(${JSON.stringify(item)})'><i class="fas fa-edit"></i> Sửa</button>
        <button class="btn btn-sm btn-outline-danger flex-fill flex-md-grow-0" onclick="deleteBoPhan(${item.idboPhan})"><i class="fas fa-trash"></i> Xóa</button>
        </div>
        </td>
        </tr>`;
        });
        }
        $('#tbodyBoPhan').html(html);
        });
        }

        function fillSelectCongTy(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn công ty --</option>';
        listCongTyCache.forEach(c => { html += `<option value="${c.idcongTy}">${c.tenCongTy}</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        function fillSelectBoPhan(selector, selectedVal = '') {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        $(selector).html(html).val(selectedVal);
        }

        // ======================= CÁC HÀM SỬA/LƯU/XÓA CÔNG TY =======================
        function editCongTy(item) {
        $('#ct_Id').val(item.idcongTy);
        $('#ct_Ten').val(item.tenCongTy);
        $('#ct_GhiChu').val(item.ghiChu);
        $('#ct_TrangThai').prop('checked', item.trangThai);
        $('#titleModalCongTy').text("Cập nhật Công ty");
        $('#modalCongTy').modal('show');
        }

        function saveCongTy() {
        let data = {
        IdcongTy: parseInt($('#ct_Id').val()),
        TenCongTy: $('#ct_Ten').val().trim(),
        GhiChu: $('#ct_GhiChu').val().trim(),
        TrangThai: $('#ct_TrangThai').is(':checked')
        };
        if(!data.TenCongTy) return Swal.fire("Lỗi", "Vui lòng nhập tên công ty!", "warning");

        $.post('/QLKiemKe/SaveKkCongTy', data, function(res) {
        if(res.success) {
        $('#modalCongTy').modal('hide');
        loadCongTy(); loadLichSu();
        Swal.fire("Thành công", res.msg, "success");
        } else Swal.fire("Lỗi", res.msg, "error");
        });
        }

        function deleteCongTy(id) {
        Swal.fire({ title: 'Xóa công ty?', icon: 'warning', showCancelButton: true, confirmButtonText: 'Xóa' }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkCongTy', { id: id }, function(res) {
        if(res.success) { loadCongTy(); loadLichSu(); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        // ======================= CÁC HÀM SỬA/LƯU/XÓA BỘ PHẬN =======================
        function editBoPhan(item) {
        $('#bp_Id').val(item.idboPhan);
        $('#bp_Ten').val(item.tenBoPhan);
        $('#bp_GhiChu').val(item.ghiChu);
        $('#bp_TrangThai').prop('checked', item.trangThai);
        fillSelectCongTy('#bp_IdCongTy', item.idcongTy || '');
        $('#titleModalBoPhan').text("Cập nhật Bộ phận");
        $('#modalBoPhan').modal('show');
        }

        function saveBoPhan() {
        let data = {
        IdboPhan: parseInt($('#bp_Id').val()),
        TenBoPhan: $('#bp_Ten').val().trim(),
        IdcongTy: $('#bp_IdCongTy').val() ? parseInt($('#bp_IdCongTy').val()) : null,
        GhiChu: $('#bp_GhiChu').val().trim(),
        TrangThai: $('#bp_TrangThai').is(':checked')
        };
        if(!data.TenBoPhan) return Swal.fire("Lỗi", "Vui lòng nhập tên bộ phận!", "warning");

        $.post('/QLKiemKe/SaveKkBoPhan', data, function(res) {
        if(res.success) {
        $('#modalBoPhan').modal('hide');
        loadBoPhan(); loadLichSu();
        Swal.fire("Thành công", res.msg, "success");
        } else Swal.fire("Lỗi", res.msg, "error");
        });
        }

        function deleteBoPhan(id) {
        Swal.fire({ title: 'Xóa bộ phận?', icon: 'warning', showCancelButton: true, confirmButtonText: 'Xóa' }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkBoPhan', { id: id }, function(res) {
        if(res.success) { loadBoPhan(); loadLichSu(); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        // ======================= CÁC HÀM SỬA/LƯU/XÓA THIẾT BỊ =======================
        function editThietBi(item) {
        $('#tb_Id').val(item.idThietBi);
        $('#tb_LoaiThietBi').val(item.loaiThietBi);
        $('#tb_TenThietBi').val(item.tenThietBi);
        $('#tb_TenMayTinh').val(item.tenMayTinh || '');
        $('#tb_TenDangNhap').val(item.tenDangNhap || '');
        $('#tb_GhiChu').val(item.ghiChu || '');
            
        fillSelectCongTy('#tb_IdCongTy', item.idcongTy || '');
            
        if (item.idcongTy) {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        let filtered = listBoPhanCache.filter(b => b.idcongTy == item.idcongTy);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        $('#tb_IdBoPhan').html(html).val(item.idboPhan || '');
        } else {
        fillSelectBoPhan('#tb_IdBoPhan', item.idboPhan || '');
        }

        // Gán giá trị người dùng và cập nhật lại dropdown Select2
        $('#tb_IdNguoiDung').val(item.idNguoiDung || '').trigger('change');

        $('#titleModalThietBi').text("Cập nhật Thiết bị");
        $('#modalThietBi').modal('show');
        }

        function saveThietBi() {
        let isAddMode = parseInt($('#tb_Id').val()) === 0;

        let data = {
        IdThietBi: parseInt($('#tb_Id').val()),
        LoaiThietBi: $('#tb_LoaiThietBi').val(),
        TenThietBi: $('#tb_TenThietBi').val().trim(),
        TenMayTinh: $('#tb_TenMayTinh').val().trim(),
        TenDangNhap: $('#tb_TenDangNhap').val().trim(),
        GhiChu: $('#tb_GhiChu').val().trim(),
        IdNguoiDung: $('#tb_IdNguoiDung').val() ? parseInt($('#tb_IdNguoiDung').val()) : null,
        IdcongTy: $('#tb_IdCongTy').val() ? parseInt($('#tb_IdCongTy').val()) : null,
        IdboPhan: $('#tb_IdBoPhan').val() ? parseInt($('#tb_IdBoPhan').val()) : null
        };
            
        if(!data.LoaiThietBi) return Swal.fire("Lỗi", "Vui lòng chọn loại thiết bị!", "warning");
        if(!data.TenThietBi) return Swal.fire("Lỗi", "Vui lòng nhập tên thiết bị/Mã Serial!", "warning");

        $.post('/QLKiemKe/SaveKkThietBi', data, function(res) {
        if(res.success) {
        loadThietBi(); loadLichSu();

        if(isAddMode) {
        Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'success',
        title: 'Thêm thiết bị thành công!',
        showConfirmButton: false,
        timer: 2000
        });
                        
        $('#tb_TenThietBi').val('').focus();
        $('#tb_TenMayTinh').val('');
        $('#tb_TenDangNhap').val('');
        $('#tb_GhiChu').val('');
        } else {
        $('#modalThietBi').modal('hide');
        Swal.fire("Thành công", res.msg, "success");
        }
        } else {
        Swal.fire("Lỗi", res.msg, "error");
        }
        });
        }

        function deleteThietBi(id) {
        Swal.fire({ title: 'Xóa thiết bị?', text: "Dữ liệu sẽ bị mất hoàn toàn!", icon: 'warning', showCancelButton: true, confirmButtonText: 'Xóa' }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkThietBi', { id: id }, function(res) {
        if(res.success) { loadThietBi(); loadLichSu(); }
        else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }
    </script>
}