        // ======================= THAO TÁC VỚI THIẾT BỊ =======================
        function editThietBi(item) {
        $('#tb_Id').val(item.idThietBi);
        $('#tb_LoaiThietBi').val(item.loaiThietBi);
        $('#tb_TenThietBi').val(item.tenThietBi);
        $('#tb_TenMayTinh').val(item.tenMayTinh || '');
        $('#tb_TenDangNhap').val(item.tenDangNhap || '');
        $('#tb_GhiChu').val(item.ghiChu || '');
            
        fillSelectCongTy('#tb_IdCongTy', item.idcongTy || '');
        fillSelectTrangThai('#tb_IdTrangThai', item.idTrangThai || '');
            
        if (item.idcongTy) {
        let html = '<option value="">-- Chọn bộ phận --</option>';
        let filtered = listBoPhanCache.filter(b => b.idcongTy == item.idcongTy);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        $('#tb_IdBoPhan').html(html).val(item.idboPhan || '');
        } else {
        fillSelectBoPhan('#tb_IdBoPhan', item.idboPhan || '');
        }

        $('#tb_IdNguoiDung').val(item.idNguoiDung || '').trigger('change');
        $('#titleModalThietBi').text("Cập nhật Thiết bị");
        $('#modalThietBi').modal('show');
        }

        function saveThietBi() {
        let isAddMode = parseInt($('#tb_Id').val()) === 0;
        let data = {
        IdThietBi: parseInt($('#tb_Id').val()),
        LoaiThietBi: $('#tb_LoaiThietBi').val(),
        IdTrangThai: $('#tb_IdTrangThai').val() ? parseInt($('#tb_IdTrangThai').val()) : null,
        TenThietBi: $('#tb_TenThietBi').val().trim().toUpperCase(),
        TenMayTinh: $('#tb_TenMayTinh').val().trim().toUpperCase(),
        TenDangNhap: $('#tb_TenDangNhap').val().trim().toUpperCase(),
        GhiChu: $('#tb_GhiChu').val().trim(),
        IdNguoiDung: $('#tb_IdNguoiDung').val() ? parseInt($('#tb_IdNguoiDung').val()) : null,
        IdcongTy: $('#tb_IdCongTy').val() ? parseInt($('#tb_IdCongTy').val()) : null,
        IdboPhan: $('#tb_IdBoPhan').val() ? parseInt($('#tb_IdBoPhan').val()) : null
        };
            
        if(!data.LoaiThietBi || !data.IdTrangThai) return Swal.fire("Lỗi", "Vui lòng chọn loại thiết bị và Trạng thái!", "warning");

        $.post('/QLKiemKe/SaveKkThietBi', data, function(res) {
        if(res.success) {
        loadThietBi();
        loadLichSu(true);

        if(isAddMode) {
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Thêm thiết bị thành công!', showConfirmButton: false, timer: 2000 });
        $('#tb_GhiChu').val('');
        $('#tb_TenThietBi').focus();
        } else {
        $('#modalThietBi').modal('hide');
        Swal.fire("Thành công", res.msg, "success");
        }
        } else Swal.fire("Lỗi", res.msg, "error");
        });
        }

        function deleteThietBi(id) {
        Swal.fire({
        title: 'Chuyển vào Thùng Rác?',
        text: "Thiết bị sẽ được chuyển sang Tab Đã Xóa và tự động hủy hoàn toàn sau 1 tháng. Nhập lý do:",
        input: 'text',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Đồng ý',
        cancelButtonText: 'Hủy',
        inputValidator: (value) => { if (!value) { return 'Bạn phải nhập lý do xóa!' } }
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/DeleteKkThietBi', { id: id, lyDo: r.value }, function(res) {
        if(res.success) {
        loadThietBi(); loadLichSu(true);
        Swal.fire("Đã chuyển", res.msg, "success");
        } else Swal.fire("Lỗi", res.msg, "error");
        });
        }
        });
        }

        function restoreThietBi(id) {
        Swal.fire({
        title: 'Khôi phục thiết bị?',
        text: "Thiết bị sẽ được khôi phục về trạng thái 'Đang hoạt động'.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Khôi phục',
        cancelButtonText: 'Hủy'
        }).then((r) => {
        if (r.isConfirmed) {
        $.post('/QLKiemKe/RestoreKkThietBi', { id: id }, function(res) {
