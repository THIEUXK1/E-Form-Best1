        // CRUD AJAX CALLS
        function editLoaiThietBi(item) { $('#ltb_Id').val(item.idLoai); $('#ltb_Ten').val(item.tenLoai); $('#ltb_GhiChu').val(item.ghiChu); $('#titleModalLoaiThietBi').text("Cập nhật Loại Thiết Bị"); $('#modalLoaiThietBi').modal('show'); }
        function saveLoaiThietBi() {
        let data = { IdLoai: parseInt($('#ltb_Id').val()), TenLoai: $('#ltb_Ten').val().trim(), GhiChu: $('#ltb_GhiChu').val().trim() };
        if(!data.TenLoai) return Swal.fire("Lỗi", "Nhập tên loại thiết bị!", "warning");
        $.post('/QLKiemKe/SaveKkLoaiThietBi', data, function(res) { if(res.success) { $('#modalLoaiThietBi').modal('hide'); loadLoaiThietBi(); loadLichSu(true); Swal.fire({toast: true, position: 'top-end', icon: 'success', title: 'Thành công!', showConfirmButton: false, timer: 2000}); } else Swal.fire("Lỗi", res.msg, "error"); });
        }
        function deleteLoaiThietBi(id) { Swal.fire({ title: 'Xóa?', icon: 'warning', showCancelButton: true }).then(r => { if (r.isConfirmed) $.post('/QLKiemKe/DeleteKkLoaiThietBi', { id: id }, function(res) { if(res.success) { loadLoaiThietBi(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); }); }); }

        function editTrangThai(item) { $('#tt_Id').val(item.idTrangThai); $('#tt_Ten').val(item.tenTrangThai); $('#tt_GhiChu').val(item.moTa); $('#titleModalTrangThai').text("Cập nhật Trạng thái"); $('#modalTrangThai').modal('show'); }
        function saveTrangThai() {
        let data = { IdTrangThai: parseInt($('#tt_Id').val()), TenTrangThai: $('#tt_Ten').val().trim(), MoTa: $('#tt_GhiChu').val().trim() };
        if(!data.TenTrangThai) return Swal.fire("Lỗi", "Nhập tên trạng thái!", "warning");
        $.post('/QLKiemKe/SaveKkTrangThai', data, function(res) { if(res.success) { $('#modalTrangThai').modal('hide'); loadTrangThai(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); });
        }
        function deleteTrangThai(id) { Swal.fire({ title: 'Xóa?', icon: 'warning', showCancelButton: true }).then(r => { if(r.isConfirmed) $.post('/QLKiemKe/DeleteKkTrangThai', { id: id }, function(res) { if(res.success) { loadTrangThai(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); }); }); }

        function editCongTy(item) { $('#ct_Id').val(item.idcongTy); $('#ct_Ten').val(item.tenCongTy); $('#ct_GhiChu').val(item.ghiChu); $('#ct_TrangThai').prop('checked', item.trangThai); $('#modalCongTy').modal('show'); }
        function saveCongTy() {
        let data = { IdcongTy: parseInt($('#ct_Id').val()), TenCongTy: $('#ct_Ten').val().trim(), GhiChu: $('#ct_GhiChu').val().trim(), TrangThai: $('#ct_TrangThai').is(':checked') };
        if(!data.TenCongTy) return Swal.fire("Lỗi", "Nhập tên công ty!", "warning");
        $.post('/QLKiemKe/SaveKkCongTy', data, function(res) { if(res.success) { $('#modalCongTy').modal('hide'); loadCongTy(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); });
        }
        function deleteCongTy(id) { Swal.fire({ title: 'Xóa?', icon: 'warning', showCancelButton: true }).then(r => { if (r.isConfirmed) $.post('/QLKiemKe/DeleteKkCongTy', { id: id }, function(res) { if(res.success) { loadCongTy(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); }); }); }

        function editBoPhan(item) { $('#bp_Id').val(item.idboPhan); $('#bp_Ten').val(item.tenBoPhan); $('#bp_GhiChu').val(item.ghiChu); $('#bp_TrangThai').prop('checked', item.trangThai); fillSelectCongTy('#bp_IdCongTy', item.idcongTy || ''); $('#modalBoPhan').modal('show'); }
        function saveBoPhan() {
        let data = { IdboPhan: parseInt($('#bp_Id').val()), TenBoPhan: $('#bp_Ten').val().trim(), IdcongTy: $('#bp_IdCongTy').val(), GhiChu: $('#bp_GhiChu').val().trim(), TrangThai: $('#bp_TrangThai').is(':checked') };
        if(!data.TenBoPhan) return Swal.fire("Lỗi", "Nhập tên bộ phận!", "warning");
        $.post('/QLKiemKe/SaveKkBoPhan', data, function(res) { if(res.success) { $('#modalBoPhan').modal('hide'); loadBoPhan(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); });
        }
        function deleteBoPhan(id) { Swal.fire({ title: 'Xóa?', icon: 'warning', showCancelButton: true }).then(r => { if (r.isConfirmed) $.post('/QLKiemKe/DeleteKkBoPhan', { id: id }, function(res) { if(res.success) { loadBoPhan(); loadLichSu(true); } else Swal.fire("Lỗi", res.msg, "error"); }); }); }
    </script>
