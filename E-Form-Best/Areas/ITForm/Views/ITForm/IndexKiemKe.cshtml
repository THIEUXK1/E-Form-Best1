@{
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Quản lý Kiểm Kê (Công ty, Bộ phận, Thiết bị, Lịch Sử)";
}

<!-- THÊM THƯ VIỆN SELECT2 & FONT AWESOME 6 ĐỂ HIỂN THỊ ICON VÀ Ô TÌM KIẾM -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="content-header py-3">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6 col-12 mb-2 mb-md-0">
                <h4 class="m-0 fw-bold" style="color: #1e293b; letter-spacing: -0.5px;">
                    <i class="fas fa-boxes me-2" style="color: #4f46e5;"></i> Quản lý Kiểm kê tài sản
                </h4>
            </div>
            <div class="col-md-6 col-12 text-md-end text-start">
                <button class="btn btn-sm rounded-pill px-3 shadow-sm text-white w-100 w-md-auto" style="background-color: #4f46e5; border-color: #4f46e5; padding-top: 8px; padding-bottom: 8px;" onclick="openModalCurrentTab()">
                    <i class="fas fa-plus me-1"></i> Thêm mới <span id="txtBtnThemMoi">Thiết bị</span>
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card border-0 shadow-sm bg-white" style="border-radius: 15px;">
            <div class="card-header bg-white pt-3 pb-0 border-0" style="border-radius: 15px 15px 0 0;">
                <!-- TABS (THIẾT BỊ ĐƯỢC ĐƯA LÊN ĐẦU, THÊM CUỘN NGANG CHO MOBILE) -->
                <ul class="nav nav-tabs border-bottom flex-nowrap overflow-x-auto" id="myTab" role="tablist" style="border-color: #e2e8f0; white-space: nowrap; -webkit-overflow-scrolling: touch;">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="thietbi-tab" data-bs-toggle="tab" data-bs-target="#thietbi" type="button" role="tab" onclick="changeTab('Thiết bị', this)">
                            <i class="fas fa-laptop me-1"></i> Thiết bị
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="congty-tab" data-bs-toggle="tab" data-bs-target="#congty" type="button" role="tab" onclick="changeTab('Công ty', this)">
                            <i class="fas fa-building me-1"></i> Công ty
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="bophan-tab" data-bs-toggle="tab" data-bs-target="#bophan" type="button" role="tab" onclick="changeTab('Bộ phận', this)">
                            <i class="fas fa-sitemap me-1"></i> Bộ phận
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold text-muted px-4 py-2" style="border: none; border-radius: 10px 10px 0 0; background-color: transparent;" id="lichsu-tab" data-bs-toggle="tab" data-bs-target="#lichsu" type="button" role="tab" onclick="changeTab('Lịch sử', this)">
                            <i class="fas fa-history me-1"></i> Lịch sử thao tác
                        </button>
                    </li>
                </ul>
            </div>
            
            <div class="card-body p-2 p-md-3">
                <div class="tab-content" id="myTabContent">
                    
                    <!-- TAB THIẾT BỊ (MẶC ĐỊNH) -->
                    <div class="tab-pane fade show active" id="thietbi" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Thiết Bị</th>
                                        <th>Thông tin máy</th>
                                        <th>Người dùng</th>
                                        <th>Vị trí (CT/BP)</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyThietBi"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB CÔNG TY -->
                    <div class="tab-pane fade" id="congty" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Công Ty</th>
                                        <th>Ghi chú</th>
                                        <th width="120">Ngày tạo</th>
                                        <th width="100">Trạng thái</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyCongTy"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB BỘ PHẬN -->
                    <div class="tab-pane fade" id="bophan" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="70">ID</th>
                                        <th>Tên Bộ Phận</th>
                                        <th>Thuộc Công Ty</th>
                                        <th>Ghi chú</th>
                                        <th width="100">Trạng thái</th>
                                        <th width="120" class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyBoPhan"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- TAB LỊCH SỬ THAO TÁC -->
                    <div class="tab-pane fade" id="lichsu" role="tabpanel">
                        <div class="d-flex justify-content-end mb-3">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="loadLichSu()"><i class="fas fa-sync-alt me-1"></i>Làm mới lịch sử</button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" style="min-width: 100%;">
                                <thead class="table-light d-none d-md-table-header-group">
                                    <tr>
                                        <th width="160">Thời gian</th>
                                        <th width="150">Người thao tác</th>
                                        <th width="120">Hành động</th>
                                        <th width="120">Đối tượng (ID)</th>
                                        <th>Chi tiết</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyLichSu"></tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL CÔNG TY -->
<div class="modal fade" id="modalCongTy" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header text-white border-0" style="background-color: #4f46e5; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalCongTy">Thông tin Công ty</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="ct_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên công ty <span class="text-danger">*</span></label>
                    <input type="text" id="ct_Ten" class="form-control rounded-3" placeholder="Nhập tên..." style="border: 1px solid #e2e8f0; padding: 10px 15px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <textarea id="ct_GhiChu" class="form-control rounded-3" rows="2" placeholder="Ghi chú..." style="border: 1px solid #e2e8f0; padding: 10px 15px;"></textarea>
                </div>
                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" id="ct_TrangThai" checked style="cursor: pointer; transform: scale(1.2); margin-top: 0.3rem;">
                    <label class="form-check-label ms-2" for="ct_TrangThai">Đang hoạt động</label>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn text-white px-4 rounded-pill" style="background-color: #4f46e5;" onclick="saveCongTy()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL BỘ PHẬN -->
<div class="modal fade" id="modalBoPhan" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header text-white border-0" style="background-color: #06b6d4; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalBoPhan">Thông tin Bộ phận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="bp_Id" value="0" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên bộ phận <span class="text-danger">*</span></label>
                    <input type="text" id="bp_Ten" class="form-control rounded-3" placeholder="Nhập tên..." style="border: 1px solid #e2e8f0; padding: 10px 15px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Thuộc công ty</label>
                    <select id="bp_IdCongTy" class="form-select rounded-3" style="border: 1px solid #e2e8f0; padding: 10px 15px;">
                        <option value="">-- Chọn công ty --</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <textarea id="bp_GhiChu" class="form-control rounded-3" rows="2" style="border: 1px solid #e2e8f0; padding: 10px 15px;"></textarea>
                </div>
                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" id="bp_TrangThai" checked style="cursor: pointer; transform: scale(1.2); margin-top: 0.3rem;">
                    <label class="form-check-label ms-2" for="bp_TrangThai">Đang hoạt động</label>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn text-white px-4 rounded-pill" style="background-color: #06b6d4;" onclick="saveBoPhan()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL THIẾT BỊ -->
<div class="modal fade" id="modalThietBi" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-dark text-white border-0" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="titleModalThietBi">Thông tin Thiết bị</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3 p-md-4">
                <input type="hidden" id="tb_Id" value="0" />
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Loại thiết bị <span class="text-danger">*</span></label>
                        <select id="tb_LoaiThietBi" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chọn loại --</option>
                            <option value="Máy tính">Máy tính (PC/Laptop)</option>
                            <option value="Máy in">Máy in</option>
                            <option value="Máy chấm công">Máy chấm công</option>
                            <option value="Switch">Switch mạng</option>
                            <option value="Loa">Loa / Âm thanh</option>
                            <option value="Khác">Khác...</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên thiết bị (Mã/Serial) <span class="text-danger">*</span></label>
                        <input type="text" id="tb_TenThietBi" class="form-control rounded-3" placeholder="VD: Laptop Dell XPS..." style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên máy tính (Hostname)</label>
                        <input type="text" id="tb_TenMayTinh" class="form-control rounded-3" placeholder="VD: DESKTOP-123" style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên đăng nhập (Account)</label>
                        <input type="text" id="tb_TenDangNhap" class="form-control rounded-3" placeholder="VD: admin_local" style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">Ghi chú</label>
                        <input type="text" id="tb_GhiChu" class="form-control rounded-3" placeholder="Thông tin thêm (Cấu hình, tình trạng...)" style="border: 1px solid #e2e8f0; height: 45px;" />
                    </div>

                    <div class="col-12 mt-4 mb-2">
                        <div style="border-top: 1px dashed #cbd5e1;"></div>
                    </div>
                    
                    <div class="col-md-12">
                        <label class="form-label fw-bold" style="color: #4f46e5;">Gán người sử dụng</label>
                        <select id="tb_IdNguoiDung" class="form-control select2-modal w-100">
                            <option value="">-- Chưa cấp phát --</option>
                            @if (ViewBag.Users != null)
                            {
                                foreach (var item in ViewBag.Users)
                                {
                                    <option value="@item.IdNguoiDung">@item.HoTen (@item.Tk)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gán Công ty</label>
                        <select id="tb_IdCongTy" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chưa rõ --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Gán Bộ phận</label>
                        <select id="tb_IdBoPhan" class="form-select rounded-3" style="border: 1px solid #e2e8f0; height: 45px;">
                            <option value="">-- Chưa rõ --</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light" style="border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-dark px-4 rounded-pill w-100 w-md-auto" onclick="saveThietBi()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- THÊM JS SELECT2 VÀO SECTION SCRIPTS ĐỂ ĐẢM BẢO HOẠT ĐỘNG -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        var currentTab = 'Thiết bị'; // Mặc định là Thiết bị
        let listCongTyCache = [];
        let listBoPhanCache = [];

        $(document).ready(function () {
        // Tối ưu UI khi mới mở tab
        stylizeActiveTab(document.getElementById('thietbi-tab'));

        // KHỞI TẠO SELECT2 CÓ TÌM KIẾM CHO MODAL (SỬA LỖI KHÔNG GÕ ĐƯỢC)
        if($.fn.select2) {
        $('.select2-modal').select2({
        dropdownParent: $('#modalThietBi'),
        placeholder: "-- Chọn người dùng --",
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0 // Đảm bảo thanh tìm kiếm luôn bật
        });

        // FIX LỖI QUAN TRỌNG: Sửa lỗi không focus/gõ chữ được vào ô tìm kiếm trên cả PC và Mobile
        $(document).on('select2:open', () => {
        let searchField = document.querySelector('.select2-search__field');
        if (searchField) {
        setTimeout(() => { searchField.focus(); }, 10);
        }
        });

        // CSS inline tạo hình vuông vắn đẹp cho Select2
        setTimeout(() => {
        $('.select2-selection--single').css({
        'height': '45px', 'display': 'flex', 'align-items': 'center',
        'border': '1px solid #e2e8f0', 'border-radius': '0.5rem'
        });
        }, 200);
        }

        loadCongTy();
        loadBoPhan();
        loadThietBi();
        loadLichSu();

        // Clear modal khi đóng
        $('.modal').on('hidden.bs.modal', function () {
        $(this).find('input[type="text"], textarea').val('');
        $(this).find('input[type="hidden"]').val('0');
        $(this).find('select').val('').trigger('change');
        $(this).find('input[type="checkbox"]').prop('checked', true);
        });

        // Lọc Bộ Phận theo Công Ty trong Modal Thiết bị
        $('#tb_IdCongTy').on('change', function() {
        let idCT = $(this).val();
        let html = '<option value="">-- Chọn bộ phận --</option>';
        if(idCT) {
        let filtered = listBoPhanCache.filter(b => b.idcongTy == idCT);
        filtered.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan}</option>`; });
        } else {
        listBoPhanCache.forEach(b => { html += `<option value="${b.idboPhan}">${b.tenBoPhan} (${b.tenCongTy || 'Trống'})</option>`; });
        }
        $('#tb_IdBoPhan').html(html);
        });
        });

        // HÀM CHUYỂN TAB CÓ CSS INLINE
        function changeTab(tabName, element) {
        currentTab = tabName;
            
        // Xử lý ẩn hiện nút "Thêm Mới"
        if(tabName === 'Lịch sử') {
        $('#txtBtnThemMoi').parent().hide();
        } else {
        $('#txtBtnThemMoi').parent().show();
        $('#txtBtnThemMoi').text(tabName);
        }

        // Xóa màu ở tất cả các tab
        $('.nav-link').removeClass('active').addClass('text-muted').css({'border-bottom': 'none', 'color': '#64748b'});
            
        // Trang trí cho tab được click
        stylizeActiveTab(element);
        }

        function stylizeActiveTab(element) {
        if(!element) return;
        $(element).addClass('active').removeClass('text-muted');
        $(element).css({'border-bottom': '3px solid #4f46e5', 'color': '#4f46e5'});
        }

        function openModalCurrentTab() {
        if (currentTab === 'Công ty') {
        $('#titleModalCongTy').text("Thêm Công ty mới");
        $('#modalCongTy').modal('show');
        } else if (currentTab === 'Bộ phận') {
        $('#titleModalBoPhan').text("Thêm Bộ phận mới");
        fillSelectCongTy('#bp_IdCongTy');
        $('#modalBoPhan').modal('show');
        } else if (currentTab === 'Thiết bị') {
        $('#titleModalThietBi').text("Thêm Thiết bị mới");
        fillSelectCongTy('#tb_IdCongTy');
        fillSelectBoPhan('#tb_IdBoPhan');
        $('#modalThietBi').modal('show');
        }
        }

        // ==========================================
        // KHỐI RENDER TABLE ĐÁP ỨNG GIAO DIỆN PC & MOBILE (DẠNG THẺ CARD TRÊN MOBILE)
        // ==========================================

        // ======================= LỊCH SỬ THAO TÁC =======================
        function loadLichSu() {
        $.get('/QLKiemKe/GetLichSu', function (res) {
        let html = '';
        if(res.data) {
        res.data.forEach(item => {
        let date = item.thoiGian ? new Date(item.thoiGian).toLocaleString('vi-VN') : '';
        let actionColor = item.hanhDong.includes("Thêm") ? "success" : (item.hanhDong.includes("Xóa") ? "danger" : "primary");
                        
        html += `
        <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative" style="border-color: #f1f5f9 !important;">
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Thời gian:</span>
        <span class="text-muted"><i class="fas fa-clock me-1"></i> ${date}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Người thao tác:</span>
        <span class="fw-bold text-dark"><i class="fas fa-user-circle me-1 text-secondary"></i> ${item.nguoiThaoTac || 'N/A'}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Hành động:</span>
        <span class="badge bg-${actionColor} px-2 py-1 rounded-pill">${item.hanhDong}</span>
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2" style="border-bottom: 1px solid #f8fafc !important;">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Đối tượng:</span>
        <span class="fw-bold">${item.doiTuong}</span> (ID: ${item.idDoiTuong})
        </td>
        <td class="d-block d-md-table-cell text-end text-md-start border-0 py-2">
        <span class="d-md-none fw-bold text-muted float-start text-uppercase" style="font-size: 11px; margin-top: 2px;">Chi tiết:</span>
