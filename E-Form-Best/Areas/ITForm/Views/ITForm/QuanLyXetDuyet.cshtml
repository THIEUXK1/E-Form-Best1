@using System.Security.Claims

@{
    ViewData["Title"] = "Quản Lý Xét Duyệt IT";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "";
}

<style>
    body {
        background-color: #f8fafc;
    }

    /* Hiệu ứng chung & Glassmorphism */
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        border-color: #1e40af !important;
    }

    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.3);
        }

        .page-btn:hover:not(.active) {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* Style cho Bộ lọc nâng cao */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
        height: 38px;
    }

        .filter-input:focus {
            border-color: #1e40af;
            box-shadow: 0 0 0 2px rgba(30,64,175,0.1);
        }

    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
        height: 38px;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* ========================================================
        CSS MỚI: HỆ THỐNG DROPDOWN CHECKBOX (MULTI-SELECT)
        ======================================================== */
    .dropdown-combo-btn {
        text-align: left;
        background-color: #fff;
        border: 1px solid #cbd5e1;
        padding: 8px 28px 8px 12px;
        font-size: 13px;
        font-weight: 600;
        border-radius: 8px;
        color: #1e293b;
        position: relative;
        min-width: 160px;
        height: 38px;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

        .dropdown-combo-btn:after {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
        }

        .dropdown-combo-btn:focus {
            border-color: #1e40af;
            box-shadow: 0 0 0 2px rgba(30,64,175,0.1);
            outline: 0;
        }

    .dropdown-combo-menu {
        min-width: 220px;
        max-height: 280px;
        overflow-y: auto;
        padding: 8px 0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        z-index: 1050;
    }

    .dropdown-combo-item {
        display: flex;
        align-items: center;
        padding: 6px 16px;
        cursor: pointer;
        user-select: none;
        font-size: 13px;
        color: #334155;
        transition: background-color 0.15s ease;
    }

        .dropdown-combo-item:hover {
            background-color: #f1f5f9;
        }

        .dropdown-combo-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #1e40af;
            flex-shrink: 0;
        }

        .dropdown-combo-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    /* ========================================================
        CSS RESPONSIVE CHO MOBILE (2026 STYLE)
        ======================================================== */
    @@media (max-width: 768px) {
        .top-bar-mobile {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 15px !important;
        }

        .search-container-mobile {
            width: 100% !important;
        }

        #quickSearch {
            width: 100% !important;
            box-sizing: border-box;
        }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .dropdown-combo-btn {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }

        .stats-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
        }

            .stats-grid-mobile > div:last-child {
                grid-column: span 2;
            }

        #dataTable thead {
            display: none;
        }

        #dataTable tbody tr {
            display: block;
            margin-bottom: 20px;
            border: 1px solid #cbd5e1 !important;
            border-radius: 20px;
            padding: 12px;
            background: #ffffff;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        #dataTable td {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 5px !important;
            border-bottom: 1px dashed #f1f5f9 !important;
            width: 100% !important;
            text-align: right !important;
        }

            #dataTable td:last-child {
                border-bottom: none !important;
                justify-content: center !important;
                padding-top: 15px !important;
            }

            #dataTable td::before {
                content: attr(data-label);
                font-weight: 800;
                color: #64748b;
                text-transform: uppercase;
                font-size: 10px;
                text-align: left;
                flex-shrink: 0;
            }

        .mobile-td-content {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .pagination-mobile {
            flex-direction: column !important;
            gap: 20px;
            align-items: center !important;
        }
    }
</style>

<div style="max-width: 1450px; margin: 0 auto; padding: 20px; background: #f1f5f9; min-height: 100vh; font-family: 'Inter', sans-serif;">

    @* --- TOP BAR --- *@
    <div class="top-bar-mobile" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px;">
        <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 26px; display: flex; align-items: center; gap: 12px;">
            <span style="background: #1e40af; color: white; width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(30, 64, 175, 0.3);">
                <i class="fa fa-shield"></i>
            </span>
            XÉT DUYỆT IT
        </h2>

        <div class="top-bar-mobile" style="display: flex; gap: 12px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #cbd5e1;">
                <span style="font-size: 12px; font-weight: 800; color: #64748b;">HIỂN THỊ:</span>
                <select id="pageSizeSelect" onchange="changePageSize()"
                        style="border: none; outline: none; font-weight: 900; color: #1e40af; cursor: pointer; font-size: 14px; background: transparent;">
                    <option value="10">10</option>
                    <option value="30" selected>30</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>

            <div class="search-container-mobile" style="position: relative;">
                <i class="fa fa-search" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="handleSearch()" placeholder="Tìm tên, bộ phận, mã đơn..."
                       style="padding: 11px 15px 11px 42px; border-radius: 12px; border: 2px solid #cbd5e1; font-size: 14px; width: 300px; outline: none; font-weight: 700; transition: 0.3s; border-color: #cbd5e1;">
            </div>

            <div style="font-size: 11px; background: #1e40af; padding: 10px 18px; border-radius: 10px; font-weight: 900; color: #ffffff; text-transform: uppercase; letter-spacing: 0.5px;">
                @currentUserRole
            </div>
        </div>
    </div>

    @* --- BỘ LỌC NÂNG CAO DROPDOWN MULTI-CHECKBOX --- *@
    <div class="advanced-filter">
        <div class="filter-group">
            <label>Từ ngày</label>
            <input type="date" id="txtFromDate" class="filter-input" onchange="handleSearch()" />
        </div>
        <div class="filter-group">
            <label>Đến ngày</label>
            <input type="date" id="txtToDate" class="filter-input" onchange="handleSearch()" />
        </div>

        <div class="filter-group">
            <label>Bộ phận</label>
            <div class="dropdown">
                <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropDept" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    -- Tất cả --
                </button>
                <div class="dropdown-menu dropdown-combo-menu" id="menuDept" aria-labelledby="btnDropDept">
                </div>
            </div>
        </div>

        <div class="filter-group">
            <label>Người hỗ trợ</label>
            <div class="dropdown">
                <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropStaff" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    -- Tất cả --
                </button>
                <div class="dropdown-menu dropdown-combo-menu" id="menuStaff" aria-labelledby="btnDropStaff">
                </div>
            </div>
        </div>

        <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
            <button class="btn-clear-filter" onclick="clearAllFilters()">
                <i class="fa fa-refresh"></i> Làm mới
            </button>
        </div>
    </div>

    @* --- STATS ROW --- *@
    <div class="stats-grid-mobile" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; margin-bottom: 30px;">
        <div data-status="CHỜ QL" onclick="filterByStatus('CHỜ QL')" class="stat-card" style="background: #fffbeb; padding: 20px 15px; border-radius: 18px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.04);">
            <div style="font-size: 11px; font-weight: 900; color: #b45309; text-transform: uppercase; margin-bottom: 8px;">Chờ QL duyệt</div>
            <div id="stat-cho-ql" style="font-size: 28px; font-weight: 1000; color: #b45309;">0</div>
        </div>
        <div data-status="IT XỬ LÝ" onclick="filterByStatus('IT XỬ LÝ')" class="stat-card" style="background: #eff6ff; padding: 20px 15px; border-radius: 18px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.04);">
            <div style="font-size: 11px; font-weight: 900; color: #1e40af; text-transform: uppercase; margin-bottom: 8px;">IT cần xử lý</div>
            <div id="stat-it-xu-ly" style="font-size: 28px; font-weight: 1000; color: #1e40af;">0</div>
        </div>
        <div data-status="CHỜ ĐG" onclick="filterByStatus('CHỜ ĐG')" class="stat-card" style="background: #f5f3ff; padding: 20px 15px; border-radius: 18px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.04);">
            <div style="font-size: 11px; font-weight: 900; color: #6366f1; text-transform: uppercase; margin-bottom: 8px;">Chờ đánh giá</div>
            <div id="stat-cho-dg" style="font-size: 28px; font-weight: 1000; color: #6366f1;">0</div>
        </div>
        <div data-status="HOÀN TẤT" onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #ecfdf5; padding: 20px 15px; border-radius: 18px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.04);">
            <div style="font-size: 11px; font-weight: 900; color: #10b981; text-transform: uppercase; margin-bottom: 8px;">Hoàn tất</div>
            <div id="stat-hoan-tat" style="font-size: 28px; font-weight: 1000; color: #10b981;">0</div>
        </div>
        <div data-status="ĐÃ HỦY" onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 20px 15px; border-radius: 18px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.04);">
            <div style="font-size: 11px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 8px;">Đơn đã hủy</div>
            <div id="stat-huy" style="font-size: 28px; font-weight: 1000; color: #b91c1c;">0</div>
        </div>
    </div>

    @* --- TABLE AREA --- *@
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <table id="dataTable" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 3px solid #e2e8f0;">
                    <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên yêu cầu</th>
                    <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 150px;">Danh mục</th>
                    <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Thông tin thiết bị</th>
                    <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 180px;">Phụ trách</th>
                    <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 140px;">Tiến trình</th>
                    <th style="padding: 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 140px;">Trạng thái</th>
                    <th style="padding: 20px; text-align: right; width: 100px;"></th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <tr><td colspan="7" id="loadingRow" style="text-align: center; padding: 60px; color: #64748b; font-weight: 600;"><i class="fa fa-spinner fa-spin" style="font-size: 24px; margin-bottom: 10px;"></i><br>Đang đồng bộ dữ liệu xét duyệt...</td></tr>
            </tbody>
        </table>

        <div id="emptyState" style="display: none; text-align: center; padding: 80px 20px; color: #94a3b8;">
            <i class="fa fa-inbox" style="font-size: 54px; margin-bottom: 15px; opacity: 0.2;"></i>
            <p style="font-weight: 700; font-size: 16px;">Tuyệt vời! Hiện không có yêu cầu nào đang chờ xử lý</p>
        </div>
    </div>

    @* --- PHÂN TRANG & FOOTER --- *@
    <div class="pagination-mobile" style="display: flex; justify-content: space-between; align-items: center; padding: 25px 5px;">
        <div id="paginationButtons" style="display: flex; gap: 8px;"></div>
        <div style="text-align: right;">
            <div style="color: #475569; font-size: 13px; font-weight: 800;">
                Trang <span id="currentPageNum" style="color: #1e40af;">1</span> / <span id="totalPagesNum">1</span>
            </div>
            <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 6px;">
                Tổng bản ghi: <span id="totalVisibleCount">0</span>
            </div>
        </div>
    </div>
</div>

<script>
    let masterData = [];
    let filteredData = [];
    let currentPage = 1;
    let rowsPerPage = 30;

    let currentActiveStatusFilter = "";

    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. PHỤC HỒI TEXT SEARCH ---
        const savedText = sessionStorage.getItem("savedXetDuyetText");
        if (savedText) document.getElementById("quickSearch").value = savedText;

        // --- 2. PHỤC HỒI NGÀY THÁNG LỌC NÂNG CAO ---
        const savedFrom = sessionStorage.getItem("savedFromDateXD");
        if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

        const savedTo = sessionStorage.getItem("savedToDateXD");
        if (savedTo) document.getElementById("txtToDate").value = savedTo;

        // --- 3. PHỤC HỒI TRẠNG THÁI THẺ CARD ---
        const savedStatus = sessionStorage.getItem("savedXetDuyetStatus");
        if (savedStatus !== null) {
            currentActiveStatusFilter = savedStatus;
        }

        // Lắng nghe sự kiện click Checkbox động trong các Menu ô lọc mới
        $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
            const $menu = $(this).closest('.dropdown-combo-menu');
            updateDropdownButtonLabel($menu);
            handleSearch();
        });

        loadDataFromAPI();
    });

    async function loadDataFromAPI() {
        try {
            const response = await fetch('/FormIT/GetQuanLyXetDuyetData');
            if (!response.ok) throw new Error("Lỗi mạng khi gọi API");

            masterData = await response.json();
            filteredData = masterData;

            // Đổ dữ liệu vào Dropdown Checkbox động
            populateDropdowns(masterData);

            // --- 4. PHỤC HỒI CACHE TRẠNG THÁI TÍCH CHỌN MULTI-SELECT ---
            const savedDeptStr = sessionStorage.getItem("savedDeptXD");
            if (savedDeptStr) {
                try {
                    let arrDept = JSON.parse(savedDeptStr) || [];
                    if (!Array.isArray(arrDept) && savedDeptStr) arrDept = [savedDeptStr];
                    arrDept.forEach(d => { $(`.chk-dept[value="${d}"]`).prop('checked', true); });
                    updateDropdownButtonLabel($('#menuDept'));
                } catch(e){}
            }

            const savedStaffStr = sessionStorage.getItem("savedStaffXD");
            if (savedStaffStr) {
                try {
                    let arrStaff = JSON.parse(savedStaffStr) || [];
                    if (!Array.isArray(arrStaff) && savedStaffStr) arrStaff = [savedStaffStr];
                    arrStaff.forEach(s => { $(`.chk-staff[value="${s}"]`).prop('checked', true); });
                    updateDropdownButtonLabel($('#menuStaff'));
                } catch(e){}
            }

            // Tính số lượng bản ghi trên từng thẻ Card mốc trạng thái
            calculateStats(masterData);

            // Bật hiệu ứng CSS thẻ Trạng Thái đã lưu
            updateVisualStatusCard(currentActiveStatusFilter);

            // Chạy hàm lọc dữ liệu tổng hợp đa vùng
            handleSearch();
        } catch (error) {
            console.error("Lỗi:", error);
            document.getElementById('tableBody').innerHTML = '<tr><td colspan="7" style="text-align:center; padding: 40px; color: #ef4444; font-weight:bold;"><i class="fa fa-warning"></i> Không thể kết nối máy chủ. Vui lòng thử lại sau.</td></tr>';
        }
    }

    // Sinh động cấu trúc Checkbox lồng trong Dropdown Menu
    function populateDropdowns(data) {
        const menuDept = document.getElementById("menuDept");
        const menuStaff = document.getElementById("menuStaff");

        // Lấy danh sách Bộ phận duy nhất
        const depts = [...new Set(data.map(x => x.boPhan).filter(Boolean))].sort();
        menuDept.innerHTML = '';
        depts.forEach(d => {
            menuDept.insertAdjacentHTML('beforeend', `
                <label class="dropdown-combo-item">
                    <input type="checkbox" class="chk-dept" value="${d}">
                    <span>${d}</span>
                </label>
            `);
        });

        // Lấy danh sách Người hỗ trợ duy nhất
        const staffSet = [...new Set(data.map(x => x.tenNguoiHoTro).filter(n => n && n !== "Chưa gán IT"))].sort();
        menuStaff.innerHTML = '';
        staffSet.forEach(s => {
            menuStaff.insertAdjacentHTML('beforeend', `
                <label class="dropdown-combo-item">
                    <input type="checkbox" class="chk-staff" value="${s}">
                    <span>${s}</span>
                </label>
            `);
        });
    }

    // Hàm cập nhật nhãn nút hiển thị đầu khối Dropdown Checkbox
    function updateDropdownButtonLabel($menu) {
        let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
        let $btn = $menu.siblings('.dropdown-combo-btn');

        if (totalChecked === 0) {
            $btn.text('-- Tất cả --');
        } else if (totalChecked === 1) {
            $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
        } else {
            $btn.text(`Đã chọn (${totalChecked})`);
        }
    }

    function calculateStats(data) {
        let daHuy = 0, choQL = 0, itXuLy = 0, choDG = 0, hoanTat = 0;
        data.forEach(item => {
            const status = determineStatus(item).statusTag;
            if (status === "ĐÃ HỦY") daHuy++;
            else if (status === "CHỜ QL") choQL++;
            else if (status === "IT XỬ LÝ") itXuLy++;
            else if (status === "CHỜ ĐG") choDG++;
            else if (status === "HOÀN TẤT") hoanTat++;
        });
        document.getElementById("stat-cho-ql").innerText = choQL;
        document.getElementById("stat-it-xu-ly").innerText = itXuLy;
        document.getElementById("stat-cho-dg").innerText = choDG;
        document.getElementById("stat-hoan-tat").innerText = hoanTat;
        document.getElementById("stat-huy").innerText = daHuy;
    }

    function determineStatus(item) {
        const isCancelled = (item.tenForm || "").includes("[ĐÃ HỦY]");
        const isApprMng = item.idNguoiDuyet != null;
        const isITOk = item.idAdmin != null;
        const hasRate = item.daDanhGia;

        let res = { pWidth: "15%", pColor: "#94a3b8", pText: "Khởi tạo", bg: "#f1f5f9", fg: "#475569", statusTag: "KHỞI TẠO" };

        if (isCancelled) {
            res = { pWidth: "100%", pColor: "#ef4444", pText: "ĐÃ HỦY", bg: "#fee2e2", fg: "#b91c1c", statusTag: "ĐÃ HỦY" };
        } else if (isITOk && hasRate) {
            res = { pWidth: "100%", pColor: "#10b981", pText: "HOÀN TẤT", bg: "#d1fae5", fg: "#047857", statusTag: "HOÀN TẤT" };
        } else if (isITOk && !hasRate) {
            res = { pWidth: "85%", pColor: "#6366f1", pText: "CHỜ ĐG", bg: "#f5f3ff", fg: "#4f46e5", statusTag: "CHỜ ĐG" };
        } else if (isApprMng) {
            res = { pWidth: "60%", pColor: "#1e40af", pText: "IT XỬ LÝ", bg: "#dbeafe", fg: "#1e40af", statusTag: "IT XỬ LÝ" };
        } else {
            res = { pWidth: "30%", pColor: "#f59e0b", pText: "CHỜ QL", bg: "#fef3c7", fg: "#b45309", statusTag: "CHỜ QL" };
        }
        return res;
    }

    function changePageSize() {
        rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
        currentPage = 1;
        renderTable();
    }

    function updateVisualStatusCard(status) {
        document.querySelectorAll('.stat-card').forEach(el => {
            el.style.border = "2px solid rgba(0,0,0,0.03)";
            el.style.boxShadow = "0 4px 6px rgba(0,0,0,0.04)";
        });

        if(status) {
            const targetCard = document.querySelector(`.stat-card[data-status="${status}"]`);
            if (targetCard) {
                targetCard.style.border = "2px solid #1e40af";
                targetCard.style.boxShadow = "0 0 0 3px rgba(30, 64, 175, 0.2)";
            }
        }
    }

    function filterByStatus(status) {
        if(currentActiveStatusFilter === status) {
            currentActiveStatusFilter = "";
        } else {
            currentActiveStatusFilter = status;
        }

        sessionStorage.setItem("savedXetDuyetStatus", currentActiveStatusFilter);
        updateVisualStatusCard(currentActiveStatusFilter);
        handleSearch();

        const table = document.getElementById("dataTable");
        table.style.opacity = "0.5";
        setTimeout(() => table.style.opacity = "1", 200);
    }

    function clearAllFilters() {
        document.getElementById("quickSearch").value = "";
        document.getElementById("txtFromDate").value = "";
        document.getElementById("txtToDate").value = "";

        // Bỏ tích chọn toàn bộ checkbox bộ lọc nâng cao
        $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
        $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });

        sessionStorage.removeItem("savedXetDuyetText");
        sessionStorage.removeItem("savedFromDateXD");
        sessionStorage.removeItem("savedToDateXD");
        sessionStorage.removeItem("savedDeptXD");
        sessionStorage.removeItem("savedStaffXD");
        sessionStorage.removeItem("savedXetDuyetStatus");

        currentActiveStatusFilter = "";
        updateVisualStatusCard("");
        handleSearch();
    }

    // ====================================================
    // HÀM LỌC TỔNG HỢP MỚI (HỖ TRỢ LỌC MẢNG ARRAY INCLUDES)
    // ====================================================
    function handleSearch() {
        const textFilter = document.getElementById("quickSearch").value.toUpperCase();
        const fromDateStr = document.getElementById("txtFromDate").value;
        const toDateStr = document.getElementById("txtToDate").value;

        // Thu thập mảng các giá trị đang tích chọn từ Checkbox
        const selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        const selectedStaffs = $('.chk-staff:checked').map(function() { return $(this).val(); }).get();

        // Đồng bộ lưu thông số vào Session Storage chống mất trạng thái chọn nhiều mục khi Refresh
        sessionStorage.setItem("savedXetDuyetText", document.getElementById("quickSearch").value);
        sessionStorage.setItem("savedFromDateXD", fromDateStr);
        sessionStorage.setItem("savedToDateXD", toDateStr);
        sessionStorage.setItem("savedDeptXD", JSON.stringify(selectedDepts));
        sessionStorage.setItem("savedStaffXD", JSON.stringify(selectedStaffs));

        filteredData = masterData.filter(item => {
            const stInfo = determineStatus(item);
            const stName = stInfo.statusTag;

            // 1. Kiểm tra trạng thái đơn từ Thẻ Card phía trên
            if (currentActiveStatusFilter && stName !== currentActiveStatusFilter) return false;

            // 2. Kiểm tra lọc mảng Đa Bộ Phận (Tích chọn nhiều ô)
            if (selectedDepts.length > 0 && !selectedDepts.includes(item.boPhan)) return false;

            // 3. Kiểm tra lọc mảng Đa Người Hỗ Trợ (Tích chọn nhiều ô)
            if (selectedStaffs.length > 0 && !selectedStaffs.includes(item.tenNguoiHoTro)) return false;

            // 4. Kiểm tra Khoảng Thời Gian
            if (fromDateStr || toDateStr) {
                if (!item.timeNguoiTao) return false;
                const parts = item.timeNguoiTao.split('/');
                if (parts.length === 3) {
                    const itemDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
                    if (fromDateStr) {
                        const fromD = new Date(fromDateStr + "T00:00:00");
                        if (itemDate < fromD) return false;
                    }
                    if (toDateStr) {
                        const toD = new Date(toDateStr + "T23:59:59");
                        if (itemDate > toD) return false;
                    }
                }
            }

            // 5. Kiểm tra Chuỗi Text tìm kiếm nhanh tự do
            if (textFilter) {
                const searchString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.danhmuc} ${item.tenForm} ${item.id} ${item.tenNguoiHoTro} ${stName}`.toUpperCase();
                if (!searchString.includes(textFilter)) return false;
            }

            return true;
        });

        currentPage = 1;
        renderTable();
    }

    function renderTable() {
        const tbody = document.getElementById("tableBody");
        const emptyState = document.getElementById("emptyState");
        const table = document.getElementById("dataTable");
        tbody.innerHTML = "";

        const startIndex = (currentPage - 1) * rowsPerPage;
        const pageData = filteredData.slice(startIndex, startIndex + rowsPerPage);

        if(pageData.length === 0) {
            emptyState.style.display = "block";
            table.style.display = "none";
        } else {
            emptyState.style.display = "none";
            table.style.display = "table";
            pageData.forEach(item => {
                const s = determineStatus(item);
                const cleanTenForm = (item.tenForm || "").replace("[ĐÃ HỦY]", "").trim();
                const avatar = item.tenNguoiHoTro && item.tenNguoiHoTro !== "Chưa có" ? item.tenNguoiHoTro.charAt(0).toUpperCase() : "?";

                const isFinal = s.statusTag === "HOÀN TẤT" || s.statusTag === "ĐÃ HỦY";
                const buttonStyle = isFinal ? "background: #f1f5f9; color: #64748b; border: 1px solid #cbd5e1;" : "background: #1e40af; color: #ffffff; box-shadow: 0 4px 6px rgba(30,64,175,0.2);";
                const buttonText = isFinal ? "Xem lại" : "Xử lý";

                const tr = document.createElement("tr");
                tr.className = "d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative";

                tr.innerHTML = `
                    <td data-label="Nhân viên" style="padding: 15px 20px;">
                        <div class="mobile-td-content">
                            <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                            <div style="font-size: 11px; color: #64748b; font-weight: 800; margin-top: 2px;">${item.boPhan} • <span style="color: #1e40af;">MS: ${item.soNhanVien}</span></div>
                        </div>
                    </td>
                    <td data-label="Danh mục" style="padding: 15px 20px;">
                        <span style="background: #f1f5f9; color: #475569; padding: 5px 12px; border-radius: 8px; font-size: 11px; font-weight: 800; border: 1px solid #e2e8f0; display: inline-block;"><i class="fa fa-tag" style="margin-right: 5px; opacity: 0.7;"></i>${item.danhmuc}</span>
                    </td>
                    <td data-label="Thiết bị" style="padding: 15px 20px;">
                        <div class="mobile-td-content">
                            <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${cleanTenForm}</div>
                            <div style="font-size: 11px; color: #94a3b8; font-weight: 700; margin-top: 4px;">ID: #${item.id} • ${item.timeNguoiTao}</div>
                        </div>
                    </td>
                    <td data-label="Phụ trách" style="padding: 15px 20px;">
                        <div style="display: flex; align-items: center; gap: 10px; justify-content: flex-end;">
                            <div style="width: 28px; height: 28px; background: #eff6ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1e40af; border: 1px solid #dbeafe; font-weight: 900; font-size: 11px;">${avatar}</div>
                            <div style="font-weight: 700; color: #334155; font-size: 13px;">${item.tenNguoiHoTro || 'Chưa có'}</div>
                        </div>
                    </td>
                    <td data-label="Tiến trình" style="padding: 15px 20px;">
                        <div style="min-width: 100px;">
                            <div style="font-size: 10px; font-weight: 1000; color: ${s.pColor}; margin-bottom: 6px; display: flex; justify-content: space-between; text-transform: uppercase;"><span>${s.pText}</span> <span>${s.pWidth}</span></div>
                            <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; border: 1px solid #f1f5f9;">
                                <div style="width: ${s.pWidth}; height: 100%; background: ${s.pColor}; border-radius: 10px; transition: 0.6s ease;"></div>
                            </div>
                        </div>
                    </td>
                    <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                        <span style="background:${s.bg}; color:${s.fg}; padding:6px 14px; border-radius:10px; font-size:10px; font-weight:1000; border: 1.5px solid ${s.fg}; display: inline-block; min-width: 90px; text-align: center;">${s.statusTag}</span>
                    </td>
                    <td data-label="Thao tác" style="padding: 15px 20px; text-align: right;">
                        <a href="/FormIT/ChiTiet/${item.id}" style="text-decoration: none; padding: 9px 20px; border-radius: 12px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.3s; ${buttonStyle}">${buttonText}</a>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        const totalPages = Math.ceil(filteredData.length / rowsPerPage) || 1;
        renderPaginationButtons(totalPages);
        document.getElementById("totalVisibleCount").innerText = filteredData.length;
        document.getElementById("currentPageNum").innerText = currentPage;
        document.getElementById("totalPagesNum").innerText = totalPages;
    }

    function renderPaginationButtons(totalPages) {
        const container = document.getElementById("paginationButtons");
        container.innerHTML = ""; if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            if (totalPages > 6 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                if (i === 3 || i === totalPages - 2) {
                    const dot = document.createElement("span");
                    dot.innerText = "..."; dot.style.padding = "8px"; dot.style.color = "#94a3b8";
                    container.appendChild(dot);
                }
                continue;
            }
            const btn = document.createElement("button");
            btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
            btn.onclick = () => {
                currentPage = i; renderTable(); window.scrollTo({ top: 0, behavior: 'smooth' });
            };
            container.appendChild(btn);
        }
    }
</script>