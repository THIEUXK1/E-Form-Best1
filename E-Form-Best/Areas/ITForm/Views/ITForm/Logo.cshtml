@{
    ViewData["Title"] = "IT System Dashboard";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";

    // Khai báo biến màu sắc để tối ưu hóa việc quản lý mã nguồn
    string deepBlue = "#1e3a8a";
    string accentBlue = "#3b82f6";
    string gradientBlue = "linear-gradient(135deg, #1e3a8a 0%, #172554 100%)";
}

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; background-color: #f1f5f9; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; padding: 20px;">

    <div style="background: #ffffff; padding: 70px 50px; border-radius: 40px; box-shadow: 0 25px 50px -12px rgba(30, 58, 138, 0.15); text-align: center; max-width: 550px; width: 100%; border: 1px solid #e2e8f0; position: relative; overflow: hidden;">

        <div style="position: absolute; top: -50px; right: -50px; width: 160px; height: 160px; background: #dbeafe; border-radius: 50%; z-index: 0; opacity: 0.6;"></div>
        <div style="position: absolute; bottom: -30px; left: -30px; width: 100px; height: 100px; background: #eff6ff; border-radius: 50%; z-index: 0;"></div>

        <div style="position: relative; z-index: 1;">

            <div style="width: 110px; height: 110px; margin: 0 auto 30px; border-radius: 28px; background: @gradientBlue; display: flex; justify-content: center; align-items: center; box-shadow: 0 15px 30px rgba(30, 58, 138, 0.3); transform: perspective(800px) rotateY(-15deg);">
                <div style="color: #ffffff; font-size: 45px; font-weight: 800; letter-spacing: -1px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">
                    IT
                </div>
            </div>

            <div style="display: inline-block; padding: 6px 18px; background: #1e3a8a; color: #ffffff; border-radius: 10px; font-size: 11px; font-weight: 700; letter-spacing: 2px; margin-bottom: 30px; text-transform: uppercase; box-shadow: 0 4px 6px rgba(30, 58, 138, 0.1);">
                Internal Support System
            </div>

            <h1 style="margin: 0; font-size: 3.5rem; color: #1e3a8a; font-weight: 900; letter-spacing: -2.5px; line-height: 0.9;">
                IT <span style="color: @accentBlue; font-weight: 300;">FORM</span>
            </h1>

            <div style="width: 60px; height: 6px; background: @accentBlue; margin: 30px auto; border-radius: 20px; opacity: 0.8;"></div>

            <p style="margin: 0 0 15px; font-size: 1.4rem; color: #111827; font-weight: 700; letter-spacing: -0.5px;">
                Cổng Thông Tin Kỹ Thuật Tập Trung
            </p>

            <p style="font-size: 1.05rem; color: #4b5563; line-height: 1.8; margin-bottom: 10px; padding: 0 15px;">
                Giải pháp tối ưu để tiếp nhận, điều phối và xử lý các yêu cầu hạ tầng, thiết bị và phần mềm nội bộ một cách
                <span style="color: #1e3a8a; font-weight: 700; display: block; margin-top: 5px;">Minh bạch – Chuyên nghiệp – Hiệu quả.</span>
            </p>

        </div>

        <div style="margin-top: 60px; padding-top: 20px; border-top: 1px solid #f1f5f9; font-size: 11px; color: #9ca3af; font-weight: 600; letter-spacing: 1px; position: relative; z-index: 1;">
            &copy; 2026 IT DEPARTMENT - SECURE & RELIABLE SYSTEM
        </div>
    </div>
</div>