@{
    Layout = null;
    ViewData["Title"] = "Đăng Nhập Hệ Thống";
    // Lấy email đã nhớ từ Cookie để điền sẵn vào ô nhập liệu
    var rememberedEmail = Context.Request.Cookies["RememberedEmail"] ?? "";
}

<!DOCTYPE html>
<html lang="vi" style="height:100%; width:100%; margin:0; padding:0;">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
</head>

<body style="margin:0; height:100vh; width:100vw; display:flex; justify-content:center; align-items:center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-family:'Segoe UI', Roboto, sans-serif; overflow:hidden;">

    <div style="position:absolute; width:300px; height:300px; background:rgba(255,255,255,0.1); border-radius:50%; top:-100px; right:-50px;"></div>
    <div style="position:absolute; width:200px; height:200px; background:rgba(255,255,255,0.1); border-radius:50%; bottom:-50px; left:-50px;"></div>

    <div style="position:relative; width:90%; max-width:400px; background:rgba(255,255,255,0.95); border-radius:30px; padding:50px 40px; box-shadow:0 25px 50px rgba(0,0,0,0.2); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.3); text-align:center;">

        <div style="width:80px; height:80px; background:#f0f4ff; border-radius:50%; display:flex; justify-content:center; align-items:center; margin:0 auto 20px; font-size:35px; box-shadow: 0 10px 20px rgba(0,0,0,0.05);">
            🔐
        </div>

        <h2 style="color:#2d3748; margin:0; font-size:1.8rem; font-weight:800; letter-spacing:-0.5px;">HỆ THỐNG E-FORM</h2>
        <p style="color:#718096; margin:8px 0 35px; font-size:0.95rem;">Vui lòng đăng nhập để tiếp tục</p>

        @if (ViewBag.Error != null)
        {
            <div style="background:#fff5f5; color:#c53030; border-left:4px solid #c53030; border-radius:8px; padding:12px; margin-bottom:25px; font-size:0.9rem; font-weight:600; text-align:left;">
                ⚠ @ViewBag.Error
            </div>
        }

        <form method="post" action="/DonXetDuyet/DangNhap" id="loginForm" style="text-align:left;">

            <input type="hidden" name="deviceName" id="deviceName" value="" />

            <div style="margin-bottom:20px;">
                <label style="display:block; font-weight:700; color:#4a5568; margin-bottom:8px; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.5px;">Tên đăng nhập / Email</label>
                <input type="text" name="email" value="@rememberedEmail" required placeholder="example@company.com"
                       onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 4px rgba(102,126,234,0.1)';"
                       onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none';"
                       style="width:100%; padding:14px 16px; border:2px solid #e2e8f0; border-radius:12px; font-size:1rem; outline:none; transition:all 0.3s ease; box-sizing:border-box;">
            </div>

            <div style="margin-bottom:20px;">
                <label style="display:block; font-weight:700; color:#4a5568; margin-bottom:8px; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.5px;">Mật khẩu</label>
                <input type="password" name="matKhau" required placeholder="••••••••"
                       onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 4px rgba(102,126,234,0.1)';"
                       onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none';"
                       style="width:100%; padding:14px 16px; border:2px solid #e2e8f0; border-radius:12px; font-size:1rem; outline:none; transition:all 0.3s ease; box-sizing:border-box;">
            </div>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; color:#718096; font-size:0.9rem;">
                    @* Tự động tích nếu đã từng "Ghi nhớ" *@
                    <input type="checkbox" name="rememberMe" value="true"
                           style="width:18px; height:18px; accent-color:#667eea; cursor:pointer;"
                           @(string.IsNullOrEmpty(rememberedEmail) ? "" : "checked")>
                    Duy trì đăng nhập vĩnh viễn
                </label>
                <a href="#" style="color:#667eea; text-decoration:none; font-size:0.9rem; font-weight:600;">Quên mật khẩu?</a>
            </div>

            <button type="submit"
                    onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(102,126,234,0.4)'; this.style.filter='brightness(1.1)';"
                    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(102,126,234,0.2)'; this.style.filter='brightness(1)';"
                    style="width:100%; padding:16px; border:none; border-radius:12px; background:linear-gradient(135deg, #667eea 0%, #764ba2 100%); color:#fff; font-weight:700; font-size:1rem; cursor:pointer; transition:all 0.3s ease; box-shadow:0 4px 12px rgba(102,126,234,0.2);">
                ĐĂNG NHẬP NGAY
            </button>
        </form>

        <div style="margin-top:35px; padding-top:25px; border-top:1px solid #edf2f7; font-size:0.9rem; color:#a0aec0;">
            Bạn gặp sự cố? <a href="#" style="color:#4a5568; font-weight:700; text-decoration:none;">Hỗ trợ kỹ thuật</a>
        </div>
    </div>

    <script>
        // Tự động nhận diện tên thiết bị khi trang web vừa tải xong
        window.onload = function() {
            var userAgent = navigator.userAgent;
            var deviceName = "Thiết bị không xác định";

            if (userAgent.match(/Windows/i)) deviceName = "Laptop Windows";
            else if (userAgent.match(/iPhone|iPad/i)) deviceName = "Thiết bị iOS";
            else if (userAgent.match(/Android/i)) deviceName = "Điện thoại Android";
            else if (userAgent.match(/Macintosh/i)) deviceName = "Máy tính Mac";

            // Gán giá trị vào thẻ input ẩn để gửi lên Controller
            document.getElementById('deviceName').value = deviceName;
        };
    </script>
</body>
</html>