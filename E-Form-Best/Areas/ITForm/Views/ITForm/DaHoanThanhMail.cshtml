
@{
    ViewData["Title"] = "DaHoanThanhMail";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
}

@model IEnumerable<E_Form_Best.Models.ITForm.Mail>

<h1 style="text-align:center; margin-bottom:20px; font-family:Arial, sans-serif; color:#333; font-weight:700;">Mail Hoàn Tất</h1>

<table style="width:100%; border-collapse:collapse; font-family:Arial, sans-serif; box-shadow:0 4px 15px rgba(0,0,0,0.1); border-radius:8px; overflow:hidden;">
    <thead>
        <tr style="background:linear-gradient(90deg,#007bff,#0056b3); color:white; text-align:left; font-weight:600;">
            <th style="padding:12px; border-bottom:2px solid #ddd;">Tên Form</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Ngày</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Bộ Phận</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Số Nhân Viên</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Email</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Người Tạo</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Thời gian tạo</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Người Duyệt</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Thời gian duyệt</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Admin</th>
            <th style="padding:12px; border-bottom:2px solid #ddd;">Thời gian Admin</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var mail in Model)
        {
            <tr onclick="window.location='/Mail/QuanLyMail/ChiTiet/@mail.Id'"
                style="cursor:pointer; transition: background-color 0.3s; border-bottom:1px solid #eee;"
                onmouseover="this.style.backgroundColor='#f1f7fb';"
                onmouseout="this.style.backgroundColor='white';">

                <td style="padding:10px;">@mail.TenForm</td>
                <td style="padding:10px;">@mail.Ngay?.ToString("dd/MM/yyyy")</td>
                <td style="padding:10px;">@mail.BoPhan</td>
                <td style="padding:10px;">@mail.SoNhanVien</td>
                <td style="padding:10px;">@mail.Email</td>
                <td style="padding:10px;">@mail.TenNguoiTao</td>
                <td style="padding:10px;">@mail.TimeTao?.ToString("dd/MM/yyyy HH:mm")</td>

                <!-- Người Duyệt với nền và màu chữ động -->
                <td style="padding:10px; font-weight:600;
                                       background-color:@(
                    mail.TenNguoiDuyet == null ? "white" :
                    mail.TenNguoiDuyet.Contains("Đơn đã hủy") ? "#f8d7da" : "#d4edda"
                                                                           );
                                       color:@(
                    mail.TenNguoiDuyet == null ? "#333" :
                    mail.TenNguoiDuyet.Contains("Đơn đã hủy") ? "red" : "green"
                                                                           );">
                    @mail.TenNguoiDuyet
                </td>

                <td style="padding:10px; background-color:@(
                    mail.TenNguoiDuyet == null ? "white" :
                    mail.TenNguoiDuyet.Contains("Đơn đã hủy") ? "#f8d7da" : "#d4edda"
                                                                           );">
                    @mail.TimeNguoiDuyet?.ToString("dd/MM/yyyy HH:mm")
                </td>

                <td style="padding:10px; font-weight:600;
                       background-color:@(
                    mail.TenAdmin == null ? "white" :
                    mail.TenAdmin.Contains("Đơn không đạt") ? "#f8d7da" : "#d4edda"
                                                   );
                       color:@(
                    mail.TenAdmin == null ? "#333" :
                    mail.TenAdmin.Contains("Đơn không đạt") ? "red" : "green"
                                                   );">
                    @mail.TenAdmin
                </td>

                <td style="padding:10px; background-color:@(
                    mail.TenAdmin == null ? "white" :
                    mail.TenAdmin.Contains("Đơn không đạt") ? "#f8d7da" : "#d4edda"
                                                   );">
                    @mail.TimeAdmin?.ToString("dd/MM/yyyy HH:mm")
                </td>

            </tr>
        }
    </tbody>
</table>
