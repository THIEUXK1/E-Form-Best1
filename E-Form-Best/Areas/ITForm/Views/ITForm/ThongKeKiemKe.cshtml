        if (item.idMay) {
        $('#btnXemMayTinhChiTiet').show().attr('onclick', `window.open('/QLKiemKe/ViewChiTietMayTinh?idMay=${item.idMay}', '_blank')`);
        } else {
        $('#btnXemMayTinhChiTiet').hide();
        }

        new bootstrap.Modal(document.getElementById('modalXemChiTietThietBi')).show();
        }

