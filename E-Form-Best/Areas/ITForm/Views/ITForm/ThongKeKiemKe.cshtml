        </div>

        </div>

        <div class="card border-0 shadow-sm mb-4" id="tableSection" style="border-radius: 15px;">
            <div class="card-header bg-white border-bottom pt-3 pb-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2" style="border-radius: 15px 15px 0 0;">
                <h6 class="fw-bold text-dark mb-0"><i class="fas fa-list-alt text-primary me-2"></i>Chi tiết danh sách (<span id="lblCountTable" class="text-danger">0</span> thiết bị)</h6>

                <div class="d-flex align-items-center">
                    <label class="me-2 small text-muted mb-0 fw-bold">Trạng thái đồng bộ phân trang:</label>
                    <span class="badge bg-light text-dark border font-weight-bold" id="lblSyncPageSize">30 dòng</span>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 1200px; overflow-y: auto;">
                    <table class="table table-hover align-middle mb-0" id="adminDataTable">
                        <thead class="table-light position-sticky top-0 shadow-sm" style="z-index: 10;">
                            <tr>
                                <th class="ps-4" width="70">ID</th>
                                <th>Thông tin máy tính & Vị trí</th>
                                <th>Loại & Ảnh đính kèm</th>
