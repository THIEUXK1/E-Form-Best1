@{
    ViewData["Title"] = "Dashboard - Thống kê tổng quan Kiểm Kê";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
    background-color: #f8fafc;
    }
    /* CSS cho các thẻ thống kê khi Hover và Click */
    .stat-card {
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 2px solid transparent !important;
    position: relative;
    overflow: hidden;
    }

    .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }

    .stat-card.active {
    border-color: #1e293b !important;
    transform: scale(1.03);
    box-shadow: 0 20px 35px rgba(0,0,0,0.15) !important;
    z-index: 10;
    }

    .stat-card.active::after {
    content: '\f058'; /* Icon check-circle */
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    position: absolute;
    top: 15px;
    right: 15px;
    color: #fff;
    font-size: 1.8rem;
    opacity: 0.9;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .card-icon-bg {
    position: absolute;
    right: -10px;
    bottom: -15px;
    font-size: 6rem;
    opacity: 0.15;
    transform: rotate(-15deg);
    transition: all 0.3s ease;
    }

    .stat-card:hover .card-icon-bg {
    transform: rotate(0deg) scale(1.1);
    opacity: 0.25;
    }

    .table-hover tbody tr:hover {
    background-color: #eef6fd;
    }

    #adminDataTable thead th {
    font-size: 12.5px;
    font-weight: 700;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    padding-top: 12px;
    padding-bottom: 12px;
    }

    /* Kẻ vằn nhẹ (zebra) + nới rộng vùng đọc từng dòng cho bảng chi tiết - chỉ áp dụng ở layout bảng desktop */
    @@media (min-width: 769px) {
    #adminDataTable tbody tr:nth-child(even) {
    background-color: #fafbfc;
    }

    #adminDataTable > tbody > tr > td {
    padding-top: 14px;
    padding-bottom: 14px;
    vertical-align: middle;
    }
    }

    /* Tùy chỉnh thanh phân trang */
    .pagination .page-item.active .page-link {
    background-color: #4f46e5;
    border-color: #4f46e5;
    }

    .pagination .page-link {
    color: #4f46e5;
    cursor: pointer;
    }

    .pagination .page-item.disabled .page-link {
    color: #6c757d;
    cursor: not-allowed;
    }

    /* ========================================================
    CSS CHO HỆ THỐNG DROPDOWN CHECKBOX (COMBOBOX KIỂU MỚI)
    ======================================================== */
    .dropdown-combo-btn {
    width: 100%;
    text-align: left;
    background-color: #fff;
    border: 1px solid #cbd5e1;
    padding: 0.375rem 2.25rem 0.375rem 0.75rem;
    font-size: 14px;
    font-weight: 500;
    border-radius: 0.375rem;
    color: #334155;
    position: relative;
    transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

    .dropdown-combo-btn:after {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    }

    .dropdown-combo-btn:focus {
    border-color: #a5b4fc;
    box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
    outline: 0;
    }

    .dropdown-combo-menu {
    width: 100%;
    max-height: 280px;
    overflow-y: auto;
    padding: 8px 0;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    z-index: 1050;
    }

    .dropdown-combo-item {
    display: flex;
    align-items: center;
    padding: 6px 16px;
    cursor: pointer;
    user-select: none;
    font-size: 13px;
    color: #334155;
    transition: background-color 0.15s ease;
    }

    .dropdown-combo-item:hover {
    background-color: #f1f5f9;
    }

    .dropdown-combo-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-right: 10px;
    cursor: pointer;
    accent-color: #4f46e5;
    flex-shrink: 0;
    }

    .dropdown-combo-item span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    }

    /* ========================================================
    CSS RESPONSIVE CHO MOBILE (CHỈ TÁC ĐỘNG KHI MÀN HÌNH NHỎ)
    ======================================================== */
    @@media (max-width: 768px) {
    .content-header .row > div {
    text-align: center !important;
    margin-bottom: 15px;
    }

    .content-header button {
    width: 100%;
    padding: 10px;
    font-size: 1.1rem;
    }

    .stat-card h2 {
    font-size: 1.5rem;
    }

    .card-icon-bg {
    font-size: 3.5rem;
    }

    .pagination {
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 10px;
    }

    #paginationInfo {
    text-align: center;
    width: 100%;
    margin-bottom: 10px !important;
    }

    #adminDataTable thead {
    display: none;
    }

    #adminDataTable tbody, #adminDataTable tr, #adminDataTable td {
    display: block;
    width: 100%;
    }

    #adminDataTable tr {
    margin-bottom: 1rem;
    background-color: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    padding: 10px 15px;
    }

    #adminDataTable td {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 10px 0 !important;
    border-bottom: 1px dashed #e2e8f0;
    }

    #adminDataTable td:last-child {
    border-bottom: 0;
    padding-bottom: 0 !important;
    padding-top: 15px !important;
    justify-content: center;
    }

    #adminDataTable td::before {
    content: attr(data-label);
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    font-size: 0.75rem;
    padding-right: 15px;
    text-align: left;
    flex-shrink: 0;
    max-width: 45%;
    }

    #adminDataTable td:last-child::before {
    display: none;
    }

    #adminDataTable td.ps-4 {
    padding-left: 0 !important;
    }

    .btn-action-mobile {
    width: 100%;
    padding: 12px !important;
    font-size: 1rem !important;
    justify-content: center;
    display: flex;
    align-items: center;
    }

    #adminDataTable tr.empty-row {
    display: block;
    text-align: center;
    border: none;
    box-shadow: none;
    background: transparent;
    padding: 0;
    }

    #adminDataTable tr.empty-row td {
    justify-content: center;
    border: none;
    }

    #adminDataTable tr.empty-row td::before {
    display: none;
    }
    }

    /* CSS CHO TIMELINE NHẬT KÝ KIỂM KÊ (giống trang Thiết bị) */
    .timeline-check {
    position: relative;
    border-left: 3px solid #e2e8f0;
    padding-left: 20px;
    margin-left: 10px;
    }

    .timeline-check-item {
    position: relative;
    margin-bottom: 25px;
    }

    .timeline-check-item::before {
    content: "";
    position: absolute;
    left: -27px;
    top: 4px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: #10b981;
    border: 2px solid #fff;
    box-shadow: 0 0 0 3px #d1fae5;
    }
</style>

<div class="content-header py-3">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6 col-12 mb-2 mb-md-0">
                <h4 class="m-0 fw-bold" style="color: #1e293b; letter-spacing: -0.5px;">
                    <i class="fas fa-chart-line me-2 text-primary"></i> Dashboard Tổng Quan Tài Sản IT
                </h4>
            </div>
            <div class="col-md-6 col-12 text-md-end">
                <button class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold me-2" onclick="exportBaoCaoSoLuong()">
                    <i class="fas fa-chart-pie me-1"></i> Xuất Báo Cáo Số Lượng
                </button>
                <button class="btn btn-outline-dark rounded-pill px-4 shadow-sm fw-bold me-2" onclick="exportBaoCaoThongThuong()">
                    <i class="fas fa-list-alt me-1"></i> Xuất Báo Cáo Thông Thường
                </button>
                <button class="btn btn-success rounded-pill px-4 shadow-sm fw-bold" onclick="exportToExcel()">
                    <i class="fas fa-file-excel me-1"></i> Xuất Báo Cáo Bản Quyền
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px; background: #fff;">
            <div class="card-body p-3">
                <div class="row g-3 align-items-end">

                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-search text-info"></i> Tìm Kiếm Nhanh</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="filterText" class="form-control border-start-0 ps-0" placeholder="S/N, Hostname, Account, Tên Vị Trí, Mã TK..." style="height: 38px;">
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-3 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-sort-alpha-down text-dark"></i> Sắp xếp danh sách</label>
                        <select id="filterSort" class="form-select rounded-3 shadow-sm border" style="height: 38px; font-weight: 500;">
                            <option value="">Mặc định (Theo ID)</option>
                            <option value="host_asc">Tên máy Hostname (A-Z)</option>
                            <option value="host_desc">Tên máy Hostname (Z-A)</option>
                            <option value="name_asc">Tên Vị Trí (A-Z)</option>
                            <option value="name_desc">Tên Vị Trí (Z-A)</option>
                        </select>
                    </div>

                    <div class="col-lg-2 col-md-3 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-list-ol text-secondary"></i> Hiển thị / Trang</label>
                        <select id="filterLimit" class="form-select rounded-3 shadow-sm border" style="height: 38px; font-weight: bold;">
                            <option value="10">10 dòng</option>
                            <option value="20">20 dòng</option>
                            <option value="30">30 dòng</option>
                            <option value="50">50 dòng</option>
                            <option value="100" selected>100 dòng</option>
                            <option value="all">Hiển thị tất cả</option>
                        </select>
                    </div>

                    <div class="col-lg-3 col-md-12 col-sm-12 text-md-end text-start">
                        <button type="button" id="btnToggleFilters" class="btn btn-outline-primary rounded-3 px-3 fw-bold" style="height: 38px;" onclick="toggleAdvancedFilters()">
                            <i class="fas fa-sliders-h me-1"></i> <span id="lblToggleText">Bộ lọc nâng cao</span>
                        </button>
                        <button class="btn btn-outline-secondary rounded-pill px-3 ms-1" onclick="clearFilters()" style="height: 38px;">
                            <i class="fas fa-sync-alt"></i> Xóa bộ lọc
                        </button>
                    </div>

                    <div class="col-12 p-0" id="boxAdvancedFiltersArea" style="display: none;">
                        <div class="row m-0 g-3 align-items-end w-100 pt-2">
                            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                                <label class="form-label fw-bold small text-muted mb-1 d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-building text-primary"></i> Công ty</span>
                                    <span class="form-check form-switch m-0" title="Bật: các mục đã chọn sẽ bị LOẠI TRỪ, xuất toàn bộ phần còn lại">
                                        <input class="form-check-input" type="checkbox" role="switch" id="chkExcludeCongTy" style="cursor:pointer;">
                                        <label class="form-check-label text-muted" for="chkExcludeCongTy" style="font-size:10px; cursor:pointer;">Loại trừ</label>
                                    </span>
                                </label>
                                <div class="dropdown">
                                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropCongTy" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                        -- Tất cả --
                                    </button>
                                    <div class="dropdown-menu dropdown-combo-menu" id="menuCongTy" aria-labelledby="btnDropCongTy">
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                                <label class="form-label fw-bold small text-muted mb-1 d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-sitemap text-success"></i> Bộ phận</span>
                                    <span class="form-check form-switch m-0" title="Bật: các mục đã chọn sẽ bị LOẠI TRỪ, xuất toàn bộ phần còn lại">
                                        <input class="form-check-input" type="checkbox" role="switch" id="chkExcludeBoPhan" style="cursor:pointer;">
                                        <label class="form-check-label text-muted" for="chkExcludeBoPhan" style="font-size:10px; cursor:pointer;">Loại trừ</label>
                                    </span>
                                </label>
                                <div class="dropdown">
                                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropBoPhan" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                        -- Tất cả --
                                    </button>
                                    <div class="dropdown-menu dropdown-combo-menu" id="menuBoPhan" aria-labelledby="btnDropBoPhan">
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                                <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-tags text-warning"></i> Loại thiết bị</label>
                                <div class="dropdown">
                                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropLoai" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                        -- Tất cả --
                                    </button>
                                    <div class="dropdown-menu dropdown-combo-menu" id="menuLoai" aria-labelledby="btnDropLoai">
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-lg-3 col-md-4 col-sm-6">
                                <label class="form-label fw-bold small text-muted mb-1"><i class="fab fa-windows text-primary"></i> Bản quyền Windows</label>
                                <div class="dropdown">
                                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropWin" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                        -- Tất cả --
                                    </button>
                                    <div class="dropdown-menu dropdown-combo-menu" id="menuWin" aria-labelledby="btnDropWin">
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-lg-3 col-md-4 col-sm-6">
                                <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-file-word text-success"></i> Bản quyền Office</label>
                                <div class="dropdown">
                                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropOffice" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                        -- Tất cả --
                                    </button>
                                    <div class="dropdown-menu dropdown-combo-menu" id="menuOffice" aria-labelledby="btnDropOffice">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card active" id="card-all" onclick="setCardFilter('', 'card-all')" style="border-radius:15px; background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Tổng Tài Sản</div>
                        <h2 class="fw-bold mb-0" id="cardTong">0</h2>
                        <i class="fas fa-desktop card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-hd" onclick="setCardFilter('hoạt động', 'card-hd')" style="border-radius:15px; background: linear-gradient(135deg, #10b981, #047857);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Hoạt động</div>
                        <h2 class="fw-bold mb-0" id="cardHoatDong">0</h2>
                        <i class="fas fa-check-circle card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-hong" onclick="setCardFilter('hỏng', 'card-hong')" style="border-radius:15px; background: linear-gradient(135deg, #ef4444, #b91c1c);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Hỏng / Mất</div>
                        <h2 class="fw-bold mb-0" id="cardHong">0</h2>
                        <i class="fas fa-car-crash card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-bt" onclick="setCardFilter('bảo trì', 'card-bt')" style="border-radius:15px; background: linear-gradient(135deg, #8b5cf6, #6d28d9);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Bảo trì / Sửa chữa</div>
                        <h2 class="fw-bold mb-0" id="cardBaoTri">0</h2>
                        <i class="fas fa-tools card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-dark border-0 shadow-sm h-100 stat-card" id="card-chuacheck" onclick="setCardFilter('chuacheck', 'card-chuacheck')" style="border-radius:15px; background: linear-gradient(135deg, #fcd34d, #f59e0b);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1"><i class="fas fa-exclamation-triangle me-1"></i>Chưa Kiểm Kê</div>
                        <h2 class="fw-bold mb-0" id="cardChuaCheck">0</h2>
                        <i class="fas fa-search-minus card-icon-bg" style="color: #000;"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-xoa" onclick="setCardFilter('xóa', 'card-xoa')" style="border-radius:15px; background: linear-gradient(135deg, #64748b, #334155);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Thùng Rác</div>
                        <h2 class="fw-bold mb-0" id="cardXoa">0</h2>
                        <i class="fas fa-trash-alt card-icon-bg"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBieuDo" aria-expanded="false" aria-controls="collapseBieuDo" id="btnToggleBieuDo">
                <i class="fas fa-chevron-right me-1" id="iconToggleBieuDo"></i> <span id="textToggleBieuDo">Xem biểu đồ thống kê</span>
            </button>
        </div>

        <div class="collapse" id="collapseBieuDo">

        <div class="row g-4 mb-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-building text-primary me-2"></i>Tài sản theo Công ty</h6>
                        <small class="text-muted" style="font-size: 11px;">(Nhấn vào biểu đồ để lọc)</small>
                    </div>
                    <div class="card-body d-flex justify-content-center" style="position: relative; height: 300px; width: 100%;">
                        <canvas id="chartCongTy" style="max-height: 280px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-laptop text-info me-2"></i>Thống kê theo Loại Thiết bị (Biểu đồ Cột)</h6>
                        <small class="text-muted" style="font-size: 11px;">(Nhấn vào biểu đồ để lọc)</small>
                    </div>
                    <div class="card-body" style="position: relative; height: 300px; width: 100%;">
                        <canvas id="chartLoai" style="max-height: 280px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-sitemap text-success me-2"></i>Phân bổ thiết bị theo Bộ phận (Theo Công Ty)</h6>
                        <small class="text-muted" style="font-size: 11px;">(Nhấn vào từng cột bộ phận để lọc danh sách)</small>
