        }).fail(function () {
        $('#tbodyLichSu').html('<tr><td colspan="4" class="text-center text-danger py-4"><i class="fas fa-exclamation-circle me-1"></i> Không thể kết nối tới máy chủ!</td></tr>');
        });
        }

        // Xem Nhật ký kiểm kê thiết bị: các lần Xác nhận kiểm kê trước đó kèm ảnh bằng chứng (khác với Lịch sử thao tác ở trên)
        function xemNhatKyKiemKeThietBi(idThietBi, tenMayTinh, tenViTri) {
