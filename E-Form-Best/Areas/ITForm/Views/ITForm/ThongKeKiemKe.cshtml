        }

        let dateNowStr = new Date().toLocaleString('vi-VN');
        let totalCount = filteredExportData.length;
        const wb = XLSX.utils.book_new();

        // Tô đậm khối thẻ KPI đầu báo cáo theo tông màu thương hiệu xanh cỏ non của hệ thống
        // (styleWorksheetUniversal không nhận diện được nhãn KPI tùy biến nên style thủ công tại đây)
        function toKhoiKpi(ws, rowLabel, rowValue, cols) {
            cols.forEach(function (c) {
                let labelRef = XLSX.utils.encode_cell({ r: rowLabel, c: c });
                let valueRef = XLSX.utils.encode_cell({ r: rowValue, c: c });
                if (ws[labelRef] && ws[labelRef].v !== "") {
                    ws[labelRef].s = {
                        font: { name: "Segoe UI", size: 10, bold: true, color: { rgb: "FFFFFF" } },
                        fill: { fgColor: { rgb: "2D4201" } },
                        alignment: { horizontal: "center", vertical: "center" },
                        border: { top: { style: "thin", color: { rgb: "1A2E05" } }, bottom: { style: "thin", color: { rgb: "1A2E05" } }, left: { style: "thin", color: { rgb: "1A2E05" } }, right: { style: "thin", color: { rgb: "1A2E05" } } }
                    };
                }
                if (ws[valueRef] && ws[valueRef].v !== "") {
                    ws[valueRef].s = {
                        font: { name: "Segoe UI", size: 16, bold: true, color: { rgb: "2D4201" } },
                        fill: { fgColor: { rgb: "F7FEE7" } },
                        alignment: { horizontal: "center", vertical: "center" },
                        border: { top: { style: "thin", color: { rgb: "BEF264" } }, bottom: { style: "thin", color: { rgb: "BEF264" } }, left: { style: "thin", color: { rgb: "BEF264" } }, right: { style: "thin", color: { rgb: "BEF264" } } }
                    };
                }
            });
        }

        // Merge dòng tiêu đề chính + dòng ngày lập cho gọn, tránh bị kẻ ô rời rạc
        function mergeBanner(ws, rowIdx, lastCol) {
            ws['!merges'] = ws['!merges'] || [];
            ws['!merges'].push({ s: { r: rowIdx, c: 0 }, e: { r: rowIdx, c: lastCol } });
        }

        // ----------------------------------------------------
        // SHEET 1: TỔNG HỢP SỐ LƯỢNG LAPTOP / MÁY TÍNH (MÁY CÂY) THEO TỪNG BỘ PHẬN
        // ----------------------------------------------------
        let deptSummaryMap = {};
        filteredExportData.forEach(item => {
            let bp = item.tenBoPhan || 'Chưa gắn';
            if (!deptSummaryMap[bp]) deptSummaryMap[bp] = { laptop: 0, mayTinh: 0, khac: 0 };
            let loai = (item.loaiThietBi || '').trim().toLowerCase();
            if (loai === 'laptop') deptSummaryMap[bp].laptop++;
            else if (loai === 'máy tính') deptSummaryMap[bp].mayTinh++;
            else deptSummaryMap[bp].khac++;
