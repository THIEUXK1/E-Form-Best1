        </div>
        </div>`;
        });
        $('#boxTimelineCheckResultThongKe').html(timelineHtml);
        } else {
        $('#boxTimelineCheckResultThongKe').html(`<div class="text-danger small">Lỗi tải nhật ký: ${res.message}</div>`);
        }
        }).fail(function () {
        $('#boxTimelineCheckResultThongKe').html('<div class="text-danger small">Không thể kết nối tới máy chủ.</div>');
