        // ==========================================
        // HÀM HELPER TỰ ĐỘNG ĐỔ MÀU SIÊU ĐẸP & KẺ VIỀN CELL
        // ==========================================
        function styleWorksheetUniversal(ws) {
            if (!ws || !ws['!ref']) return;
            const range = XLSX.utils.decode_range(ws['!ref']);

            // Các dòng "banner" chỉ có duy nhất 1 ô chứa dữ liệu (tiêu đề báo cáo, dòng ngày lập, tiêu đề mục I./II...) được thiết kế
            // để tự tràn chữ ra các cột trống bên phải - không được tính vào bề rộng cột thật, nếu không cột A sẽ bị kéo giãn quá đà.
            let bannerRows = new Set();
            for (let R = range.s.r; R <= range.e.r; ++R) {
                let filledCols = 0;
                for (let C = range.s.c; C <= range.e.c; ++C) {
                    let ref = XLSX.utils.encode_cell({ r: R, c: C });
                    if (ws[ref] && ws[ref].v !== undefined && ws[ref].v !== null && ws[ref].v !== "") filledCols++;
                }
                if (filledCols <= 1) bannerRows.add(R);
            }

            // Tự tính bề rộng từng cột theo nội dung dài nhất đang có, lấy độ rộng khai báo thủ công (nếu có) làm mức tối thiểu.
            // Tránh trường hợp các cột không được khai báo trong '!cols' (VD: cột nhãn/giá trị của khối thẻ KPI Tổng quan)
            // bị Excel co về bề rộng mặc định ~8.43 ký tự, gây vỡ dòng/chữ bị cắt xấu.
            let manualCols = ws['!cols'] || [];
            let autoCols = [];
            for (let C = range.s.c; C <= range.e.c; ++C) {
                let maxLen = 8;
                for (let R = range.s.r; R <= range.e.r; ++R) {
                    if (bannerRows.has(R)) continue;
                    let ref = XLSX.utils.encode_cell({ r: R, c: C });
                    let cellVal = ws[ref] ? ws[ref].v : null;
                    if (cellVal !== null && cellVal !== undefined && cellVal !== "") {
                        let len = String(cellVal).length;
                        if (len > maxLen) maxLen = len;
                    }
                }
                let autoWch = Math.min(maxLen + 3, 45);
                let manualWch = manualCols[C] ? manualCols[C].wch : 0;
                autoCols.push({ wch: Math.max(autoWch, manualWch) });
            }
            ws['!cols'] = autoCols;

            const thinBorder = {
                top: { style: "thin", color: { rgb: "CBD5E1" } },
                bottom: { style: "thin", color: { rgb: "CBD5E1" } },
                left: { style: "thin", color: { rgb: "CBD5E1" } },
                right: { style: "thin", color: { rgb: "CBD5E1" } }
            };

            let rowsMeta = [];
            for (let i = 0; i <= range.e.r; i++) {
                rowsMeta.push({ hpt: i === 0 ? 35 : 21 });
            }

            for (let R = range.s.r; R <= range.e.r; ++R) {
                let isMainTitle = (R === 0);
                let isSectionHeading = false;
                let isTableHeader = false;
                let isSummaryRow = false;
                let isMetadata = (R === 1 || R === 2);
                let isKpiLabelRow = false;
                let isKpiValueRow = false;

                // Nhận diện khối KPI Summary Grid (Tab 1 hàng 4, 5 hoặc Tab 2 hàng 4, 5)
                let firstCellRef = XLSX.utils.encode_cell({ r: R, c: range.s.c });
                let firstCellVal = ws[firstCellRef] ? String(ws[firstCellRef].v) : "";

                if (firstCellVal.includes("TỔNG THIẾT BỊ") || firstCellVal.includes("KPI CỐT LÕI") || (ws[XLSX.utils.encode_cell({r:R, c:1})] && String(ws[XLSX.utils.encode_cell({r:R, c:1})].v).includes("TỔNG THIẾT BỊ"))) {
                    isKpiLabelRow = true;
                    isMetadata = false;
                }
                // Nếu hàng trên là KPI label thì hàng này là KPI value
                if (R > 0) {
                    let prevCellRef = XLSX.utils.encode_cell({ r: R - 1, c: 1 });
                    let prevCellVal = ws[prevCellRef] ? String(ws[prevCellRef].v) : "";
                    if (prevCellVal.includes("TỔNG THIẾT BỊ") || (ws[XLSX.utils.encode_cell({r:R-1, c:0})] && String(ws[XLSX.utils.encode_cell({r:R-1, c:0})].v).includes("KPI CỐT LÕI"))) {
                        isKpiValueRow = true;
                        isMetadata = false;
                    }
                }

                if (firstCellVal.startsWith("I. ") || firstCellVal.startsWith("II. ") || firstCellVal.startsWith("III. ") || firstCellVal.startsWith("KẾ HOẠCH")) {
                    isSectionHeading = true;
                    isMetadata = false;
                }
                if (firstCellVal === "STT" || firstCellVal === "Trạng Thái Bản Quyền") {
                    isTableHeader = true;
                    isMetadata = false;
                }

                for (let C = range.s.c; C <= range.e.c; ++C) {
                    let cellRef = XLSX.utils.encode_cell({ r: R, c: C });
                    if (ws[cellRef]) {
                        let valStr = String(ws[cellRef].v);
                        if (valStr.includes("TỔNG CỘNG") || valStr.includes("Tổng cộng")) {
                            isSummaryRow = true;
                            break;
                        }
                    }
                }

                for (let C = range.s.c; C <= range.e.c; ++C) {
                    let cellRef = XLSX.utils.encode_cell({ r: R, c: C });
                    if (!ws[cellRef]) continue;

                    let cell = ws[cellRef];
                    cell.s = {
                        font: { name: "Segoe UI", size: 10, color: { rgb: "334155" } },
                        alignment: { vertical: "center" }
                    };

                    if (isMainTitle) {
                        cell.s.font = { name: "Segoe UI", size: 16, bold: true, color: { rgb: "1E293B" } };
                        cell.s.alignment = { horizontal: "left", vertical: "center" };
                    }
                    else if (isMetadata) {
                        cell.s.font = { name: "Segoe UI", size: 10, italic: true, color: { rgb: "64748B" } };
                    }
                    else if (isSectionHeading) {
                        cell.s.font = { name: "Segoe UI", size: 12, bold: true, color: { rgb: "4F46E5" } };
                        cell.s.alignment = { horizontal: "left", vertical: "center" };
                    }
                    else if (isKpiLabelRow) {
                        if (cell.v !== "") {
                            cell.s.fill = { fgColor: { rgb: "3B82F6" } };
                            cell.s.font = { name: "Segoe UI", size: 10, bold: true, color: { rgb: "FFFFFF" } };
                            cell.s.alignment = { horizontal: "center", vertical: "center" };
                            cell.s.border = thinBorder;
                        }
                    }
                    else if (isKpiValueRow) {
                        if (cell.v !== "") {
                            cell.s.fill = { fgColor: { rgb: "EFF6FF" } };
                            cell.s.font = { name: "Segoe UI", size: 14, bold: true, color: { rgb: "1D4ED8" } };
                            cell.s.alignment = { horizontal: "center", vertical: "center" };
                            cell.s.border = thinBorder;
                            rowsMeta[R] = { hpt: 30 };
                        }
                    }
                    else if (isTableHeader) {
                        cell.s.fill = { fgColor: { rgb: "4F46E5" } };
                        cell.s.font = { name: "Segoe UI", size: 11, bold: true, color: { rgb: "FFFFFF" } };
                        cell.s.alignment = { horizontal: "center", vertical: "center", wrapText: true };
                        cell.s.border = {
                            top: { style: "medium", color: { rgb: "1E293B" } },
                            bottom: { style: "medium", color: { rgb: "1E293B" } },
                            left: { style: "thin", color: { rgb: "CBD5E1" } },
                            right: { style: "thin", color: { rgb: "CBD5E1" } }
                        };
                    }
                    else if (isSummaryRow) {
                        cell.s.fill = { fgColor: { rgb: "F1F5F9" } };
                        cell.s.font = { name: "Segoe UI", size: 10, bold: true, color: { rgb: "0F172A" } };
                        cell.s.border = {
                            top: { style: "thin", color: { rgb: "CBD5E1" } },
                            bottom: { style: "double", color: { rgb: "1E293B" } },
                            left: { style: "thin", color: { rgb: "CBD5E1" } },
                            right: { style: "thin", color: { rgb: "CBD5E1" } }
                        };
                        if (C === 0) cell.s.alignment = { horizontal: "center" };
                    }
                    else {
                        cell.s.border = thinBorder;

                        if (C === 0 || C === 1 || cell.v === "Đạt chuẩn ✔" || cell.v === "Cần xác minh ⚠" || cell.v === "Nguy hiểm ✘") {
                            cell.s.alignment.horizontal = "center";
                        }

                        if (typeof cell.v === "string") {
                            let valLower = cell.v.toLowerCase().trim();
                            if (valLower.includes("đạt chuẩn") || valLower === "hoạt động") {
                                cell.s.fill = { fgColor: { rgb: "E8F5E9" } };
                                cell.s.font.color = { rgb: "2E7D32" };
                                cell.s.font.bold = true;
                            } else if (valLower.includes("nguy hiểm") || valLower.includes("khẩn cấp") || valLower === "chưa có bản quyền") {
                                cell.s.fill = { fgColor: { rgb: "FFEBEE" } };
                                cell.s.font.color = { rgb: "C62828" };
                                cell.s.font.bold = true;
                            } else if (valLower.includes("cần xác minh") || valLower.includes("cao") || valLower.includes("quá hạn")) {
                                cell.s.fill = { fgColor: { rgb: "FFF8E1" } };
                                cell.s.font.color = { rgb: "F57F17" };
                                cell.s.font.bold = true;
                            }
                        }
                    }
                }
            }
            if (ws['!rows']) ws['!rows'] = rowsMeta;
        }

        // ==========================================
        // HÀM XUẤT EXCEL BÁO CÁO SỐ LƯỢNG TỔNG QUAN (BAO QUÁT TẤT CẢ LOẠI THIẾT BỊ)
        // ==========================================
        window.exportBaoCaoSoLuong = function() {
        if (filteredExportData.length === 0) {
            Swal.fire("Thông báo", "Không có dữ liệu để xuất Excel!", "info");
            return;
        }

        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);
        let dateNowStr = new Date().toLocaleString('vi-VN');
        const wb = XLSX.utils.book_new();

        let totalCount = filteredExportData.length;
        let countHD = 0, countBaoTri = 0, countHong = 0, countXoa = 0, countChuaCheck = 0;

        let mapLoai = {};
        let mapCongTy = {};
        let deptMap = {};

        filteredExportData.forEach(x => {
            let t = (x.tenTrangThai || '').toLowerCase();
            if (t.includes('xóa') || x.ngayXoa != null) countXoa++;
            else if (t.includes('hoạt động')) countHD++;
            else if (t.includes('bảo trì')) countBaoTri++;
            else if (t.includes('hỏng')) countHong++;

            if (!x.thoiGianCheck || new Date(x.thoiGianCheck) < fourMonthsAgo) countChuaCheck++;

            let loai = x.loaiThietBi || 'Khác';
            mapLoai[loai] = (mapLoai[loai] || 0) + 1;

            let cty = x.tenCongTy || 'Chưa gắn';
            mapCongTy[cty] = (mapCongTy[cty] || 0) + 1;

            let bp = x.tenBoPhan || 'Chưa gắn';
            let key = cty + "||" + bp;
            if (!deptMap[key]) deptMap[key] = { cty: cty, bp: bp, total: 0 };
            deptMap[key].total++;
        });

        // ----------------------------------------------------
        // TAB 1: TỔNG QUAN SỐ LƯỢNG
        // ----------------------------------------------------
        let sheet1Rows = [
            ["BÁO CÁO SỐ LƯỢNG TỔNG QUAN TÀI SẢN IT (TẤT CẢ LOẠI THIẾT BỊ)"],
            ["Ngày lập báo cáo: " + dateNowStr + "  |  Nguồn dữ liệu: Hệ thống Dashboard quản trị tài sản"],
            [],
            ["", "TỔNG THIẾT BỊ", "", "HOẠT ĐỘNG", "", "HỎNG / MẤT", "", "BẢO TRÌ", "", "CHƯA KIỂM KÊ", "", "THÙNG RÁC"],
            ["", totalCount, "", countHD, "", countHong, "", countBaoTri, "", countChuaCheck, "", countXoa],
            [],
            ["I. SỐ LƯỢNG THEO LOẠI THIẾT BỊ"],
            ["Loại Thiết Bị", "Số Lượng", "Tỷ Lệ (%)"]
        ];

        Object.entries(mapLoai).sort((a, b) => b[1] - a[1]).forEach(([key, val]) => {
            let pct = totalCount > 0 ? (val / totalCount * 100).toFixed(1) : "0.0";
            sheet1Rows.push([key, val, pct + "%"]);
        });
        sheet1Rows.push(["TỔNG CỘNG", totalCount, "100.0%"]);

        sheet1Rows.push([], [], ["II. SỐ LƯỢNG THEO CÔNG TY"], ["Công Ty", "Số Lượng", "Tỷ Lệ (%)"]);
        Object.entries(mapCongTy).sort((a, b) => b[1] - a[1]).forEach(([key, val]) => {
            let pct = totalCount > 0 ? (val / totalCount * 100).toFixed(1) : "0.0";
            sheet1Rows.push([key, val, pct + "%"]);
        });
        sheet1Rows.push(["TỔNG CỘNG", totalCount, "100.0%"]);

        const ws1 = XLSX.utils.aoa_to_sheet(sheet1Rows);
        ws1['!cols'] = [{ wch: 35 }, { wch: 15 }, { wch: 15 }];
        styleWorksheetUniversal(ws1);
        XLSX.utils.book_append_sheet(wb, ws1, "1. Tổng Quan");

        // ----------------------------------------------------
        // TAB 2: SỐ LƯỢNG THEO BỘ PHẬN (THEO CÔNG TY)
        // ----------------------------------------------------
        let sheet2Rows = [
            ["SỐ LƯỢNG THIẾT BỊ THEO PHÒNG BAN BỘ PHẬN"],
            ["Ngày xuất báo cáo: " + dateNowStr + " | Tổng số thiết bị: " + totalCount],
            [],
            ["STT", "Công Ty", "Bộ Phận", "Tổng Số Máy", "Tỷ Lệ (%)"]
        ];

        Object.values(deptMap).sort((a, b) => b.total - a.total).forEach((item, idx) => {
            let pct = totalCount > 0 ? (item.total / totalCount * 100).toFixed(1) : "0.0";
            sheet2Rows.push([idx + 1, item.cty, item.bp, item.total, pct + "%"]);
        });

        const ws2 = XLSX.utils.aoa_to_sheet(sheet2Rows);
