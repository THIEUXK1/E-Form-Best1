@{
    ViewData["Title"] = "Dashboard - Thống kê tổng quan Kiểm Kê";
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
    background-color: #f8fafc;
    }
    /* CSS cho các thẻ thống kê khi Hover và Click */
    .stat-card {
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 2px solid transparent !important;
    position: relative;
    overflow: hidden;
    }

    .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }

    .stat-card.active {
    border-color: #1e293b !important;
    transform: scale(1.03);
    box-shadow: 0 20px 35px rgba(0,0,0,0.15) !important;
    z-index: 10;
    }

    .stat-card.active::after {
    content: '\f058'; /* Icon check-circle */
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    position: absolute;
    top: 15px;
    right: 15px;
    color: #fff;
    font-size: 1.8rem;
    opacity: 0.9;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .card-icon-bg {
    position: absolute;
    right: -10px;
    bottom: -15px;
    font-size: 6rem;
    opacity: 0.15;
    transform: rotate(-15deg);
    transition: all 0.3s ease;
    }

    .stat-card:hover .card-icon-bg {
    transform: rotate(0deg) scale(1.1);
    opacity: 0.25;
    }

    .table-hover tbody tr:hover {
    background-color: #f1f5f9;
    }

    /* Tùy chỉnh thanh phân trang */
    .pagination .page-item.active .page-link {
    background-color: #4f46e5;
    border-color: #4f46e5;
    }

    .pagination .page-link {
    color: #4f46e5;
    cursor: pointer;
    }

    .pagination .page-item.disabled .page-link {
    color: #6c757d;
    cursor: not-allowed;
    }

    /* ========================================================
    CSS CHO HỆ THỐNG DROPDOWN CHECKBOX (COMBOBOX KIỂU MỚI)
    ======================================================== */
    .dropdown-combo-btn {
    width: 100%;
    text-align: left;
    background-color: #fff;
    border: 1px solid #cbd5e1;
    padding: 0.375rem 2.25rem 0.375rem 0.75rem;
    font-size: 14px;
    font-weight: 500;
    border-radius: 0.375rem;
    color: #334155;
    position: relative;
    transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

    .dropdown-combo-btn:after {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    }

    .dropdown-combo-btn:focus {
    border-color: #a5b4fc;
    box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
    outline: 0;
    }

    .dropdown-combo-menu {
    width: 100%;
    max-height: 280px;
    overflow-y: auto;
    padding: 8px 0;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    z-index: 1050;
    }

    .dropdown-combo-item {
    display: flex;
    align-items: center;
    padding: 6px 16px;
    cursor: pointer;
    user-select: none;
    font-size: 13px;
    color: #334155;
    transition: background-color 0.15s ease;
    }

    .dropdown-combo-item:hover {
    background-color: #f1f5f9;
    }

    .dropdown-combo-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-right: 10px;
    cursor: pointer;
    accent-color: #4f46e5;
    flex-shrink: 0;
    }

    .dropdown-combo-item span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    }

    /* ========================================================
    CSS RESPONSIVE CHO MOBILE (CHỈ TÁC ĐỘNG KHI MÀN HÌNH NHỎ)
    ======================================================== */
    @@media (max-width: 768px) {
    .content-header .row > div {
    text-align: center !important;
    margin-bottom: 15px;
    }

    .content-header button {
    width: 100%;
    padding: 10px;
    font-size: 1.1rem;
    }

    .stat-card h2 {
    font-size: 1.5rem;
    }

    .card-icon-bg {
    font-size: 3.5rem;
    }

    .pagination {
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 10px;
    }

    #paginationInfo {
    text-align: center;
    width: 100%;
    margin-bottom: 10px !important;
    }

    #adminDataTable thead {
    display: none;
    }

    #adminDataTable tbody, #adminDataTable tr, #adminDataTable td {
    display: block;
    width: 100%;
    }

    #adminDataTable tr {
    margin-bottom: 1rem;
    background-color: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    padding: 10px 15px;
    }

    #adminDataTable td {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 10px 0 !important;
    border-bottom: 1px dashed #e2e8f0;
    }

    #adminDataTable td:last-child {
    border-bottom: 0;
    padding-bottom: 0 !important;
    padding-top: 15px !important;
    justify-content: center;
    }

    #adminDataTable td::before {
    content: attr(data-label);
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    font-size: 0.75rem;
    padding-right: 15px;
    text-align: left;
    flex-shrink: 0;
    max-width: 45%;
    }

    #adminDataTable td:last-child::before {
    display: none;
    }

    #adminDataTable td.ps-4 {
    padding-left: 0 !important;
    }

    .btn-action-mobile {
    width: 100%;
    padding: 12px !important;
    font-size: 1rem !important;
    justify-content: center;
    display: flex;
    align-items: center;
    }

    #adminDataTable tr.empty-row {
    display: block;
    text-align: center;
    border: none;
    box-shadow: none;
    background: transparent;
    padding: 0;
    }

    #adminDataTable tr.empty-row td {
    justify-content: center;
    border: none;
    }

    #adminDataTable tr.empty-row td::before {
    display: none;
    }
    }
</style>

<div class="content-header py-3">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6 col-12 mb-2 mb-md-0">
                <h4 class="m-0 fw-bold" style="color: #1e293b; letter-spacing: -0.5px;">
                    <i class="fas fa-chart-line me-2 text-primary"></i> Dashboard Tổng Quan Tài Sản IT
                </h4>
            </div>
            <div class="col-md-6 col-12 text-md-end">
                <button class="btn btn-success rounded-pill px-4 shadow-sm fw-bold" onclick="exportToExcel()">
                    <i class="fas fa-file-excel me-1"></i> Xuất Báo Cáo Excel
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px; background: #fff;">
            <div class="card-body p-3">
                <div class="row g-3 align-items-end">

                    <div class="col-lg-2 col-md-4 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-building text-primary"></i> Công ty</label>
                        <div class="dropdown">
                            <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropCongTy" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                -- Tất cả --
                            </button>
                            <div class="dropdown-menu dropdown-combo-menu" id="menuCongTy" aria-labelledby="btnDropCongTy">
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-sitemap text-success"></i> Bộ phận</label>
                        <div class="dropdown">
                            <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropBoPhan" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                -- Tất cả --
                            </button>
                            <div class="dropdown-menu dropdown-combo-menu" id="menuBoPhan" aria-labelledby="btnDropBoPhan">
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-tags text-warning"></i> Loại thiết bị</label>
                        <div class="dropdown">
                            <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropLoai" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                -- Tất cả --
                            </button>
                            <div class="dropdown-menu dropdown-combo-menu" id="menuLoai" aria-labelledby="btnDropLoai">
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-5 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-search text-info"></i> Tìm Kiếm Nhanh</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="filterText" class="form-control border-start-0 ps-0" placeholder="S/N, Hostname, Account, Tên Vị Trí, Mã TK..." style="height: 38px;">
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-3 col-sm-6">
                        <label class="form-label fw-bold small text-muted mb-1"><i class="fas fa-sort-alpha-down text-dark"></i> Sắp xếp danh sách</label>
                        <select id="filterSort" class="form-select rounded-3 shadow-sm border" style="height: 38px; font-weight: 500;">
                            <option value="">Mặc định (Theo ID)</option>
                            <option value="host_asc">Tên máy Hostname (A-Z)</option>
                            <option value="host_desc">Tên máy Hostname (Z-A)</option>
                            <option value="name_asc">Tên Vị Trí (A-Z)</option>
                            <option value="name_desc">Tên Vị Trí (Z-A)</option>
                        </select>
                    </div>

                    <div class="col-lg-1 col-md-4 col-sm-12 text-end">
                        <button class="btn btn-outline-secondary rounded-pill w-100" onclick="clearFilters()" style="height: 38px;">
                            <i class="fas fa-sync-alt"></i> Xóa bộ
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card active" id="card-all" onclick="setCardFilter('', 'card-all')" style="border-radius:15px; background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Tổng Tài Sản</div>
                        <h2 class="fw-bold mb-0" id="cardTong">0</h2>
                        <i class="fas fa-desktop card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-hd" onclick="setCardFilter('hoạt động', 'card-hd')" style="border-radius:15px; background: linear-gradient(135deg, #10b981, #047857);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Hoạt động</div>
                        <h2 class="fw-bold mb-0" id="cardHoatDong">0</h2>
                        <i class="fas fa-check-circle card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-hong" onclick="setCardFilter('hỏng', 'card-hong')" style="border-radius:15px; background: linear-gradient(135deg, #ef4444, #b91c1c);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Hỏng / Mất</div>
                        <h2 class="fw-bold mb-0" id="cardHong">0</h2>
                        <i class="fas fa-car-crash card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-bt" onclick="setCardFilter('bảo trì', 'card-bt')" style="border-radius:15px; background: linear-gradient(135deg, #8b5cf6, #6d28d9);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Bảo trì / Sửa chữa</div>
                        <h2 class="fw-bold mb-0" id="cardBaoTri">0</h2>
                        <i class="fas fa-tools card-icon-bg"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-dark border-0 shadow-sm h-100 stat-card" id="card-chuacheck" onclick="setCardFilter('chuacheck', 'card-chuacheck')" style="border-radius:15px; background: linear-gradient(135deg, #fcd34d, #f59e0b);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1"><i class="fas fa-exclamation-triangle me-1"></i>Chưa Kiểm Kê</div>
                        <h2 class="fw-bold mb-0" id="cardChuaCheck">0</h2>
                        <i class="fas fa-search-minus card-icon-bg" style="color: #000;"></i>
                    </div>
                </div>
            </div>
            <div class="col-xl-2 col-lg-4 col-6">
                <div class="card text-white border-0 shadow-sm h-100 stat-card" id="card-xoa" onclick="setCardFilter('xóa', 'card-xoa')" style="border-radius:15px; background: linear-gradient(135deg, #64748b, #334155);">
                    <div class="card-body p-3 text-start">
                        <div class="small fw-bold text-uppercase opacity-75 mb-1">Thùng Rác</div>
                        <h2 class="fw-bold mb-0" id="cardXoa">0</h2>
                        <i class="fas fa-trash-alt card-icon-bg"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-building text-primary me-2"></i>Tài sản theo Công ty</h6>
                        <small class="text-muted" style="font-size: 11px;">(Nhấn vào biểu đồ để lọc)</small>
                    </div>
                    <div class="card-body d-flex justify-content-center" style="position: relative; height: 300px; width: 100%;">
                        <canvas id="chartCongTy" style="max-height: 280px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-laptop text-info me-2"></i>Thống kê theo Loại Thiết bị (Biểu đồ Cột)</h6>
                        <small class="text-muted" style="font-size: 11px;">(Nhấn vào biểu đồ để lọc)</small>
                    </div>
                    <div class="card-body" style="position: relative; height: 300px; width: 100%;">
                        <canvas id="chartLoai" style="max-height: 280px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-sitemap text-success me-2"></i>Phân bổ thiết bị theo Bộ phận (Theo Công Ty)</h6>
                        <small class="text-muted" style="font-size: 11px;">(Nhấn vào từng cột bộ phận để lọc danh sách)</small>
                    </div>
                    <div class="card-body">
                        <div class="row" id="boPhanChartsContainer">
                            <div class="col-12 text-center text-muted"><div class="spinner-border text-primary spinner-border-sm" role="status"></div> Đang tải biểu đồ...</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h6 class="fw-bold text-dark mb-0"><i class="fas fa-tasks text-warning me-2"></i>Tiến độ Kiểm Kê</h6>
                    </div>
                    <div class="card-body d-flex justify-content-center" style="position: relative; height: 300px; width: 100%;">
                        <canvas id="chartTienDo" style="max-height: 280px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4" id="tableSection" style="border-radius: 15px;">
            <div class="card-header bg-white border-bottom pt-3 pb-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2" style="border-radius: 15px 15px 0 0;">
                <h6 class="fw-bold text-dark mb-0"><i class="fas fa-list-alt text-primary me-2"></i>Chi tiết danh sách (<span id="lblCountTable" class="text-danger">0</span> thiết bị)</h6>

                <div class="d-flex align-items-center">
                    <label class="me-2 small text-muted mb-0 fw-bold">Hiển thị:</label>
                    <select id="pageSizeSelect" class="form-select form-select-sm shadow-sm border-0 bg-light" style="width: 80px; font-weight: bold;" onchange="changePageSize()">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="30" selected>30</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 1200px; overflow-y: auto;">
                    <table class="table table-hover align-middle mb-0" id="adminDataTable">
                        <thead class="table-light position-sticky top-0 shadow-sm" style="z-index: 10;">
                            <tr>
                                <th class="ps-4" width="70">ID</th>
                                <th>Thông tin máy tính & Vị trí</th>
                                <th>Loại & Ảnh đính kèm</th>
                                <th>Tài khoản & Người dùng</th>
                                <th>Sơ đồ Vị trí (CT - BP)</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center" width="160">Lần cuối Check</th>
                                <th>Ghi chú</th>
                                <th class="text-center" width="120">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyData">
                            <tr class="empty-row"><td colspan="9" class="text-center text-muted py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2">Đang tải dữ liệu...</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white border-top d-flex flex-column flex-md-row justify-content-between align-items-center py-3" style="border-radius: 0 0 15px 15px;">
                <div class="small text-muted mb-2 mb-md-0 fw-bold" id="paginationInfo">Đang tải...</div>
                <ul class="pagination pagination-sm mb-0 shadow-sm" id="paginationControls">
                </ul>
            </div>
        </div>

    </div>
</section>

<div class="modal fade" id="modalLichSu" tabindex="-1" aria-labelledby="modalLichSuLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 15px;">
            <div class="modal-header bg-light" style="border-radius: 15px 15px 0 0;">
                <h5 class="modal-title fw-bold" id="modalLichSuLabel">
                    <i class="fas fa-history text-primary me-2"></i>Lịch sử thiết bị: <span id="lsTenThietBi" class="text-danger"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light position-sticky top-0 shadow-sm">
                            <tr>
                                <th class="ps-4">Thời gian</th>
                                <th>Hành động</th>
                                <th>Người thao tác</th>
                                <th>Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyLichSu">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light" style="border-radius: 0 0 15px 15px;">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Các biến lưu trữ dữ liệu
        let allDataCache = [];
        let finalFilteredGlobal = [];
        let filteredExportData = [];

        // Các biến phục vụ Phân trang (Pagination)
        let currentPage = 1;
        let pageSize = 30;

        // Các biểu đồ
        let chartCongTy = null;
        let chartLoai = null;
        let chartTienDo = null;
        let chartBoPhanInstances = [];

        // Trạng thái thẻ Card đang được chọn
        let activeCardFilter = '';

        $(document).ready(function () {
        // Sự kiện tìm kiếm nhanh & thay đổi sắp xếp
        $('#filterText, #filterSort').on('keyup change', function () {
        applyFiltersAndRender();
        });

        // Lắng nghe sự kiện thay đổi của Checkbox lồng trong Dropdown Menu
        $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
        updateDropdownButtonLabel($(this).closest('.dropdown-combo-menu'));
        applyFiltersAndRender();
        });

        // Tải dữ liệu lần đầu
        loadData();
        });

        function loadData() {
        $.get('/QLKiemKe/GetKkThietBiss', function (res) {
        if (res.success) {
        allDataCache = res.data || [];
        populateFilters(allDataCache);
        applyFiltersAndRender();
        } else {
        Swal.fire("Lỗi tải dữ liệu", res.msg, "error");
        }
        }).fail(function() { Swal.fire("Lỗi", "Lỗi kết nối máy chủ!", "error"); });
        }

        // Đổ dữ liệu vào Dropdown Checkbox Menu
        function populateFilters(data) {
        let companies = [...new Set(data.map(x => x.tenCongTy).filter(Boolean))].sort();
        let depts = [...new Set(data.map(x => x.tenBoPhan).filter(Boolean))].sort();
        let types = [...new Set(data.map(x => x.loaiThietBi).filter(Boolean))].sort();

        $('#menuCongTy').empty();
        $('#menuBoPhan').empty();
        $('#menuLoai').empty();

        // Sinh Checkbox Công ty
        companies.forEach(x => {
        $('#menuCongTy').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-company" value="${x}">
        <span>${x}</span>
        </label>
        `);
        });

        // Sinh Checkbox Bộ phận
        depts.forEach(x => {
        $('#menuBoPhan').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-dept" value="${x}">
        <span>${x}</span>
        </label>
        `);
        });

        // Sinh Checkbox Loại thiết bị
        types.forEach(x => {
        $('#menuLoai').append(`
        <label class="dropdown-combo-item">
        <input type="checkbox" class="chk-loai" value="${x}">
        <span>${x}</span>
        </label>
        `);
        });
        }

        // Hàm cập nhật nhãn hiển thị lên nút Dropdown (Ví dụ: "Đã chọn (2)")
        function updateDropdownButtonLabel($menu) {
        let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
        let $btn = $menu.siblings('.dropdown-combo-btn');

        if (totalChecked === 0) {
        $btn.text('-- Tất cả --');
        } else if (totalChecked === 1) {
        $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
        } else {
        $btn.text(`Đã chọn (${totalChecked})`);
        }
        }

        // Nút Xóa tất cả bộ lọc
        function clearFilters() {
        $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
        $('.dropdown-combo-menu').each(function() {
        updateDropdownButtonLabel($(this));
        });
        $('#filterText').val('');
        $('#filterSort').val('');
        setCardFilter('', 'card-all');
        }

        function setCardFilter(status, cardId) {
        activeCardFilter = status.toLowerCase();
        $('.stat-card').removeClass('active');
        $('#' + cardId).addClass('active');
        applyFiltersAndRender();
        }

        // ====================================================
        // HÀM LỌC CHÍNH (XỬ LÝ DỮ LIỆU ĐA TÍCH CHỌN TRÊN DROPDOWN)
        // ====================================================
        function applyFiltersAndRender() {
        let selectedCompanies = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoais = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();

        let fText = $('#filterText').val().toLowerCase().trim();
        let fSort = $('#filterSort').val();

        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);

        let baseFiltered = allDataCache;

        // Xử lý lọc mảng Multi-select từ Dropdown Checkbox
        if (selectedCompanies.length > 0) baseFiltered = baseFiltered.filter(x => selectedCompanies.includes(x.tenCongTy));
        if (selectedDepts.length > 0) baseFiltered = baseFiltered.filter(x => selectedDepts.includes(x.tenBoPhan));
        if (selectedLoais.length > 0) baseFiltered = baseFiltered.filter(x => selectedLoais.includes(x.loaiThietBi));

        if (fText) {
        baseFiltered = baseFiltered.filter(x =>
        (x.tenMayTinh && x.tenMayTinh.toLowerCase().includes(fText)) ||
        (x.tenViTri && x.tenViTri.toLowerCase().includes(fText)) ||
        (x.tenNguoiDung && x.tenNguoiDung.toLowerCase().includes(fText)) ||
        (x.tenDangNhap && x.tenDangNhap.toLowerCase().includes(fText)) ||
        (x.tk && x.tk.toLowerCase().includes(fText))
        );
        }

        // Đếm số lượng Card Thống kê
        let countTotal = 0, countHD = 0, countBaoTri = 0, countHong = 0, countXoa = 0, countChuaCheck = 0;

        baseFiltered.forEach(x => {
        let t = (x.tenTrangThai || '').toLowerCase();
        if (t.includes('xóa') || x.ngayXoa != null) {
        countXoa++;
        } else {
        countTotal++;
        if (t.includes('hoạt động')) countHD++;
        else if (t.includes('bảo trì')) countBaoTri++;
        else if (t.includes('hỏng')) countHong++;

        if (!x.thoiGianCheck) {
        countChuaCheck++;
        } else {
        if (new Date(x.thoiGianCheck) < fourMonthsAgo) countChuaCheck++;
        }
        }
        });

        $('#cardTong').text(countTotal);
        $('#cardHoatDong').text(countHD);
        $('#cardBaoTri').text(countBaoTri);
        $('#cardHong').text(countHong);
        $('#cardXoa').text(countXoa);
        $('#cardChuaCheck').text(countChuaCheck);

        let finalFiltered = baseFiltered;
        if (activeCardFilter === 'chuacheck') {
        finalFiltered = finalFiltered.filter(x => {
        if (x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')) return false;
        if (!x.thoiGianCheck) return true;
        return new Date(x.thoiGianCheck) < fourMonthsAgo;
        });
        } else if (activeCardFilter === 'xóa') {
        finalFiltered = finalFiltered.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa'));
        } else if (activeCardFilter !== '') {
        finalFiltered = finalFiltered.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes(activeCardFilter) && !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));
        } else {
        finalFiltered = finalFiltered.filter(x => !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));
        }

        // Sắp xếp tiếng Việt có dấu
        if (fSort) {
        finalFiltered.sort((a, b) => {
        let valA = '', valB = '';
        if (fSort.startsWith('host')) {
        valA = (a.tenMayTinh || '').toLowerCase(); valB = (b.tenMayTinh || '').toLowerCase();
        } else if (fSort.startsWith('name')) {
        valA = (a.tenViTri || '').toLowerCase(); valB = (b.tenViTri || '').toLowerCase();
        }
        if (fSort.endsWith('asc')) {
        return valA.localeCompare(valB, 'vi', { sensitivity: 'base' });
        } else {
        return valB.localeCompare(valA, 'vi', { sensitivity: 'base' });
        }
        });
        }

        finalFilteredGlobal = finalFiltered;
        filteredExportData = finalFiltered;
        currentPage = 1;

        $('#lblCountTable').text(finalFilteredGlobal.length);
        renderTablePage();

        // Vẽ lại các biểu đồ động
        let mapCongTy = {}; let mapLoai = {};
        let countDaCheck = 0; let countChuaCheckChart = 0;
        let companyDeptsMap = {};

        finalFiltered.forEach(x => {
        let ct = x.tenCongTy || 'Chưa gắn CT';
        mapCongTy[ct] = (mapCongTy[ct] || 0) + 1;

        let bp = x.tenBoPhan || 'Chưa gắn BP';
        if (!companyDeptsMap[ct]) companyDeptsMap[ct] = {};
        companyDeptsMap[ct][bp] = (companyDeptsMap[ct][bp] || 0) + 1;

        let type = x.loaiThietBi || 'Khác';
        mapLoai[type] = (mapLoai[type] || 0) + 1;

        if (!x.thoiGianCheck || new Date(x.thoiGianCheck) < fourMonthsAgo) {
        countChuaCheckChart++;
        } else {
        countDaCheck++;
        }
        });

        let sortedCT = Object.entries(mapCongTy).sort((a,b) => b[1]-a[1]);
        chartCongTy = drawPieChart(chartCongTy, 'chartCongTy', sortedCT.map(i=>i[0]), sortedCT.map(i=>i[1]), function(label) {
        setTimeout(() => {
        $('.chk-company').prop('checked', false);
        $(`.chk-company[value="${label}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuCongTy'));
        applyFiltersAndRender();
        document.getElementById('tableSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
        });

        let sortedLoai = Object.entries(mapLoai).sort((a,b) => b[1]-a[1]);
        chartLoai = drawBarChart(chartLoai, 'chartLoai', sortedLoai.map(i=>i[0]), sortedLoai.map(i=>i[1]), 'Số lượng', '#06b6d4', function(label) {
        setTimeout(() => {
        $('.chk-loai').prop('checked', false);
        $(`.chk-loai[value="${label}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuLoai'));
        applyFiltersAndRender();
        document.getElementById('tableSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
        });

        chartTienDo = drawTienDoChart(chartTienDo, 'chartTienDo', countDaCheck, countChuaCheckChart);

        chartBoPhanInstances.forEach(c => c.destroy());
        chartBoPhanInstances = [];
        $('#boPhanChartsContainer').empty();

        let bpColors = ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899', '#06b6d4', '#64748b'];
        let colorIdx = 0;

        if (typeof companyDeptsMap === 'object' && Object.keys(companyDeptsMap).length === 0) {
        $('#boPhanChartsContainer').html('<div class="col-12 text-center text-muted py-5"><i class="fas fa-folder-open fa-2x mb-2 d-block opacity-50"></i>Không có dữ liệu bộ phận</div>');
        } else {
        let colClass = Object.keys(companyDeptsMap).length > 1 ? 'col-md-6' : 'col-12';
        let chartIndex = 0;

        for (let cty in companyDeptsMap) {
        let sortedBP = Object.entries(companyDeptsMap[cty]).sort((a,b) => b[1]-a[1]).slice(0, 15);
        let canvasId = 'chartBP_' + chartIndex;
        let currentColor = bpColors[colorIdx % bpColors.length];

        let htmlCol = `
        <div class="${colClass} mb-4">
        <h6 class="text-center fw-bold" style="color: ${currentColor}; font-size: 0.95rem;"><i class="fas fa-building me-1"></i>${cty}</h6>
        <div style="position: relative; height: 250px; width: 100%;">
        <canvas id="${canvasId}"></canvas>
        </div>
        </div>`;
        $('#boPhanChartsContainer').append(htmlCol);

        let newChart = drawBarChart(null, canvasId, sortedBP.map(i=>i[0]), sortedBP.map(i=>i[1]), 'Số thiết bị', currentColor, function(label) {
        setTimeout(() => {
        $('.chk-company').prop('checked', false);
        $(`.chk-company[value="${cty}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuCongTy'));

        $('.chk-dept').prop('checked', false);
        $(`.chk-dept[value="${label}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuBoPhan'));

        applyFiltersAndRender();
        document.getElementById('tableSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
        });

        chartBoPhanInstances.push(newChart);
        chartIndex++; colorIdx++;
        }
        }
        }

        // ====================================================
        // HÀM VẼ BẢNG DỮ LIỆU & PHÂN TRANG (PAGINATION)
        // ====================================================
        function changePageSize() {
        pageSize = parseInt($('#pageSizeSelect').val());
        currentPage = 1;
        renderTablePage();
        }

        // Đã gán hàm toàn cục để phân trang chạy chuẩn
        window.changePage = function(pageNumber) {
        currentPage = pageNumber;
        renderTablePage();
        }

        function renderTablePage() {
        let totalItems = finalFilteredGlobal.length;
        let totalPages = Math.ceil(totalItems / pageSize);
        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);

        let htmlTable = '';

        if (totalItems === 0) {
        htmlTable = `<tr class="empty-row"><td colspan="9" class="text-center text-muted py-5"><i class="fas fa-box-open fa-3x mb-3 d-block opacity-50"></i> Không có dữ liệu phù hợp</td></tr>`;
        $('#paginationInfo').text("Không có mục nào để hiển thị");
        $('#paginationControls').html('');
        } else {
        let startIndex = (currentPage - 1) * pageSize;
        let endIndex = Math.min(startIndex + pageSize, totalItems);
        let pageData = finalFilteredGlobal.slice(startIndex, endIndex);

        $('#paginationInfo').html(`Đang hiển thị <b>${startIndex + 1}</b> đến <b>${endIndex}</b> trong tổng số <b class="text-primary">${totalItems}</b> thiết bị`);

        pageData.forEach(item => {
        let namePart = item.tenNguoiDung
        ? `<span class="text-primary">${item.tenNguoiDung}</span> <span class="text-danger fw-normal">(${item.tk || 'N/A'})</span>`
        : `<span class="text-muted fst-italic">Chưa có người dùng</span>`;

        let accPart = item.tenDangNhap ? item.tenDangNhap : `<span class="fst-italic">Chưa có tài khoản</span>`;
        let userStr = `<div class="fw-bold">${namePart}</div><div class="small text-muted mt-1"><i class="fas fa-user-circle me-1"></i> ${accPart}</div>`;
        let locStr = [item.tenCongTy, item.tenBoPhan].filter(Boolean).join(' - ') || 'Chưa gắn';

        let t = (item.tenTrangThai || '').toLowerCase();
        let badgeClass = "bg-secondary";
        if (t.includes("hoạt động")) badgeClass = "bg-success";
        else if (t.includes("bảo trì")) badgeClass = "bg-warning text-dark";
        else if (t.includes("hỏng") || t.includes("xóa")) badgeClass = "bg-danger";

        let checkHtml = '';
        if (!item.thoiGianCheck) {
        checkHtml = `<span class="badge bg-danger rounded-pill px-3 py-2"><i class="fas fa-exclamation-triangle me-1"></i> Chưa Check</span>`;
        } else {
        let checkDate = new Date(item.thoiGianCheck);
        if (checkDate < fourMonthsAgo) {
        checkHtml = `<span class="badge bg-warning text-dark rounded-pill px-2 py-2" title="Đã quá 4 tháng"><i class="fas fa-clock me-1"></i> Quá hạn (${checkDate.toLocaleDateString('vi-VN')})</span>`;
        } else {
        checkHtml = `<span class="badge bg-success rounded-pill px-3 py-2"><i class="fas fa-check me-1"></i> ${checkDate.toLocaleDateString('vi-VN')}</span>`;
        }
        }

        let htmlImg = '';
        if (item.duongDanAnh) {
        let imgUrl = `/QLKiemKe/GetImage?fileName=${encodeURIComponent(item.duongDanAnh)}`;
        htmlImg = `
        <div class="mt-2 text-md-start text-end">
        <img src="${imgUrl}"
        alt="Ảnh thiết bị"
        class="img-thumbnail shadow-sm"
        style="width: 50px; height: 50px; object-fit: cover; cursor: pointer; border-radius: 8px;"
        onclick="viewFullImage('${imgUrl}', '${item.tenMayTinh || item.tenViTri || 'Vị trí'}')"
        title="Nhấn để xem ảnh lớn" />
        </div>`;
        } else {
        htmlImg = `
        <div class="mt-2 text-muted small fst-italic text-md-start text-end" style="font-size: 11px;">
        <i class="fas fa-image" style="opacity: 0.4;"></i> Không có ảnh
        </div>`;
        }

        let htmlGhiChu = item.ghiChu
        ? `<div class="small text-wrap text-muted" style="max-width: 150px;">${item.ghiChu}</div>`
        : `<span class="text-muted fst-italic small" style="opacity: 0.6;">Không</span>`;

        htmlTable += `
        <tr>
        <td class="ps-4 fw-bold text-muted" data-label="Mã ID">#${item.idThietBi}</td>
        <td data-label="Thông tin TB & Hostname">
        <div class="text-end text-md-start">
        <div class="fw-bold text-dark fs-6">${item.tenMayTinh || '<i class="text-muted fw-normal">No Hostname</i>'}</div>
        <div class="small text-muted"><i class="fas fa-map-pin"></i> Vị trí: ${item.tenViTri}</div>
        </div>
        </td>
        <td data-label="Loại & Ảnh đính kèm">
        <div class="text-end text-md-start">
        <span class="badge border border-secondary text-secondary bg-light px-2 py-1 mb-1 d-inline-block">${item.loaiThietBi || 'Khác'}</span>
        ${htmlImg}
        </div>
        </td>
        <td data-label="Tài khoản & Người dùng">
        <div class="text-end text-md-start">${userStr}</div>
        </td>
        <td class="small" data-label="Vị trí (Công ty - Bộ phận)">
        <div class="text-end text-md-start"><i class="fas fa-map-marker-alt text-muted me-1"></i>${locStr}</div>
        </td>
        <td class="text-center" data-label="Trạng thái kiểm kê">
        <div class="text-end text-md-center"><span class="badge ${badgeClass} w-100 py-2 shadow-sm">${item.tenTrangThai || 'Chưa rõ'}</span></div>
        </td>
        <td class="text-center" data-label="Lần cuối Check">
        <div class="text-end text-md-center">${checkHtml}</div>
        </td>
        <td data-label="Ghi chú">
        <div class="d-flex justify-content-end justify-content-md-start">${htmlGhiChu}</div>
        </td>
        <td class="text-center" data-label="Thao tác hệ thống">
        <button class="btn btn-sm text-white rounded-pill shadow-sm px-3 py-1 btn-action-mobile"
        style="background: linear-gradient(135deg, #8b5cf6, #6366f1); border: none; font-weight: 600; font-size: 0.8rem; transition: all 0.3s ease;"
        onmouseover="this.style.transform='translateY(-2px)';"
        onmouseout="this.style.transform='translateY(0)';"
        onclick="xemLichSuThietBi(${item.idThietBi}, '${item.tenMayTinh || item.tenViTri || 'Vị trí'}')">
        <i class="fas fa-history me-1"></i> Lịch sử
        </button>
        </td>
        </tr>`;
        });

        renderPaginationControls(totalPages);
        }
        $('#tbodyData').html(htmlTable);
        }

        function renderPaginationControls(totalPages) {
        let html = '';
        if (totalPages <= 1) { $('#paginationControls').html(''); return; }

        let prevDisabled = currentPage === 1 ? 'disabled' : '';
        html += `<li class="page-item ${prevDisabled}"><a class="page-link" onclick="window.changePage(${currentPage - 1})"><i class="fas fa-chevron-left"></i></a></li>`;

        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, currentPage + 2);

        if (startPage > 1) {
        html += `<li class="page-item"><a class="page-link" onclick="window.changePage(1)">1</a></li>`;
        if (startPage > 2) html += `<li class="page-item disabled"><span class="page-link border-0">...</span></li>`;
        }

        for (let i = startPage; i <= endPage; i++) {
        let activeClass = i === currentPage ? 'active' : '';
        html += `<li class="page-item ${activeClass}"><a class="page-link" onclick="window.changePage(${i})">${i}</a></li>`;
        }

        if (endPage < totalPages) {
        if (endPage < totalPages - 1) html += `<li class="page-item disabled"><span class="page-link border-0">...</span></li>`;
        html += `<li class="page-item"><a class="page-link" onclick="window.changePage(${totalPages})">${totalPages}</a></li>`;
        }

        let nextDisabled = currentPage === totalPages ? 'disabled' : '';
        html += `<li class="page-item ${nextDisabled}"><a class="page-link" onclick="window.changePage(${currentPage + 1})"><i class="fas fa-chevron-right"></i></a></li>`;

        $('#paginationControls').html(html);
        }

        // ==========================================
        // CÁC HÀM VẼ CHART.JS ĐỘNG
        // ==========================================
        function drawBarChart(chartInstance, canvasId, labels, data, labelTitle, colorCode, onClickCallback = null) {
        if (chartInstance) chartInstance.destroy();
        return new Chart(document.getElementById(canvasId).getContext('2d'), {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{ label: labelTitle, data: data, backgroundColor: colorCode, borderRadius: 6 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        onClick: (e, activeElements) => {
        if (activeElements.length > 0 && onClickCallback) {
        const dataIndex = activeElements[0].index;
        onClickCallback(labels[dataIndex]);
        }
        },
        onHover: (event, chartElement) => {
        event.native.target.style.cursor = chartElement[0] ? 'pointer' : 'default';
        },
        plugins: {
        legend: { display: false },
        datalabels: {
        anchor: 'end', align: 'top', color: '#475569',
        font: { weight: 'bold', size: 12 },
        formatter: function(value) { return value > 0 ? value : ''; }
        }
        },
        scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 }, grace: '10%' },
        x: { ticks: { autoSkip: false, maxRotation: 25, minRotation: 0 } }
        }
        },
        plugins: [ChartDataLabels]
        });
        }

        function drawPieChart(chartInstance, canvasId, labels, data, onClickCallback = null) {
        if (chartInstance) chartInstance.destroy();
        let colors = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4', '#64748b', '#ec4899'];
        return new Chart(document.getElementById(canvasId).getContext('2d'), {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{ data: data, backgroundColor: colors, borderWidth: 2, hoverOffset: 4 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        onClick: (e, activeElements) => {
        if (activeElements.length > 0 && onClickCallback) {
        const dataIndex = activeElements[0].index;
        onClickCallback(labels[dataIndex]);
        }
        },
        onHover: (event, chartElement) => {
        event.native.target.style.cursor = chartElement[0] ? 'pointer' : 'default';
        },
        plugins: {
        legend: { position: 'right', labels: { boxWidth: 12 } },
        datalabels: {
        color: '#fff', font: { weight: 'bold', size: 14 },
        formatter: function(value) { return value > 0 ? value : ''; }
        }
        },
        cutout: '60%'
        },
        plugins: [ChartDataLabels]
        });
        }

        function drawTienDoChart(chartInstance, canvasId, valDaCheck, valChuaCheck) {
        if (chartInstance) chartInstance.destroy();
        return new Chart(document.getElementById(canvasId).getContext('2d'), {
        type: 'pie',
        data: {
        labels: ['Đã Kiểm Kê (Gần đây)', 'Chưa / Quá hạn'],
        datasets: [{ data: [valDaCheck, valChuaCheck], backgroundColor: ['#10b981', '#fcd34d'], borderWidth: 1, hoverOffset: 4 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 15 } },
        datalabels: {
        color: '#fff', font: { weight: 'bold', size: 14 },
        formatter: function(value) { return value > 0 ? value : ''; }
        }
        }
        },
        plugins: [ChartDataLabels]
        });
        }

        function viewFullImage(url, title) {
        Swal.fire({
        title: title, imageUrl: url, imageAlt: 'Ảnh thiết bị',
        showCloseButton: true, showConfirmButton: false, width: 'auto', padding: '1em',
        customClass: { image: 'rounded-3 shadow', popup: 'rounded-4' }
        });
        }

        function xemLichSuThietBi(idThietBi, tenThietBi) {
        $('#lsTenThietBi').text(tenThietBi);
        $('#tbodyLichSu').html('<tr><td colspan="4" class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><div class="mt-2">Đang tải dữ liệu...</div></td></tr>');

        let myModal = new bootstrap.Modal(document.getElementById('modalLichSu'));
        myModal.show();

        $.get('/QLKiemKe/GetLichSuThietBi', { idThietBi: idThietBi }, function (res) {
        if (res.success) {
        let html = '';
        if (res.data.length === 0) {
        html = '<tr><td colspan="4" class="text-center text-muted py-4"><i class="fas fa-history fa-2x mb-2 d-block opacity-50"></i>Chưa ghi nhận lịch sử thao tác nào</td></tr>';
        } else {
        res.data.forEach(item => {
        let time = item.thoiGian ? new Date(item.thoiGian).toLocaleString('vi-VN') : 'Không rõ thời gian';
        let badgeHanhDong = 'bg-primary';

        if (item.hanhDong && item.hanhDong.toLowerCase().includes('xóa')) badgeHanhDong = 'bg-danger';
        else if (item.hanhDong && item.hanhDong.toLowerCase().includes('sửa')) badgeHanhDong = 'bg-warning text-dark';
        else if (item.hanhDong && item.hanhDong.toLowerCase().includes('thêm')) badgeHanhDong = 'bg-success';

        html += `
        <tr>
        <td class="ps-4 small fw-bold text-muted">${time}</td>
        <td><span class="badge ${badgeHanhDong} rounded-pill px-3 py-1 shadow-sm">${item.hanhDong || 'Không rõ'}</span></td>
        <td class="fw-bold text-dark"><i class="fas fa-user-circle text-muted me-1"></i>${item.nguoiThaoTac || 'N/A'}</td>
        <td class="small text-wrap" style="max-width: 350px;">${item.chiTiet || ''}</td>
        </tr>`;
        });
        }
        $('#tbodyLichSu').html(html);
        } else {
        $('#tbodyLichSu').html(`<tr><td colspan="4" class="text-center text-danger py-4"><i class="fas fa-exclamation-circle me-1"></i> Lỗi: ${res.msg}</td></tr>`);
        }
        }).fail(function () {
        $('#tbodyLichSu').html('<tr><td colspan="4" class="text-center text-danger py-4"><i class="fas fa-exclamation-circle me-1"></i> Không thể kết nối tới máy chủ!</td></tr>');
        });
        }

        // ==========================================
        // HÀM XUẤT EXCEL SỬ DỤNG SHEETJS
        // ==========================================
        window.exportToExcel = function() {
        if (filteredExportData.length === 0) {
        Swal.fire("Thông báo", "Không có dữ liệu để xuất Excel!", "info");
        return;
        }

        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);

        const excelData = filteredExportData.map(item => {
        let trangThaiCheckExcel = "CHƯA KIỂM KÊ";
        if (item.thoiGianCheck) {
        let d = new Date(item.thoiGianCheck);
        trangThaiCheckExcel = d < fourMonthsAgo ? `Quá hạn (${d.toLocaleDateString('vi-VN')})` : d.toLocaleDateString('vi-VN');
        }

        return {
        "ID": item.idThietBi,
        "Tên Vị Trí": item.tenViTri || '', // ĐÃ ĐỒNG BỘ: Chuyển đổi tên sang cột Excel tương ứng
        "Tên Máy (Hostname)": item.tenMayTinh || '',
        "Loại Thiết Bị": item.loaiThietBi || '',
        "Tên Đăng Nhập (Account)": item.tenDangNhap || 'Chưa có',
        "Người Sử Dụng": item.tenNguoiDung ? `${item.tenNguoiDung} (${item.tk || 'N/A'})` : 'Chưa có người dùng',
        "Công Ty": item.tenCongTy || 'Chưa gắn',
        "Bộ Phận": item.tenBoPhan || 'Chưa gắn',
        "Trạng Thái": item.tenTrangThai || 'Chưa rõ',
        "Ghi Chú": item.ghiChu || '',
        "Ảnh Đính Kèm": item.duongDanAnh ? "Có ảnh" : "Không",
        "Lần Cập Nhật Cuối": item.ngayCapNhat ? new Date(item.ngayCapNhat).toLocaleString('vi-VN') : '',
        "Ngày Kiểm Kê Lần Cuối": trangThaiCheckExcel
        };
        });

        const wb = XLSX.utils.book_new();
        const ws = XLSX.utils.json_to_sheet(excelData);

        ws['!cols'] = [
        { wch: 8 }, { wch: 25 }, { wch: 20 }, { wch: 15 }, { wch: 20 },
        { wch: 35 }, { wch: 20 }, { wch: 20 }, { wch: 15 }, { wch: 30 },
        { wch: 15 }, { wch: 20 }, { wch: 35 }
        ];

        XLSX.utils.book_append_sheet(wb, ws, "BaoCaoKiemKe");
        let dateStr = new Date().toISOString().slice(0,10).replace(/-/g,"");
        XLSX.writeFile(wb, `BaoCao_TaiSanIT_${dateStr}.xlsx`);
        }
    </script>
}