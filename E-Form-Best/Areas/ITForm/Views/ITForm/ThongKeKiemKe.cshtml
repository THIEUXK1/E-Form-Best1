        // ==========================================
        // HÀM XUẤT EXCEL CHUYÊN NGHIỆP DỰA TRÊN FILE ĐÍNH KÈM
        // ==========================================
        // Phân loại chính xác trạng thái bản quyền Windows dựa trên dữ liệu thực tế hiện có
        // (Trường bản quyền hiện là ô nhập tự do nên dữ liệu có thể lẫn cả giá trị cũ lẫn mới)
        // QUY ƯỚC CHUẨN CÔNG TY: chỉ Windows Professional (Pro) mới được tính "Đạt chuẩn".
        // Home/Enterprise/Education tuy có bản quyền nhưng KHÔNG đúng chuẩn Pro nên vẫn cần xác minh/nâng cấp.
        function phanLoaiBanQuyenWindows(raw) {
        let v = (raw || '').trim();
        if (v === '') return { nhom: 'Trống / Chưa cập nhật', risk: true };
        let low = v.toLowerCase();
        if (low.includes('chưa có') || low.includes('không có')) return { nhom: 'Chưa có bản quyền', risk: true };
        if (low.includes('không xác định')) return { nhom: 'Không xác định', risk: true };
        if (low.includes('chưa rõ')) return { nhom: 'Có bản quyền - Chưa rõ phiên bản', risk: true };
        if (low.includes('professional')) return { nhom: 'Windows Professional (Đạt chuẩn)', risk: false };
        if (low.includes('home')) return { nhom: 'Windows Home (Không đạt chuẩn - Cần nâng cấp Pro)', risk: true };
        if (low.includes('education')) return { nhom: 'Windows Education (Không đạt chuẩn - Cần nâng cấp Pro)', risk: true };
        if (low.includes('enterprise') || low.includes('iot')) return { nhom: 'Windows Enterprise (Không đạt chuẩn - Cần nâng cấp Pro)', risk: true };
        if (low.includes('có bản quyền')) return { nhom: 'Có bản quyền - Chưa rõ phiên bản', risk: true };
        if (low.includes('pro')) return { nhom: 'Windows Professional (Đạt chuẩn)', risk: false };
        return { nhom: 'Không xác định', risk: true };
        }

        // Phân loại chính xác trạng thái bản quyền Office dựa trên dữ liệu thực tế hiện có
        function phanLoaiBanQuyenOffice(raw) {
        let v = (raw || '').trim();
        if (v === '') return { nhom: 'Trống / Chưa cập nhật', risk: true };
        let low = v.toLowerCase();
        if (low.includes('không có') || low.includes('chưa có')) return { nhom: 'Chưa có bản quyền', risk: true };
        if (low.includes('không xác định')) return { nhom: 'Không xác định', risk: true };
        if (low.includes('chưa rõ')) return { nhom: 'Có bản quyền - Chưa rõ phiên bản', risk: true };
        if (low.includes('có bản quyền') || low.includes('professional plus') || low.includes('standard') ||
            low.includes('microsoft 365') || low.includes('home & business') || low.includes('home & student') ||
            low.includes('apps for')) return { nhom: 'Có bản quyền (Đầy đủ)', risk: false };
        return { nhom: 'Không xác định', risk: true };
        }

        window.exportToExcel = function() {
        if (filteredExportData.length === 0) {
            Swal.fire("Thông báo", "Không có dữ liệu để xuất Excel!", "info");
            return;
        }

        // Bản quyền Windows/Office chỉ áp dụng cho Máy tính và Laptop - Màn hình/Máy in/Điện thoại bàn... không chạy Windows/Office
        // nên phải loại khỏi báo cáo bản quyền, tránh tính nhầm thành "rủi ro thiếu bản quyền".
        const loaiMayTinhHopLe = ['máy tính', 'laptop'];
        let licenseData = filteredExportData.filter(x => x.loaiThietBi && loaiMayTinhHopLe.includes(x.loaiThietBi.trim().toLowerCase()));
        if (licenseData.length === 0) {
            Swal.fire("Thông báo", "Không có thiết bị Máy tính/Laptop nào trong dữ liệu đang lọc để xuất báo cáo bản quyền!", "info");
            return;
        }

        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);
        let dateNowStr = new Date().toLocaleString('vi-VN');
        const wb = XLSX.utils.book_new();

        // --- Đếm tổng hợp dữ liệu cho Tab 1 (chỉ tính Máy tính/Laptop) ---
        let totalCount = licenseData.length;
        let activeCount = 0;
        let winOkCount = 0;
        let winRiskCount = 0;
        let officeRiskCount = 0;

        let winGroup = {};
        let officeGroup = {};

        licenseData.forEach(x => {
            let t = (x.tenTrangThai || '').toLowerCase();
            if (t.includes('hoạt động')) activeCount++;

            // Thống kê Win
            let winKq = phanLoaiBanQuyenWindows(x.winLicense);
            winGroup[winKq.nhom] = (winGroup[winKq.nhom] || 0) + 1;
            if (winKq.risk) winRiskCount++; else winOkCount++;

            // Thống kê Office
            let offKq = phanLoaiBanQuyenOffice(x.officeLicense);
            officeGroup[offKq.nhom] = (officeGroup[offKq.nhom] || 0) + 1;
            if (offKq.risk) officeRiskCount++;
        });

        // ----------------------------------------------------
        // TAB 1: TỔNG QUAN BẢN QUYỀN
        // ----------------------------------------------------
        let sheet1Rows = [
            ["BÁO CÁO TÌNH TRẠNG BẢN QUYỀN PHẦN MỀM HỆ THỐNG IT"],
            ["Ngày lập báo cáo: " + dateNowStr + "  |  Nguồn dữ liệu: Hệ thống Dashboard quản trị tài sản"],
            ["Phạm vi: Chỉ tính thiết bị loại Máy tính và Laptop (không gồm Màn hình, Máy in, Điện thoại bàn...)"],
            [],
            ["", "TỔNG THIẾT BỊ", "", "ĐANG HOẠT ĐỘNG", "", "WIN - ĐẠT CHUẨN PRO", "", "WIN - RỦI RO BẢN QUYỀN", "", "OFFICE - RỦI RO BẢN QUYỀN"],
            ["", totalCount, "", activeCount, "", winOkCount, "", winRiskCount, "", officeRiskCount],
            [],
            ["I. PHÂN TÍCH TRẠNG THÁI BẢN QUYỀN WINDOWS"],
            ["Trạng Thái Bản Quyền", "Số Lượng Máy", "Tỷ Lệ (%)", "Mức Độ Rủi Ro", "Khuyến Nghị"]
        ];

        Object.entries(winGroup).sort((a, b) => b[1] - a[1]).forEach(([key, val]) => {
            let pct = totalCount > 0 ? (val / totalCount) : 0;
            let riskLvl = "Đạt chuẩn ✔";
            let rec = "Duy trì và gia hạn đúng hạn";
            if (key.includes("Chưa có")) { riskLvl = "Nguy hiểm ✘"; rec = "Mua bổ sung bản quyền Windows Pro ngay"; }
            else if (key.includes("Không đạt chuẩn")) { riskLvl = "Cần nâng cấp ⚠"; rec = "Chuyển đổi/nâng cấp lên Windows Pro theo chuẩn công ty"; }
            else if (key.includes("Chưa rõ") || key.includes("Trống") || key.includes("Không xác định")) { riskLvl = "Cần xác minh ⚠"; rec = "Kiểm tra và cập nhật thông tin"; }
            sheet1Rows.push([key, val, (pct * 100).toFixed(1) + "%", riskLvl, rec]);
        });
        sheet1Rows.push(["TỔNG CỘNG WINDOWS", totalCount, "100.0%", "", ""]);

        sheet1Rows.push([], [], ["II. PHÂN TÍCH TRẠNG THÁI BẢN QUYỀN OFFICE"], ["Trạng Thái Bản Quyền", "Số Lượng Máy", "Tỷ Lệ (%)", "Mức Độ Rủi Ro", "Khuyến Nghị"]);
        Object.entries(officeGroup).sort((a, b) => b[1] - a[1]).forEach(([key, val]) => {
            let pct = totalCount > 0 ? (val / totalCount) : 0;
            let riskLvl = "Đạt chuẩn ✔";
            let rec = "Duy trì đúng chính sách";
            if (key.includes("Chưa rõ") || key.includes("Trống") || key.includes("Không xác định")) { riskLvl = "Cần xác minh ⚠"; rec = "Kiểm tra thực tế cài đặt"; }
            else if (key.includes("Chưa có")) { riskLvl = "Nguy hiểm ✘"; rec = "Đăng ký mua Microsoft 365"; }
            sheet1Rows.push([key, val, (pct * 100).toFixed(1) + "%", riskLvl, rec]);
        });
        sheet1Rows.push(["TỔNG CỘNG OFFICE", totalCount, "100.0%", "", ""]);

        const ws1 = XLSX.utils.aoa_to_sheet(sheet1Rows);
        ws1['!cols'] = [{ wch: 35 }, { wch: 15 }, { wch: 15 }, { wch: 18 }, { wch: 35 }];
        styleWorksheetUniversal(ws1);
        XLSX.utils.book_append_sheet(wb, ws1, "1. Tổng Quan");

        // ----------------------------------------------------
        // TAB 2: PHÂN TÍCH THEO BỘ PHẬN
        // ----------------------------------------------------
        let deptMap = {};
        licenseData.forEach(x => {
            let cty = x.tenCongTy || 'Chưa rõ';
            let bp = x.tenBoPhan || 'Chưa rõ';
            let key = cty + "||" + bp;

            if (!deptMap[key]) {
                deptMap[key] = { cty: cty, bp: bp, total: 0, winRisk: 0, offRisk: 0 };
            }
            deptMap[key].total++;

            if (phanLoaiBanQuyenWindows(x.winLicense).risk) deptMap[key].winRisk++;
            if (phanLoaiBanQuyenOffice(x.officeLicense).risk) deptMap[key].offRisk++;
        });

        let sheet2Rows = [
            ["PHÂN TÍCH BẢN QUYỀN PHẦN MỀM THEO PHÒNG BAN BỘ PHẬN"],
            ["Ngày xuất báo cáo: " + dateNowStr + " | Tổng số thiết bị: " + totalCount],
            [],
            ["STT", "Công Ty", "Bộ Phận", "Tổng Số Máy", "Windows Rủi Ro", "Tỷ Lệ Win Rủi Ro", "Office Rủi Ro", "Tỷ Lệ Off Rủi Ro"]
        ];

        Object.values(deptMap).sort((a,b) => b.total - a.total).forEach((item, idx) => {
            let wPct = item.total > 0 ? ((item.winRisk / item.total) * 100).toFixed(1) + "%" : "0.0%";
            let oPct = item.total > 0 ? ((item.offRisk / item.total) * 100).toFixed(1) + "%" : "0.0%";
            sheet2Rows.push([idx + 1, item.cty, item.bp, item.total, item.winRisk, wPct, item.offRisk, oPct]);
        });

        const ws2 = XLSX.utils.aoa_to_sheet(sheet2Rows);
        ws2['!cols'] = [{ wch: 6 }, { wch: 15 }, { wch: 20 }, { wch: 15 }, { wch: 15 }, { wch: 18 }, { wch: 15 }, { wch: 18 }];
        ws2['!views'] = [{ state: 'frozen', ySplit: 4 }];
        ws2['!autofilter'] = { ref: XLSX.utils.encode_range({ s: { r: 3, c: 0 }, e: { r: 3, c: 7 } }) };
        styleWorksheetUniversal(ws2);
        XLSX.utils.book_append_sheet(wb, ws2, "2. Phân Tích Theo Bộ Phận");

        // ----------------------------------------------------
        // TAB 3: DANH SÁCH RỦI RO
        // ----------------------------------------------------
        let sheet3Rows = [
            ["DANH SÁCH THIẾT BỊ CÓ RỦI RO BẢN QUYỀN - CẦN XỬ LÝ SỚM"],
            ["Bao gồm các thiết bị phát hiện thiếu hụt hệ điều hành Windows HOẶC bộ ứng dụng Office"],
            [],
            ["STT", "ID Máy", "Tên Máy (Hostname)", "Loại TB", "Bộ Phận", "Công Ty", "Bản Quyền Windows", "Bản Quyền Office", "Người Sử Dụng", "Mức Độ Ưu Tiên", "Hành Động Cần Thực Hiện"]
        ];

        let riskIdx = 1;
        licenseData.forEach(item => {
            let isWinRisk = phanLoaiBanQuyenWindows(item.winLicense).risk;
            let isOffRisk = phanLoaiBanQuyenOffice(item.officeLicense).risk;

            if (isWinRisk || isOffRisk) {
                let priority = "🟠 Cao";
                let action = "Mua bản quyền Office bổ sung";
                if (isWinRisk && isOffRisk) {
                    priority = "🔴 Khẩn Cấp";
                    action = "Mua cả Windows + Office bản quyền";
                } else if (isWinRisk) {
                    action = "Nâng cấp / Hợp thức hóa Windows Pro";
                }

                sheet3Rows.push([
                    riskIdx++,
                    item.idThietBi,
                    item.tenMayTinh || 'No Hostname',
                    item.loaiThietBi || 'Khác',
                    item.tenBoPhan || 'Chưa gắn',
                    item.tenCongTy || 'Chưa gắn',
                    item.winLicense || 'Trống / Chưa rõ',
                    item.officeLicense || 'Trống / Chưa rõ',
                    item.tenNguoiDung ? `${item.tenNguoiDung} (${item.tk || 'N/A'})` : 'Chưa cấp phát',
                    priority,
                    action
                ]);
            }
        });

        const ws3 = XLSX.utils.aoa_to_sheet(sheet3Rows);
        ws3['!cols'] = [
            { wch: 6 }, { wch: 10 }, { wch: 20 }, { wch: 15 }, { wch: 18 },
            { wch: 15 }, { wch: 25 }, { wch: 25 }, { wch: 30 }, { wch: 15 }, { wch: 35 }
        ];
        ws3['!views'] = [{ state: 'frozen', ySplit: 4 }]; // Đóng băng hàng tiêu đề bảng
        ws3['!autofilter'] = { ref: XLSX.utils.encode_range({ s: { r: 3, c: 0 }, e: { r: 3, c: 10 } }) };
        styleWorksheetUniversal(ws3);
        XLSX.utils.book_append_sheet(wb, ws3, "3. Danh Sách Rủi Ro");

        // ----------------------------------------------------
        // TAB 4: KẾ HOẠCH HÀNH ĐỘNG (LỘ TRÌNH KHẮC PHỤC)
        // ----------------------------------------------------
        let sheet4Rows = [
            ["KẾ HOẠCH KHẮC PHỤC VÀ LỘ TRÌNH TUÂN THỦ BẢN QUYỀN"],
            ["Xây dựng dựa trên thực tế phân bổ rủi ro hệ thống tài sản số năm 2026"],
            [],
            ["STT", "Mức Độ Ưu Tiên", "Hạng Mục Công Việc", "Chi Tiết Thực Hiện", "Thời Hạn Dự Kiến", "Bộ Phận Phụ Trách"],
            [1, "🔴 Khẩn Cấp", "Kích hoạt bản quyền Windows", "Cài đặt khóa và hợp thức hóa các máy thuộc nhóm Chưa có và Trống thông tin", "2 tuần", "IT Admin + Ban Giám Đốc"],
            [2, "🔴 Khẩn Cấp", "Triển khai bản quyền Microsoft Office", "Mua sắm trang bị gói subscription Microsoft 365 Business cho nhân sự văn phòng", "1 tháng", "IT + Phòng Tài Chính"],
            [3, "🟠 Cao", "Xác minh trạng thái Chưa rõ phiên bản", "Kỹ thuật viên chạy lệnh kiểm tra slmgr /dli trực tiếp tại máy của người dùng", "2 tuần", "Bộ phận Kỹ thuật IT"],
            [4, "🟡 Trung Bình", "Xây dựng quy trình Quản lý Tài Sản Phần Mềm", "Ban hành quy định nghiêm cấm cài phần mềm bẻ khóa, kiểm kê định kỳ hàng quý", "1 tháng", "IT + Phòng Nhân Sự"],
            [5, "🟢 Dài Hạn", "Triển khai hệ thống giám sát tự động (SAM)", "Cài đặt các agent Lansweeper/ManageEngine để quét cấu hình bản quyền thời gian thực", "3 tháng", "IT Project Team"]
        ];

        const ws4 = XLSX.utils.aoa_to_sheet(sheet4Rows);
        ws4['!cols'] = [{ wch: 6 }, { wch: 15 }, { wch: 30 }, { wch: 45 }, { wch: 18 }, { wch: 25 }];
        styleWorksheetUniversal(ws4);
        XLSX.utils.book_append_sheet(wb, ws4, "4. Kế Hoạch Hành Động");

        // --- GHI WORKBOOK VÀ KÍCH HOẠT LỆNH TẢI FILE ---
        let dateStr = new Date().toISOString().slice(0,10).replace(/-/g,"");
        XLSX.writeFile(wb, `BaoCao_TuanThu_BanQuyen_IT_${dateStr}.xlsx`);
        }
    </script>
}