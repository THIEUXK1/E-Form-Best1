        let summaryRows = [
            ["📊 TỔNG HỢP SỐ LƯỢNG LAPTOP / MÁY TÍNH (MÁY CÂY) THEO BỘ PHẬN"],
            ["Ngày xuất báo cáo: " + dateNowStr + "  |  Tổng số thiết bị đang lọc: " + totalCount],
            [],
            ["", "TỔNG BỘ PHẬN", "", "TỔNG LAPTOP", "", "TỔNG MÁY TÍNH (MÁY CÂY)", ""],
            ["", tongBoPhan, "", 0, "", 0, ""],
            [],
            ["I. CHI TIẾT THEO TỪNG BỘ PHẬN"],
            ["STT", "Bộ Phận", "Số Lượng Laptop", "Số Lượng Máy Tính (Máy Cây)", "Tổng Laptop + Máy Tính", "Thiết Bị Khác", "Tổng Tất Cả Thiết Bị"]
        ];

        const KPI_ROW = 4, DATA_START_ROW = 8;
        Object.entries(deptSummaryMap)
            .sort((a, b) => (b[1].laptop + b[1].mayTinh) - (a[1].laptop + a[1].mayTinh))
            .forEach(([bp, sl], idx) => {
                tongLaptop += sl.laptop; tongMayTinh += sl.mayTinh; tongKhac += sl.khac;
                summaryRows.push([idx + 1, bp, sl.laptop, sl.mayTinh, sl.laptop + sl.mayTinh, sl.khac, sl.laptop + sl.mayTinh + sl.khac]);
            });
        summaryRows.push(["", "TỔNG CỘNG", tongLaptop, tongMayTinh, tongLaptop + tongMayTinh, tongKhac, totalCount]);
        // Điền lại giá trị KPI Tổng Laptop / Tổng Máy tính sau khi đã cộng dồn xong ở trên
        summaryRows[KPI_ROW][3] = tongLaptop;
        summaryRows[KPI_ROW][5] = tongMayTinh;

        const wsSummary = XLSX.utils.aoa_to_sheet(summaryRows);
        wsSummary['!cols'] = [{ wch: 6 }, { wch: 28 }, { wch: 16 }, { wch: 22 }, { wch: 20 }, { wch: 14 }, { wch: 18 }];
        wsSummary['!views'] = [{ state: 'frozen', ySplit: DATA_START_ROW }];
        wsSummary['!autofilter'] = { ref: XLSX.utils.encode_range({ s: { r: DATA_START_ROW - 1, c: 0 }, e: { r: DATA_START_ROW - 1, c: 6 } }) };
        styleWorksheetUniversal(wsSummary);
        toKhoiKpi(wsSummary, 3, KPI_ROW, [1, 3, 5]);
        mergeBanner(wsSummary, 0, 6);
        mergeBanner(wsSummary, 1, 6);
        if (wsSummary['!rows'] && wsSummary['!rows'][KPI_ROW]) wsSummary['!rows'][KPI_ROW].hpt = 30;
        XLSX.utils.book_append_sheet(wb, wsSummary, "Tổng Hợp Theo Bộ Phận");

        // ----------------------------------------------------
        // SHEET 2: DANH SÁCH CHI TIẾT TỪNG THIẾT BỊ (tô nhẹ theo loại: Laptop xanh dương nhạt, Máy tính xanh lá nhạt)
        // ----------------------------------------------------
        let rows = [
