        html += dong('Thời gian Check gần nhất', thoiGianCheck, 'fa-clock');
        html += dong('Ngày tạo', ngayTao, 'fa-calendar-plus');
        html += dong('Ngày cập nhật', ngayCapNhat, 'fa-calendar-check');
        html += `<div class="col-12 mb-3">
        <div class="small text-muted text-uppercase fw-bold" style="font-size:11px;"><i class="fas fa-sticky-note me-1"></i>Ghi chú</div>
