        // Cột: STT, Loại thiết bị, Quy cách, Đơn vị, Số lượng, Nhà sản xuất, Tên máy, Mã NV sử dụng, Tên người sử dụng
        // ==========================================
        // Nhà sản xuất không được lưu thành trường riêng trong CSDL nên suy đoán từ chuỗi Quy cách/Tên máy
        // bằng cách so khớp các thương hiệu phổ biến; nếu không khớp được thì lấy từ đầu tiên của Quy cách.
        const DANH_SACH_HANG_SAN_XUAT = [
            'Dell', 'HP', 'Hewlett Packard', 'Lenovo', 'Asus', 'Acer', 'Apple', 'MSI',
            'Samsung', 'LG', 'Sony', 'Toshiba', 'Fujitsu', 'Microsoft', 'Xiaomi',
            'Canon', 'Epson', 'Brother', 'Xerox', 'Ricoh', 'Kyocera',
            'Cisco', 'TP-Link', 'Tplink', 'D-Link', 'Ubiquiti', 'Mikrotik', 'Huawei',
            'Panasonic', 'ViewSonic', 'AOC', 'Philips', 'BenQ'
        ];
        function suyDoanNhaSanXuat(quyCach, tenMay) {
        let text = `${quyCach || ''} ${tenMay || ''}`;
        for (const hang of DANH_SACH_HANG_SAN_XUAT) {
            if (text.toLowerCase().includes(hang.toLowerCase())) return hang;
        }
        let tuDauQuyCach = (quyCach || '').trim().split(/\s+/)[0];
        return tuDauQuyCach || 'Không xác định';
        }

        window.exportBaoCaoThongThuong = function() {
        if (filteredExportData.length === 0) {
