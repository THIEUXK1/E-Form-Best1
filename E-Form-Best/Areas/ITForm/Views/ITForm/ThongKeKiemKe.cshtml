        $('#bodyXemChiTietThietBi').html(html);

        if (item.duongDanAnh) {
        $('#imgXemChiTietThietBi').attr('src', '/QLKiemKe/GetImage?fileName=' + encodeURIComponent(item.duongDanAnh)).show();
        } else {
        $('#imgXemChiTietThietBi').hide();
