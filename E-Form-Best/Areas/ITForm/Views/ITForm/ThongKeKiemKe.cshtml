@section Scripts {
    <script>
        // Các biến lưu trữ dữ liệu
        let allDataCache = [];
        let finalFilteredGlobal = [];
        let filteredExportData = [];

        // Các biến phục vụ Phân trang (Pagination)
        let currentPage = 1;
        let pageSize = 100;

        // "Hiển thị tất cả" quy về 1 số rất lớn để tái sử dụng nguyên vẹn công thức phân trang hiện có (không cần rẽ nhánh riêng)
        function layPageSizeTuGiaTri(val) {
        return val === 'all' ? 999999 : parseInt(val);
        }

        // Các biểu đồ
        let chartCongTy = null;
        let chartLoai = null;
        let chartTienDo = null;
        let chartBoPhanInstances = [];

        // Trạng thái thẻ Card đang được chọn
        let activeCardFilter = '';

        // Chế độ lọc Công ty/Bộ phận: false = chỉ lấy các mục đã chọn, true = lấy tất cả TRỪ các mục đã chọn
        let excludeCongTyMode = false;
        let excludeBoPhanMode = false;

        $(document).ready(function () {
        // Phần biểu đồ mặc định thu gọn, resize lại khi người dùng bấm mở ra (canvas ẩn lúc vẽ ban đầu sẽ bị sai kích thước)
        document.getElementById('collapseBieuDo').addEventListener('shown.bs.collapse', function () {
        $('#iconToggleBieuDo').removeClass('fa-chevron-right').addClass('fa-chevron-down');
        $('#textToggleBieuDo').text('Thu gọn biểu đồ thống kê');

        if (chartCongTy) chartCongTy.resize();
        if (chartLoai) chartLoai.resize();
        if (chartTienDo) chartTienDo.resize();
        chartBoPhanInstances.forEach(function (c) { if (c) c.resize(); });
        });
        document.getElementById('collapseBieuDo').addEventListener('hidden.bs.collapse', function () {
        $('#iconToggleBieuDo').removeClass('fa-chevron-down').addClass('fa-chevron-right');
        $('#textToggleBieuDo').text('Xem biểu đồ thống kê');
        });

        // Đọc trạng thái ẩn hiện bộ lọc nâng cao từ localStorage
        let savedState = localStorage.getItem('dash_toggleAdvancedFilters') || 'hide';
        if (savedState === 'show') {
        $('#boxAdvancedFiltersArea').show();
        $('#lblToggleText').text('Thu gọn bộ lọc');
        } else {
        $('#boxAdvancedFiltersArea').hide();
        $('#lblToggleText').text('Bộ lọc nâng cao');
        }

        // --- KHÔI PHỤC CÁC BỘ LỌC CƠ BẢN TỪ LOCALSTORAGE ---
        if (localStorage.getItem('dash_filterText')) {
            $('#filterText').val(localStorage.getItem('dash_filterText'));
        }
        if (localStorage.getItem('dash_filterSort')) {
            $('#filterSort').val(localStorage.getItem('dash_filterSort'));
        }
        if (localStorage.getItem('dash_pageSize')) {
            let savedLimitVal = localStorage.getItem('dash_pageSize');
            pageSize = layPageSizeTuGiaTri(savedLimitVal);
            $('#filterLimit').val(savedLimitVal);
            $('#lblSyncPageSize').text(savedLimitVal === 'all' ? 'Tất cả' : (pageSize + ' dòng'));
        }
        if (localStorage.getItem('dash_activeCardFilter') !== null) {
            activeCardFilter = localStorage.getItem('dash_activeCardFilter');
            let activeCardId = localStorage.getItem('dash_activeCardId') || 'card-all';
            $('.stat-card').removeClass('active');
            $('#' + activeCardId).addClass('active');
        }

        // Khôi phục chế độ Loại trừ Công ty/Bộ phận
        excludeCongTyMode = localStorage.getItem('dash_excludeCongTyMode') === 'true';
        excludeBoPhanMode = localStorage.getItem('dash_excludeBoPhanMode') === 'true';
        $('#chkExcludeCongTy').prop('checked', excludeCongTyMode);
        $('#chkExcludeBoPhan').prop('checked', excludeBoPhanMode);

        $('#chkExcludeCongTy').on('change', function () {
        excludeCongTyMode = $(this).is(':checked');
        localStorage.setItem('dash_excludeCongTyMode', excludeCongTyMode);
        updateDropdownButtonLabel($('#menuCongTy'));
        applyFiltersAndRender();
        });
        $('#chkExcludeBoPhan').on('change', function () {
        excludeBoPhanMode = $(this).is(':checked');
        localStorage.setItem('dash_excludeBoPhanMode', excludeBoPhanMode);
        updateDropdownButtonLabel($('#menuBoPhan'));
        applyFiltersAndRender();
        });

        // Sự kiện tìm kiếm nhanh & thay đổi sắp xếp & Thay đổi Số dòng hiển thị từ thanh bộ lọc chính
        $('#filterText, #filterSort').on('keyup change', function () {
        applyFiltersAndRender();
        });

        $('#filterLimit').on('change', function () {
        let val = $(this).val();
        pageSize = layPageSizeTuGiaTri(val);
        currentPage = 1;
        $('#lblSyncPageSize').text(val === 'all' ? 'Tất cả' : (pageSize + ' dòng'));
        renderTablePage();
        });

        // Lắng nghe sự kiện thay đổi của Checkbox lồng trong Dropdown Menu
        $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
        updateDropdownButtonLabel($(this).closest('.dropdown-combo-menu'));
        applyFiltersAndRender();
        });

        // Tải dữ liệu lần đầu
        loadData();
        });

        // Hàm trượt ẩn hiện nâng cao và lưu trạng thái
        function toggleAdvancedFilters() {
        let $area = $('#boxAdvancedFiltersArea');
        if ($area.is(':visible')) {
        $area.slideUp(200);
        $('#lblToggleText').text('Bộ lọc nâng cao');
        localStorage.setItem('dash_toggleAdvancedFilters', 'hide');
        } else {
        $area.slideDown(200);
        $('#lblToggleText').text('Thu gọn bộ lọc');
        localStorage.setItem('dash_toggleAdvancedFilters', 'show');
        }
        }

        function loadData() {
        $.get('/QLKiemKe/GetKkThietBiss', function (res) {
        if (res.success) {
        allDataCache = res.data || [];
        populateFilters(allDataCache);
        applyFiltersAndRender();
        } else {
        Swal.fire("Lỗi tải dữ liệu", res.msg, "error");
        }
        }).fail(function() { Swal.fire("Lỗi", "Lỗi kết nối máy chủ!", "error"); });
        }

        // Đổ dữ liệu động vào hệ thống các Checkbox
        function populateFilters(data) {
        let companies = [...new Set(data.map(x => x.tenCongTy).filter(Boolean))].sort();
        let depts = [...new Set(data.map(x => x.tenBoPhan).filter(Boolean))].sort();
        let types = [...new Set(data.map(x => x.loaiThietBi).filter(Boolean))].sort();

        // Danh sách có thêm cấu hình "Trống / Chưa rõ" để lọc null/rỗng theo nghiệp vụ mới
        let winLicenses = ["Windows Pro", "Windows Home", "Windows Enterprise", "Windows Education", "Windows Server", "Có (Chưa rõ phiên bản)", "Chưa có", "Trống / Chưa rõ"];
        let officeLicenses = ["Office Professional Plus", "Office Standard", "Office Home & Business", "Office Home & Student", "Microsoft 365 Apps", "Có (Chưa rõ phiên bản)", "Chưa có", "Trống / Chưa rõ"];

        $('#menuCongTy').empty();
        $('#menuBoPhan').empty();
        $('#menuLoai').empty();
        $('#menuWin').empty();
        $('#menuOffice').empty();

        companies.forEach(x => {
        $('#menuCongTy').append(`<label class="dropdown-combo-item"><input type="checkbox" class="chk-company" value="${x}"><span>${x}</span></label>`);
        });

        depts.forEach(x => {
        $('#menuBoPhan').append(`<label class="dropdown-combo-item"><input type="checkbox" class="chk-dept" value="${x}"><span>${x}</span></label>`);
        });

        types.forEach(x => {
        $('#menuLoai').append(`<label class="dropdown-combo-item"><input type="checkbox" class="chk-loai" value="${x}"><span>${x}</span></label>`);
        });

        winLicenses.forEach(x => {
        $('#menuWin').append(`<label class="dropdown-combo-item"><input type="checkbox" class="chk-win" value="${x}"><span>${x}</span></label>`);
        });

        officeLicenses.forEach(x => {
        $('#menuOffice').append(`<label class="dropdown-combo-item"><input type="checkbox" class="chk-office" value="${x}"><span>${x}</span></label>`);
        });

        // --- KHÔI PHỤC TRẠNG THÁI CÁC DROPDOWN MULTI-CHECKBOX TỪ LOCALSTORAGE ---
        try {
            let savedCompanies = JSON.parse(localStorage.getItem('dash_selectedCompanies') || '[]');
            savedCompanies.forEach(val => { $(`.chk-company[value="${val}"]`).prop('checked', true); });
            
            let savedDepts = JSON.parse(localStorage.getItem('dash_selectedDepts') || '[]');
            savedDepts.forEach(val => { $(`.chk-dept[value="${val}"]`).prop('checked', true); });
            
            let savedLoais = JSON.parse(localStorage.getItem('dash_selectedLoais') || '[]');
            savedLoais.forEach(val => { $(`.chk-loai[value="${val}"]`).prop('checked', true); });
            
            let savedWins = JSON.parse(localStorage.getItem('dash_selectedWins') || '[]');
            savedWins.forEach(val => { $(`.chk-win[value="${val}"]`).prop('checked', true); });
            
            let savedOffices = JSON.parse(localStorage.getItem('dash_selectedOffices') || '[]');
            savedOffices.forEach(val => { $(`.chk-office[value="${val}"]`).prop('checked', true); });
        } catch (e) { 
            console.error("Lỗi khôi phục bộ lọc nâng cao từ localStorage", e); 
        }

        // Cập nhật nhãn đại diện trên nút Dropdown
        $('.dropdown-combo-menu').each(function() {
        updateDropdownButtonLabel($(this));
        });
        }

        function updateDropdownButtonLabel($menu) {
        let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
        let $btn = $menu.siblings('.dropdown-combo-btn');
        let menuId = $menu.attr('id');
        let isExcludeMode = (menuId === 'menuCongTy' && excludeCongTyMode) || (menuId === 'menuBoPhan' && excludeBoPhanMode);

        if (totalChecked === 0) {
        $btn.text('-- Tất cả --');
        } else if (isExcludeMode) {
        $btn.text(`Tất cả, trừ ${totalChecked} mục`);
        } else if (totalChecked === 1) {
        $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
        } else {
        $btn.text(`Đã chọn (${totalChecked})`);
        }
        }

        function clearFilters() {
        $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
        $('.dropdown-combo-menu').each(function() {
        updateDropdownButtonLabel($(this));
        });
        excludeCongTyMode = false;
        excludeBoPhanMode = false;
        $('#chkExcludeCongTy').prop('checked', false);
        $('#chkExcludeBoPhan').prop('checked', false);
        localStorage.setItem('dash_excludeCongTyMode', 'false');
        localStorage.setItem('dash_excludeBoPhanMode', 'false');
        $('#filterText').val('');
        $('#filterSort').val('');
        $('#filterLimit').val('100');
        pageSize = 100;
        $('#lblSyncPageSize').text('100 dòng');
        setCardFilter('', 'card-all');
        }

        function setCardFilter(status, cardId) {
        activeCardFilter = status.toLowerCase();
        $('.stat-card').removeClass('active');
        $('#' + cardId).addClass('active');
        applyFiltersAndRender();
        }

        // ====================================================
        // HÀM LỌC CHÍNH (XỬ LÝ DỮ LIỆU + KIỂM TRA MẢNG BẢN QUYỀN MỚI THÊM)
        // ====================================================
        function applyFiltersAndRender() {
        let selectedCompanies = $('.chk-company:checked').map(function() { return $(this).val(); }).get();
        let selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
        let selectedLoais = $('.chk-loai:checked').map(function() { return $(this).val(); }).get();
        let selectedWins = $('.chk-win:checked').map(function() { return $(this).val(); }).get();
        let selectedOffices = $('.chk-office:checked').map(function() { return $(this).val(); }).get();

        let fText = $('#filterText').val().toLowerCase().trim();
        let fSort = $('#filterSort').val();

        // --- TIẾN HÀNH LƯU TRẠNG THÁI HIỆN TẠI VÀO LOCALSTORAGE KHI CÓ THAY ĐỔI ---
        localStorage.setItem('dash_filterText', $('#filterText').val());
        localStorage.setItem('dash_filterSort', fSort);
        localStorage.setItem('dash_pageSize', $('#filterLimit').val());
        localStorage.setItem('dash_activeCardFilter', activeCardFilter);
        localStorage.setItem('dash_activeCardId', $('.stat-card.active').attr('id') || 'card-all');
        localStorage.setItem('dash_selectedCompanies', JSON.stringify(selectedCompanies));
        localStorage.setItem('dash_selectedDepts', JSON.stringify(selectedDepts));
        localStorage.setItem('dash_selectedLoais', JSON.stringify(selectedLoais));
        localStorage.setItem('dash_selectedWins', JSON.stringify(selectedWins));
        localStorage.setItem('dash_selectedOffices', JSON.stringify(selectedOffices));

        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);

        let baseFiltered = allDataCache;

        // Xử lý lọc mảng Multi-select từ Dropdown Checkbox
        // Công ty/Bộ phận hỗ trợ 2 chiều: mặc định "chỉ lấy mục đã chọn", bật switch "Loại trừ" thì lấy tất cả TRỪ mục đã chọn
        if (selectedCompanies.length > 0) {
        baseFiltered = excludeCongTyMode
        ? baseFiltered.filter(x => !selectedCompanies.includes(x.tenCongTy))
        : baseFiltered.filter(x => selectedCompanies.includes(x.tenCongTy));
        }
        if (selectedDepts.length > 0) {
        baseFiltered = excludeBoPhanMode
        ? baseFiltered.filter(x => !selectedDepts.includes(x.tenBoPhan))
        : baseFiltered.filter(x => selectedDepts.includes(x.tenBoPhan));
        }
        if (selectedLoais.length > 0) baseFiltered = baseFiltered.filter(x => selectedLoais.includes(x.loaiThietBi));

        // Logic lọc bản quyền đặc thù nâng cao (Xử lý chuỗi trống, null hoặc text "Trống / Chưa rõ")
        if (selectedWins.length > 0) {
        baseFiltered = baseFiltered.filter(x =>
        selectedWins.includes(x.winLicense) ||
        (selectedWins.includes("Chưa có") && x.winLicense === "Chưa có") ||
        (selectedWins.includes("Trống / Chưa rõ") && (!x.winLicense || x.winLicense.trim() === ""))
        );
        }
        if (selectedOffices.length > 0) {
        baseFiltered = baseFiltered.filter(x =>
        selectedOffices.includes(x.officeLicense) ||
        (selectedOffices.includes("Chưa có") && x.officeLicense === "Chưa có") ||
        (selectedOffices.includes("Trống / Chưa rõ") && (!x.officeLicense || x.officeLicense.trim() === ""))
        );
        }

        if (fText) {
        baseFiltered = baseFiltered.filter(x =>
        (x.tenMayTinh && x.tenMayTinh.toLowerCase().includes(fText)) ||
        (x.tenViTri && x.tenViTri.toLowerCase().includes(fText)) ||
        (x.tenNguoiDung && x.tenNguoiDung.toLowerCase().includes(fText)) ||
        (x.tenDangNhap && x.tenDangNhap.toLowerCase().includes(fText)) ||
        (x.tk && x.tk.toLowerCase().includes(fText)) ||
        (x.winLicense && x.winLicense.toLowerCase().includes(fText)) ||
        (x.officeLicense && x.officeLicense.toLowerCase().includes(fText))
        );
        }

        // Đếm số lượng hiển thị lên hệ thống Card Thống kê
        let countTotal = 0, countHD = 0, countBaoTri = 0, countHong = 0, countXoa = 0, countChuaCheck = 0;

        baseFiltered.forEach(x => {
        let t = (x.tenTrangThai || '').toLowerCase();
        if (t.includes('xóa') || x.ngayXoa != null) {
        countXoa++;
        } else {
        countTotal++;
        if (t.includes('hoạt động')) countHD++;
        else if (t.includes('bảo trì')) countBaoTri++;
        else if (t.includes('hỏng')) countHong++;

        if (!x.thoiGianCheck) {
        countChuaCheck++;
        } else {
        if (new Date(x.thoiGianCheck) < fourMonthsAgo) countChuaCheck++;
        }
        }
        });

        $('#cardTong').text(countTotal);
        $('#cardHoatDong').text(countHD);
        $('#cardBaoTri').text(countBaoTri);
        $('#cardHong').text(countHong);
        $('#cardXoa').text(countXoa);
        $('#cardChuaCheck').text(countChuaCheck);

        let finalFiltered = baseFiltered;
        if (activeCardFilter === 'chuacheck') {
        finalFiltered = finalFiltered.filter(x => {
        if (x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')) return false;
        if (!x.thoiGianCheck) return true;
        return new Date(x.thoiGianCheck) < fourMonthsAgo;
        });
        } else if (activeCardFilter === 'xóa') {
        finalFiltered = finalFiltered.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa'));
        } else if (activeCardFilter !== '') {
        finalFiltered = finalFiltered.filter(x => x.tenTrangThai && x.tenTrangThai.toLowerCase().includes(activeCardFilter) && !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));
        } else {
        finalFiltered = finalFiltered.filter(x => !(x.tenTrangThai && x.tenTrangThai.toLowerCase().includes('xóa')));
        }

        // Sắp xếp tiếng Việt
        if (fSort) {
        finalFiltered.sort((a, b) => {
        let valA = '', valB = '';
        if (fSort.startsWith('host')) {
        valA = (a.tenMayTinh || '').toLowerCase(); valB = (b.tenMayTinh || '').toLowerCase();
        } else if (fSort.startsWith('name')) {
        valA = (a.tenViTri || '').toLowerCase(); valB = (b.tenViTri || '').toLowerCase();
        }
        if (fSort.endsWith('asc')) {
        return valA.localeCompare(valB, 'vi', { sensitivity: 'base' });
        } else {
        return valB.localeCompare(valA, 'vi', { sensitivity: 'base' });
        }
        });
        }

        finalFilteredGlobal = finalFiltered;
        filteredExportData = finalFiltered;
        currentPage = 1;

        $('#lblCountTable').text(finalFilteredGlobal.length);
        renderTablePage();

        // Vẽ lại các biểu đồ động Chart.js
        let mapCongTy = {}; let mapLoai = {};
        let countDaCheck = 0; let countChuaCheckChart = 0;
        let companyDeptsMap = {};

        finalFiltered.forEach(x => {
        let ct = x.tenCongTy || 'Chưa gắn CT';
        mapCongTy[ct] = (mapCongTy[ct] || 0) + 1;

        let bp = x.tenBoPhan || 'Chưa gắn BP';
        if (!companyDeptsMap[ct]) companyDeptsMap[ct] = {};
        companyDeptsMap[ct][bp] = (companyDeptsMap[ct][bp] || 0) + 1;

        let type = x.loaiThietBi || 'Khác';
        mapLoai[type] = (mapLoai[type] || 0) + 1;

        if (!x.thoiGianCheck || new Date(x.thoiGianCheck) < fourMonthsAgo) {
        countChuaCheckChart++;
        } else {
        countDaCheck++;
        }
        });

        sortedCT = Object.entries(mapCongTy).sort((a,b) => b[1]-a[1]);
        // Gán 1 màu cố định cho mỗi công ty (theo thứ tự xuất hiện) và dùng lại đúng màu đó ở cả biểu đồ tròn lẫn biểu đồ bộ phận bên dưới, để cùng 1 công ty luôn nhận diện bằng 1 màu duy nhất trên toàn trang
        let companyColorMap = {};
        sortedCT.forEach((entry, i) => {
        companyColorMap[entry[0]] = { bg: CHART_PALETTE[i % CHART_PALETTE.length], ink: CHART_PALETTE_INK[i % CHART_PALETTE_INK.length] };
        });

        chartCongTy = drawPieChart(chartCongTy, 'chartCongTy', sortedCT.map(i=>i[0]), sortedCT.map(i=>i[1]), function(label) {
        setTimeout(() => {
        $('.chk-company').prop('checked', false);
        $(`.chk-company[value="${label}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuCongTy'));
        applyFiltersAndRender();
        document.getElementById('tableSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
        }, companyColorMap);

        let sortedLoai = Object.entries(mapLoai).sort((a,b) => b[1]-a[1]);
        chartLoai = drawBarChart(chartLoai, 'chartLoai', sortedLoai.map(i=>i[0]), sortedLoai.map(i=>i[1]), 'Số lượng', CHART_PALETTE[0], function(label) {
        setTimeout(() => {
        $('.chk-loai').prop('checked', false);
        $(`.chk-loai[value="${label}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuLoai'));
        applyFiltersAndRender();
        document.getElementById('tableSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
        });

        chartTienDo = drawTienDoChart(chartTienDo, 'chartTienDo', countDaCheck, countChuaCheckChart);

        chartBoPhanInstances.forEach(c => c.destroy());
        chartBoPhanInstances = [];
        $('#boPhanChartsContainer').empty();

        if (typeof companyDeptsMap === 'object' && Object.keys(companyDeptsMap).length === 0) {
        $('#boPhanChartsContainer').html('<div class="col-12 text-center text-muted py-5"><i class="fas fa-folder-open fa-2x mb-2 d-block opacity-50"></i>Không có dữ liệu bộ phận</div>');
        } else {
        let colClass = Object.keys(companyDeptsMap).length > 1 ? 'col-md-6' : 'col-12';
        let chartIndex = 0;

        for (let cty in companyDeptsMap) {
        let sortedBP = Object.entries(companyDeptsMap[cty]).sort((a,b) => b[1]-a[1]).slice(0, 15);
        let canvasId = 'chartBP_' + chartIndex;
        // Dùng lại đúng màu của công ty này ở biểu đồ tròn phía trên, thay vì 1 bảng màu tách biệt
        let currentColor = (companyColorMap[cty] && companyColorMap[cty].bg) || CHART_PALETTE[chartIndex % CHART_PALETTE.length];

        let htmlCol = `
        <div class="${colClass} mb-4">
        <h6 class="text-center fw-bold" style="color: ${currentColor}; font-size: 0.95rem;"><i class="fas fa-building me-1"></i>${cty}</h6>
        <div style="position: relative; height: 250px; width: 100%;">
        <canvas id="${canvasId}"></canvas>
        </div>
        </div>`;
        $('#boPhanChartsContainer').append(htmlCol);

        let newChart = drawBarChart(null, canvasId, sortedBP.map(i=>i[0]), sortedBP.map(i=>i[1]), 'Số thiết bị', currentColor, function(label) {
        setTimeout(() => {
        $('.chk-company').prop('checked', false);
        $(`.chk-company[value="${cty}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuCongTy'));

        $('.chk-dept').prop('checked', false);
        $(`.chk-dept[value="${label}"]`).prop('checked', true);
        updateDropdownButtonLabel($('#menuBoPhan'));

        applyFiltersAndRender();
        document.getElementById('tableSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);
        });

        chartBoPhanInstances.push(newChart);
        chartIndex++;
        }
        }
        }

        // ====================================================
        // HÀM VẼ BẢNG DỮ LIỆU & PHÂN TRANG (PAGINATION)
        // ====================================================
        window.changePage = function(pageNumber) {
        currentPage = pageNumber;
        renderTablePage();
        }

        function renderTablePage() {
        let totalItems = finalFilteredGlobal.length;
        let totalPages = Math.ceil(totalItems / pageSize);
        let fourMonthsAgo = new Date();
        fourMonthsAgo.setMonth(fourMonthsAgo.getMonth() - 4);

        let htmlTable = '';

        if (totalItems === 0) {
        htmlTable = `<tr class="empty-row"><td colspan="10" class="text-center text-muted py-5"><i class="fas fa-box-open fa-3x mb-3 d-block opacity-50"></i> Không có dữ liệu phù hợp</td></tr>`;
        $('#paginationInfo').text("Không có mục nào để hiển thị");
        $('#paginationControls').html('');
        } else {
        let startIndex = (currentPage - 1) * pageSize;
        let endIndex = Math.min(startIndex + pageSize, totalItems);
        let pageData = finalFilteredGlobal.slice(startIndex, endIndex);

        $('#paginationInfo').html(`Đang hiển thị <b>${startIndex + 1}</b> đến <b>${endIndex}</b> trong tổng số <b class="text-primary">${totalItems}</b> thiết bị`);

        pageData.forEach(item => {
        let namePart = item.tenNguoiDung
        ? `<span class="text-primary fw-bold">${item.tenNguoiDung}</span> <span class="text-danger fw-normal">(${item.tk || 'N/A'})</span>`
        : `<span class="text-muted fst-italic">Chưa cấp phát</span>`;

        let accPart = item.tenDangNhap ? item.tenDangNhap : `<span class="text-muted fst-italic">Trống</span>`;
        let userStr = `<div>${namePart}</div><div class="small text-muted mt-1"><i class="fas fa-user-circle me-1"></i> Account: <b>${accPart}</b></div>`;
        let locStr = [item.tenCongTy, item.tenBoPhan].filter(Boolean).join(' - ') || 'Chưa gắn';

        // Chuỗi hiển thị bản quyền Windows và Office trên bảng
        let winStr = item.winLicense ? `<div class="text-primary small mb-1"><i class="fab fa-windows me-1"></i> ${item.winLicense}</div>` : '<div class="text-muted small mb-1"><i>Win: Trống / Chưa rõ</i></div>';
        let officeStr = item.officeLicense ? `<div class="text-success small"><i class="fas fa-file-word me-1"></i> ${item.officeLicense}</div>` : '<div class="text-muted small"><i>Office: Trống / Chưa rõ</i></div>';
        let licenseColumnHtml = `<div>${winStr}${officeStr}</div>`;

        let t = (item.tenTrangThai || '').toLowerCase();
        let badgeClass = "bg-secondary";
        if (t.includes("hoạt động")) badgeClass = "bg-success";
        else if (t.includes("bảo trì")) badgeClass = "bg-warning text-dark";
        else if (t.includes("hỏng") || t.includes("xóa")) badgeClass = "bg-danger";

        let checkHtml = '';
        if (!item.thoiGianCheck) {
        checkHtml = `<span class="badge bg-danger rounded-pill px-3 py-2"><i class="fas fa-exclamation-triangle me-1"></i> Chưa Check</span>`;
        } else {
        let checkDate = new Date(item.thoiGianCheck);
        if (checkDate < fourMonthsAgo) {
        checkHtml = `<span class="badge bg-warning text-dark rounded-pill px-2 py-2" title="Đã quá 4 tháng"><i class="fas fa-clock me-1"></i> Quá hạn (${checkDate.toLocaleDateString('vi-VN')})</span>`;
        } else {
        checkHtml = `<span class="badge bg-success rounded-pill px-3 py-2"><i class="fas fa-check me-1"></i> ${checkDate.toLocaleDateString('vi-VN')}</span>`;
        }
        }

        let htmlImg = '';
        if (item.duongDanAnh) {
        let imgUrl = `/QLKiemKe/GetImage?fileName=${encodeURIComponent(item.duongDanAnh)}`;
        htmlImg = `
        <div class="mt-2 text-md-start text-end">
        <img src="${imgUrl}" alt="Ảnh thiết bị" class="img-thumbnail shadow-sm" style="width: 50px; height: 50px; object-fit: cover; cursor: pointer; border-radius: 8px;" onclick="viewFullImage('${imgUrl}', '${item.tenMayTinh || item.tenViTri || 'Vị trí'}')" title="Nhấn để xem ảnh lớn" />
        </div>`;
        } else {
        htmlImg = `<div class="mt-2 text-muted small fst-italic text-md-start text-end" style="font-size: 11px;"><i class="fas fa-image" style="opacity: 0.4;"></i> Không có ảnh</div>`;
        }

        let htmlGhiChu = item.ghiChu ? `<div class="small text-wrap text-muted" style="max-width: 140px;">${item.ghiChu}</div>` : `<span class="text-muted fst-italic small" style="opacity: 0.5;">Trống</span>`;

        let btnXemMayTinh = item.idMay
        ? `<button class="btn btn-sm text-white rounded-pill shadow-sm px-2 py-1 btn-action-mobile" style="background: linear-gradient(135deg, #0ea5e9, #0369a1); border: none; font-weight: 600; font-size: 0.75rem;" onclick="window.open('/QLKiemKe/ViewChiTietMayTinh?idMay=${item.idMay}', '_blank')" title="Thiết bị này đã liên kết với 1 máy tính trong hệ thống"><i class="fas fa-desktop me-1"></i> Xem máy tính</button>`
        : '';

        htmlTable += `
        <tr>
        <td class="ps-4 fw-bold text-muted" data-label="Mã ID">#${item.idThietBi}</td>
        <td data-label="Thông tin TB & Hostname">
        <div class="text-end text-md-start">
        <div class="fw-bold text-dark fs-6">${item.tenMayTinh || '<i class="text-muted fw-normal">No Hostname</i>'}</div>
        <div class="small text-muted"><i class="fas fa-map-pin"></i> Vị trí: <b>${item.tenViTri}</b></div>
        </div>
        </td>
        <td data-label="Loại & Ảnh đính kèm">
        <div class="text-end text-md-start">
        <div class="text-end text-md-start">
        <span class="badge border border-secondary text-secondary bg-light px-2 py-1 mb-1 d-inline-block">${item.loaiThietBi || 'Khác'}</span>
        ${htmlImg}
        </div>
        </td>
        <td data-label="Hệ điều hành / Bản quyền">
        <div class="text-end text-md-start">${licenseColumnHtml}</div>
        </td>
        <td data-label="Tài khoản & Người dùng">
        <div class="text-end text-md-start">${userStr}</div>
        </td>
        <td class="small" data-label="Vị trí (Công ty - Bộ phận)">
        <div class="text-end text-md-start"><i class="fas fa-map-marker-alt text-muted me-1"></i>${locStr}</div>
        </td>
        <td class="text-center" data-label="Trạng thái kiểm kê">
        <div class="text-end text-md-center"><span class="badge ${badgeClass} w-100 py-2 shadow-sm">${item.tenTrangThai || 'Chưa rõ'}</span></div>
        </td>
        <td class="text-center" data-label="Lần cuối Check">
        <div class="text-end text-md-center">${checkHtml}</div>
        </td>
        <td data-label="Ghi chú">
        <div class="d-flex justify-content-end justify-content-md-start">${htmlGhiChu}</div>
        </td>
        <td class="text-center" data-label="Thao tác">
        <div class="d-flex gap-1 justify-content-center flex-md-row flex-column">
        <button class="btn btn-sm btn-outline-primary rounded-pill px-2 py-1 btn-action-mobile" style="font-size: 0.75rem; font-weight: 600;" onclick='xemChiTietThietBi(${JSON.stringify(item).replace(/'/g, "&#39;")})'>
        <i class="fas fa-eye me-1"></i> Chi tiết
        </button>
        <button class="btn btn-sm text-white rounded-pill shadow-sm px-2 py-1 btn-action-mobile" style="background: linear-gradient(135deg, #8b5cf6, #6366f1); border: none; font-weight: 600; font-size: 0.75rem;" onclick="xemLichSuThietBi(${item.idThietBi}, '${item.tenMayTinh || item.tenViTri || 'Vị trí'}')">
        <i class="fas fa-history me-1"></i> Lịch sử
        </button>
        <button class="btn btn-sm text-white rounded-pill shadow-sm px-2 py-1 btn-action-mobile" style="background: linear-gradient(135deg, #10b981, #0ea5e9); border: none; font-weight: 600; font-size: 0.75rem;" onclick="xemNhatKyKiemKeThietBi(${item.idThietBi}, '${item.tenMayTinh || ''}', '${item.tenViTri || ''}')" title="Xem lại các lần Xác nhận kiểm kê trước đó, kèm ảnh bằng chứng">
        <i class="fas fa-clipboard-check me-1"></i> Nhật ký kiểm kê
        </button>
        ${btnXemMayTinh}
        </div>
        </td>
        </tr>`;
        });

        renderPaginationControls(totalPages);
        }
        $('#tbodyData').html(htmlTable);
        }

        function renderPaginationControls(totalPages) {
        let html = '';
        if (totalPages <= 1) { $('#paginationControls').html(''); return; }

        let prevDisabled = currentPage === 1 ? 'disabled' : '';
        html += `<li class="page-item ${prevDisabled}"><a class="page-link" onclick="window.changePage(${currentPage - 1})"><i class="fas fa-chevron-left"></i></a></li>`;

        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, currentPage + 2);

        if (startPage > 1) {
        html += `<li class="page-item"><a class="page-link" onclick="window.changePage(1)">1</a></li>`;
        if (startPage > 2) html += `<li class="page-item disabled"><span class="page-link border-0">...</span></li>`;
        }

        for (let i = startPage; i <= endPage; i++) {
        let activeClass = i === currentPage ? 'active' : '';
        html += `<li class="page-item ${activeClass}"><a class="page-link" onclick="window.changePage(${i})">${i}</a></li>`;
        }

        if (endPage < totalPages) {
        if (endPage < totalPages - 1) html += `<li class="page-item disabled"><span class="page-link border-0">...</span></li>`;
        html += `<li class="page-item"><a class="page-link" onclick="window.changePage(${totalPages})">${totalPages}</a></li>`;
        }

        let nextDisabled = currentPage === totalPages ? 'disabled' : '';
        html += `<li class="page-item ${nextDisabled}"><a class="page-link" onclick="window.changePage(${currentPage + 1})"><i class="fas fa-chevron-right"></i></a></li>`;

        $('#paginationControls').html(html);
        }

        // ==========================================
        // CÁC HÀM VẼ CHART.JS ĐỘNG
        // ==========================================
        function drawBarChart(chartInstance, canvasId, labels, data, labelTitle, colorCode, onClickCallback = null) {
        if (chartInstance) chartInstance.destroy();
        return new Chart(document.getElementById(canvasId).getContext('2d'), {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{ label: labelTitle, data: data, backgroundColor: colorCode, borderRadius: 6 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        onClick: (e, activeElements) => {
        if (activeElements.length > 0 && onClickCallback) {
        const dataIndex = activeElements[0].index;
        onClickCallback(labels[dataIndex]);
        }
        },
        onHover: (event, chartElement) => {
        event.native.target.style.cursor = chartElement[0] ? 'pointer' : 'default';
        },
        plugins: {
        network: { display: false },
        legend: { display: false },
        datalabels: {
        anchor: 'end', align: 'top', color: '#475569',
        font: { weight: 'bold', size: 12 },
        formatter: function(value) { return value > 0 ? value : ''; }
        }
        },
        scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 }, grace: '10%' },
        x: { ticks: { autoSkip: false, maxRotation: 25, minRotation: 0 } }
        }
        },
        plugins: [ChartDataLabels]
        });
        }

        // Bảng màu categorical đã kiểm định (đủ tương phản & phân biệt tốt cho người mù màu), dùng cố định theo thứ tự cho mọi biểu đồ
        const CHART_PALETTE = ['#2a78d6', '#1baf7a', '#eda100', '#008300', '#4a3aa7', '#e34948', '#e87ba4', '#eb6834'];
        // Vàng/cam sáng cần chữ tối để đủ tương phản, các màu còn lại dùng chữ trắng
        const CHART_PALETTE_INK = ['#fff', '#fff', '#3a2a00', '#fff', '#fff', '#fff', '#3a0a1e', '#fff'];

        function drawPieChart(chartInstance, canvasId, labels, data, onClickCallback = null, colorMap = null) {
        if (chartInstance) chartInstance.destroy();
        let colors = colorMap ? labels.map(l => colorMap[l].bg) : labels.map((_, i) => CHART_PALETTE[i % CHART_PALETTE.length]);
        let inkColors = colorMap ? labels.map(l => colorMap[l].ink) : labels.map((_, i) => CHART_PALETTE_INK[i % CHART_PALETTE_INK.length]);
        return new Chart(document.getElementById(canvasId).getContext('2d'), {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{ data: data, backgroundColor: colors, borderColor: '#fff', borderWidth: 2, hoverOffset: 4 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        onClick: (e, activeElements) => {
        if (activeElements.length > 0 && onClickCallback) {
        const dataIndex = activeElements[0].index;
        onClickCallback(labels[dataIndex]);
        }
        },
        onHover: (event, chartElement) => {
        event.native.target.style.cursor = chartElement[0] ? 'pointer' : 'default';
        },
        plugins: {
        legend: { position: 'right', labels: { boxWidth: 12, color: '#475569', font: { weight: '600' } } },
        datalabels: {
        color: (ctx) => inkColors[ctx.dataIndex % inkColors.length], font: { weight: 'bold', size: 13 },
        formatter: function(value) { return value > 0 ? value : ''; }
        }
        },
        cutout: '60%'
        },
        plugins: [ChartDataLabels]
        });
        }

        function drawTienDoChart(chartInstance, canvasId, valDaCheck, valChuaCheck) {
        if (chartInstance) chartInstance.destroy();
        return new Chart(document.getElementById(canvasId).getContext('2d'), {
        type: 'pie',
        data: {
        labels: ['Đã Kiểm Kê (Gần đây)', 'Chưa / Quá hạn'],
        datasets: [{ data: [valDaCheck, valChuaCheck], backgroundColor: ['#1baf7a', '#eda100'], borderColor: '#fff', borderWidth: 2, hoverOffset: 4 }]
        },
        options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 15, color: '#475569', font: { weight: '600' } } },
        datalabels: {
        color: (ctx) => ctx.dataIndex === 1 ? '#3a2a00' : '#fff', font: { weight: 'bold', size: 14 },
        formatter: function(value) { return value > 0 ? value : ''; }
        }
        }
        },
        plugins: [ChartDataLabels]
        });
        }

        // Hiển thị TOÀN BỘ các trường của thiết bị trong 1 modal ngay tại trang này (không điều hướng sang trang khác)
        function xemChiTietThietBi(item) {
        function dong(nhan, giaTri, icon) {
        let hienThi = (giaTri === null || giaTri === undefined || giaTri === '') ? '<span class="text-muted fst-italic">Chưa có</span>' : giaTri;
        return `<div class="col-md-6 mb-3">
        <div class="small text-muted text-uppercase fw-bold" style="font-size:11px;"><i class="fas ${icon} me-1"></i>${nhan}</div>
        <div class="fw-semibold text-dark">${hienThi}</div>
        </div>`;
        }

        let ngayTao = item.ngayTao ? new Date(item.ngayTao).toLocaleString('vi-VN') : '';
        let ngayCapNhat = item.ngayCapNhat ? new Date(item.ngayCapNhat).toLocaleString('vi-VN') : '';
        let thoiGianCheck = item.thoiGianCheck ? new Date(item.thoiGianCheck).toLocaleString('vi-VN') : '';
