            if (!zone) return;

            zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('dragover'); });
            zone.addEventListener('dragleave', function () { zone.classList.remove('dragover'); });
            zone.addEventListener('drop', function (e) {
            e.preventDefault();
            zone.classList.remove('dragover');
            if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            let file = e.dataTransfer.files[0];
            if (file.type.startsWith('image/')) {
            taiSanAnhBlob = null;
            $('#fileTaiSanAnh')[0].files = e.dataTransfer.files;
            hienThiXemTruocAnhTaiSan(file);
            }
            }
            });

            let modalTaiSan = document.getElementById('modalXacNhanTaiSan');
            modalTaiSan.addEventListener('paste', function (e) {
            if (e.clipboardData && e.clipboardData.items) {
            for (let i = 0; i < e.clipboardData.items.length; i++) {
            let item = e.clipboardData.items[i];
            if (item.type.indexOf('image') !== -1) {
            let blob = item.getAsFile();
            taiSanAnhBlob = blob;
            $('#fileTaiSanAnh').val('');
            hienThiXemTruocAnhTaiSan(blob);
            break;
            }
            }
            }
            });
            }

