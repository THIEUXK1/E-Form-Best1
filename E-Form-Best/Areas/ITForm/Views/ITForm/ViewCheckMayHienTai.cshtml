@{
    Layout = "~/Areas/ITForm/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thông tin máy hiện tại";
}

<style>
    .drag-drop-zone {
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        padding: 20px;
        background: #f8fafc;
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .drag-drop-zone.dragover {
            border-color: #10b981;
            background: #d1fae5;
        }

    .avatar-mini-wrapper {
        position: relative;
        width: 70px;
        height: 70px;
        flex-shrink: 0;
        background: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
    }

        .avatar-mini-wrapper img {
            width: 70px;
            height: 70px;
            border-radius: 10px;
            object-fit: cover;
            border: 2px solid #cbd5e1;
            cursor: pointer;
        }

    .avatar-mini-wrapper-sm {
        position: relative;
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        background: #e2e8f0;
        border-radius: 8px;
        overflow: hidden;
    }

        .avatar-mini-wrapper-sm img {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid #cbd5e1;
            cursor: pointer;
        }

    /* Combobox tìm kiếm tự viết (không phụ thuộc CDN) cho Công ty/Bộ phận trong modal Xác nhận tài sản */
    .mini-combo {
        position: relative;
    }

    .mini-combo-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        max-height: 220px;
        overflow-y: auto;
        z-index: 2000;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.15);
        margin-top: 4px;
    }

    .mini-combo-item {
        padding: 8px 12px;
        cursor: pointer;
        font-size: 14px;
        color: #334155;
    }

        .mini-combo-item:hover {
            background: #f1f5f9;
        }

        .mini-combo-item.active {
            background: #eef2ff;
            font-weight: 700;
            box-shadow: inset 3px 0 0 #4f46e5;
        }

    .mini-combo-empty {
        padding: 10px 12px;
        color: #94a3b8;
        font-size: 13px;
        font-style: italic;
    }
</style>

<div class="container-fluid mt-4">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        @if (User.IsInRole("XemTSCN") || User.IsInRole("All"))
        {
            <div class="d-flex justify-content-end align-items-center mb-2">
                <a href="/QLKiemKe/TaiSanBoPhan" target="_blank" class="btn btn-sm btn-outline-primary">
                    <i class="fa fa-building" style="margin-right: 4px;"></i> Xem tài sản bộ phận
                </a>
            </div>
        }

        <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fa fa-desktop" style="margin-right: 8px;"></i>Thông Tin Cấu Hình Máy Hiện Tại</h5>
                <div>
                    <button id="btnMoModalXacNhanTaiSan" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#modalXacNhanTaiSan" disabled title="Cần tải xong thông tin máy từ Tool local mới có thể xác nhận">
                        <i class="fa fa-check-square-o" style="margin-right: 4px;"></i> Xác nhận tài sản
                    </button>
                    <button id="btnRefresh" class="btn btn-sm btn-light text-primary" style="display: none;">
                        <i class="fa fa-refresh" style="margin-right: 4px;"></i> Làm mới
                    </button>
                </div>
            </div>
            <div class="card-body">

                <div id="alwaysShowTableContainer">
                    <table class="table table-bordered table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 35%;">Thông số hệ thống</th>
                                <th style="width: 65%;">Giá trị chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="table-warning">
                                <td><strong><i class="fa fa-barcode text-danger" style="margin-right: 8px; width: 16px;"></i>Số Serial Máy (Serial Number):</strong></td>
                                <td id="lblSeriMay" class="fw-bold text-danger">Đang tải...</td>
                            </tr>
                            <tr class="table-warning">
                                <td><strong><i class="fa fa-info-circle text-primary" style="margin-right: 8px; width: 16px;"></i>Dòng máy (Hãng sản xuất):</strong></td>
                                <td id="lblDongMay" class="fw-bold text-primary">Đang tải...</td>
                            </tr>
                            <tr class="table-warning">
                                <td><strong><i class="fa fa-laptop text-primary" style="margin-right: 8px; width: 16px;"></i>Tên máy (Machine Name):</strong></td>
                                <td id="lblTenMay" class="fw-bold">Đang tải...</td>
                            </tr>
                            <tr class="table-warning">
                                <td><strong><i class="fa fa-user text-secondary" style="margin-right: 8px; width: 16px;"></i>Tên người dùng hệ thống:</strong></td>
                                <td id="lblTenNguoiDungHeThong" class="fw-bold">Đang tải...</td>
                            </tr>
                            <tr class="table-warning">
                                <td><strong><i class="fa fa-video-camera text-warning" style="margin-right: 8px; width: 16px;"></i>Trạng thái kết nối thêm:</strong></td>
                                <td id="lblThongTinManHinhNgoai" class="fw-bold text-success">Đang tải...</td>
                            </tr>
                            <tr class="table-warning">
                                <td><strong><i class="fa fa-television text-success" style="margin-right: 8px; width: 16px;"></i>Danh sách tất cả Màn hình phát hiện:</strong></td>
                                <td id="lblThongTinManHinh" class="fw-bold text-dark">Đang tải...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div id="boxThongTinSoHuu" class="mt-3" style="display: none;">
                    <table class="table table-bordered table-striped mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th style="width: 35%;">Thông tin sở hữu (theo Kiểm kê thiết bị)</th>
                                <th style="width: 65%;">Giá trị</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong><i class="fa fa-user-circle text-primary" style="margin-right: 8px; width: 16px;"></i>Máy này đang thuộc về:</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3 flex-wrap">
                                        <div class="avatar-mini-wrapper" id="wrapAvatarMay" style="display: none;">
                                            <img id="imgAvatarMay" src="" onerror="this.style.visibility='hidden';" />
                                        </div>
                                        <div>
                                            <div id="lblMaySoHuuBoi" class="fw-bold text-primary">Chưa xác nhận kiểm kê</div>
                                            <div id="lblChiTietMay" class="small text-muted"></div>
                                        </div>
                                        <div id="btnsAnhMay" style="display: none;">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnXemAnhMay"><i class="fa fa-eye"></i> Xem ảnh</button>
                                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnSuaAnhMay" style="display: none;"><i class="fa fa-pencil"></i> Sửa ảnh</button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <tr id="rowManHinhSoHuuBoi" style="display: none;">
                                <td><strong><i class="fa fa-desktop text-success" style="margin-right: 8px; width: 16px;"></i>Màn hình rời đang thuộc về:</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3 flex-wrap">
                                        <div class="avatar-mini-wrapper" id="wrapAvatarManHinh" style="display: none;">
                                            <img id="imgAvatarManHinh" src="" onerror="this.style.visibility='hidden';" />
                                        </div>
                                        <div>
                                            <div id="lblManHinhSoHuuBoi" class="fw-bold text-success">Chưa xác nhận kiểm kê</div>
                                            <div id="lblChiTietManHinh" class="small text-muted"></div>
                                        </div>
                                        <div id="btnsAnhManHinh" style="display: none;">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnXemAnhManHinh"><i class="fa fa-eye"></i> Xem ảnh</button>
                                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnSuaAnhManHinh" style="display: none;"><i class="fa fa-pencil"></i> Sửa ảnh</button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-cubes text-warning" style="margin-right: 8px; width: 16px;"></i>Tài sản khác đi kèm:</strong></td>
                                <td id="lblTaiSanKhacDiKem" class="text-dark">Không có</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div id="authGateContainer" class="text-center my-4 p-4 border rounded bg-light">
                    <i class="fa fa-lock text-warning" style="font-size: 32px; margin-bottom: 10px;"></i>
                    <h5 class="fw-bold text-dark">Thông tin cấu hình nâng cao đang được ẩn</h5>
                    <p class="text-muted small">Vui lòng nhập tài khoản xác minh để mở khóa xem các thông số chi tiết hệ điều hành, RAM, ổ cứng và bản quyền.</p>
                    <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modalXacThuc">
                        <i class="fa fa-eye" style="margin-right: 8px;"></i> Nhập mật khẩu để xem chi tiết
                    </button>
                </div>

                <div id="loadingStatus" class="text-center my-4" style="display: none;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted">Đang quét cấu hình hệ thống nâng cao, vui lòng đợi...</p>
                </div>

                <div id="infoTableContainer" style="display: none;">
                    <table class="table table-bordered table-striped table-hover mt-3">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 35%;">Thông số hệ thống nâng cao</th>
                                <th style="width: 65%;">Giá trị chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong><i class="fa fa-windows text-info" style="margin-right: 8px; width: 16px;"></i>Hệ điều hành:</strong></td>
                                <td id="lblHeDieuHanh"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-shield text-info" style="margin-right: 8px; width: 16px;"></i>Trạng thái bản quyền Windows:</strong></td>
                                <td id="lblBanQuyenWin" class="fw-bold text-info"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-microchip text-success" style="margin-right: 8px; width: 16px;"></i>Kiến trúc OS:</strong></td>
                                <td id="lblKienTruc"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-code text-danger" style="margin-right: 8px; width: 16px;"></i>Phiên bản .NET Framework:</strong></td>
                                <td id="lblPhienBanNet"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-server text-warning" style="margin-right: 8px; width: 16px;"></i>Số lõi CPU (Processor Count):</strong></td>
                                <td id="lblSoLoiCPU"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-database text-primary" style="margin-right: 8px; width: 16px;"></i>Chuẩn Loại RAM (Memory Type):</strong></td>
                                <td id="lblLoaiRam"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-tasks text-primary" style="margin-right: 8px; width: 16px;"></i>RAM khả dụng:</strong></td>
                                <td id="lblRamKhaDung"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-hdd-o text-info" style="margin-right: 8px; width: 16px;"></i>Thông tin ổ cứng (Storage):</strong></td>
                                <td id="lblThongTinOCung"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-file-word-o text-info" style="margin-right: 8px; width: 16px;"></i>Phiên bản Microsoft Office:</strong></td>
                                <td id="lblThongTinOffice" class="fw-bold text-info"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-key text-danger" style="margin-right: 8px; width: 16px;"></i>Trạng thái bản quyền Office:</strong></td>
                                <td id="lblBanQuyenOffice" class="fw-bold text-danger"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-folder-open text-warning" style="margin-right: 8px; width: 16px;"></i>Thư mục hệ thống:</strong></td>
                                <td id="lblThuMucHeThong"></td>
                            </tr>
                            <tr>
                                <td><strong><i class="fa fa-clock-o text-info" style="margin-right: 8px; width: 16px;"></i>Thời gian hoạt động (Uptime):</strong></td>
                                <td id="lblThoiGianHoatDong"></td>
                            </tr>
                            <tr class="bg-white">
                                <td><strong><i class="fa fa-wifi text-danger" style="margin-right: 8px; width: 16px;"></i>Địa chỉ MAC Không Dây (Wi-Fi):</strong></td>
                                <td id="lblMacWifi" class="fw-bold"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div id="errorAlert" class="alert alert-danger" style="display: none;" role="alert">
                    <i class="fa fa-exclamation-triangle" style="margin-right: 8px;"></i> <span id="errorMsg">Đã xảy ra lỗi khi lấy thông tin cấu hình máy.</span>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalXacThuc" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalXacThucLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title" id="modalXacThucLabel"><i class="fa fa-shield" style="margin-right: 8px;"></i>Xác minh tài khoản quản trị</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div id="modalAlertError" class="alert alert-danger p-2" style="display: none; font-size: 14px;"></div>
                        <form id="formCheckAdminIT">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Tài khoản (TK)</label>
                                <input type="text" id="txtAuthUser" class="form-control" placeholder="Nhập tài khoản quản trị..." required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Mật khẩu</label>
                                <input type="password" id="txtAuthPassword" class="form-control" placeholder="Nhập mật khẩu..." required />
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="button" id="btnSubmitXacThuc" class="btn btn-danger">
                            <i class="fa fa-unlock-alt" style="margin-right: 4px;"></i> Xác nhận & Quét cấu hình
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalXacNhanTaiSan" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalXacNhanTaiSanLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title" id="modalXacNhanTaiSanLabel"><i class="fa fa-check-square-o" style="margin-right: 8px;"></i>Xác nhận tài sản</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div id="modalTaiSanAlertError" class="alert alert-danger p-2" style="display: none; font-size: 14px;"></div>
                        <form id="formXacNhanTaiSan" onsubmit="return false;">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Tài khoản</label>
                                        <input type="text" id="txtTaiSanUser" class="form-control" placeholder="Nhập tài khoản..." required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Mật khẩu</label>
                                        <input type="password" id="txtTaiSanPassword" class="form-control" placeholder="Nhập mật khẩu..." required />
                                    </div>
                                    <hr />
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Vị trí đặt máy <span class="text-danger">*</span></label>
                                        <input type="text" id="txtTaiSanViTri" class="form-control" placeholder="VD: Tầng 3 - Phòng Kế toán..." required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Công ty <span class="text-danger">*</span></label>
                                        <div class="mini-combo" id="comboCongTy">
                                            <input type="text" class="form-control" id="searchCongTy" placeholder="🔍 Gõ để tìm Công ty..." autocomplete="off" />
                                            <div class="mini-combo-menu" id="menuCongTySearch"></div>
                                        </div>
                                        <select id="ddlTaiSanCongTy" style="display:none">
                                            <option value="">-- Chưa chọn --</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold d-flex justify-content-between align-items-center">
                                            <span>Bộ phận <span class="text-danger">*</span></span>
                                            <button type="button" id="btnThemNhanhBoPhan" class="btn btn-sm btn-link p-0 text-decoration-none" style="font-size: 13px;">
                                                <i class="fa fa-plus-circle"></i> Thêm nhanh
                                            </button>
                                        </label>
                                        <div class="mini-combo" id="comboBoPhan">
                                            <input type="text" class="form-control" id="searchBoPhan" placeholder="🔍 Gõ để tìm Bộ phận..." autocomplete="off" />
                                            <div class="mini-combo-menu" id="menuBoPhanSearch"></div>
                                        </div>
                                        <select id="ddlTaiSanBoPhan" style="display:none">
                                            <option value="">-- Chưa chọn --</option>
                                        </select>
                                        <div id="boxThemNhanhBoPhan" class="mt-2 p-2 border rounded bg-light" style="display: none;">
                                            <label class="form-label small fw-bold mb-1">Tên bộ phận mới (gợi ý theo tên máy, có thể sửa lại)</label>
                                            <div class="input-group input-group-sm">
                                                <input type="text" id="txtThemNhanhTenBoPhan" class="form-control text-uppercase" placeholder="VD: ZP-IT" style="text-transform: uppercase;" />
                                                <button type="button" id="btnXacNhanThemBoPhan" class="btn btn-success"><i class="fa fa-check"></i> Thêm</button>
                                                <button type="button" id="btnHuyThemBoPhan" class="btn btn-outline-secondary"><i class="fa fa-times"></i></button>
                                            </div>
                                            <div class="form-text">Bộ phận sẽ được thêm vào Công ty đang chọn ở trên và không được trùng tên trong công ty đó.</div>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Ảnh chụp thiết bị (tùy chọn)</label>
                                        <div class="drag-drop-zone text-center mb-2" id="dropZoneTaiSanAnh" title="Kéo thả ảnh vào đây, click để chọn ảnh, hoặc click vào đây rồi nhấn Ctrl + V để dán ảnh" onclick="$('#fileTaiSanAnh').click();">
                                            <div class="py-2 text-muted" id="txtTaiSanAnhHint">
                                                <i class="fa fa-camera-retro fa-2x mb-2 text-success"></i>
                                                <p class="mb-0 small fw-semibold">Chọn ảnh từ máy / Kéo thả ảnh / Click vào đây rồi nhấn <b>Ctrl + V</b> để dán</p>
                                            </div>
                                        </div>
                                        <input type="file" id="fileTaiSanAnh" accept="image/*" capture="environment" class="d-none" onchange="previewTaiSanAnh(this)" />
                                        <div class="text-center" id="boxPreviewTaiSanAnh" style="display: none;">
                                            <div class="position-relative d-inline-block">
                                                <img id="imgTaiSanAnhPreview" src="" alt="Ảnh thiết bị" style="max-height: 160px; max-width: 100%; border-radius: 10px; border: 2px dashed #10b981; padding: 3px;" />
                                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="clearTaiSanAnh(); event.stopPropagation();" style="width: 24px; height: 24px; padding: 0; line-height: 1;">
                                                    <i class="fa fa-times" style="font-size: 11px;"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="mb-3 p-2 border rounded bg-light" id="boxManHinhNgoai" style="display: none;">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="chkXacNhanManHinhNgoai" checked />
                                            <label class="form-check-label fw-bold text-dark" for="chkXacNhanManHinhNgoai">
                                                <i class="fa fa-desktop text-primary" style="margin-right: 4px;"></i>
                                                Xác nhận có màn hình rời đi kèm: <span id="lblManHinhNgoaiInfo" class="text-primary"></span>
                                            </label>
                                        </div>
                                        <div class="form-text mb-2">Bỏ tích nếu màn hình rời này không thuộc sở hữu cá nhân/không cần kiểm kê riêng.</div>
                                        <div class="mb-2">
                                            <label class="form-label small fw-bold mb-1">Quy cách màn hình</label>
                                            <input type="text" id="txtQuyCachManHinhNgoai" class="form-control form-control-sm bg-light" readonly title="Lấy tự động từ tên màn hình phát hiện được ở trên, không sửa được" />
                                        </div>
                                        <div id="boxAnhManHinhNgoai">
                                            <label class="form-label small fw-bold mb-1">Ảnh chụp màn hình (tùy chọn)</label>
                                            <div class="drag-drop-zone text-center mb-2" id="dropZoneManHinhAnh" title="Kéo thả ảnh vào đây, click để chọn ảnh, hoặc click vào đây rồi nhấn Ctrl + V để dán ảnh" onclick="$('#fileManHinhAnh').click(); vungAnhPasteHienTai = 'manhinh';">
                                                <div class="py-2 text-muted" id="txtManHinhAnhHint">
                                                    <i class="fa fa-camera-retro fa-2x mb-2 text-success"></i>
                                                    <p class="mb-0 small fw-semibold">Chọn ảnh từ máy / Kéo thả ảnh / Click vào đây rồi nhấn <b>Ctrl + V</b> để dán</p>
                                                </div>
                                            </div>
                                            <input type="file" id="fileManHinhAnh" accept="image/*" capture="environment" class="d-none" onchange="previewManHinhAnh(this)" />
                                            <div class="text-center" id="boxPreviewManHinhAnh" style="display: none;">
                                                <div class="position-relative d-inline-block">
                                                    <img id="imgManHinhAnhPreview" src="" alt="Ảnh màn hình" style="max-height: 160px; max-width: 100%; border-radius: 10px; border: 2px dashed #10b981; padding: 3px;" />
                                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="clearManHinhAnh(); event.stopPropagation();" style="width: 24px; height: 24px; padding: 0; line-height: 1;">
                                                        <i class="fa fa-times" style="font-size: 11px;"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mb-2 p-2 border rounded" id="boxKhuVucTaiSanKhac">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <label class="form-label fw-bold mb-0">Tài sản khác đi kèm (tùy chọn)</label>
                                            <button type="button" id="btnToggleTaiSanKhac" class="btn btn-sm btn-outline-success">
                                                <i class="fa fa-plus-square"></i> Tài sản
                                            </button>
                                        </div>
                                        <div class="form-text mb-2">Súng bắn mã vạch, Điện thoại bàn, Máy chiếu, PDA... sẽ được gửi cùng lúc với Tài khoản/Công ty/Bộ phận ở trên khi bấm "Gửi".</div>
                                        <div id="boxTaiSanKhac" style="display: none;">
                                            <div id="dsRowTaiSanKhac"></div>
                                            <button type="button" id="btnThemDongTaiSanKhac" class="btn btn-sm btn-outline-success">
                                                <i class="fa fa-plus"></i> Thêm dòng
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="button" id="btnSubmitXacNhanTaiSan" class="btn btn-success">
                            <i class="fa fa-paper-plane" style="margin-right: 4px;"></i> Gửi
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="modalCapNhatAnhThietBi" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title"><i class="fa fa-camera-retro" style="margin-right: 8px;"></i>Cập nhật ảnh thiết bị</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="drag-drop-zone text-center mb-2" id="dropZoneCapNhatAnhTB" title="Kéo thả ảnh vào đây, click để chọn ảnh, hoặc click vào đây rồi nhấn Ctrl + V để dán ảnh" onclick="$('#fileCapNhatAnhTB').click();">
                            <div class="py-2 text-muted" id="txtCapNhatAnhTBHint">
                                <i class="fa fa-camera-retro fa-2x mb-2 text-success"></i>
                                <p class="mb-0 small fw-semibold">Chọn ảnh từ máy / Kéo thả ảnh / Click vào đây rồi nhấn <b>Ctrl + V</b> để dán</p>
                            </div>
                            <div class="text-center" id="boxPreviewCapNhatAnhTB" style="display: none;">
                                <img id="imgPreviewCapNhatAnhTB" src="" alt="Ảnh thiết bị" style="max-height: 200px; max-width: 100%; border-radius: 10px; border: 2px dashed #10b981; padding: 3px;" />
                            </div>
                        </div>
                        <input type="file" id="fileCapNhatAnhTB" accept="image/*" class="d-none" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="button" id="btnLuuAnhThietBi" class="btn btn-success">
                            <i class="fa fa-save" style="margin-right: 4px;"></i> Lưu ảnh
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-body text-center" style="padding: 60px 20px;">
                <i class="fa fa-lock text-warning" style="font-size: 64px; margin-bottom: 20px;"></i>
                <h4 class="text-danger fw-bold">Thông tin được bảo mật</h4>
                <p class="text-muted mt-2" style="font-size: 16px;">
                    Phần thông tin cấu hình máy tính này đã được ẩn đi. <br />
                    Để xem được dữ liệu, bạn phải đăng nhập bằng tài khoản của mình.
                </p>
                <a href="/DonXetDuyet/DangXuat" class="btn btn-primary mt-3" style="padding: 10px 25px;">
                    <i class="fa fa-sign-in" style="margin-right: 6px;"></i> Đăng nhập
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bundle.min.js"></script>
        <script>
            $(document).ready(function () {
            // Chỉ người có quyền XemTSCN/All mới được đổi ảnh đại diện của NGƯỜI KHÁC ngay tại dòng "thuộc về"
            var coQuyenSuaAnhNguoiKhac = @((User.IsInRole("XemTSCN") || User.IsInRole("All")) ? "true" : "false");

            // Biến lưu cache cục bộ dữ liệu từ Tool Exe đổ lên nhằm hiển thị ngay khi gõ pass chuẩn
            var duLieuQuetMayKhachCache = null;

            // Ảnh thiết bị lấy từ Kéo-thả hoặc Ctrl+V dán (khác với ảnh chọn qua input file thường)
            var taiSanAnhBlob = null;

            // Ảnh màn hình rời lấy từ Kéo-thả hoặc Ctrl+V dán
            var manHinhAnhBlob = null;

            // Đánh dấu khu vực ảnh đang được chọn để nhận Ctrl+V (vì modal có nhiều khu vực ảnh: Thiết bị chính, Màn hình rời, và từng dòng Tài sản khác)
            var vungAnhPasteHienTai = 'thietbi';

            // Dòng Tài sản khác (jQuery) đang được chọn để nhận Ctrl+V dán ảnh, cập nhật mỗi khi click vào khu vực ảnh của 1 dòng
            var rowTaiSanKhacPasteHienTai = null;

            // Tự động kéo tải dữ liệu ngay từ local helper khi vừa load trang
            taiSauThongSoCoBan();
            initTaiSanAnhZoneEvents();

            // Bỏ dấu tiếng Việt để so khớp tìm kiếm không phân biệt dấu
            function removeVietnameseTonesJS(str) {
            if (!str) return "";
            var s = str.normalize("NFD");
            var result = "";
            for (var i = 0; i < s.length; i++) {
            var code = s.charCodeAt(i);
            if (code >= 768 && code <= 879) continue; // Bỏ các dấu kết hợp Unicode (U+0300-U+036F)
            result += s[i];
            }
            return result.replace(/đ/g, "d").replace(/Đ/g, "D");
            }

            // Combobox tìm kiếm tự viết (không phụ thuộc CDN ngoài) cho 2 field Công ty/Bộ phận trong modal Xác nhận tài sản:
            // select thật vẫn giữ nguyên (ẩn đi) để không đổi logic đọc/ghi giá trị ở nơi khác, chỉ thêm lớp UI tìm kiếm phía trên.
            function initMiniCombo(selectId, searchId, menuId) {
            var $select = $('#' + selectId);
            var $search = $('#' + searchId);
            var $menu = $('#' + menuId);

            function renderMenu(filterText) {
            var filter = removeVietnameseTonesJS(filterText || '').toUpperCase();
            var html = '';
            $select.find('option').each(function () {
            var val = $(this).val();
            var text = $(this).text();
            if (!val) return; // Bỏ qua option rỗng "-- Chưa chọn --"
            if (filter && removeVietnameseTonesJS(text).toUpperCase().indexOf(filter) === -1) return;
            var activeClass = (val === $select.val()) ? ' active' : '';
            html += '<div class="mini-combo-item' + activeClass + '" data-value="' + val + '">' + text + '</div>';
            });
            $menu.html(html || '<div class="mini-combo-empty">Không tìm thấy kết quả</div>');
            }

            function dongBoHienThiTuSelect() {
            var text = $select.find('option:selected').text();
            $search.val($select.val() ? text : '');
            }

            $search.on('focus click', function (e) {
            e.stopPropagation();
            renderMenu('');
            $menu.show();
            });

            $search.on('input', function () {
            renderMenu($(this).val());
            $menu.show();
            });

            $menu.on('click', '.mini-combo-item', function () {
            $select.val($(this).data('value')).trigger('change');
            dongBoHienThiTuSelect();
            $menu.hide();
            });

            // Mỗi khi giá trị select thật đổi (kể cả do code khác gán bằng .val().trigger('change')) thì đồng bộ lại ô hiển thị
            $select.on('change', dongBoHienThiTuSelect);
            dongBoHienThiTuSelect();
            }

            $(document).on('click', function (e) {
            if (!$(e.target).closest('.mini-combo').length) { $('.mini-combo-menu').hide(); }
            });

            initMiniCombo('ddlTaiSanCongTy', 'searchCongTy', 'menuCongTySearch');
            initMiniCombo('ddlTaiSanBoPhan', 'searchBoPhan', 'menuBoPhanSearch');

            // Nạp danh sách Công ty / Bộ phận cho modal Xác nhận tài sản
            var dsBoPhanCache = []; // Cache toàn bộ Bộ phận để lọc lại theo Công ty được chọn

            // Ghi nhớ Công ty/Bộ phận đã chọn để tự khôi phục lại khi load lại trang
            var congTyDaNap = false, boPhanDaNap = false;
            // Cờ đánh dấu đang trong quá trình tự khôi phục lựa chọn cũ, để các listener change bên dưới không ghi đè/xóa nhầm localStorage
            var dangKhoiPhucCongTyBoPhan = false;
            function khoiPhucCongTyBoPhanDaLuu() {
            if (!congTyDaNap || !boPhanDaNap) return;
            dangKhoiPhucCongTyBoPhan = true;
            var savedCongTy = localStorage.getItem('kk_taiSanCongTy');
            var savedBoPhan = localStorage.getItem('kk_taiSanBoPhan');
            if (savedCongTy && $("#ddlTaiSanCongTy option[value='" + savedCongTy + "']").length) {
            $("#ddlTaiSanCongTy").val(savedCongTy).trigger('change');
            }
            renderDropdownBoPhan($("#ddlTaiSanCongTy").val());
            if (savedBoPhan && $("#ddlTaiSanBoPhan option[value='" + savedBoPhan + "']").length) {
            $("#ddlTaiSanBoPhan").val(savedBoPhan).trigger('change');
            }
            dangKhoiPhucCongTyBoPhan = false;
            }

            $.get('/QLKiemKe/GetKkCongTys', function (res) {
            if (res && res.success && res.data) {
            var html = '<option value="">-- Chưa chọn --</option>';
            res.data.forEach(function (ct) { html += '<option value="' + ct.idcongTy + '">' + ct.tenCongTy + '</option>'; });
            $("#ddlTaiSanCongTy").html(html).trigger('change');
            }
            congTyDaNap = true;
            khoiPhucCongTyBoPhanDaLuu();
            });
            $.get('/QLKiemKe/GetKkBoPhans', function (res) {
            if (res && res.success && res.data) {
            dsBoPhanCache = res.data;
            }
            boPhanDaNap = true;
            khoiPhucCongTyBoPhanDaLuu();
            });

            // Nạp danh sách Loại thiết bị cho form "Thêm tài sản khác"
            var dsLoaiThietBiCache = [];
            $.get('/QLKiemKe/GetKkLoaiThietBis', function (res) {
            if (res && res.success && res.data) {
            dsLoaiThietBiCache = res.data;
            }
            });

            // Chỉ hiển thị các Bộ phận thuộc đúng Công ty đang chọn (idCongTy rỗng thì hiển thị toàn bộ)
            function renderDropdownBoPhan(idCongTyLoc) {
            var html = '<option value="">-- Chưa chọn --</option>';
            dsBoPhanCache.forEach(function (bp) {
            if (!idCongTyLoc || String(bp.idcongTy) === String(idCongTyLoc)) {
            html += '<option value="' + bp.idboPhan + '">' + bp.tenBoPhan + '</option>';
            }
            });
            $("#ddlTaiSanBoPhan").html(html).trigger('change');
            }

            // Khi đổi Công ty thì lọc lại danh sách Bộ phận tương ứng, reset lựa chọn cũ và ghi nhớ lựa chọn để khôi phục khi load lại trang
            $("#ddlTaiSanCongTy").change(function () {
            if (dangKhoiPhucCongTyBoPhan) return;
            var val = $(this).val();
            if (val) localStorage.setItem('kk_taiSanCongTy', val); else localStorage.removeItem('kk_taiSanCongTy');
            localStorage.removeItem('kk_taiSanBoPhan'); // Đổi Công ty thì Bộ phận cũ không còn hợp lệ nữa
            renderDropdownBoPhan(val);
            $("#boxThemNhanhBoPhan").hide();
            });

            // Ghi nhớ Bộ phận đã chọn để khôi phục khi load lại trang
            $("#ddlTaiSanBoPhan").change(function () {
            if (dangKhoiPhucCongTyBoPhan) return;
            var val = $(this).val();
            if (val) localStorage.setItem('kk_taiSanBoPhan', val); else localStorage.removeItem('kk_taiSanBoPhan');
            });

            // Bấm "Thêm nhanh": bóc tách gợi ý Tên bộ phận từ Tên máy hiện tại (VD: ZP-IT003 -> ZP-IT, VN-IT045 -> VN-IT)
            $("#btnThemNhanhBoPhan").click(function () {
            if (!$("#ddlTaiSanCongTy").val()) {
            Swal.fire('Thông báo', 'Vui lòng chọn Công ty trước khi thêm nhanh Bộ phận.', 'warning');
            return;
            }

            var tenMayHienTai = duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.tenMay || '') : $("#lblTenMay").text().trim();
            var goiY = tenMayHienTai.replace(/[0-9]+$/, '').replace(/[-_]+$/, '').trim().toUpperCase();

            $("#txtThemNhanhTenBoPhan").val(goiY);
            $("#boxThemNhanhBoPhan").slideDown(150);
            $("#txtThemNhanhTenBoPhan").focus();
            });

            // Luôn ép chữ hoa 100% khi người dùng tự gõ/sửa lại tên bộ phận, kể cả khi dán (paste) văn bản
            $("#txtThemNhanhTenBoPhan").on('input', function () {
            var viTriCon = this.selectionStart;
            $(this).val($(this).val().toUpperCase());
            this.setSelectionRange(viTriCon, viTriCon);
            });

            $("#btnHuyThemBoPhan").click(function () {
            $("#boxThemNhanhBoPhan").slideUp(150);
            });

            // Xác nhận thêm nhanh: gọi API lưu Bộ phận mới (server tự chặn trùng tên trong cùng Công ty), rồi nạp lại dropdown và tự chọn luôn bộ phận vừa thêm
            $("#btnXacNhanThemBoPhan").click(function () {
            var tenBoPhanMoi = $("#txtThemNhanhTenBoPhan").val().trim().toUpperCase();
            var idCongTyHienTai = $("#ddlTaiSanCongTy").val();

            if (!idCongTyHienTai) {
            Swal.fire('Thông báo', 'Vui lòng chọn Công ty trước.', 'warning');
            return;
            }
            if (!tenBoPhanMoi) {
            Swal.fire('Thông báo', 'Vui lòng nhập Tên bộ phận.', 'warning');
            return;
            }

            $.post('/QLKiemKe/SaveKkBoPhan', { IdboPhan: 0, TenBoPhan: tenBoPhanMoi, IdcongTy: idCongTyHienTai }, function (res) {
            if (res.success) {
            $.get('/QLKiemKe/GetKkBoPhans', function (res2) {
            if (res2 && res2.success && res2.data) {
            dsBoPhanCache = res2.data;
            renderDropdownBoPhan(idCongTyHienTai);

            var boPhanMoi = dsBoPhanCache.find(function (bp) {
            return (bp.tenBoPhan || '').trim().toLowerCase() === tenBoPhanMoi.toLowerCase() && String(bp.idcongTy) === String(idCongTyHienTai);
            });
            if (boPhanMoi) { $("#ddlTaiSanBoPhan").val(boPhanMoi.idboPhan).trigger('change'); localStorage.setItem('kk_taiSanBoPhan', boPhanMoi.idboPhan); }

            $("#boxThemNhanhBoPhan").slideUp(150);
            Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã thêm bộ phận mới', showConfirmButton: false, timer: 1500 });
            }
            });
            } else {
            Swal.fire('Lỗi', res.message || 'Không thể thêm bộ phận.', 'error');
            }
            }).fail(function () {
            Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ để thêm bộ phận.', 'error');
            });
            });

            var SO_LAN_THU_TOI_DA = 4; // Tool local đôi khi phản hồi chậm nên cho phép tự thử lại vài lần trước khi báo lỗi hẳn

            function taiSauThongSoCoBan(soLanDaThu) {
            soLanDaThu = soLanDaThu || 0;
            $("#errorAlert").hide();

            if (soLanDaThu > 0) {
            var textDoiCho = "Đang chờ Tool local phản hồi (lần " + (soLanDaThu + 1) + "/" + SO_LAN_THU_TOI_DA + ")...";
            $("#lblSeriMay, #lblDongMay, #lblTenMay, #lblTenNguoiDungHeThong, #lblThongTinManHinhNgoai").text(textDoiCho);
            $("#lblThongTinManHinh").html(textDoiCho);
            }

            $.ajax({
            url: 'http://localhost:8888/get-hardware',
            type: 'GET',
            dataType: 'json',
            timeout: 20000, // Tăng thời gian chờ vì Tool local có lúc tải hơi lâu
            success: function (response) {
            if (response.success && response.data) {
            // Lưu trữ dữ liệu vào cache bộ nhớ tạm trên trình duyệt
            duLieuQuetMayKhachCache = response.data;

            // Gán dữ liệu cho 6 thông số màu vàng hiển thị công khai ở bảng 1
            $("#lblSeriMay").text(duLieuQuetMayKhachCache.seriMay || "N/A");
            $("#lblDongMay").text(duLieuQuetMayKhachCache.dongMay || "N/A");
            $("#lblTenMay").text(duLieuQuetMayKhachCache.tenMay || "N/A");
            $("#lblTenNguoiDungHeThong").text(duLieuQuetMayKhachCache.tenNguoiDungHeThong || "N/A");
            $("#lblThongTinManHinhNgoai").text(duLieuQuetMayKhachCache.thongTinManHinhNgoai || "N/A");
            $("#lblThongTinManHinh").html(duLieuQuetMayKhachCache.thongTinManHinh || "N/A");

            // Dữ liệu tải thành công -> cho phép mở modal Xác nhận tài sản
            $("#btnMoModalXacNhanTaiSan").prop("disabled", false).attr("title", "");

            // Có màn hình rời phát hiện được -> hiện ô tích xác nhận kiểm kê luôn màn hình
            capNhatBoxManHinhNgoai();

            // Đối chiếu Serial máy + màn hình rời với trang Thiết bị để biết đang thuộc về ai
            traCuuThongTinSoHuu();
            } else {
            thongBaoLoiCoBan("Dữ liệu từ Tool local trả về bị rỗng.");
            }
            },
            error: function (xhr, status, error) {
            // Tool local phản hồi chậm -> tự thử lại thay vì báo lỗi ngay
            if (soLanDaThu < SO_LAN_THU_TOI_DA - 1) {
            setTimeout(function () { taiSauThongSoCoBan(soLanDaThu + 1); }, 1500);
            } else {
            thongBaoLoiCoBan("Đã gặp sự cố thiếu MSI hãy liên hệ với IT để được hỗ trợ.");
            }
            }
            });
            }

            function thongBaoLoiCoBan(msg) {
            var textLoi = "Lỗi tải: " + (msg || "Không thể lấy dữ liệu");
            $("#lblSeriMay, #lblDongMay, #lblTenMay, #lblTenNguoiDungHeThong, #lblThongTinManHinhNgoai").text(textLoi);
            $("#lblThongTinManHinh").html(textLoi);

            // Chưa có dữ liệu hợp lệ -> khóa nút Xác nhận tài sản lại
            $("#btnMoModalXacNhanTaiSan").prop("disabled", true).attr("title", "Cần tải xong thông tin máy từ Tool local mới có thể xác nhận");
            }

            // Bóc tách đúng màn hình rời thực tế (bỏ qua màn hình chính tích hợp "Màn hình tiêu chuẩn (S/N: 0)")
            // Ưu tiên đọc dsManHinhRaw (phân cách bằng "|"); một số bản Tool local cũ không trả trường này nên fallback đọc thongTinManHinh (chuỗi HTML, phân cách bằng thẻ <br/>)
            function layThongTinManHinhNgoaiThucTe() {
            if (!duLieuQuetMayKhachCache) return null;
            var dsMan;
            if (duLieuQuetMayKhachCache.dsManHinhRaw) {
            dsMan = duLieuQuetMayKhachCache.dsManHinhRaw.split('|');
            } else if (duLieuQuetMayKhachCache.thongTinManHinh) {
            dsMan = duLieuQuetMayKhachCache.thongTinManHinh.split(/<br\s*\/?>/i);
            } else {
            return null;
            }
            for (var i = 0; i < dsMan.length; i++) {
            var match = dsMan[i].trim().match(/\]:\s*(.+?)\s*\(S\/N:\s*([^)]*)\)/i);
            if (!match) continue;
            var model = match[1].trim();
            var serial = match[2].trim();
            if (serial && serial !== '0' && serial.toUpperCase() !== 'N/A' && model.toLowerCase().indexOf('tiêu chuẩn') === -1) {
            return { model: model, serial: serial };
            }
            }
            return null;
            }

            // Hiện/ẩn ô tích "Xác nhận có màn hình rời đi kèm" - chỉ dựa vào việc quét được màn hình có S/N thật (không phụ thuộc
            // chuỗi thongTinManHinhNgoai của Tool local, vì Tool cũ mặc định máy chỉ có 1 màn hình là màn hình tích hợp của laptop,
            // trong khi máy cây/máy bàn không có màn hình tích hợp nên dù chỉ 1 màn hình vẫn phải tính là màn hình rời)
            function capNhatBoxManHinhNgoai() {
            var manHinhNgoai = layThongTinManHinhNgoaiThucTe();

            if (manHinhNgoai) {
            var tenDayDuManHinh = manHinhNgoai.model + ' (S/N: ' + manHinhNgoai.serial + ')';
            $("#lblManHinhNgoaiInfo").text(tenDayDuManHinh);
            $("#boxManHinhNgoai").show();
            $("#chkXacNhanManHinhNgoai").prop('checked', true);
            // Khóa cứng, lấy y hệt tên đã hiển thị ở dòng trên - không cho sửa tay để tránh Quy cách lệch với tên máy quét được
            $("#txtQuyCachManHinhNgoai").val(tenDayDuManHinh);
            } else {
            $("#boxManHinhNgoai").hide();
            $("#chkXacNhanManHinhNgoai").prop('checked', false);
            $("#txtQuyCachManHinhNgoai").val('');
            }
            }

            // Dựng dòng chi tiết nhỏ (Tên máy / Số serial / Quy cách) hiển thị dưới tên chủ sở hữu ở dòng Máy/Màn hình
            function layDongChiTietThietBi(info) {
            if (!info) return '';
            var phan = [];
            if (info.tenMayTinh) phan.push('Tên máy: <b>' + info.tenMayTinh + '</b>');
            if (info.seribacode) phan.push('S/N: <b>' + info.seribacode + '</b>');
            if (info.quyCach) phan.push('Quy cách: <b>' + info.quyCach + '</b>');
            return phan.join(' &nbsp;|&nbsp; ');
            }

            // Mở ảnh phóng to bằng SweetAlert (đã có sẵn thư viện Swal trên trang, không cần dựng thêm modal riêng)
            function xemAnhPhongTo(urlAnh) {
            Swal.fire({ imageUrl: urlAnh, imageAlt: 'Ảnh thiết bị', showCloseButton: true, showConfirmButton: false, width: 'auto', background: '#f8fafc' });
            }

            // Đối chiếu Serial máy hiện tại + màn hình rời (nếu có) với dữ liệu đã kiểm kê ở KK_ThietBi để hiển thị đang thuộc về ai
            // Hiện ảnh thiết bị (Máy/Màn hình) kèm nút Xem ảnh (mọi người) và nút Sửa ảnh (chỉ người có quyền XemTSCN/All)
            function renderAnhChuSoHuu(info, suffix) {
            var wrap = $('#wrapAvatar' + suffix);
            var img = $('#imgAvatar' + suffix);
            var btnsWrap = $('#btnsAnh' + suffix);
            var btnXem = $('#btnXemAnh' + suffix);
            var btnSua = $('#btnSuaAnh' + suffix);

            if (!info || !info.idThietBi) {
            wrap.hide();
            btnsWrap.hide();
            return;
            }

            var urlAnh = '/QLKiemKe/GetEvidenceImage?fileName=' + encodeURIComponent(info.duongDanAnh || '');
            img.css('visibility', 'visible').attr('src', urlAnh);
            wrap.show();
            btnsWrap.show();

            img.off('click').on('click', function () { xemAnhPhongTo(urlAnh); });
            btnXem.off('click').on('click', function () { xemAnhPhongTo(urlAnh); });

            if (coQuyenSuaAnhNguoiKhac) {
            btnSua.show();
            btnSua.off('click').on('click', function () { moModalSuaAnhThietBi(info.idThietBi); });
            } else {
            btnSua.hide();
            }
            }

            function traCuuThongTinSoHuu() {
            var seriMayHienTai = duLieuQuetMayKhachCache ? duLieuQuetMayKhachCache.seriMay : null;
            if (!seriMayHienTai || seriMayHienTai === "N/A") { $("#boxThongTinSoHuu").hide(); return; }

            var manHinhNgoai = layThongTinManHinhNgoaiThucTe();
            var seriManHinhHienTai = manHinhNgoai ? manHinhNgoai.serial : null;

            $.get('/QLKiemKe/GetThongTinSoHuuTheoSeri', { seriMay: seriMayHienTai, seriManHinh: seriManHinhHienTai }, function (res) {
            if (!res || !res.success) { $("#boxThongTinSoHuu").hide(); return; }

            // Dòng "Máy này đang thuộc về"
            if (res.may && res.may.tenNguoiDung) {
            $("#lblMaySoHuuBoi").text(res.may.tenNguoiDung + (res.may.tk ? ' (' + res.may.tk + ')' : ''));
            } else {
            $("#lblMaySoHuuBoi").text("Chưa xác nhận kiểm kê");
            }
            $("#lblChiTietMay").html(layDongChiTietThietBi(res.may));
            renderAnhChuSoHuu(res.may, 'May');

            // Dòng "Màn hình rời đang thuộc về" - chỉ hiện khi máy này có phát hiện màn hình rời
            if (seriManHinhHienTai) {
            $("#rowManHinhSoHuuBoi").show();
            if (res.manHinh && res.manHinh.tenNguoiDung) {
            $("#lblManHinhSoHuuBoi").text(res.manHinh.tenNguoiDung + (res.manHinh.tk ? ' (' + res.manHinh.tk + ')' : ''));
            } else {
            $("#lblManHinhSoHuuBoi").text("Chưa xác nhận kiểm kê");
            }
            $("#lblChiTietManHinh").html(layDongChiTietThietBi(res.manHinh));
            renderAnhChuSoHuu(res.manHinh, 'ManHinh');
            } else {
            $("#rowManHinhSoHuuBoi").hide();
            }

            // Dòng "Tài sản khác đi kèm" - liệt kê toàn bộ thiết bị khác cùng chủ sở hữu với máy này, kèm ảnh từng thiết bị
            if (res.taiSanKhac && res.taiSanKhac.length > 0) {
            var htmlParts = res.taiSanKhac.map(function (ts) {
            var thongTin = (ts.loaiThietBi || 'Thiết bị') + (ts.seribacode ? ' - S/N: ' + ts.seribacode : '') + (ts.quyCach ? ' - Quy cách: ' + ts.quyCach : '') + (ts.tenViTri ? ' (' + ts.tenViTri + ')' : '');
            return '<div class="d-flex align-items-center gap-2 mb-2 item-tai-san-khac" data-id="' + ts.idThietBi + '" data-anh="' + (ts.duongDanAnh || '') + '">' +
            '<div class="avatar-mini-wrapper-sm"><img class="img-tsk" src="/QLKiemKe/GetEvidenceImage?fileName=' + encodeURIComponent(ts.duongDanAnh || '') + '" onerror="this.style.visibility=\'hidden\';" /></div>' +
            '<span>' + thongTin + '</span>' +
            '<button type="button" class="btn btn-sm btn-outline-secondary btn-xem-tsk"><i class="fa fa-eye"></i></button>' +
            (coQuyenSuaAnhNguoiKhac ? '<button type="button" class="btn btn-sm btn-outline-primary btn-sua-tsk"><i class="fa fa-pencil"></i></button>' : '') +
            '</div>';
            });
            $("#lblTaiSanKhacDiKem").html(htmlParts.join(''));

            // Gắn sự kiện Xem ảnh / Sửa ảnh cho từng dòng Tài sản khác vừa render
            $("#lblTaiSanKhacDiKem .img-tsk, #lblTaiSanKhacDiKem .btn-xem-tsk").off('click').on('click', function () {
            var $row = $(this).closest('.item-tai-san-khac');
            xemAnhPhongTo('/QLKiemKe/GetEvidenceImage?fileName=' + encodeURIComponent($row.data('anh') || ''));
            });
            $("#lblTaiSanKhacDiKem .btn-sua-tsk").off('click').on('click', function () {
            var $row = $(this).closest('.item-tai-san-khac');
            moModalSuaAnhThietBi($row.data('id'));
            });
            } else {
            $("#lblTaiSanKhacDiKem").text("Không có");
            }

            $("#boxThongTinSoHuu").show();
            }).fail(function () {
            $("#boxThongTinSoHuu").hide();
            });
            }

            // Cho phép Kéo-thả ảnh và Ctrl+V dán ảnh vào ô "Ảnh chụp thiết bị"
            function initTaiSanAnhZoneEvents() {
            let zone = document.getElementById('dropZoneTaiSanAnh');
            if (!zone) return;

            zone.addEventListener('click', function () { vungAnhPasteHienTai = 'thietbi'; });
            zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('dragover'); });
            zone.addEventListener('dragleave', function () { zone.classList.remove('dragover'); });
            zone.addEventListener('drop', function (e) {
            e.preventDefault();
            zone.classList.remove('dragover');
            if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            let file = e.dataTransfer.files[0];
            if (file.type.startsWith('image/')) {
            taiSanAnhBlob = null;
            $('#fileTaiSanAnh')[0].files = e.dataTransfer.files;
            hienThiXemTruocAnh(file, 'imgTaiSanAnhPreview', 'boxPreviewTaiSanAnh', 'txtTaiSanAnhHint');
            }
            }
            });

            // Vùng ảnh màn hình rời - cùng cơ chế Kéo-thả/Ctrl+V, độc lập với vùng ảnh thiết bị chính ở trên
            let zoneManHinh = document.getElementById('dropZoneManHinhAnh');
            if (zoneManHinh) {
            zoneManHinh.addEventListener('click', function () { vungAnhPasteHienTai = 'manhinh'; });
            zoneManHinh.addEventListener('dragover', function (e) { e.preventDefault(); zoneManHinh.classList.add('dragover'); });
            zoneManHinh.addEventListener('dragleave', function () { zoneManHinh.classList.remove('dragover'); });
            zoneManHinh.addEventListener('drop', function (e) {
            e.preventDefault();
            zoneManHinh.classList.remove('dragover');
            if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            let file = e.dataTransfer.files[0];
            if (file.type.startsWith('image/')) {
            manHinhAnhBlob = null;
            $('#fileManHinhAnh')[0].files = e.dataTransfer.files;
            hienThiXemTruocAnh(file, 'imgManHinhAnhPreview', 'boxPreviewManHinhAnh', 'txtManHinhAnhHint');
            }
            }
            });
            }

            // Ctrl+V dán ảnh trong modal - định tuyến theo vùng đang được chọn (vungAnhPasteHienTai) vì modal có nhiều khu vực ảnh
            let modalTaiSan = document.getElementById('modalXacNhanTaiSan');
            modalTaiSan.addEventListener('paste', function (e) {
            if (e.clipboardData && e.clipboardData.items) {
            for (let i = 0; i < e.clipboardData.items.length; i++) {
            let item = e.clipboardData.items[i];
            if (item.type.indexOf('image') !== -1) {
            let blob = item.getAsFile();
            if (vungAnhPasteHienTai === 'manhinh') {
            manHinhAnhBlob = blob;
            $('#fileManHinhAnh').val('');
            hienThiXemTruocAnh(blob, 'imgManHinhAnhPreview', 'boxPreviewManHinhAnh', 'txtManHinhAnhHint');
            } else if (vungAnhPasteHienTai === 'tskhac' && rowTaiSanKhacPasteHienTai && rowTaiSanKhacPasteHienTai.closest('body').length) {
            rowTaiSanKhacPasteHienTai.removeData('anhBlob').data('anhBlob', blob);
            hienThiXemTruocAnhRow(rowTaiSanKhacPasteHienTai, blob);
            } else {
            taiSanAnhBlob = blob;
            $('#fileTaiSanAnh').val('');
            hienThiXemTruocAnh(blob, 'imgTaiSanAnhPreview', 'boxPreviewTaiSanAnh', 'txtTaiSanAnhHint');
            }
            break;
            }
            }
            }
            });
            }

            // Đọc file/blob ảnh và hiện xem trước - dùng chung cho cả vùng ảnh Thiết bị chính và Màn hình rời
            function hienThiXemTruocAnh(fileHoacBlob, imgId, boxId, hintId) {
            let r = new FileReader();
            r.onload = function (evt) {
            $('#' + imgId).attr('src', evt.target.result);
            $('#' + boxId).show();
            $('#' + hintId).hide();
            };
            r.readAsDataURL(fileHoacBlob);
            }

            // Gán ra window vì HTML gọi các hàm này qua thuộc tính inline onclick/onchange (chạy ở phạm vi global, không thấy được hàm khai báo trong closure này)
            window.previewTaiSanAnh = function (input) {
            if (input.files && input.files[0]) {
            taiSanAnhBlob = null;
            hienThiXemTruocAnh(input.files[0], 'imgTaiSanAnhPreview', 'boxPreviewTaiSanAnh', 'txtTaiSanAnhHint');
            }
            };

            window.clearTaiSanAnh = function () {
            $('#fileTaiSanAnh').val('');
            taiSanAnhBlob = null;
            $('#imgTaiSanAnhPreview').attr('src', '');
            $('#boxPreviewTaiSanAnh').hide();
            $('#txtTaiSanAnhHint').show();
            };

            window.previewManHinhAnh = function (input) {
            if (input.files && input.files[0]) {
            manHinhAnhBlob = null;
            hienThiXemTruocAnh(input.files[0], 'imgManHinhAnhPreview', 'boxPreviewManHinhAnh', 'txtManHinhAnhHint');
            }
            };

            window.clearManHinhAnh = function () {
            $('#fileManHinhAnh').val('');
            manHinhAnhBlob = null;
            $('#imgManHinhAnhPreview').attr('src', '');
            $('#boxPreviewManHinhAnh').hide();
            $('#txtManHinhAnhHint').show();
            };

            // MODAL CẬP NHẬT ẢNH THIẾT BỊ (KK_ThietBi.DuongDanAnh) - hỗ trợ Chọn file / Kéo-thả / Ctrl+V dán ảnh, giống hệt
            // khu vực "Ảnh chụp thiết bị" ở modal Xác nhận tài sản, thay vì mở thẳng hộp thoại chọn file của hệ điều hành.
            var idThietBiDangSuaAnh = null;
            var blobAnhThietBiDangChon = null;

            function moModalSuaAnhThietBi(idThietBi) {
            if (!idThietBi) return;
            idThietBiDangSuaAnh = idThietBi;
            blobAnhThietBiDangChon = null;
            $('#fileCapNhatAnhTB').val('');
            $('#imgPreviewCapNhatAnhTB').attr('src', '');
            $('#boxPreviewCapNhatAnhTB').hide();
            $('#txtCapNhatAnhTBHint').show();
            $('#modalCapNhatAnhThietBi').modal('show');
            }

            function initCapNhatAnhThietBiZoneEvents() {
            let zone = document.getElementById('dropZoneCapNhatAnhTB');
            if (!zone) return;

            zone.addEventListener('dragover', function (e) { e.preventDefault(); zone.classList.add('dragover'); });
            zone.addEventListener('dragleave', function () { zone.classList.remove('dragover'); });
            zone.addEventListener('drop', function (e) {
            e.preventDefault();
            zone.classList.remove('dragover');
            if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            let file = e.dataTransfer.files[0];
            if (file.type.startsWith('image/')) {
            blobAnhThietBiDangChon = null;
            $('#fileCapNhatAnhTB')[0].files = e.dataTransfer.files;
            hienThiXemTruocAnh(file, 'imgPreviewCapNhatAnhTB', 'boxPreviewCapNhatAnhTB', 'txtCapNhatAnhTBHint');
            }
            }
            });

            let modalEl = document.getElementById('modalCapNhatAnhThietBi');
            modalEl.addEventListener('paste', function (e) {
            if (e.clipboardData && e.clipboardData.items) {
            for (let i = 0; i < e.clipboardData.items.length; i++) {
            let item = e.clipboardData.items[i];
            if (item.type.indexOf('image') !== -1) {
            let blob = item.getAsFile();
            blobAnhThietBiDangChon = blob;
            $('#fileCapNhatAnhTB').val('');
            hienThiXemTruocAnh(blob, 'imgPreviewCapNhatAnhTB', 'boxPreviewCapNhatAnhTB', 'txtCapNhatAnhTBHint');
            break;
            }
            }
            }
            });
            }
            initCapNhatAnhThietBiZoneEvents();

            $('#fileCapNhatAnhTB').on('change', function () {
            if (this.files && this.files[0]) {
            blobAnhThietBiDangChon = null;
            hienThiXemTruocAnh(this.files[0], 'imgPreviewCapNhatAnhTB', 'boxPreviewCapNhatAnhTB', 'txtCapNhatAnhTBHint');
            }
            });

            $('#btnLuuAnhThietBi').click(function () {
            var fileGoc = $('#fileCapNhatAnhTB')[0].files[0];
            var fileHoacBlob = blobAnhThietBiDangChon || fileGoc;

            if (!fileHoacBlob) { Swal.fire('Thông báo', 'Vui lòng chọn/kéo thả/dán ảnh trước khi lưu.', 'warning'); return; }
            if (!idThietBiDangSuaAnh) return;

            var formData = new FormData();
            formData.append('fileAnh', fileHoacBlob, 'anh_thiet_bi.jpg');
            formData.append('idThietBi', idThietBiDangSuaAnh);

            $('#btnLuuAnhThietBi').prop('disabled', true);
            $.ajax({
            url: '/QLKiemKe/CapNhatAnhThietBiSoHuu',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
            $('#btnLuuAnhThietBi').prop('disabled', false);
            if (res.success) {
            $('#modalCapNhatAnhThietBi').modal('hide');
            Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã cập nhật ảnh thiết bị', showConfirmButton: false, timer: 1500 });
            traCuuThongTinSoHuu();
            } else {
            Swal.fire('Lỗi', res.message || 'Không thể cập nhật ảnh thiết bị.', 'error');
            }
            },
            error: function () {
            $('#btnLuuAnhThietBi').prop('disabled', false);
            Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ để cập nhật ảnh.', 'error');
            }
            });
            });

            // XỬ LÝ SỰ KIỆN ĐĂNG NHẬP TRÊN MODAL ĐỂ MỞ KHÓA BẢNG 2
            $("#btnSubmitXacThuc").click(function () {
            var taikhoanInput = $("#txtAuthUser").val().trim();
            var matkhauInput = $("#txtAuthPassword").val().trim();
            $("#modalAlertError").hide();

            if (taikhoanInput === "" || matkhauInput === "") {
            $("#modalAlertError").text("Vui lòng không để trống tài khoản hoặc mật khẩu.").fadeIn();
            return;
            }

            $.ajax({
            url: '/QLKiemKe/XacThucAdmin',
            type: 'POST',
            data: { taikhoan: taikhoanInput, matkhau: matkhauInput },
            success: function (res) {
            if (res.success) {
            // Đóng Modal gỡ rào cản kiểm tra
            var modalElement = document.getElementById('modalXacThuc');
            var modalInstance = bootstrap.Modal.getInstance(modalElement);
            if (modalInstance) modalInstance.hide();

            // Ẩn nút bấm đòi mật khẩu và hiện nút làm mới
            $("#authGateContainer").hide();
            $("#btnRefresh").show();

            // Tiến hành bung dữ liệu đã lấy từ Tool lên bảng chi tiết (Bảng 2)
            taiToanBoThongTinChiTiet();
            } else {
            $("#modalAlertError").text(res.message).fadeIn();
            }
            },
            error: function () {
            $("#modalAlertError").text("Đã xảy ra lỗi kết nối đường truyền xác thực với máy chủ website.").fadeIn();
            }
            });
            });

            $("#formCheckAdminIT").on('submit', function (e) {
            e.preventDefault();
            $("#btnSubmitXacThuc").click();
            });

            // ĐÃ ĐƯỢC SỬA: Gom tất cả thuộc tính phần cứng (ẩn/hiện) truyền lên Server
            $("#btnSubmitXacNhanTaiSan").click(function () {
            var taikhoanInput = $("#txtTaiSanUser").val().trim();
            var matkhauInput = $("#txtTaiSanPassword").val().trim();

            // Lấy mã Serial Number và Machine Name hiện tại từ cache hoặc từ giao diện trực quan
            var seriMayInput = duLieuQuetMayKhachCache ? duLieuQuetMayKhachCache.seriMay : $("#lblSeriMay").text().trim();
            var tenMayInput = duLieuQuetMayKhachCache ? duLieuQuetMayKhachCache.tenMay : $("#lblTenMay").text().trim();

            $("#modalTaiSanAlertError").hide();

            // SỬA ĐỔI CHẶN LỖI: Nếu 2 trường này null, rỗng, lỗi tải hoặc chưa load xong thì không cho xác nhận
            if (!seriMayInput || seriMayInput === "" || seriMayInput === "N/A" || seriMayInput === "Đang tải..." || seriMayInput.indexOf("Lỗi tải") !== -1 ||
            !tenMayInput || tenMayInput === "" || tenMayInput === "N/A" || tenMayInput === "Đang tải..." || tenMayInput.indexOf("Lỗi tải") !== -1) {
            $("#modalTaiSanAlertError").text("Số Serial Máy hoặc Tên máy hiện tại chưa hợp lệ hoặc trống. Cần liên hệ với IT để check lỗi.").fadeIn();
            return;
            }

            if (taikhoanInput === "" || matkhauInput === "") {
            $("#modalTaiSanAlertError").text("Vui lòng không để trống tài khoản hoặc mật khẩu.").fadeIn();
            return;
            }

            var viTriInput = $("#txtTaiSanViTri").val().trim();
            if (viTriInput === "") {
            $("#modalTaiSanAlertError").text("Vui lòng nhập Vị trí đặt máy.").fadeIn();
            return;
            }

            var idCongTyInput = $("#ddlTaiSanCongTy").val();
            if (!idCongTyInput) {
            $("#modalTaiSanAlertError").text("Vui lòng chọn Công ty.").fadeIn();
            return;
            }

            var idBoPhanInput = $("#ddlTaiSanBoPhan").val();
            if (!idBoPhanInput) {
            $("#modalTaiSanAlertError").text("Vui lòng chọn Bộ phận.").fadeIn();
            return;
            }

            // Kiểm tra trước các dòng "Tài sản khác" (nếu có mở khu vực + điền dòng nào)
            var taiSanKhacInfo = layDanhSachTaiSanKhacHopLe();
            if (taiSanKhacInfo.error) {
            $("#modalTaiSanAlertError").text(taiSanKhacInfo.error).fadeIn();
            return;
            }

            // Nếu đã tích xác nhận có màn hình rời đi kèm -> gộp thêm 1 dòng "Màn hình" vào Tài sản khác để kiểm kê chung, dùng đúng Vị trí vừa nhập ở trên
            if ($("#boxManHinhNgoai").is(':visible') && $("#chkXacNhanManHinhNgoai").is(':checked')) {
            var manHinhNgoaiXacNhan = layThongTinManHinhNgoaiThucTe();
            if (manHinhNgoaiXacNhan) {
            var fileManHinh = $("#fileManHinhAnh")[0].files[0];
            var quyCachManHinh = $("#txtQuyCachManHinhNgoai").val().trim() || manHinhNgoaiXacNhan.model;
            taiSanKhacInfo.rows.push({ loai: 'Màn hình', serial: manHinhNgoaiXacNhan.serial, quyCach: quyCachManHinh, viTri: viTriInput, file: manHinhAnhBlob || fileManHinh || null });
            }
            }

            // Chuẩn bị toàn bộ dữ liệu phần cứng cần thiết để có thể INSERT khi thiết bị chưa tồn tại
            var fd = new FormData();
            fd.append('taikhoan', taikhoanInput);
            fd.append('matkhau', matkhauInput);
            fd.append('seriMay', seriMayInput);
            fd.append('tenMay', tenMayInput);
            fd.append('dongMay', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.dongMay || '') : '');
            fd.append('heDieuHanh', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.heDieuHanh || '') : '');
            fd.append('kienTruc', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.kienTruc || '') : '');
            fd.append('phienBanNet', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.phienBanNet || '') : '');
            fd.append('soLoiCPU', duLieuQuetMayKhachCache && duLieuQuetMayKhachCache.soLoiCPU ? duLieuQuetMayKhachCache.soLoiCPU : '');
            fd.append('tenNguoiDungHeThong', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.tenNguoiDungHeThong || '') : '');
            fd.append('thuMucHeThong', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.thuMucHeThong || '') : '');
            fd.append('thoiGianHoatDong', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.thoiGianHoatDong || '') : '');
            fd.append('ramKhaDung', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.ramKhaDung || '') : '');
            fd.append('thongTinManHinhNgoai', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.thongTinManHinhNgoai || '') : '');
            fd.append('thongTinOffice', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.thongTinOffice || '') : '');
            fd.append('banQuyenWin', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.banQuyenWin || '') : '');
            fd.append('banQuyenOffice', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.banQuyenOffice || '') : '');
            // Các trường chi tiết nâng cao (RAM/Ổ cứng/Màn hình/MAC Wifi) - Tool local trả về theo đúng tên trường server đang nhận
            fd.append('dsRamRaw', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.dsRamRaw || '') : '');
            fd.append('dsOcungRaw', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.dsOcungRaw || '') : '');
            fd.append('dsManHinhRaw', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.dsManHinhRaw || '') : '');
            fd.append('dsMacWifiRaw', duLieuQuetMayKhachCache ? (duLieuQuetMayKhachCache.dsMacWifiRaw || '') : '');
            fd.append('tenViTri', viTriInput);
            if ($("#ddlTaiSanCongTy").val()) fd.append('idCongTy', $("#ddlTaiSanCongTy").val());
            if ($("#ddlTaiSanBoPhan").val()) fd.append('idBoPhan', $("#ddlTaiSanBoPhan").val());
            var fileAnh = $("#fileTaiSanAnh")[0].files[0];
            if (taiSanAnhBlob) fd.append('anhThietBi', taiSanAnhBlob, 'device_photo.jpg');
            else if (fileAnh) fd.append('anhThietBi', fileAnh);

            $.ajax({
            url: '/QLKiemKe/XacNhanTaiSanMaMay',
            type: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function (res) {
            if (res.success) {
            // Gửi tiếp các dòng "Tài sản khác" (nếu có) dùng chung Tài khoản/Công ty/Bộ phận vừa xác nhận, rồi mới đóng modal & báo thành công
            guiTaiSanKhac(taikhoanInput, matkhauInput, idCongTyInput, idBoPhanInput, taiSanKhacInfo.rows, function (resTaiSanKhac) {

            // Đóng modal xác nhận tài sản khi hoàn tất thành công
            var modalElement = document.getElementById('modalXacNhanTaiSan');
            var modalInstance = bootstrap.Modal.getInstance(modalElement);
            if (modalInstance) modalInstance.hide();

            // Khởi tạo lại trạng thái form nhập liệu trống
            $("#txtTaiSanUser").val('');
            $("#txtTaiSanPassword").val('');
            $("#txtTaiSanViTri").val('');
            $("#ddlTaiSanCongTy").val('');
            renderDropdownBoPhan(""); // Khôi phục lại toàn bộ danh sách Bộ phận sau khi bỏ chọn Công ty
            $("#boxThemNhanhBoPhan").hide();
            clearTaiSanAnh();
            clearManHinhAnh();
            resetTaiSanKhac();

            // ĐÃ CẬP NHẬT: Hiển thị đúng thông báo yêu cầu của bạn khi thành công
            var thongBaoTaiSanKhac = (resTaiSanKhac && resTaiSanKhac.success) ? (' ' + resTaiSanKhac.message) :
                (resTaiSanKhac && resTaiSanKhac.message ? ' Tuy nhiên, Tài sản khác gặp lỗi: ' + resTaiSanKhac.message : '');
            var successAlert = $('<div class="alert alert-success alert-dismissible fade show" role="alert" style="position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 420px;">' +
            '<strong>Thành công!</strong> Bạn đã xác nhận tài sản cá nhân thành công.' + thongBaoTaiSanKhac +
            '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
            '</div>');
            $('body').append(successAlert);
            setTimeout(function() { successAlert.alert('close'); }, 5000); // Tự giải phóng thông báo sau 5 giây
            });

            } else {
            $("#modalTaiSanAlertError").text(res.message).fadeIn();
            }
            },
            error: function () {
            $("#modalTaiSanAlertError").text("Đã xảy ra lỗi kết nối đường truyền xác thực với máy chủ website.").fadeIn();
            }
            });
            });

            $("#formXacNhanTaiSan").on('submit', function (e) {
            e.preventDefault();
            $("#btnSubmitXacNhanTaiSan").click();
            });

            // ===================== FORM "THÊM TÀI SẢN KHÁC" (Súng bắn mã vạch, Điện thoại bàn, Máy chiếu, PDA...) =====================
            var demDongTaiSanKhac = 0;

            // Các loại thiết bị máy tính đã được xử lý riêng ở phần "Xác nhận tài sản" phía trên -> không cho chọn lại ở "Tài sản khác"
            var dsLoaiThietBiLoaiTru = ['máy tính', 'laptop', 'máy ảo', 'server', 'switch', 'màn hình', 'máy chấm công'];

            function taoOptionLoaiThietBi() {
            var html = '<option value="">-- Chọn --</option>';
            dsLoaiThietBiCache.forEach(function (lt) {
            var tenChuanHoa = (lt.tenLoai || '').trim().toLowerCase();
            if (dsLoaiThietBiLoaiTru.indexOf(tenChuanHoa) !== -1) return;
            html += '<option value="' + lt.tenLoai + '">' + lt.tenLoai + '</option>';
            });
            return html;
            }

            function themDongTaiSanKhac() {
            var idx = demDongTaiSanKhac++;
            var rowHtml =
            '<div class="border rounded p-2 mb-2 dong-tai-san-khac" data-row-index="' + idx + '">' +
            '  <div class="row g-2">' +
            '    <div class="col-md-2">' +
            '      <label class="form-label small fw-bold mb-1">Loại thiết bị <span class="text-danger">*</span></label>' +
            '      <select class="form-select form-select-sm select-loai-tskhac">' + taoOptionLoaiThietBi() + '</select>' +
            '    </div>' +
            '    <div class="col-md-2">' +
            '      <label class="form-label small fw-bold mb-1">Serial <span class="text-danger">*</span></label>' +
            '      <input type="text" class="form-control form-control-sm input-serial-tskhac" placeholder="Nhập Serial..." />' +
            '    </div>' +
            '    <div class="col-md-2">' +
            '      <label class="form-label small fw-bold mb-1">Quy cách</label>' +
            '      <input type="text" class="form-control form-control-sm input-quycach-tskhac" placeholder="VD: Model, số lượng..." />' +
            '    </div>' +
            '    <div class="col-md-2">' +
            '      <label class="form-label small fw-bold mb-1">Vị trí</label>' +
            '      <input type="text" class="form-control form-control-sm input-vitri-tskhac" placeholder="VD: Tầng 3 - Phòng Kế toán..." />' +
            '    </div>' +
            '    <div class="col-md-3">' +
            '      <label class="form-label small fw-bold mb-1">Ảnh</label>' +
            '      <div class="drag-drop-zone dropzone-anh-tskhac text-center d-flex align-items-center justify-content-center gap-2" title="Kéo thả ảnh, click để chọn ảnh, hoặc click rồi Ctrl+V để dán ảnh" style="padding: 4px 6px; min-height: 38px; border-radius: 6px;">' +
            '        <span class="hint-anh-tskhac text-muted" style="font-size:11px;"><i class="fa fa-camera-retro"></i> Chọn/Kéo/Dán</span>' +
            '        <img class="preview-anh-tskhac" src="" style="display:none; max-height:32px; max-width:60px; border-radius:4px; object-fit:cover;" />' +
            '        <input type="file" accept="image/*" class="d-none input-anh-tskhac" />' +
            '      </div>' +
            '    </div>' +
            '    <div class="col-md-1 d-flex align-items-end">' +
            '      <button type="button" class="btn btn-sm btn-outline-danger btn-xoa-dong-tskhac w-100" title="Xóa dòng"><i class="fa fa-trash"></i></button>' +
            '    </div>' +
            '  </div>' +
            '</div>';
            $("#dsRowTaiSanKhac").append(rowHtml);
            }

            // Đọc file/blob ảnh và hiện xem trước ngay trong dòng Tài sản khác tương ứng (mỗi dòng có ảnh riêng)
            function hienThiXemTruocAnhRow(row, fileHoacBlob) {
            var r = new FileReader();
            r.onload = function (evt) {
            row.find('.preview-anh-tskhac').attr('src', evt.target.result).show();
            row.find('.hint-anh-tskhac').hide();
            };
            r.readAsDataURL(fileHoacBlob);
            }

            // Click vào khu vực ảnh của 1 dòng Tài sản khác: mở hộp thoại chọn file + đánh dấu dòng này đang nhận Ctrl+V
            $("#dsRowTaiSanKhac").on('click', '.dropzone-anh-tskhac', function () {
            rowTaiSanKhacPasteHienTai = $(this).closest('.dong-tai-san-khac');
            vungAnhPasteHienTai = 'tskhac';
            $(this).find('.input-anh-tskhac').trigger('click');
            });

            $("#dsRowTaiSanKhac").on('change', '.input-anh-tskhac', function () {
            var row = $(this).closest('.dong-tai-san-khac');
            row.removeData('anhBlob');
            if (this.files && this.files[0]) hienThiXemTruocAnhRow(row, this.files[0]);
            });

            $("#dsRowTaiSanKhac").on('dragover', '.dropzone-anh-tskhac', function (e) { e.preventDefault(); $(this).addClass('dragover'); });
            $("#dsRowTaiSanKhac").on('dragleave', '.dropzone-anh-tskhac', function () { $(this).removeClass('dragover'); });
            $("#dsRowTaiSanKhac").on('drop', '.dropzone-anh-tskhac', function (e) {
            e.preventDefault();
            $(this).removeClass('dragover');
            var dt = e.originalEvent.dataTransfer;
            if (dt && dt.files && dt.files.length > 0) {
            var file = dt.files[0];
            if (file.type.startsWith('image/')) {
            var row = $(this).closest('.dong-tai-san-khac');
            row.removeData('anhBlob');
            row.find('.input-anh-tskhac')[0].files = dt.files;
            hienThiXemTruocAnhRow(row, file);
            }
            }
            });

            $("#btnThemDongTaiSanKhac").click(function () { themDongTaiSanKhac(); });

            $("#dsRowTaiSanKhac").on('click', '.btn-xoa-dong-tskhac', function () {
            $(this).closest('.dong-tai-san-khac').remove();
            });

            // Luôn ép chữ hoa 100% khi nhập Serial, kể cả khi dán (paste) văn bản
            $("#dsRowTaiSanKhac").on('input', '.input-serial-tskhac', function () {
            var viTriCon = this.selectionStart;
            $(this).val($(this).val().toUpperCase());
            this.setSelectionRange(viTriCon, viTriCon);
            });

            // Bấm "+ Tài sản" ngay cạnh form Xác nhận tài sản để mở/đóng khu vực thêm dòng, tự thêm sẵn 1 dòng trống lần đầu
            $("#btnToggleTaiSanKhac").click(function () {
            $("#boxTaiSanKhac").slideToggle(150);
            if ($("#dsRowTaiSanKhac .dong-tai-san-khac").length === 0) themDongTaiSanKhac();
            });

            // Gom + kiểm tra các dòng Tài sản khác đã điền (bỏ qua dòng còn để trống hoàn toàn); trả về { rows, error }
            function layDanhSachTaiSanKhacHopLe() {
            var rows = [];
            var error = null;
            $("#dsRowTaiSanKhac .dong-tai-san-khac").each(function (i) {
            var loai = $(this).find('.select-loai-tskhac').val();
            var serial = $(this).find('.input-serial-tskhac').val().trim();
            var quyCach = $(this).find('.input-quycach-tskhac').val().trim();
            var viTri = $(this).find('.input-vitri-tskhac').val().trim();
            // Ưu tiên ảnh dán/kéo-thả (lưu qua .data('anhBlob')) vì input file gốc không giữ được Blob thô không tên
            var file = $(this).data('anhBlob') || $(this).find('.input-anh-tskhac')[0].files[0];

            if (!serial && !loai && !quyCach && !viTri && !file) return; // Dòng bỏ trống hoàn toàn -> bỏ qua, không tính là lỗi

            if (!serial) { error = 'Tài sản khác - Dòng ' + (i + 1) + ': Vui lòng nhập Serial.'; return false; }
            if (!loai) { error = 'Tài sản khác - Dòng ' + (i + 1) + ': Vui lòng chọn Loại thiết bị.'; return false; }

            rows.push({ loai: loai, serial: serial, quyCach: quyCach, viTri: viTri, file: file });
            });
            return { rows: rows, error: error };
            }

            // Gửi các dòng Tài sản khác (nếu có) lên server, dùng chung Tài khoản/Công ty/Bộ phận vừa xác nhận thành công
            function guiTaiSanKhac(taikhoanInput, matkhauInput, idCongTyInput, idBoPhanInput, rows, callback) {
            if (!rows || rows.length === 0) { callback(); return; }

            var fd = new FormData();
            fd.append('taikhoan', taikhoanInput);
            fd.append('matkhau', matkhauInput);
            fd.append('idCongTy', idCongTyInput);
            fd.append('idBoPhan', idBoPhanInput);
            rows.forEach(function (r, i) {
            fd.append('rows[' + i + '].Serial', r.serial);
            fd.append('rows[' + i + '].LoaiThietBi', r.loai);
            fd.append('rows[' + i + '].QuyCach', r.quyCach || '');
            fd.append('rows[' + i + '].TenViTri', r.viTri);
            if (r.file) fd.append('rows[' + i + '].Anh', r.file, r.file.name || 'device_photo.jpg'); // Đặt tên file mặc định vì ảnh dán Ctrl+V là Blob thô không có tên
            });

            $.ajax({
            url: '/QLKiemKe/ThemNhanhTaiSanKhac',
            type: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function (res) { callback(res); },
            error: function () { callback({ success: false, message: 'Đã xảy ra lỗi kết nối khi gửi Tài sản khác.' }); }
            });
            }

            function resetTaiSanKhac() {
            $("#dsRowTaiSanKhac").empty();
            demDongTaiSanKhac = 0;
            $("#boxTaiSanKhac").hide();
            rowTaiSanKhacPasteHienTai = null; // Các dòng vừa bị xóa hết, tránh giữ tham chiếu tới dòng đã không còn tồn tại
            }

            // Hàm cập nhật gán dữ liệu chi tiết nâng cao từ Cache bộ nhớ
            function taiToanBoThongTinChiTiet() {
            $("#loadingStatus").show();
            $("#infoTableContainer").hide();
            $("#errorAlert").hide();

            if (duLieuQuetMayKhachCache != null) {
            $("#loadingStatus").hide();

            // Cập nhật lại đồng bộ bảng 1
            $("#lblSeriMay").text(duLieuQuetMayKhachCache.seriMay || "N/A");
            $("#lblDongMay").text(duLieuQuetMayKhachCache.dongMay || "N/A");
            $("#lblTenMay").text(duLieuQuetMayKhachCache.tenMay || "N/A");
            $("#lblTenNguoiDungHeThong").text(duLieuQuetMayKhachCache.tenNguoiDungHeThong || "N/A");
            $("#lblThongTinManHinhNgoai").text(duLieuQuetMayKhachCache.thongTinManHinhNgoai || "N/A");
            $("#lblThongTinManHinh").html(duLieuQuetMayKhachCache.thongTinManHinh || "N/A");

            // Gán dữ liệu cho bảng nâng cao thứ 2 từ Tool cục bộ
            $("#lblHeDieuHanh").text(duLieuQuetMayKhachCache.heDieuHanh || "N/A");
            $("#lblKienTruc").text(duLieuQuetMayKhachCache.kienTruc || "N/A");
            $("#lblPhienBanNet").text(duLieuQuetMayKhachCache.phienBanNet || "N/A");
            $("#lblSoLoiCPU").text(duLieuQuetMayKhachCache.soLoiCPU || "0");
            $("#lblRamKhaDung").text(duLieuQuetMayKhachCache.ramKhaDung || "N/A");

            // ĐÃ SỬA THÀNH .html(): Render đúng text format dạng <b class='text-success'>SSD</b>
            $("#lblThongTinOCung").html(duLieuQuetMayKhachCache.thongTinOCung || "N/A");

            $("#lblLoaiRam").html(duLieuQuetMayKhachCache.loaiRam || "N/A");
            $("#lblThongTinOffice").text(duLieuQuetMayKhachCache.thongTinOffice || "N/A");
            $("#lblBanQuyenWin").text(duLieuQuetMayKhachCache.banQuyenWin || "N/A");
            $("#lblBanQuyenOffice").text(duLieuQuetMayKhachCache.banQuyenOffice || "N/A");
            $("#lblThuMucHeThong").text(duLieuQuetMayKhachCache.thuMucHeThong || "N/A");

            $("#lblThoiGianHoatDong").text(duLieuQuetMayKhachCache.thoiGianHoatDong || "N/A");
            $("#lblMacWifi").html(duLieuQuetMayKhachCache.macWifi || "N/A");

            // Hiện bảng chi tiết nâng cao lên công khai
            $("#infoTableContainer").fadeIn(300);
            } else {
            $("#loadingStatus").hide();
            $("#errorMsg").text("Chưa nạp được gói tin phần cứng từ Tool local. Vui lòng kiểm tra ứng dụng chạy ngầm.");
            $("#errorAlert").show();
            }
            }

            // Xử lý sự kiện khi bấm nút làm mới cấu hình
            $("#btnRefresh").click(function () {
            // Gọi lại hàm quét fresh trực tiếp từ tool local rồi nạp lại vào bảng
            $.ajax({
            url: 'http://localhost:8888/get-hardware',
            type: 'GET',
            dataType: 'json',
            timeout: 20000, // Tăng thời gian chờ vì Tool local có lúc tải hơi lâu
            success: function(res) {
            if(res.success && res.data) {
            duLieuQuetMayKhachCache = res.data;
            taiToanBoThongTinChiTiet();
            capNhatBoxManHinhNgoai();
            traCuuThongTinSoHuu();
            }
            },
            error: function() {
            $("#errorMsg").text("Đã gặp sự cố thiếu MSI hãy liên hệ với IT để được hỗ trợ.");
            $("#errorAlert").show();
            }
            });
            });
            });
        </script>
    }
}