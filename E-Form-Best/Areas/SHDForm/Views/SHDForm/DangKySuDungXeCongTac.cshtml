@model E_Form_Best.Models.ITForm.FormShd
@using System.Security.Claims

@{
    ViewData["Title"] = "Đăng ký xe công tác - SHD";
    Layout = "~/Areas/SHDForm/Views/Shared/_Layout.cshtml";

    // --- LẤY THÔNG TIN TỪ CLAIMS ---
    var tenNguoiNv = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var phongBan = User.FindFirst("PhongBan")?.Value ?? "";
    var soNhanVien = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var tenCongTy = User.FindFirst("TenCongTy")?.Value ?? "";
    var ngayHienThi = DateTime.Now.ToString("dd/MM/yyyy");

    // Toolkit Style màu SHD 2026 (Indigo & Cyan)
    string primaryColor = "#4338ca"; // Indigo 700
    string secondaryColor = "#0891b2"; // Cyan 600
    string darkBg = "#1e1b4b"; // Indigo 950
    string lightBg = "#f0f9ff"; // Cyan 50

    string inputStyle = $"width: 100%; padding: 12px; border-radius: 10px; border: 1px solid #c7d2fe; background: #ffffff; font-weight: 600; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; color: {darkBg};";
    string labelStyle = $"font-weight: 700; color: {primaryColor}; font-size: 11px; margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.5px;";
    string pasteZoneStyle = $"width: 100%; border: 2px dotted #a5b4fc; height: 180px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: #f5f3ff; color: {primaryColor}; cursor: pointer; overflow: hidden; font-size: 12px; font-weight: 600; transition: 0.3s; margin-top: 10px; position: relative; outline: none;";
}

<div style="background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%); padding: 40px 15px; min-height: 100vh; font-family: 'Inter', sans-serif;">

    <form id="shdForm" method="post" enctype="multipart/form-data" action="/FormSHD/DangKySuDungXeCongTac"
          style="max-width: 900px; margin: 0 auto; background: #ffffff; border-radius: 30px; box-shadow: 0 20px 50px rgba(67, 56, 202, 0.15); overflow: hidden; border: 1px solid rgba(255,255,255,0.8);">

        @Html.AntiForgeryToken()

        @* --- HEADER --- *@
        <div style="background: linear-gradient(135deg, @primaryColor 0%, @darkBg 100%); padding: 40px; color: #ffffff; text-align: center; position: relative;">
            <div style="position: absolute; top: 15px; right: 25px; font-size: 11px; opacity: 0.8; font-weight: 500; letter-spacing: 1px;">SHD E-PORTAL V3.0</div>
            <h2 style="margin: 0; font-size: 24px; text-transform: uppercase; font-weight: 900; letter-spacing: 1.5px;">Đăng ký sử dụng xe công tác</h2>
            <div style="margin-top: 12px; display: inline-block; padding: 6px 16px; background: rgba(255,255,255,0.15); border-radius: 50px; font-size: 13px;">
                📅 Ngày lập đơn: <span style="font-weight: 700; color: #fff;">@ngayHienThi</span>
            </div>
        </div>

        <div style="padding: 40px;">
            @* --- PHẦN 1: THÔNG TIN NHÂN SỰ --- *@
            <div style="margin-bottom: 35px;">
                <h3 style="color: @primaryColor; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @secondaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">1</span>
                    Thông tin người đăng ký (SHD)
                </h3>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 15px;">
                    <div>
                        <label style="@labelStyle">Họ tên nhân viên</label>
                        <input name="TenNguoiNv" value="@tenNguoiNv" readonly style="@inputStyle; background: #f8fafc;">
                    </div>
                    <div>
                        <label style="@labelStyle">Phòng ban</label>
                        <input name="BoPhan" value="@phongBan" readonly style="@inputStyle; background: #f8fafc;">
                    </div>
                    <div>
                        <label style="@labelStyle">Mã nhân viên</label>
                        <input name="SoNhanVien" value="@soNhanVien" readonly style="@inputStyle; background: #f8fafc;">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label style="@labelStyle">Đơn vị / Công ty</label>
                        <input name="TenCongTy" value="@tenCongTy" readonly style="@inputStyle; background: #f8fafc; border-style: dashed;">
                    </div>
                    <div>
                        <label style="@labelStyle">Danh mục hồ sơ</label>
                        <input name="Danhmuc" value="ĐƠN ĐĂNG KÝ SỬ DỤNG XE CÔNG TÁC" readonly style="@inputStyle; background: #f8fafc; border-style: dashed; color: @secondaryColor;">
                    </div>
                </div>
            </div>

            @* --- PHẦN 2: CHI TIẾT XE --- *@
            <div style="background: #f8fafc; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0; margin-bottom: 30px;">
                <h3 style="color: @darkBg; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @darkBg; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">2</span>
                    Nội dung và Lịch trình chi tiết
                </h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label style="@labelStyle">Số điện thoại liên hệ <span style="color:#e53e3e">*</span></label>
                        <input type="text" name="chiTiet.SoDienThoai" placeholder="Nhập số điện thoại..." required style="@inputStyle; border: 1px solid @primaryColor;">
                    </div>
                    <div>
                        <label style="@labelStyle">Số lượng người đi <span style="color:#e53e3e">*</span></label>
                        <input type="number" name="chiTiet.SoLuong" value="1" min="1" required style="@inputStyle; border: 1px solid @primaryColor;">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label style="@labelStyle">🕒 Thời gian đi dự tính <span style="color:#e53e3e">*</span></label>
                        <input type="datetime-local" id="inpTimeDuTinh" name="chiTiet.TimeDuTinh" required style="@inputStyle; border: 1px solid @primaryColor;">
                    </div>
                    <div>
                        <label style="@labelStyle">🕒 Thời gian về dự tính (Không bắt buộc)</label>
                        <input type="datetime-local" id="inpThoiGianVe" name="chiTiet.ThoiGianVe" style="@inputStyle;">
                    </div>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Mục đích sử dụng xe / Lộ trình <span style="color:#e53e3e">*</span></label>
                    <textarea name="chiTiet.LiDo" placeholder="Vui lòng nhập lý do sử dụng xe và các điểm dừng chi tiết..." required style="@inputStyle; height: 70px; resize: none; border: 1px solid @primaryColor;"></textarea>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="@labelStyle">Ghi chú (Nếu có)</label>
                    <input type="text" name="chiTiet.GhiChu" placeholder="Ghi chú thêm cho tài xế hoặc bộ phận quản lý..." style="@inputStyle;">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="@labelStyle">Ảnh minh chứng (Click & Ctrl+V)</label>
                        <div id="paste_AnhXe" class="paste-zone" style="@pasteZoneStyle" tabindex="0">
                            Nhấp vào đây và nhấn Ctrl+V để dán ảnh
                        </div>
                        <input type="file" id="AnhXe" name="AnhXe" hidden accept="image/*">
                    </div>

                    <div>
                        <label style="@labelStyle">Tài liệu đính kèm (PDF/Scan)</label>
                        <div style="margin-top:10px; background: #ffffff; padding: 15px; border-radius: 12px; border: 1px dashed #cbd5e1; height: 180px; display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;">
                            <input type="file" name="UploadFile" style="font-size: 13px; width: 100%;">
                            <p style="font-size: 11px; color: @primaryColor; margin-top: 15px; line-height: 1.4; opacity: 0.7;">Tải lên kế hoạch công tác đã phê duyệt hoặc thư mời.</p>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PHẦN 3: CHỌN LOẠI YÊU CẦU HỖ TRỢ (MỚI) --- *@
            <div style="background: #ffffff; padding: 25px; border-radius: 20px; border: 1px solid #c7d2fe; margin-bottom: 30px; box-shadow: 0 4px 6px rgba(67, 56, 202, 0.05);">
                <h3 style="color: @primaryColor; font-size: 15px; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: 800; text-transform: uppercase;">
                    <span style="background: @primaryColor; color: white; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 12px;">3</span>
                    Nhân sự hỗ trợ tiếp nhận (Điều xe SHD)
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px;">
                    @if (ViewBag.ListNguoiHoTro != null)
                    {
                        foreach (var item in (List<E_Form_Best.Models.ITForm.ShdNguoiHoTro>)ViewBag.ListNguoiHoTro)
                        {
                            @*
                                Giả định rằng Controller đã lọc sẵn ListNguoiHoTro có công việc tương ứng.
                                Nếu cần hiển thị danh sách checkbox dựa trên từng đầu việc:
                            *@
                            <label style="display: flex; align-items: center; gap: 12px; padding: 15px; border: 1px solid #e0e7ff; border-radius: 12px; cursor: pointer; transition: 0.2s; background: #f8fafc;"
                                   onmouseover="this.style.borderColor='@primaryColor'; this.style.background='#f5f3ff'; this.style.transform='translateY(-2px)';"
                                   onmouseout="this.style.borderColor='#e0e7ff'; this.style.background='#f8fafc'; this.style.transform='translateY(0)';"
                                   title="Phụ trách bởi: @item.Ten">

                                <input type="checkbox" name="SelectedCongViecIds" value="@item.Id" style="width: 20px; height: 20px; accent-color: @primaryColor;">

                                <div style="flex: 1;">
                                    <div style="font-weight: 700; color: @darkBg; font-size: 14px;">
                                        🚚 Điều xe công tác SHD
                                    </div>
                                    <div style="font-size: 11px; color: @primaryColor; opacity: 0.8;">NV phụ trách: @item.Ten</div>
                                </div>
                            </label>
                        }
                    }
                    else
                    {
                        <p style="font-size: 12px; color: @primaryColor; font-style: italic; grid-column: 1/-1;">Đang cập nhật danh sách nhân sự SHD...</p>
                    }
                </div>
            </div>

            @* --- PHẦN 4: QUY ĐỊNH --- *@
            <div style="background: #f0f9ff; border: 1.5px solid @secondaryColor; border-radius: 20px; padding: 25px; margin-bottom: 30px;">
                <h3 style="color: @secondaryColor; font-size: 14px; display: flex; align-items: center; gap: 10px; margin-bottom: 15px; font-weight: 800; text-transform: uppercase;">
                    <i class="fa fa-info-circle"></i> Quy định sử dụng xe SHD
                </h3>
                <ul style="margin: 0 0 20px 20px; padding: 0; color: @darkBg; font-size: 12px; line-height: 1.8; font-weight: 600; list-style-type: disc;">
                    <li>Sử dụng xe đúng lộ trình phục vụ hoạt động Xuất Nhập Khẩu/Công tác của SHD.</li>
                    <li>Thông báo cho tài xế ngay nếu có thay đổi về thời gian hoặc địa điểm dừng.</li>
                    <li>Đảm bảo các chứng từ vận chuyển (nếu có) được mang theo đầy đủ.</li>
                </ul>

                <label id="containerCamKet" style="cursor: pointer; display: flex; align-items: flex-start; gap: 12px; background: #ffffff; padding: 15px; border-radius: 12px; border: 2px solid #bae6fd; transition: 0.3s;">
                    <input type="checkbox" id="chkCamKet" style="width: 22px; height: 22px; margin-top: 2px; accent-color: @secondaryColor; cursor: pointer;">
                    <span style="font-size: 13px; font-weight: 800; color: @darkBg; line-height: 1.5;">
                        Tôi xác nhận mọi thông tin trên là chính xác và cam kết tuân thủ quy định của SHD.
                    </span>
                </label>
            </div>

            @* --- NÚT GỬI --- *@
            <div style="text-align: center;">
                <button type="button" onclick="xuLyLuuDon()"
                        style="width: 100%; padding: 20px; background: linear-gradient(to right, @primaryColor, @secondaryColor); color: #fff; border: none; border-radius: 15px; font-weight: 900; font-size: 18px; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(67, 56, 202, 0.3); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="fa fa-paper-plane" style="margin-right: 10px;"></i> Gửi yêu cầu điều xe SHD
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    // 1. Tự động thiết lập thời gian mặc định
    window.onload = function() {
        const now = new Date();
        const offset = now.getTimezoneOffset() * 60000;
        
        // Thời gian đi: Hiện tại
        const timeDi = new Date(now - offset).toISOString().slice(0, 16);
        document.getElementById('inpTimeDuTinh').value = timeDi;

        // Mặc định trống cho thời gian về
        document.getElementById('inpThoiGianVe').value = "";
    };

    // 2. Xử lý dán ảnh (Ctrl+V) cho SHD
    const zone = document.getElementById("paste_AnhXe");
    if (zone) {
        zone.addEventListener('paste', (e) => {
            const items = (e.clipboardData || e.originalEvent.clipboardData).items;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    const blob = items[i].getAsFile();
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        zone.innerHTML = `<img src="${event.target.result}" style="width:100%; height:100%; object-fit:contain; border-radius:10px;">`;
                        zone.style.border = "2px solid @primaryColor";

                        const fileInput = document.getElementById("AnhXe");
                        const dataTransfer = new DataTransfer();
                        dataTransfer.items.add(blob);
                        fileInput.files = dataTransfer.files;
                    };
                    reader.readAsDataURL(blob);
                }
            }
        });
        zone.addEventListener('click', () => zone.focus());
    }

    // 3. Xử lý gửi đơn và Kiểm tra ràng buộc
    function xuLyLuuDon() {
        const sdt = document.querySelector('input[name="chiTiet.SoDienThoai"]').value.trim();
        const soLuong = document.querySelector('input[name="chiTiet.SoLuong"]').value;
        const liDo = document.querySelector('textarea[name="chiTiet.LiDo"]').value.trim();
        const timeDi = document.getElementById('inpTimeDuTinh').value;
        const timeVe = document.getElementById('inpThoiGianVe').value;
        const chk = document.getElementById('chkCamKet');
        const selectedHoTro = document.querySelectorAll('input[name="SelectedCongViecIds"]:checked');

        // Kiểm tra các trường cơ bản
        if (!sdt) { alert("⚠️ Vui lòng nhập số điện thoại liên hệ!"); return; }
        if (!soLuong || soLuong < 1) { alert("⚠️ Vui lòng nhập số lượng người đi hợp lệ!"); return; }
        if (!timeDi) { alert("⚠️ Vui lòng chọn thời gian đi!"); return; }
        
        // Kiểm tra logic thời gian nếu có nhập ngày về
        if (timeVe && timeDi) {
            if (new Date(timeVe) <= new Date(timeDi)) {
                alert("⚠️ Thời gian về dự tính phải sau thời gian đi!");
                return;
            }
        }

        if (liDo.length < 5) {
            alert("⚠️ Vui lòng mô tả chi tiết lộ trình và mục đích!");
            return;
        }

        if (selectedHoTro.length === 0) {
            alert("⚠️ Vui lòng chọn nhân sự hỗ trợ tiếp nhận đơn!");
            return;
        }

        if (!chk.checked) {
            alert("⚠️ Bạn chưa xác nhận cam kết tuân thủ quy định của SHD!");
            return;
        }

        if (confirm("Hệ thống SHD sẽ gửi yêu cầu điều xe. Bạn chắc chắn chứ?")) {
            document.getElementById("shdForm").submit();
        }
    }
</script>