@using System.Security.Claims
@{
    ViewData["Title"] = "Quản Lý Xét Duyệt SHD - B2";
    Layout = "~/Areas/SHDform/Views/Shared/_Layout.cshtml";
    
    // Đồng bộ màu Luxury SHD 2026
    string indigoPrimary = "#312e81";
    string cyanAccent = "#22d3ee";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? User.FindFirst("UserRole")?.Value ?? "Guest";
}

<style>
    /* --- Desktop & Base Styles --- */
    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 28px;
        height: 28px;
        background: #ecfeff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0891b2;
        border: 1px solid #cffafe;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(49, 46, 129, 0.1) !important;
        border-color: @cyanAccent !important;
    }

    .status-pill {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 1000;
        display: inline-block;
        min-width: 95px;
        text-align: center;
        text-transform: uppercase;
    }

    /* Phân trang SHD Style */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: @indigoPrimary;
            color: white;
            border-color: @indigoPrimary;
            box-shadow: 0 4px 6px -1px rgba(49, 46, 129, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f0fdfa;
            border-color: @cyanAccent;
        }

    /* ==========================================
           CSS RESPONSIVE CHO MOBILE (DẠNG CARD)
           ========================================== */
    @@media (max-width: 768px) {
        .header-mobile {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 15px !important;
        }

        .controls-mobile {
            flex-direction: column !important;
            width: 100% !important;
            gap: 12px !important;
        }

            .controls-mobile > div, #quickSearch {
                width: 100% !important;
                box-sizing: border-box !important;
            }
        /* Thống kê: Lưới 2 cột */
        .stat-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }
        /* Biến Table thành Card list */
        #dataTable thead {
            display: none;
        }

        #dataTable tbody tr {
            display: block;
            margin-bottom: 15px;
            border: 2px solid #e2e8f0 !important;
            border-radius: 20px;
            padding: 12px;
            background: #ffffff;
            position: relative;
            border-left: 6px solid @indigoPrimary !important;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        #dataTable tbody td {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: none !important;
            padding: 10px 5px !important;
            width: 100% !important;
            text-align: right !important;
            border-bottom: 1px dashed #f1f5f9 !important;
        }
            /* Nút thao tác cuối card */
            #dataTable tbody td:last-child {
                border-bottom: none !important;
                justify-content: center !important;
                padding-top: 15px !important;
            }
            /* Nhãn giả cho Card Mobile */
            #dataTable tbody td::before {
                content: attr(data-label);
                font-weight: 800;
                color: #64748b;
                text-transform: uppercase;
                font-size: 10px;
                text-align: left;
                flex-shrink: 0;
                margin-right: 15px;
            }

        .mobile-td-content {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            text-align: right;
        }

        .pagination-mobile {
            flex-direction: column !important;
            gap: 20px;
            align-items: center !important;
        }
    }
</style>

<div style="padding: 20px; background: #f8fafc; min-height: 100vh; font-family: 'Inter', sans-serif;">

    @* --- TOP BAR --- *@
    <div class="header-mobile" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 15px;">
        <h2 style="margin: 0; color: @indigoPrimary; font-weight: 1000; font-size: 24px; display: flex; align-items: center; gap: 10px;">
            <span style="background: @indigoPrimary; color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-ship"></i>
            </span>
            XÉT DUYỆT BỘ PHẬN SHD (B2)
        </h2>

        <div class="controls-mobile" style="display: flex; gap: 10px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 12px; border: 2px solid #e2e8f0;">
                <span style="font-size: 12px; font-weight: 700; color: #64748b;">Hiển thị:</span>
                <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: @indigoPrimary; cursor: pointer; background: transparent; font-size: 14px;">
                    <option value="10">10</option>
                    <option value="20" selected>20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>

            <div style="position: relative;" class="controls-mobile">
                <i class="fa fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 14px; font-weight: 900;"></i>
                <input type="text" id="quickSearch" onkeyup="handleFilterAndPaginate()" placeholder="Tìm tên, bộ phận, mã đơn..."
                       style="padding: 10px 12px 10px 38px; border-radius: 12px; border: 2px solid #e2e8f0; font-size: 14px; width: 280px; outline: none; font-weight: 700; box-sizing: border-box;">
            </div>
            <div style="font-size: 11px; background: @indigoPrimary; padding: 8px 15px; border-radius: 8px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">@userRole</div>
        </div>
    </div>

    @* --- THỐNG KÊ (Stats) --- *@
    <div class="stat-grid-mobile" style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 25px;">
        <div onclick="filterByStatus('')" class="stat-card" style="background: white; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #1e293b; text-transform: uppercase; margin-bottom: 5px;">TỔNG ĐƠN</div>
            <div id="stat-total" style="font-size: 22px; font-weight: 1000; color: #1e293b;">0</div>
        </div>
        <div onclick="filterByStatus('BP XÁC NHẬN')" class="stat-card" style="background: #ecfeff; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #0891b2; text-transform: uppercase; margin-bottom: 5px;">CHỜ B2</div>
            <div id="stat-b2" style="font-size: 22px; font-weight: 1000; color: #0891b2;">0</div>
        </div>
        <div onclick="filterByStatus('GIÁM ĐỐC')" class="stat-card" style="background: #fdf4ff; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #86198f; text-transform: uppercase; margin-bottom: 5px;">CHỜ GĐ</div>
            <div id="stat-gd" style="font-size: 22px; font-weight: 1000; color: #86198f;">0</div>
        </div>
        <div onclick="filterByStatus('ADMIN')" class="stat-card" style="background: #e0e7ff; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: @indigoPrimary; text-transform: uppercase; margin-bottom: 5px;">ADMIN</div>
            <div id="stat-admin" style="font-size: 22px; font-weight: 1000; color: @indigoPrimary;">0</div>
        </div>
        <div onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #ecfdf5; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #10b981; text-transform: uppercase; margin-bottom: 5px;">XONG</div>
            <div id="stat-xong" style="font-size: 22px; font-weight: 1000; color: #10b981;">0</div>
        </div>
        <div onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 15px 10px; border-radius: 16px; border: 2px solid rgba(0,0,0,0.03); cursor: pointer; transition: 0.3s; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <div style="font-size: 10px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 5px;">HỦY</div>
            <div id="stat-huy" style="font-size: 22px; font-weight: 1000; color: #b91c1c;">0</div>
        </div>
    </div>

    @* --- BẢNG DỮ LIỆU --- *@
    <div style="background: white; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
        <table id="dataTable" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 3px solid #f1f5f9;">
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Nội dung đơn SHD</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Người Hỗ Trợ</th>
                    <th style="padding: 18px 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; width: 140px;">Tiến độ</th>
                    <th style="padding: 18px 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                    <th style="padding: 18px 20px; text-align: right;"></th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <tr>
                    <td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border: none;">
                        <i class="fa fa-spinner fa-spin" style="font-size: 32px; margin-bottom: 15px; color: @indigoPrimary;"></i>
                        <p style="font-weight: 600;">Đang tải danh sách B2 SHD...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* --- PHẦN PHÂN TRANG --- *@
    <div class="pagination-mobile" style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; margin-top: 5px;">
        <div id="paginationButtons" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
        <div style="text-align: right;">
            <div style="color: #64748b; font-size: 13px; font-weight: 700;">
                Trang <span id="currentPageNum" style="color: @indigoPrimary;">1</span> / <span id="totalPagesNum">1</span>
            </div>
            <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 5px;">
                Tổng cộng: <span id="totalVisibleCount">0</span> bản ghi
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];
        let filteredData = [];
        let currentPage = 1;
        let rowsPerPage = 20;

        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const response = await fetch('/FormSHD/GetQuanLyXetDuyetB2Data');
                masterData = await response.json();
                updateStatistics(masterData);
                handleFilterAndPaginate();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: #ef4444; font-weight: bold;">Lỗi tải dữ liệu.</td></tr>`;
            }
        });

        function updateStatistics(data) {
            const getCnt = (tag) => data.filter(x => x.statusTag === tag).length;
            document.getElementById("stat-total").innerText = data.length;
            document.getElementById("stat-b2").innerText = getCnt("BP XÁC NHẬN");
            document.getElementById("stat-gd").innerText = getCnt("GIÁM ĐỐC");
            document.getElementById("stat-admin").innerText = getCnt("ADMIN");
            document.getElementById("stat-xong").innerText = getCnt("HOÀN TẤT");
            document.getElementById("stat-huy").innerText = getCnt("ĐÃ HỦY");
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            currentPage = 1;
            handleFilterAndPaginate();
        }

        function filterByStatus(s) {
            document.getElementById("quickSearch").value = s;
            currentPage = 1;
            handleFilterAndPaginate();
            const tb = document.getElementById("dataTable");
            tb.style.opacity = "0.5";
            setTimeout(() => tb.style.opacity = "1", 150);
        }

        function handleFilterAndPaginate() {
            const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();

            filteredData = masterData.filter(item => {
                const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${item.supportName} ${item.statusTag}`.toUpperCase();
                return searchText === "" || rowString.includes(searchText);
            });

            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const pageData = filteredData.slice(startIndex, startIndex + rowsPerPage);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 50px; text-align: center; color: #94a3b8; border:none; display:block;">Không tìm thấy kết quả phù hợp.</td></tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                // Tạo Badge B2, GD
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-clock-o"></i> ${item.timeNguoiTao}</span>`;
                if (item.hasB2) {
                    badgesHtml += `<span class="sub-badge" style="color: #0891b2; border-color: #cffafe; background: #ecfeff; margin-left:5px;"><i class="fa fa-users"></i> B2 (${item.b2DuyetCount}/${item.b2TotalCount})</span>`;
                }
                if (item.hasGD) {
                    badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:5px;"><i class="fa fa-briefcase"></i> GĐ (${item.gdDuyetCount}/${item.gdTotalCount})</span>`;
                }

                // Logic nút xử lý
                const isCancelled = item.statusTag === "ĐÃ HỦY";
                let btnClass = (item.isB2Processing && !isCancelled) ? "fa-edit" : "fa-eye";
                let btnText = (item.isB2Processing && !isCancelled) ? "Xử lý B2" : "Xem lại";
                let btnBg = (item.isB2Processing && !isCancelled) ? "@indigoPrimary" : "#f1f5f9";
                let btnColor = (item.isB2Processing && !isCancelled) ? "#ffffff" : "#64748b";

                html += `
                    <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                            <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: @indigoPrimary;">MS: ${item.soNhanVien}</span></div>
                        </td>
                        <td data-label="Nội dung đơn SHD" style="padding: 15px 20px;">
                            <div class="mobile-td-content">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 700; display: flex; flex-wrap: wrap; align-items: center; margin-top:4px;">
                                    ${badgesHtml}
                                </div>
                            </div>
                        </td>
                        <td data-label="Người Hỗ Trợ" style="padding: 15px 20px;">
                            <div class="mobile-td-content">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                    <div style="font-weight: 700; color: #334155; font-size: 13px;">${item.supportName}</div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Tiến độ" style="padding: 15px 20px;">
                            <div class="mobile-td-content">
                                <div style="width: 100px;">
                                    <div style="font-size: 9px; font-weight: 1000; color: ${item.pColor}; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                        <span>${item.pText}</span> <span>${item.pWidth}</span>
                                    </div>
                                    <div style="width: 100%; height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden;">
                                        <div style="width: ${item.pWidth}; height: 100%; background: ${item.pColor}; border-radius: 10px; transition: 0.5s ease;"></div>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <div class="mobile-td-content">
                                <span class="status-pill" style="background:${item.bg}; color:${item.fg}; border: 1.5px solid ${item.fg};">${item.statusTag}</span>
                            </div>
                        </td>
                        <td data-label="Thao tác" style="padding: 15px 20px; text-align: right;">
                            <a href="/FormSHD/ChiTiet/${item.id}"
                               style="text-decoration: none; padding: 10px 20px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: ${btnBg}; color: ${btnColor}; width: 100%; text-align: center; box-sizing: border-box;">
                                 <i class="fa ${btnClass}"></i> ${btnText}
                            </a>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = "";
            if (totalPages <= 1) return;
            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 5 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) container.insertAdjacentHTML('beforeend', `<span style="padding:8px; color:#cbd5e1; font-weight:bold">...</span>`);
                    continue;
                }
                const btn = document.createElement("button");
                btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => { currentPage = i; handleFilterAndPaginate(); window.scrollTo({ top: 0, behavior: 'smooth' }); };
                container.appendChild(btn);
            }
        }
    </script>
}