@{
    ViewData["Title"] = "SHD Branding Logo";
    Layout = "~/Areas/SHDForm/Views/Shared/_Layout.cshtml";

    // Khai báo lại bộ màu đồng bộ với Menu (Luxury Deep Indigo & Cyan)
    string indigoDeep = "#312e81";
    string indigoNavy = "#1e1b4b";
    string cyanAccent = "#22d3ee";
    string luxuryGradient = "linear-gradient(135deg, #312e81 0%, #1e1b4b 100%)";
}

<style>
    /* Hiệu ứng mượt mà cho 2026 */
    .brand-card {
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    .brand-logo:hover {
        transform: scale(1.05) rotate(2deg);
    }

    /* ==========================================
               CSS RESPONSIVE CHO MOBILE (2026 STYLE)
               ========================================== */
    @@media (max-width: 768px) {
        .brand-wrapper {
            padding: 10px !important;
            min-height: 90vh !important;
        }

        .brand-card {
            padding: 40px 20px !important; /* Giảm padding trên mobile */
            border-radius: 30px !important;
        }

        .brand-logo {
            width: 120px !important; /* Thu nhỏ logo box */
            height: 120px !important;
            margin-bottom: 30px !important;
        }

            .brand-logo div {
                font-size: 32px !important; /* Giảm font chữ SHD */
            }

        .brand-title {
            font-size: 2rem !important; /* Giảm size tiêu đề h1 */
        }

        .btn-group-mobile {
            flex-direction: column !important; /* Nút bấm xếp dọc */
            gap: 10px !important;
        }

        .btn-mobile {
            width: 100% !important;
            box-sizing: border-box;
        }

        .brand-desc {
            font-size: 0.95rem !important;
        }
    }
</style>

<div class="brand-wrapper" style="display: flex; justify-content: center; align-items: center; min-height: 80vh; background-color: #f1f5f9; font-family: 'Inter', 'Segoe UI', Roboto, sans-serif; padding: 20px;">

    <div class="brand-card" style="background: #ffffff; padding: 60px; border-radius: 40px; box-shadow: 0 25px 50px -12px rgba(30, 46, 129, 0.15); text-align: center; max-width: 600px; width: 100%; border: 1px solid #e2e8f0; position: relative; overflow: hidden;">
        
        <!-- Các khối decor nghệ thuật -->
        <div style="position: absolute; top: -40px; left: -40px; width: 150px; height: 150px; background: linear-gradient(135deg, rgba(34, 211, 238, 0.1), rgba(49, 46, 129, 0.05)); border-radius: 50%; z-index: 0;"></div>
        <div style="position: absolute; bottom: -20px; right: -20px; width: 100px; height: 100px; background: rgba(34, 211, 238, 0.05); border-radius: 50%; z-index: 0;"></div>

        <div style="position: relative; z-index: 1;">
            
            <!-- Hiển thị Logo SHD chính diện -->
            <div class="brand-logo" style="width: 160px; height: 160px; margin: 0 auto 40px; border-radius: 35px; background: @luxuryGradient; display: flex; justify-content: center; align-items: center; box-shadow: 0 20px 40px rgba(30, 46, 129, 0.3); border: 2px solid rgba(255,255,255,0.1); transition: transform 0.3s ease; cursor: pointer;">
                <div style="color: #ffffff; font-size: 42px; font-weight: 900; letter-spacing: 3px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">
                    SHD
                </div>
            </div>

            <!-- Nhãn hiệu phụ -->
            <div style="display: inline-block; padding: 8px 20px; background: #f0f9ff; color: @indigoDeep; border-radius: 12px; font-size: 11px; font-weight: 800; letter-spacing: 3px; margin-bottom: 25px; text-transform: uppercase; border: 1px solid rgba(34, 211, 238, 0.3);">
                Shipping Department Identity
            </div>

            <!-- Tiêu đề chính -->
            <h1 class="brand-title" style="margin: 0; font-size: 2.8rem; color: @indigoDeep; font-weight: 900; letter-spacing: -1.5px; line-height: 1.1;">
                Hệ Thống <span style="color: @cyanAccent; text-shadow: 1px 1px 0px rgba(0,0,0,0.05);">SHD FORM</span>
            </h1>

            <!-- Thanh ngăn cách nghệ thuật -->
            <div style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 30px 0;">
                <div style="width: 40px; height: 4px; background: @indigoDeep; border-radius: 10px; opacity: 0.2;"></div>
                <div style="width: 12px; height: 12px; background: @cyanAccent; border-radius: 50%; box-shadow: 0 0 10px @cyanAccent;"></div>
                <div style="width: 40px; height: 4px; background: @indigoDeep; border-radius: 10px; opacity: 0.2;"></div>
            </div>

            <p class="brand-desc" style="font-size: 1.1rem; color: #64748b; line-height: 1.6; max-width: 450px; margin: 0 auto;">
                Cổng thông tin quản lý đơn từ và biểu mẫu điện tử của bộ phận <strong>SHD Shipping Department</strong>. Số hóa quy trình làm việc chuyên nghiệp.
            </p>

            <!-- Nút chức năng giả lập -->
            <div class="btn-group-mobile" style="margin-top: 40px; display: flex; justify-content: center; gap: 15px;">
                <div class="btn-mobile" style="padding: 12px 25px; background: @indigoDeep; color: #fff; border-radius: 15px; font-size: 0.9rem; font-weight: 600; cursor: default; box-shadow: 0 10px 20px rgba(30, 46, 129, 0.2); border: 1px solid rgba(34, 211, 238, 0.2);">
                    E-Form Portal
                </div>
                <div class="btn-mobile" style="padding: 12px 25px; background: #fff; color: @indigoDeep; border-radius: 15px; font-size: 0.9rem; font-weight: 600; cursor: default; border: 1px solid #e2e8f0;">
                    Indigo Theme
                </div>
            </div>

        </div>

        <!-- Footer của Card -->
        <div style="margin-top: 50px; padding-top: 25px; border-top: 1px solid #f1f5f9; font-size: 10px; color: #94a3b8; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;">
            &copy; @DateTime.Now.Year Digital Management - SHD Shipping Department
        </div>

    </div>
</div>