@using System.Security.Claims

@{
    ViewData["Title"] = "Báo Cáo - Kho Lưu Trữ Đơn SHD";
    Layout = "~/Areas/SHDForm/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    /* Badge & Avatar Styles */
    .sub-badge {
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        border: 1px solid;
        margin-top: 2px;
    }

    .support-avatar {
        width: 26px;
        height: 26px;
        background: #ecfeff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0891b2;
        border: 1px solid #cffafe;
    }

    .stat-card {
        transition: all 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1) !important;
        }
    
    /* Filter Inputs */
    .filter-input {
        padding: 10px 12px;
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        font-size: 13px;
        font-weight: 600;
        outline: none;
        transition: 0.2s;
        background: #f8fafc;
    }

        .filter-input:focus {
            border-color: #3b82f6;
            background: white;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

    /* Pagination Buttons */
    .page-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: #1e40af;
            color: white;
            border-color: #1e40af;
            box-shadow: 0 4px 6px -1px rgba(30, 64, 175, 0.2);
        }

        .page-btn:hover:not(.active) {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }
</style>

<div style="background: #f1f5f9; min-height: 100vh; padding: 25px; font-family: 'Plus Jakarta Sans', sans-serif; color: #1e293b;">
    <div style="max-width: 1600px; margin: 0 auto;">

        @* --- TOP HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; gap: 15px; flex-wrap: wrap;">
            <div>
                <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 26px; display: flex; align-items: center; gap: 12px;">
                    <span style="background: linear-gradient(135deg, #1e40af, #3b82f6); color: white; width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(30, 64, 175, 0.2);">
                        <i class="fa fa-ship"></i>
                    </span>
                    XUẤT BÁO CÁO SHD (ĐÃ HOÀN TẤT)
                </h2>
                <p style="margin: 5px 0 0 57px; color: #64748b; font-weight: 600; font-size: 13px;">Dữ liệu lưu trữ hồ sơ Xuất Nhập Khẩu đã phê duyệt</p>
            </div>

            <div style="display: flex; gap: 12px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 8px 15px; border-radius: 14px; border: 2px solid #e2e8f0;">
                    <span style="font-size: 12px; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Dòng:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #1e40af; cursor: pointer; background: transparent; font-size: 14px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 14px;"></i>
                    <input type="text" id="quickSearch" onkeyup="handleFilterAndPaginate()" placeholder="Tìm tên, bộ phận, mã đơn..."
                           style="padding: 11px 15px 11px 45px; border-radius: 14px; border: 2px solid #e2e8f0; font-size: 14px; width: 320px; outline: none; font-weight: 700; transition: 0.3s;"
                           onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#e2e8f0'">
                </div>
                
                <div style="font-size: 11px; background: linear-gradient(135deg, #0891b2, #06b6d4); padding: 9px 16px; border-radius: 10px; font-weight: 900; color: #ffffff; text-transform: uppercase; box-shadow: 0 4px 10px rgba(8, 145, 178, 0.2);">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- EXCEL EXPORT FORM --- *@
        <div style="background: white; padding: 25px; border-radius: 24px; border: 1px solid #e2e8f0; margin-bottom: 25px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
            <form action="/FormSHD/ExportExcelSHD" method="get" style="display: flex; gap: 20px; align-items: flex-end; flex-wrap: wrap;">
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label style="font-size: 11px; font-weight: 900; color: #475569; letter-spacing: 0.5px;">TỪ NGÀY (HOÀN TẤT)</label>
                    <input type="date" name="tuNgay" class="filter-input">
                </div>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label style="font-size: 11px; font-weight: 900; color: #475569; letter-spacing: 0.5px;">ĐẾN NGÀY</label>
                    <input type="date" name="denNgay" class="filter-input">
                </div>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label style="font-size: 11px; font-weight: 900; color: #475569; letter-spacing: 0.5px;">LOẠI ĐƠN SHD</label>
                    <select name="loaiDon" class="filter-input" style="min-width: 250px;">
                        <option value="">-- Tất cả loại đơn --</option>
                        <option value="SHD_XeCongTac_1">Xe công tác SHD (1)</option>
                        <option value="SHD_XeDaily_2">Xe Daily SHD (2)</option>
                    </select>
                </div>
                <button type="submit" style="background: linear-gradient(135deg, #10b981, #059669); color: white; border: none; padding: 12px 28px; border-radius: 14px; font-weight: 1000; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: 0.3s; box-shadow: 0 6px 15px rgba(16, 185, 129, 0.2);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa fa-file-excel-o"></i> XUẤT EXCEL CHI TIẾT
                </button>
            </form>
        </div>

        @* --- STATS GRID --- *@
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px;">
            <div class="stat-card" style="background: white; padding: 22px; border-radius: 20px; border: 1px solid #e2e8f0; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #64748b; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">TỔNG LƯU TRỮ SHD</div>
                <div id="stat-total" style="font-size: 32px; font-weight: 1000; color: #1e293b;">0</div>
            </div>
            <div class="stat-card" style="background: #ecfeff; padding: 22px; border-radius: 20px; border: 1px solid #cffafe; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #0891b2; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">NGƯỜI XỬ LÝ SHD</div>
                <div id="stat-shd" style="font-size: 32px; font-weight: 1000; color: #0891b2;">0</div>
            </div>
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 24px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Nhân viên</th>
                        <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Thông tin đơn</th>
                        <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Người Hỗ Trợ</th>
                        <th style="padding: 20px; text-align: left; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; width: 220px;">Thông tin hoàn tất</th>
                        <th style="padding: 20px; text-align: center; color: #475569; font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Trạng thái</th>
                        <th style="padding: 20px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr>
                        <td colspan="6" style="padding: 80px; text-align: center; color: #94a3b8;">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 15px;">
                                <i class="fa fa-circle-notch fa-spin" style="font-size: 40px; color: #3b82f6;"></i>
                                <p style="font-weight: 700; font-size: 15px;">Đang truy xuất dữ liệu từ kho SHD...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @* --- PAGINATION --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 25px 0; margin-top: 5px;">
            <div id="paginationButtons" style="display: flex; gap: 10px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 13px; font-weight: 800;">
                    Trang <span id="currentPageNum" style="color: #1e40af; font-weight: 1000;">1</span> / <span id="totalPagesNum" style="font-weight: 1000;">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 6px;">
                    Tổng cộng: <span id="totalVisibleCount" style="color: #1e293b;">0</span> bản ghi
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];
        let filteredData = [];
        let currentPage = 1;
        let rowsPerPage = 20;

        document.addEventListener("DOMContentLoaded", async () => {
            await loadInitialData();
        });

        async function loadInitialData() {
            try {
                const response = await fetch('/FormSHD/GetXuatBaoCaoData');
                if (!response.ok) throw new Error("Network response error");
                
                masterData = await response.json();
                
                // Update Stats
                document.getElementById("stat-total").innerText = masterData.length;
                document.getElementById("stat-shd").innerText = masterData.length;
                
                handleFilterAndPaginate();
            } catch (error) {
                console.error("Lỗi:", error);
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 80px; text-align: center;"><div style="color: #ef4444; font-weight: 800;"><i class="fa fa-exclamation-triangle" style="font-size: 32px; margin-bottom: 15px;"></i><br>Không thể tải dữ liệu báo cáo SHD. Vui lòng thử lại.</div></td></tr>`;
            }
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            currentPage = 1;
            handleFilterAndPaginate();
        }

        function handleFilterAndPaginate() {
            const searchText = document.getElementById("quickSearch").value.toUpperCase().trim();

            filteredData = masterData.filter(item => {
                const supportText = (item.supportNames || []).join(" ");
                const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${supportText} ${item.tenAdmin}`.toUpperCase();
                return searchText === "" || rowString.includes(searchText);
            });

            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const pageData = filteredData.slice(startIndex, startIndex + rowsPerPage);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 100px; text-align: center; color: #94a3b8;"><i class="fa fa-folder-open-o" style="font-size: 50px; opacity: 0.2; margin-bottom: 15px;"></i><p style="font-weight: 700;">Không tìm thấy dữ liệu báo cáo nào.</p></td></tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>ID: #${item.id} • <i class="fa fa-calendar"></i> ${item.timeNguoiTao}</span>`;
                if (item.hasB2) badgesHtml += `<span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff; margin-left:6px;">B2 OK</span>`;
                if (item.hasGD) badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:6px;">GĐ OK</span>`;

                let supportHtml = "";
                if (item.supportNames && item.supportNames.length > 0) {
                    item.supportNames.forEach(name => {
                        supportHtml += `
                            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                                <div class="support-avatar"><i class="fa fa-user-circle-o"></i></div>
                                <span style="font-weight: 700; color: #334155; font-size: 13px;">${name}</span>
                            </div>`;
                    });
                } else {
                    supportHtml = `<span style="color: #cbd5e1; font-size: 12px; font-style: italic;">Chưa có</span>`;
                }

                html += `
                    <tr style="border-bottom: 1px solid #f1f5f9; transition: 0.3s;" onmouseover="this.style.background='#f0f9ff'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 18px 20px;">
                            <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                            <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #1e40af;">MS: ${item.soNhanVien}</span></div>
                        </td>
                        <td style="padding: 18px 20px;">
                            <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                            <div style="font-size: 11px; color: #94a3b8; font-weight: 700; display: flex; gap: 5px; flex-wrap: wrap; align-items: center; margin-top:5px;">
                                ${badgesHtml}
                            </div>
                        </td>
                        <td style="padding: 18px 20px;">
                            <div style="display: flex; flex-direction: column;">${supportHtml}</div>
                        </td>
                        <td style="padding: 18px 20px;">
                            <div style="font-size: 11px; font-weight: 900; color: #0891b2; display: flex; align-items: center; gap: 6px;">
                                <i class="fa fa-check-circle"></i> Duyệt: ${item.tenAdmin}
                            </div>
                            <div style="font-size: 10px; color: #64748b; font-weight: 700; margin-top: 5px; padding-left: 17px;">
                                <i class="fa fa-clock-o"></i> ${item.timeAdmin}
                            </div>
                        </td>
                        <td style="padding: 18px 20px; text-align: center;">
                            <span style="background:#f0fdf4; color:#15803d; padding:6px 14px; border-radius:10px; font-size:10px; font-weight:1000; border: 1.5px solid #15803d; display: inline-block; min-width: 100px; text-transform: uppercase; letter-spacing: 0.5px;">
                                ${item.trangThai}
                            </span>
                        </td>
                        <td style="padding: 18px 20px; text-align: right;">
                            <a href="/FormSHD/ChiTiet/${item.id}"
                               style="text-decoration: none; padding: 10px 20px; border-radius: 12px; font-size: 11px; font-weight: 1000; display: inline-flex; align-items: center; gap: 8px; transition: 0.3s; background: linear-gradient(135deg, #1e40af, #3b82f6); color: #ffffff; box-shadow: 0 4px 10px rgba(30, 64, 175, 0.15);"
                               onmouseover="this.style.opacity='0.9'; this.style.transform='translateX(3px)'" onmouseout="this.style.opacity='1'; this.style.transform='translateX(0)'">
                                XEM CHI TIẾT <i class="fa fa-chevron-right" style="font-size: 9px;"></i>
                            </a>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = "";
            if (totalPages <= 1) return;

            const maxVisible = 5;
            let start = Math.max(1, currentPage - 2);
            let end = Math.min(totalPages, start + maxVisible - 1);
            if (end - start < maxVisible - 1) start = Math.max(1, end - maxVisible + 1);

            for (let i = start; i <= end; i++) {
                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    handleFilterAndPaginate();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}