@model IEnumerable<E_Form_Best.Models.ITForm.FormShd>

@{
    ViewData["Title"] = "Trung Tâm Phân Tích SHD";
    Layout = "~/Areas/SHDForm/Views/Shared/_Layout.cshtml";

    // Toolkit màu sắc SHD Luxury 2026
    string primaryIndigo = "#312e81";
    string accentCyan = "#22d3ee";
}

<style>
    body {
        font-family: 'Inter', 'Segoe UI', sans-serif;
        background-color: #f1f5f9;
        color: #1e293b;
    }

    /* Layout Thẻ Thống Kê - Cố định 7 cột trên 1 hàng */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 12px;
        margin-bottom: 25px;
    }

    .stat-card {
        background: white;
        padding: 18px 10px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        transition: 0.3s;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-width: 0;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(49, 46, 129, 0.1);
            border-color: @accentCyan;
        }

    .card-title {
        font-size: 10px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .card-value {
        font-size: 24px;
        font-weight: 1000;
        display: block;
        line-height: 1;
    }

    /* Container Biểu Đồ */
    .chart-container {
        background: white;
        padding: 22px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        margin-bottom: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        display: flex;
        flex-direction: column;
    }

    .chart-header {
        font-weight: 900;
        color: #1e293b;
        margin-bottom: 20px;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Table Styles */
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .custom-table th {
            background-color: #f8fafc;
            color: #475569;
            text-align: left;
            padding: 14px;
            border-bottom: 2px solid #e2e8f0;
            font-weight: 900;
            text-transform: uppercase;
            font-size: 11px;
        }

        .custom-table td {
            padding: 12px 14px;
            border-bottom: 1px solid #f1f5f9;
            color: #1e293b;
            font-weight: 600;
        }

    .badge-count {
        background: #ecfeff;
        color: #0891b2;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 800;
        border: 1px solid #a5f3fc;
    }

    .badge-time {
        color: #0891b2;
        font-weight: 800;
        font-size: 13px;
    }

    .table-responsive {
        overflow-x: auto;
        border-radius: 15px;
    }

    /* --- BỘ LỌC NÂNG CAO ĐỒNG BỘ HOÀN TOÀN VỚI HR --- */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
    }

        .filter-input:focus {
            border-color: @primaryIndigo;
            box-shadow: 0 0 0 2px rgba(49, 46, 129, 0.1);
        }

    .btn-action {
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-apply {
        background: @primaryIndigo;
        color: white;
    }

        .btn-apply:hover {
            background: #1e3a8a;
        }

    .btn-clear {
        background: #f1f5f9;
        color: #475569;
    }

        .btn-clear:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* ==========================================
           CSS RESPONSIVE CHO MOBILE (DƯỚI 768PX)
           ========================================== */
    @@media (max-width: 768px) {
        .mobile-header {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 15px;
        }

            .mobile-header h2 {
                font-size: 20px !important;
            }

            .mobile-header p {
                margin-left: 0 !important;
                font-size: 12px !important;
            }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }

        .stats-row {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }

        .stat-card {
            padding: 15px 5px !important;
        }

        .card-value {
            font-size: 18px !important;
        }

        .chart-grid-split {
            grid-template-columns: 1fr !important;
            gap: 15px !important;
        }

        .main-container {
            padding: 15px !important;
        }

        .chart-container {
            padding: 15px !important;
        }

        .chart-header {
            font-size: 13px !important;
        }

        canvas {
            max-height: 300px !important;
        }
        /* Biến bảng thành dạng thẻ */
        .custom-table thead {
            display: none;
        }

        .custom-table, .custom-table tbody, .custom-table tr, .custom-table td {
            display: block;
            width: 100%;
        }

            .custom-table tr {
                margin-bottom: 15px;
                border: 1px solid #e2e8f0;
                border-radius: 12px;
                overflow: hidden;
                background: white;
            }

            .custom-table td {
                text-align: right !important;
                padding: 10px 15px !important;
                border-bottom: 1px dashed #f1f5f9;
                position: relative;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                .custom-table td::before {
                    content: attr(data-label);
                    float: left;
                    font-weight: 800;
                    color: #64748b;
                    text-transform: uppercase;
                    font-size: 10px;
                }

                .custom-table td:last-child {
                    border-bottom: none;
                    background: #f8fafc;
                }
    }
</style>

<div class="main-container" style="max-width: 1650px; margin: 0 auto; padding: 25px;">

    @* --- HEADER --- *@
    <div class="mobile-header" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h2 style="font-weight: 1000; color: @primaryIndigo; margin: 0; font-size: 26px; display: flex; align-items: center; gap: 12px;">
                <i class="fa fa-line-chart" style="background: @primaryIndigo; color: white; padding: 10px; border-radius: 12px; box-shadow: 0 4px 10px rgba(49,46,129,0.3);"></i>
                HỆ THỐNG PHÂN TÍCH DỮ LIỆU SHD
            </h2>
            <p style="margin: 5px 0 0 65px; color: #64748b; font-weight: 600;">Báo cáo trực quan tình trạng hồ sơ & năng suất bộ phận Xuất Nhập Khẩu</p>
        </div>
    </div>

    @* --- BỘ LỌC NÂNG CAO ĐỒNG BỘ HOÀN TOÀN TỪ BẢN HR --- *@
    <div class="advanced-filter">
        <div class="filter-group">
            <label>Từ ngày</label>
            <input type="date" id="txtFromDate" class="filter-input" />
        </div>
        <div class="filter-group">
            <label>Đến ngày</label>
            <input type="date" id="txtToDate" class="filter-input" />
        </div>
        <div class="filter-group">
            <label>Bộ phận</label>
            <select id="selBoPhan" class="filter-input" onchange="applyFilters()">
                <option value="">-- Tất cả --</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Người hỗ trợ</label>
            <select id="selStaff" class="filter-input" onchange="applyFilters()">
                <option value="">-- Tất cả --</option>
            </select>
        </div>
        <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
            <button class="btn-action btn-apply" onclick="initStats()">
                <i class="fa fa-filter"></i> Truy xuất
            </button>
            <button class="btn-action btn-clear" onclick="clearAllFilters()">
                <i class="fa fa-refresh"></i> Xóa lọc
            </button>
        </div>
    </div>

    @* --- 7 THẺ THỐNG KÊ CHI TIẾT --- *@
    <div class="stats-row">
        <div class="stat-card" style="border-top: 5px solid #1e293b;"><span class="card-title">Tổng đơn nhận</span><span class="card-value" id="lblTotal">0</span></div>
        <div class="stat-card" style="border-top: 5px solid #f59e0b;"><span class="card-title">Chờ QL Duyệt</span><span class="card-value" id="lblWaitQL" style="color: #b45309;">0</span></div>
        <div class="stat-card" style="border-top: 5px solid #0ea5e9;"><span class="card-title">BP Xác nhận</span><span class="card-value" id="lblB2" style="color: #0369a1;">0</span></div>
        <div class="stat-card" style="border-top: 5px solid #d946ef;"><span class="card-title">Giám đốc</span><span class="card-value" id="lblGD" style="color: #86198f;">0</span></div>
        <div class="stat-card" style="border-top: 5px solid @accentCyan;"><span class="card-title">SHD Đang xử lý</span><span class="card-value" id="lblWaitAdmin" style="color: @accentCyan;">0</span></div>
        <div class="stat-card" style="border-top: 5px solid #10b981;"><span class="card-title">Đã hoàn tất</span><span class="card-value" id="lblDone" style="color: #047857;">0</span></div>
        <div class="stat-card" style="border-top: 5px solid #ef4444;"><span class="card-title">Đơn đã hủy</span><span class="card-value" id="lblCancel" style="color: #b91c1c;">0</span></div>
    </div>

    @* --- HÀNG BIỂU ĐỒ 1 --- *@
    <div class="chart-grid-split" style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-bottom: 20px;">
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-pie-chart" style="color: @accentCyan;"></i> Phân bổ trạng thái SHD</div>
            <div style="height: 320px;"><canvas id="chartStatus"></canvas></div>
        </div>
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-truck" style="color: #1e40af;"></i> Lưu lượng đơn theo Bộ phận sử dụng</div>
            <div style="height: 320px;"><canvas id="chartDept"></canvas></div>
        </div>
    </div>

    @* --- HÀNG BIỂU ĐỒ 2: HIỆU SUẤT NHÂN VIÊN --- *@
    <div class="chart-container">
        <div class="chart-header">
            <i class="fa fa-users" style="color: @accentCyan;"></i> Hiệu suất xử lý của Nhân sự Admin SHD (Đã xong vs Đang xử lý)
            <span style="font-size: 11px; font-weight: normal; color: #64748b; margin-left: 8px;">(Bấm vào cột để lọc toàn bộ báo cáo)</span>
        </div>
        <div style="height: 350px;"><canvas id="chartStaff"></canvas></div>
    </div>

    @* --- HÀNG BIỂU ĐỒ 3: DANH MỤC & LOẠI ĐƠN --- *@
    <div class="chart-grid-split" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-th-large" style="color: #f59e0b;"></i> Thống kê theo Danh mục</div>
            <div style="height: 320px;"><canvas id="chartCategory"></canvas></div>
        </div>
        <div class="chart-container">
            <div class="chart-header"><i class="fa fa-list-ul" style="color: #ef4444;"></i> Top loại đơn yêu cầu SHD</div>
            <div style="height: 320px;"><canvas id="chartIdForm"></canvas></div>
        </div>
    </div>

    @* --- BẢNG CHI TIẾT --- *@
    <div class="chart-container" style="margin-bottom: 50px;">
        <div class="chart-header"><i class="fa fa-clock-o" style="color: #475569;"></i> Chỉ số thời gian xử lý trung bình theo nghiệp vụ SHD</div>
        <div class="table-responsive">
            <table class="custom-table" id="dataTable">
                <thead>
                    <tr>
                        <th>Nhân Viên Phụ Trách</th>
                        <th>Danh Mục Nghiệp Vụ</th>
                        <th style="text-align: center;">Số Đơn Xử Lý</th>
                        <th style="text-align: center;">Thời Gian Hoàn Tất TB</th>
                    </tr>
                </thead>
                <tbody id="tblStaffBody"></tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
    Chart.register(ChartDataLabels);

    const statusColors = {
    'ĐÃ HỦY/TỪ CHỐI': '#ef4444',
    'CHỜ QL DUYỆT': '#f59e0b',
    'CHỜ BP XÁC NHẬN': '#0ea5e9',
    'CHỜ GIÁM ĐỐC': '#d946ef',
    'SHD ĐANG XỬ LÝ': '#0891b2',
    'HOÀN TẤT': '#10b981'
    };

    let cachedDataChung = [];
    let cachedDataStaff = [];

    let chartStatusInstance = null;
    let chartDeptInstance = null;
    let chartStaffInstance = null;
    let chartCategoryInstance = null;
    let chartIdFormInstance = null;

    document.addEventListener('DOMContentLoaded', () => {
    // Phục hồi filter từ Session Storage đồng bộ hoàn toàn với bản HR
    const savedFrom = sessionStorage.getItem("savedShdStatFromDate");
    if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

    const savedTo = sessionStorage.getItem("savedToDateShdStat");
    if (savedTo) document.getElementById("txtToDate").value = savedTo;

    initStats();
    });

    function mapStatus(backendStatus) {
    if (!backendStatus) return "SHD ĐANG XỬ LÝ";
    if (backendStatus.includes("HỦY") || backendStatus.includes("TỪ CHỐI")) return "ĐÃ HỦY/TỪ CHỐI";
    if (backendStatus.includes("HOÀN TẤT")) return "HOÀN TẤT";
    if (backendStatus.includes("CHỜ QL")) return "CHỜ QL DUYỆT";
    if (backendStatus.includes("BP XÁC NHẬN")) return "CHỜ BP XÁC NHẬN";
    if (backendStatus.includes("GIÁM ĐỐC")) return "CHỜ GIÁM ĐỐC";
    return "SHD ĐANG XỬ LÝ";
    }

    const commonLabelOptions = {
    color: '#fff',
    font: { weight: 'bold', family: 'Inter', size: 11 },
    formatter: (value) => value > 0 ? value : '',
    anchor: 'center',
    align: 'center'
    };

    function formatDuration(min) {
    if (!min || min <= 0) return "-";
    const d = Math.floor(min / 1440);
    const h = Math.floor((min % 1440) / 60);
    const m = Math.round(min % 60);
    if (d > 0) return `${d}n ${h}h`;
    if (h > 0) return `${h}h ${m}m`;
    return `${m}ph`;
    }

    async function initStats() {
    const fromDate = document.getElementById("txtFromDate").value;
    const toDate = document.getElementById("txtToDate").value;

    // Ghi lại thời gian vào Session Storage
    sessionStorage.setItem("savedShdStatFromDate", fromDate);
    sessionStorage.setItem("savedShdStatToDate", toDate);

    const urlParams = `?fromDate=${fromDate}&toDate=${toDate}`;

    try {
    const [resChung, resStaff] = await Promise.all([
    fetch('/FormSHD/GetDataThongKe' + urlParams),
    fetch('/FormSHD/GetDataNguoiHoTro' + urlParams)
    ]);

    const dataChungRaw = await resChung.json();
    const dataStaffRaw = await resStaff.json();

    cachedDataChung = dataChungRaw.map(x => ({...x, trangThaiDon: mapStatus(x.trangThaiDon)}));
    cachedDataStaff = dataStaffRaw.map(x => ({...x, trangThai: mapStatus(x.trangThai)}));

    populateDropdowns();

    // Phục hồi Combobox sau khi đổ dữ liệu
    const savedBoPhan = sessionStorage.getItem("savedShdStatBoPhan");
    if (savedBoPhan) document.getElementById("selBoPhan").value = savedBoPhan;

    const savedStaff = sessionStorage.getItem("savedShdStatStaff");
    if (savedStaff) document.getElementById("selStaff").value = savedStaff;

    applyFilters();
    } catch (e) {
    console.error("Lỗi tải báo cáo SHD:", e);
    }
    }

    function populateDropdowns() {
    const selBoPhan = document.getElementById("selBoPhan");
    const selStaff = document.getElementById("selStaff");

    const depts = [...new Set(cachedDataChung.map(x => x.boPhan).filter(Boolean))].sort();
    selBoPhan.innerHTML = '<option value="">-- Tất cả --</option>';
    depts.forEach(d => {
    selBoPhan.innerHTML += `<option value="${d}">${d}</option>`;
    });

    const staffSet = [...new Set(cachedDataStaff.map(x => x.tenNguoiHoTro).filter(n => n && n !== "Chưa xác định"))].sort();
    selStaff.innerHTML = '<option value="">-- Tất cả --</option>';
    staffSet.forEach(s => {
    selStaff.innerHTML += `<option value="${s}">${s}</option>';
    });
    }

    function clearAllFilters() {
    document.getElementById("txtFromDate").value = "";
    document.getElementById("txtToDate").value = "";
    document.getElementById("selBoPhan").value = "";
    document.getElementById("selStaff").value = "";

    sessionStorage.removeItem("savedShdStatFromDate");
    sessionStorage.removeItem("savedShdStatToDate");
    sessionStorage.removeItem("savedShdStatBoPhan");
    sessionStorage.removeItem("savedShdStatStaff");

    initStats();
    }

    function applyFilters() {
    const boPhanFilter = document.getElementById("selBoPhan").value;
    const staffFilter = document.getElementById("selStaff").value;

    sessionStorage.setItem("savedShdStatBoPhan", boPhanFilter);
    sessionStorage.setItem("savedShdStatStaff", staffFilter);

    let displayChung = cachedDataChung;
    let displayStaff = cachedDataStaff;

    if (boPhanFilter) {
    displayChung = displayChung.filter(x => x.boPhan === boPhanFilter);
    displayStaff = displayStaff.filter(x => x.boPhan === boPhanFilter);
    }

    if (staffFilter) {
    displayChung = displayChung.filter(x => x.tenNguoiHoTro === staffFilter);
    displayStaff = displayStaff.filter(x => x.tenNguoiHoTro === staffFilter);
    }

    const s = { "ĐÃ HỦY/TỪ CHỐI": 0, "CHỜ QL DUYỆT": 0, "CHỜ BP XÁC NHẬN": 0, "CHỜ GIÁM ĐỐC": 0, "SHD ĐANG XỬ LÝ": 0, "HOÀN TẤT": 0 };
    displayChung.forEach(item => {
    if(s[item.trangThaiDon] !== undefined) s[item.trangThaiDon]++;
    });

    updateCounters(displayChung.length, s);
    drawStatusChart(s);
    drawDeptChart(displayChung);
    drawCategoryChart(displayChung);
    drawIdFormChart(displayChung);
    drawStaffChart(displayStaff);
    renderTable(displayStaff);
    }

    function updateCounters(total, s) {
    document.getElementById('lblTotal').innerText = total;
    document.getElementById('lblWaitQL').innerText = s["CHỜ QL DUYỆT"];
    document.getElementById('lblB2').innerText = s["CHỜ BP XÁC NHẬN"];
    document.getElementById('lblGD').innerText = s["CHỜ GIÁM ĐỐC"];
    document.getElementById('lblWaitAdmin').innerText = s["SHD ĐANG XỬ LÝ"];
    document.getElementById('lblDone').innerText = s["HOÀN TẤT"];
    document.getElementById('lblCancel').innerText = s["ĐÃ HỦY/TỪ CHỐI"];
    }

    function drawStatusChart(s) {
    if (chartStatusInstance) chartStatusInstance.destroy();
    chartStatusInstance = new Chart(document.getElementById('chartStatus'), {
    type: 'doughnut',
    data: {
    labels: Object.keys(s),
    datasets: [{
    data: Object.values(s),
    backgroundColor: Object.keys(s).map(key => statusColors[key]),
    borderWidth: 0
    }]
    },
    options: {
    maintainAspectRatio: false,
    cutout: '65%',
    plugins: {
    legend: { position: 'bottom', labels: { usePointStyle: true, font: { weight: 700, size: 10 } } },
    datalabels: commonLabelOptions
    }
    }
    });
    }

    function drawDeptChart(data) {
    if (chartDeptInstance) chartDeptInstance.destroy();
    const group = groupData(data, 'boPhan');
    chartDeptInstance = new Chart(document.getElementById('chartDept'), {
    type: 'bar',
    data: {
    labels: Object.keys(group),
    datasets: [{ label: 'Số đơn', data: Object.values(group), backgroundColor: '#1e40af', borderRadius: 8 }]
    },
    options: {
    maintainAspectRatio: false,
    plugins: { datalabels: { ...commonLabelOptions, anchor: 'end', align: 'top', color: '#1e293b' } },
    scales: { y: { beginAtZero: true, grid: { display: false } } }
    }
    });
    }

    function drawStaffChart(dataStaff) {
    if (chartStaffInstance) chartStaffInstance.destroy();

    const staffs = [...new Set(dataStaff.map(item => item.tenNguoiHoTro))];
    const statusList = ["HOÀN TẤT", "SHD ĐANG XỬ LÝ"];

    const datasets = statusList.map(status => ({
    label: status,
    data: staffs.map(name => dataStaff.filter(x => x.tenNguoiHoTro === name && x.trangThai === status).length),
    backgroundColor: statusColors[status],
    borderRadius: 5
    }));

    chartStaffInstance = new Chart(document.getElementById('chartStaff'), {
    type: 'bar',
    data: { labels: staffs, datasets: datasets },
    options: {
    maintainAspectRatio: false,
    onHover: (event, chartElement) => {
    event.native.target.style.cursor = chartElement.length ? 'pointer' : 'default';
    },
    onClick: (event, elements, chart) => {
    if (elements && elements.length > 0) {
    const firstElement = elements[0];
    const clickedStaffName = chart.data.labels[firstElement.index];

    document.getElementById('selStaff').value = clickedStaffName;
    applyFilters();
    }
    },
    plugins: { legend: { position: 'top', labels: { font: { size: 10 } } }, datalabels: commonLabelOptions },
    scales: { x: { stacked: true }, y: { stacked: true } }
    }
    });
    }

    function drawCategoryChart(data) {
    if (chartCategoryInstance) chartCategoryInstance.destroy();
    const group = groupData(data, 'danhmuc');
    chartCategoryInstance = new Chart(document.getElementById('chartCategory'), {
    type: 'polarArea',
    data: {
    labels: Object.keys(group),
    datasets: [{
    data: Object.values(group),
    backgroundColor: ['#0891b2', '#06b6d4', '#22d3ee', '#1e40af', '#3b82f6', '#60a5fa']
    }]
    },
    options: {
    maintainAspectRatio: false,
    plugins: { legend: { position: 'right', labels: { font: { size: 9 } } } }
    }
    });
    }

    function drawIdFormChart(data) {
    if (chartIdFormInstance) chartIdFormInstance.destroy();
    const group = groupData(data, 'tenLoaiDon');
    const sortedLabels = Object.keys(group).sort((a,b) => group[b] - group[a]).slice(0, 8);

    chartIdFormInstance = new Chart(document.getElementById('chartIdForm'), {
    type: 'bar',
    data: {
    labels: sortedLabels,
    datasets: [{ label: 'Số lượng', data: sortedLabels.map(l => group[l]), backgroundColor: '#3b82f6', borderRadius: 5 }]
    },
    options: {
    indexAxis: 'y',
    maintainAspectRatio: false,
    plugins: { datalabels: { ...commonLabelOptions, anchor: 'end', align: 'right', color: '#1e293b' } }
    }
    });
    }

    function renderTable(data) {
    const summary = data.reduce((acc, curr) => {
    const key = `${curr.tenNguoiHoTro}|${curr.danhMuc}`;
    if (!acc[key]) {
    acc[key] = { name: curr.tenNguoiHoTro, cat: curr.danhMuc, count: 0, totalMin: 0, tCount: 0 };
    }
    acc[key].count++;
    if (curr.phutXuLy) {
    acc[key].totalMin += curr.phutXuLy;
    acc[key].tCount++;
    }
    return acc;
    }, {});

    const tbody = document.getElementById('tblStaffBody');
    if (Object.keys(summary).length === 0) {
    tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding: 20px; color:#94a3b8;">Không có dữ liệu báo cáo SHD.</td></tr>`;
    return;
    }

    tbody.innerHTML = Object.values(summary)
    .sort((a, b) => b.count - a.count)
    .map(item => `
    <tr>
    <td data-label="Nhân Viên Phụ Trách"><i class="fa fa-user-circle" style="color:#cbd5e1"></i> ${item.name}</td>
    <td data-label="Danh Mục Nghiệp Vụ" style="color: #64748b;">${item.cat}</td>
    <td data-label="Số Đơn Xử Lý" style="text-align: center;"><span class="badge-count">${item.count}</span></td>
    <td data-label="Thời Gian Hoàn Tất TB" style="text-align: center;" class="badge-time">
    ${item.tCount > 0 ? formatDuration(item.totalMin / item.tCount) : '-'}
    </td>
    </tr>
    `).join('');
    }

    function groupData(data, key) {
    return data.reduce((acc, x) => {
    let val = x[key] || "N/A";
    acc[val] = (acc[val] || 0) + 1;
    return acc;
    }, {});
    }
</script>