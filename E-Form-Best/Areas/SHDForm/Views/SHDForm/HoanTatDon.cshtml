@using System.Security.Claims
@model IEnumerable<E_Form_Best.Models.ITForm.FormHr>

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn SHD";
    Layout = "~/Areas/SHDForm/Views/Shared/_Layout.cshtml";

    // Đồng bộ mã màu Luxury SHD 2026
    string indigoPrimary = "#312e81";
    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    /* --- FONTS & BASE --- */
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    .sub-badge {
        font-size: 9px;
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: 1.5px solid;
        margin-top: 3px;
    }

    .support-avatar {
        width: 28px;
        height: 28px;
        background: #ecfeff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0891b2;
        border: 1px solid #cffafe;
    }

    .stat-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid rgba(0,0,0,0.03);
        background: white;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(49, 46, 129, 0.1) !important;
        }

    /* Modal Styles */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.5);
        z-index: 9998;
        backdrop-filter: blur(8px);
        transition: 0.3s;
    }

    .type-filter-modal {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        width: 480px;
        max-width: 95%;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);
        z-index: 9999;
        padding: 30px;
        overflow: hidden;
    }

    .type-checkbox-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-top: 20px;
        margin-bottom: 25px;
        max-height: 400px;
        overflow-y: auto;
        padding-right: 8px;
    }

    .type-item-label {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        cursor: pointer;
        transition: 0.2s;
        font-size: 14px;
        font-weight: 700;
        color: #334155;
    }

        .type-item-label:hover {
            background: #f1f5f9;
            border-color: @indigoPrimary;
            color: @indigoPrimary;
        }

    .type-checkbox {
        width: 20px;
        height: 20px;
        accent-color: @indigoPrimary;
        cursor: pointer;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }

    /* Phân trang */
    .page-btn {
        padding: 10px 18px;
        border-radius: 12px;
        border: 1.5px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 800;
        font-size: 13px;
        cursor: pointer;
        transition: 0.3s;
    }

        .page-btn.active {
            background: @indigoPrimary;
            color: white;
            border-color: @indigoPrimary;
            box-shadow: 0 10px 15px -3px rgba(49, 46, 129, 0.3);
        }

    /* Bộ lọc nâng cao */
    .advanced-filter {
        background: white;
        padding: 15px 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }

    .filter-input {
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        outline: none;
        transition: 0.3s;
        min-width: 140px;
        height: 38px;
    }

        .filter-input:focus {
            border-color: @indigoPrimary;
            box-shadow: 0 0 0 2px rgba(49, 46, 129, 0.1);
        }

    .btn-clear-filter {
        background: #f1f5f9;
        color: #475569;
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 6px;
        height: 38px;
    }

        .btn-clear-filter:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

    /* ========================================================
            CSS MỚI: HỆ THỐNG DROPDOWN CHECKBOX (MULTI-SELECT LUXURY)
            ======================================================== */
    .dropdown-combo-btn {
        text-align: left;
        background-color: #fff;
        border: 1px solid #cbd5e1;
        padding: 8px 28px 8px 12px;
        font-size: 13px;
        font-weight: 600;
        border-radius: 8px;
        color: #1e293b;
        position: relative;
        min-width: 160px;
        height: 38px;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

        .dropdown-combo-btn:after {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
        }

        .dropdown-combo-btn:focus {
            border-color: @indigoPrimary;
            box-shadow: 0 0 0 2px rgba(49, 46, 129, 0.1);
            outline: 0;
        }

    .dropdown-combo-menu {
        min-width: 220px;
        max-height: 280px;
        overflow-y: auto;
        padding: 8px 0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        z-index: 1050;
    }

    .dropdown-combo-item {
        display: flex;
        align-items: center;
        padding: 6px 16px;
        cursor: pointer;
        user-select: none;
        font-size: 13px;
        color: #334155;
        transition: background-color 0.15s ease;
    }

        .dropdown-combo-item:hover {
            background-color: #f1f5f9;
        }

        .dropdown-combo-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: @@indigoPrimary;
            flex-shrink: 0;
        }

        .dropdown-combo-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    #dataTable tbody td.shd-empty-cell {
        display: table-cell !important;
        width: auto !important;
        text-align: center !important;
        padding: 50px !important;
        color: #94a3b8 !important;
    }

    /* ========================================================
            CSS RESPONSIVE MOBILE (DẠNG CARD THẺ CHUẨN)
            ======================================================== */
    @@media (max-width: 768px) {
        .mobile-stack {
            flex-direction: column !important;
            align-items: stretch !important;
            gap: 15px !important;
        }

        .mobile-full-width {
            width: 100% !important;
        }

        .mobile-search-box {
            width: 100% !important;
        }

        .advanced-filter {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            width: 100%;
        }

        .dropdown-combo-btn {
            width: 100%;
        }

        .filter-input {
            width: 100%;
        }

        .stat-grid-mobile {
            grid-template-columns: repeat(2, 1fr) !important;
            gap: 10px !important;
        }

        .stat-card {
            padding: 15px !important;
        }

            .stat-card div[id^="stat-"] {
                font-size: 24px !important;
            }

        #dataTable thead {
            display: none;
        }

        #dataTable, #dataTable tbody, #dataTable tr, #dataTable td {
            display: block;
            width: 100%;
        }

            #dataTable tr {
                margin-bottom: 20px;
                border: 2px solid #e2e8f0 !important;
                border-radius: 20px;
                background: white;
                padding: 10px 0;
                border-left: 6px solid @indigoPrimary !important;
                box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            }

            #dataTable td {
                text-align: right !important;
                padding: 12px 15px !important;
                border-bottom: 1px dashed #f1f5f9;
                display: flex;
                justify-content: space-between;
                align-items: center;
                box-sizing: border-box;
                width: 100% !important;
            }

                #dataTable td:last-child {
                    border-bottom: none !important;
                    background: #f8fafc;
                    justify-content: center !important;
                    padding: 15px !important;
                }

                #dataTable td::before {
                    content: attr(data-label);
                    float: left;
                    font-weight: 800;
                    color: #94a3b8;
                    text-transform: uppercase;
                    font-size: 10px;
                    letter-spacing: 0.5px;
                }

        .mobile-val-wrap {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            text-align: right;
            max-width: 65%;
        }

        .type-checkbox-grid {
            grid-template-columns: 1fr !important;
        }

        .pagination-mobile {
            flex-direction: column !important;
            gap: 20px;
            text-align: center !important;
        }
    }
</style>

<div style="background: #f8fafc; min-height: 100vh; padding: 30px; font-family: 'Plus Jakarta Sans', sans-serif; color: #1e293b;">
    <div style="max-width: 1600px; margin: 0 auto;">

        @* --- TOP HEADER --- *@
        <div class="mobile-stack" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px;">
            <div>
                <h2 style="margin: 0; color: @indigoPrimary; font-weight: 1000; font-size: 28px; display: flex; align-items: center; gap: 15px; letter-spacing: -0.5px;">
                    <span style="background: linear-gradient(135deg, @indigoPrimary, #3b82f6); color: white; width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(49, 46, 129, 0.2);">
                        <i class="fa fa-archive"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN SHD
                </h2>
                <p style="margin: 5px 0 0 63px; color: #64748b; font-weight: 600; font-size: 14px;">Hệ thống truy xuất hồ sơ Xuất Nhập Khẩu</p>
            </div>

            <div class="mobile-stack" style="display: flex; gap: 15px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 18px; border-radius: 16px; border: 1.5px solid #e2e8f0;">
                    <span style="font-size: 12px; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Dòng:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: @indigoPrimary; cursor: pointer; background: transparent; font-size: 15px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div class="mobile-search-box" style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 15px;"></i>
                    <input type="text" id="searchInput" onkeyup="applyAllFilters()" placeholder="Tìm tên, mã thẻ, bộ phận..."
                           style="padding: 12px 20px 12px 48px; border-radius: 16px; border: 1.5px solid #e2e8f0; font-size: 14px; width: 300px; outline: none; font-weight: 700; transition: 0.3s; box-sizing: border-box;">
                </div>

                <button class="mobile-full-width" onclick="openTypeFilterModal()" style="padding: 12px 20px; background: white; border: 1.5px solid #e2e8f0; border-radius: 16px; color: #475569; font-weight: 800; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;">
                    <i class="fa fa-filter"></i> Phân loại đơn
                </button>

                <div class="mobile-full-width" style="font-size: 12px; background: linear-gradient(135deg, #0891b2, #06b6d4); padding: 10px 18px; border-radius: 12px; font-weight: 900; color: #ffffff; text-transform: uppercase; text-align: center;">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- BỘ LỌC NÂNG CAO DROPDOWN MULTI-CHECKBOX MỚI --- *@
        <div class="advanced-filter">
            <div class="filter-group">
                <label>Từ ngày</label>
                <input type="date" id="txtFromDate" class="filter-input" onchange="applyAllFilters()" />
            </div>
            <div class="filter-group">
                <label>Đến ngày</label>
                <input type="date" id="txtToDate" class="filter-input" onchange="applyAllFilters()" />
            </div>

            <div class="filter-group">
                <label>Bộ phận</label>
                <div class="dropdown">
                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropBoPhan" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        -- Tất cả --
                    </button>
                    <div class="dropdown-menu dropdown-combo-menu" id="menuBoPhan" aria-labelledby="btnDropBoPhan">
                    </div>
                </div>
            </div>

            <div class="filter-group">
                <label>Người hỗ trợ</label>
                <div class="dropdown">
                    <button class="dropdown-combo-btn dropdown-toggle text-truncate" type="button" id="btnDropStaff" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        -- Tất cả --
                    </button>
                    <div class="dropdown-menu dropdown-combo-menu" id="menuStaff" aria-labelledby="btnDropStaff">
                    </div>
                </div>
            </div>

            <div class="filter-group" style="flex-direction: row; align-items: flex-end; gap: 10px; margin-left: auto;">
                <button class="btn-clear-filter" onclick="clearAllFilters()">
                    <i class="fa fa-refresh"></i> Làm mới
                </button>
            </div>
        </div>

        @* --- STATS GRID --- *@
        <div class="stat-grid-mobile" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 35px;">
            @* Giảm padding từ 22px xuống 12px *@
            <div data-status="" onclick="filterByStatus('')" class="stat-card" style="background: white; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #64748b; text-transform: uppercase; margin-bottom: 4px;">TỔNG KHO</div>
                <div id="stat-total" style="font-size: 22px; font-weight: 1000; color: #1e293b;">0</div>
            </div>
            <div data-status="CHỜ QL" onclick="filterByStatus('CHỜ QL')" class="stat-card" style="background: #fffbeb; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #b45309; text-transform: uppercase; margin-bottom: 4px;">CHỜ QL</div>
                <div id="stat-ql" style="font-size: 22px; font-weight: 1000; color: #b45309;">0</div>
            </div>
            <div data-status="BƯỚC 2" onclick="filterByStatus('BƯỚC 2')" class="stat-card" style="background: #f5f3ff; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #6b21a8; text-transform: uppercase; margin-bottom: 4px;">BP XN</div>
                <div id="stat-b2" style="font-size: 22px; font-weight: 1000; color: #6b21a8;">0</div>
            </div>
            <div data-status="GIÁM ĐỐC" onclick="filterByStatus('GIÁM ĐỐC')" class="stat-card" style="background: #fdf4ff; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #86198f; text-transform: uppercase; margin-bottom: 4px;">GĐ</div>
                <div id="stat-gd" style="font-size: 22px; font-weight: 1000; color: #86198f;">0</div>
            </div>
            <div data-status="CHỜ SHD" onclick="filterByStatus('CHỜ SHD')" class="stat-card" style="background: #f0f9ff; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #0369a1; text-transform: uppercase; margin-bottom: 4px;">CHỜ SHD</div>
                <div id="stat-shd" style="font-size: 22px; font-weight: 1000; color: #0369a1;">0</div>
            </div>
            <div data-status="HOÀN TẤT" onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #f0fdf4; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #15803d; text-transform: uppercase; margin-bottom: 4px;">XONG</div>
                <div id="stat-hoanTat" style="font-size: 22px; font-weight: 1000; color: #15803d;">0</div>
            </div>
            <div data-status="ĐÃ HỦY" onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 12px; border-radius: 20px; cursor: pointer; text-align: center;">
                <div style="font-size: 10px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 4px;">HỦY</div>
                <div id="stat-huy" style="font-size: 22px; font-weight: 1000; color: #b91c1c;">0</div>
            </div>
        </div>

        @* --- TABLE AREA --- *@
        <div style="background: white; border-radius: 28px; border: 1px solid rgba(226, 232, 240, 0.8); overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.03);">
            <table id="dataTable" style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #f1f5f9;">
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase;">Nhân viên</th>
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase;">Dịch vụ SHD</th>
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase;">Người hỗ trợ</th>
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; width: 180px;">Tiến độ</th>
                        <th style="padding: 20px 25px; text-align: center; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase;">Trạng thái</th>
                        <th style="padding: 20px 25px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr>
                        <td colspan="6" style="padding: 80px; text-align: center; color: #94a3b8; border: none;">
                            <i class="fa fa-circle-notch fa-spin" style="font-size: 40px; color: @indigoPrimary;"></i>
                            <p style="font-weight: 700; margin-top: 15px;">Đang đồng bộ dữ liệu SHD...</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @* --- PHẦN PHÂN TRANG --- *@
        <div class="pagination-mobile" style="display: flex; justify-content: space-between; align-items: center; padding: 25px 0;">
            <div id="paginationButtons" style="display: flex; gap: 10px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 14px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: @indigoPrimary; font-weight: 900;">1</span> / <span id="totalPagesNum">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; text-transform: uppercase; margin-top: 6px;">
                    Hiển thị <span id="totalVisibleCount">0</span> / <span id="stat-total-inner">0</span> hồ sơ
                </div>
            </div>
        </div>
    </div>
</div>

@* --- MODAL FILTER SHD --- *@
<div id="modalOverlay" class="modal-overlay" onclick="closeTypeFilterModal()"></div>
<div id="typeFilterModal" class="type-filter-modal">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 20px;">
        <h3 style="margin: 0; color: #0f172a; font-size: 20px; font-weight: 900; display: flex; align-items: center; gap: 12px;">
            <i class="fa fa-layer-group" style="color: @indigoPrimary;"></i> DANH MỤC SHD
        </h3>
        <button onclick="closeTypeFilterModal()" style="background: #f1f5f9; border: none; width: 36px; height: 36px; border-radius: 50%; cursor: pointer;">&times;</button>
    </div>

    <div class="type-checkbox-grid">
        <label class="type-item-label">
            <input type="checkbox" class="type-checkbox" value="SHD_XeCongTac_1" onchange="updateToggleBtnText()">
            <span><i class="fa fa-car"></i> Đăng ký xe công tác SHD</span>
        </label>
    </div>

    <div style="display: flex; justify-content: space-between; gap: 12px; margin-top: 10px;">
        <button id="btnToggleSelectAll" type="button" onclick="toggleSelectAll()" style="padding: 14px; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 16px; font-weight: 800; flex: 1;">Chọn tất cả</button>
        <button onclick="saveAndApplyTypeFilters()" style="padding: 14px; background: @indigoPrimary; color: white; border: none; border-radius: 16px; font-weight: 800; flex: 2; box-shadow: 0 8px 15px rgba(49, 46, 129, 0.2);">Áp dụng</button>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];
        let filteredData = [];
        let currentPage = 1;
        let rowsPerPage = 20;
        const STORAGE_KEY = 'ShdArchiveSelectedTypes';
        let currentActiveStatusFilter = "";

        document.addEventListener("DOMContentLoaded", async () => {
            const savedText = sessionStorage.getItem("savedShdKhoText");
            if (savedText) document.getElementById("searchInput").value = savedText;

            const savedFrom = sessionStorage.getItem("savedFromDateShdKho");
            if (savedFrom) document.getElementById("txtFromDate").value = savedFrom;

            const savedTo = sessionStorage.getItem("savedToDateShdKho");
            if (savedTo) document.getElementById("txtToDate").value = savedTo;

            const savedStatus = sessionStorage.getItem("savedShdKhoStatus");
            if (savedStatus !== null) {
                currentActiveStatusFilter = savedStatus;
            }

            // Lắng nghe sự kiện thay đổi trạng thái Checkbox của Menu lơ lửng nâng cao mới
            $(document).on('change', '.dropdown-combo-menu input[type="checkbox"]', function () {
                const $menu = $(this).closest('.dropdown-combo-menu');
                updateDropdownButtonLabel($menu);
                applyAllFilters();
            });

            try {
                const response = await fetch('/FormSHD/GetHoanTatDonData');
                masterData = await response.json();

                populateDropdowns(masterData);

                // --- PHỤC HỒI CACHE TRẠNG THÁI TÍCH CHỌN MULTI-SELECT ---
                const savedBoPhanStr = sessionStorage.getItem("savedBoPhanShdKho");
                if (savedBoPhanStr) {
                    try {
                        let arrDept = JSON.parse(savedBoPhanStr) || [];
                        if (!Array.isArray(arrDept) && savedBoPhanStr) arrDept = [savedBoPhanStr];
                        arrDept.forEach(d => { $(`.chk-dept[value="${d}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuBoPhan'));
                    } catch(e){}
                }

                const savedStaffStr = sessionStorage.getItem("savedStaffShdKho");
                if (savedStaffStr) {
                    try {
                        let arrStaff = JSON.parse(savedStaffStr) || [];
                        if (!Array.isArray(arrStaff) && savedStaffStr) arrStaff = [savedStaffStr];
                        arrStaff.forEach(s => { $(`.chk-staff[value="${s}"]`).prop('checked', true); });
                        updateDropdownButtonLabel($('#menuStaff'));
                    } catch(e){}
                }

                updateStatistics(masterData);
                updateVisualStatusCard(currentActiveStatusFilter);
                loadSavedTypeFilters();
            } catch (error) {
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" class="shd-empty-cell" style="color: #ef4444 !important;">Lỗi tải dữ liệu SHD. Vui lòng F5.</td></tr>`;
            }
        });

        function populateDropdowns(data) {
            const menuBoPhan = document.getElementById("menuBoPhan");
            const menuStaff = document.getElementById("menuStaff");

            const depts = [...new Set(data.map(x => x.boPhan).filter(Boolean))].sort();
            menuBoPhan.innerHTML = '';
            depts.forEach(d => {
                menuBoPhan.insertAdjacentHTML('beforeend', `
                    <label class="dropdown-combo-item">
                        <input type="checkbox" class="chk-dept" value="${d}">
                        <span>${d}</span>
                    </label>
                `);
            });

            const staffSet = [...new Set(data.map(x => x.supportName).filter(n => n && n !== "Chưa chỉ định" && n !== "Chưa gán"))].sort();
            menuStaff.innerHTML = '';
            staffSet.forEach(s => {
                menuStaff.insertAdjacentHTML('beforeend', `
                    <label class="dropdown-combo-item">
                        <input type="checkbox" class="chk-staff" value="${s}">
                        <span>${s}</span>
                    </label>
                `);
            });
        }

        function updateDropdownButtonLabel($menu) {
            let totalChecked = $menu.find('input[type="checkbox"]:checked').length;
            let $btn = $menu.siblings('.dropdown-combo-btn');

            if (totalChecked === 0) {
                $btn.text('-- Tất cả --');
            } else if (totalChecked === 1) {
                $btn.text($menu.find('input[type="checkbox"]:checked').first().val());
            } else {
                $btn.text(`Đã chọn (${totalChecked})`);
            }
        }

        function updateStatistics(data) {
            const getCnt = (tag) => data.filter(x => x.statusTag === tag).length;
            document.getElementById("stat-total").innerText = data.length;
            document.getElementById("stat-total-inner").innerText = data.length;
            document.getElementById("stat-ql").innerText = getCnt("CHỜ QL");
            document.getElementById("stat-b2").innerText = getCnt("BƯỚC 2");
            document.getElementById("stat-gd").innerText = getCnt("GIÁM ĐỐC");
            document.getElementById("stat-shd").innerText = getCnt("CHỜ SHD");
            document.getElementById("stat-hoanTat").innerText = getCnt("HOÀN TẤT");
            document.getElementById("stat-huy").innerText = getCnt("ĐÃ HỦY");
        }

        function openTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'block';
            document.getElementById('typeFilterModal').style.display = 'block';
        }

        function closeTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'none';
            document.getElementById('typeFilterModal').style.display = 'none';
        }

        // ====================================================
        // ĐỒNG BỘ LOGIC: XỬ LÝ HỆ THỐNG PHÂN LOẠI ĐƠN SHD THEO MẢNG
        // ====================================================
        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !isAllChecked);
            updateToggleBtnText();
        }

        function updateToggleBtnText() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            const btn = document.getElementById("btnToggleSelectAll");
            if (btn) btn.innerText = isAllChecked ? "Bỏ chọn tất cả" : "Chọn tất cả";
        }

        function loadSavedTypeFilters() {
            let saved = localStorage.getItem(STORAGE_KEY);
            let checkboxes = document.querySelectorAll('.type-checkbox');
            if (saved) {
                let selectedArray = JSON.parse(saved);
                checkboxes.forEach(cb => cb.checked = selectedArray.includes(cb.value));
            } else {
                checkboxes.forEach(cb => cb.checked = true);
            }
            updateToggleBtnText();
            applyAllFilters();
        }

        function saveAndApplyTypeFilters() {
            let selectedArray = [];
            document.querySelectorAll('.type-checkbox:checked').forEach(cb => selectedArray.push(cb.value));
            localStorage.setItem(STORAGE_KEY, JSON.stringify(selectedArray));
            closeTypeFilterModal();
            applyAllFilters();
        }

        function updateVisualStatusCard(status) {
            document.querySelectorAll('.stat-card').forEach(el => {
                el.style.border = "2px solid rgba(0,0,0,0.03)";
                el.style.boxShadow = "none";
            });

            if(status) {
                const targetCard = document.querySelector(`.stat-card[data-status="${status}"]`);
                if (targetCard) {
                    targetCard.style.border = "2px solid #312e81";
                    targetCard.style.boxShadow = "0 0 0 3px rgba(49, 46, 129, 0.2)";
                }
            }
        }

        function filterByStatus(s) {
            if(currentActiveStatusFilter === s) {
                currentActiveStatusFilter = "";
            } else {
                currentActiveStatusFilter = s;
            }

            sessionStorage.setItem("savedShdKhoStatus", currentActiveStatusFilter);
            updateVisualStatusCard(currentActiveStatusFilter);

            applyAllFilters();

            let table = document.getElementById("tableBody");
            table.style.opacity = "0.4";
            setTimeout(() => { table.style.opacity = "1"; }, 150);
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            applyAllFilters();
        }

        function clearAllFilters() {
            document.getElementById("searchInput").value = "";
            document.getElementById("txtFromDate").value = "";
            document.getElementById("txtToDate").value = "";

            $('.dropdown-combo-menu input[type="checkbox"]').prop('checked', false);
            $('.dropdown-combo-menu').each(function() { updateDropdownButtonLabel($(this)); });

            sessionStorage.removeItem("savedShdKhoText");
            sessionStorage.removeItem("savedFromDateShdKho");
            sessionStorage.removeItem("savedToDateShdKho");
            sessionStorage.removeItem("savedBoPhanShdKho");
            sessionStorage.removeItem("savedStaffShdKho");
            sessionStorage.removeItem("savedShdKhoStatus");

            currentActiveStatusFilter = "";
            updateVisualStatusCard("");

            applyAllFilters();
        }

        // ====================================================
        // HÀM LỌC TỔNG HỢP MỚI (HỖ TRỢ MẢNG MULTI-CHECKBOX ARRAY INCLUDES)
        // ====================================================
        function applyAllFilters() {
            const searchText = document.getElementById("searchInput").value.toUpperCase().trim();
            const fromDateStr = document.getElementById("txtFromDate").value;
            const toDateStr = document.getElementById("txtToDate").value;

            const selectedDepts = $('.chk-dept:checked').map(function() { return $(this).val(); }).get();
            const selectedStaffs = $('.chk-staff:checked').map(function() { return $(this).val(); }).get();

            sessionStorage.setItem("savedShdKhoText", document.getElementById("searchInput").value);
            sessionStorage.setItem("savedFromDateShdKho", fromDateStr);
            sessionStorage.setItem("savedToDateShdKho", toDateStr);
            sessionStorage.setItem("savedBoPhanShdKho", JSON.stringify(selectedDepts));
            sessionStorage.setItem("savedStaffShdKho", JSON.stringify(selectedStaffs));

            const savedTypesStr = localStorage.getItem(STORAGE_KEY);
            const allowedTypes = savedTypesStr ? JSON.parse(savedTypesStr) : [];
            const totalCheckboxes = document.querySelectorAll('.type-checkbox').length;
            const isAllChecked = (allowedTypes.length === totalCheckboxes || allowedTypes.length === 0);

            filteredData = masterData.filter(item => {
                // 1. Lọc Modal (Phân loại đơn)
                if (!isAllChecked && item.idForm && !allowedTypes.includes(item.idForm.toString().trim())) return false;

                // 2. Thẻ Trạng Thái độc lập
                if (currentActiveStatusFilter && item.statusTag !== currentActiveStatusFilter) return false;

                // 3. Lọc mảng nhiều Bộ phận
                if (selectedDepts.length > 0 && !selectedDepts.includes(item.boPhan)) return false;

                // 4. Lọc mảng nhiều Người hỗ trợ
                if (selectedStaffs.length > 0 && !selectedStaffs.includes(item.supportName)) return false;

                // 5. Ngày tháng (timeNguoiTao format: dd/MM/yyyy)
                if (fromDateStr || toDateStr) {
                    if (!item.timeNguoiTao || item.timeNguoiTao === "--") return false;
                    const parts = item.timeNguoiTao.split('/');
                    if (parts.length === 3) {
                        const itemDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}T00:00:00`);
                        if (fromDateStr) {
                            const fromD = new Date(fromDateStr + "T00:00:00");
                            if (itemDate < fromD) return false;
                        }
                        if (toDateStr) {
                            const toD = new Date(toDateStr + "T23:59:59");
                            if (itemDate > toD) return false;
                        }
                    }
                }

                // 6. Text tìm kiếm nhanh tự do
                if (searchText) {
                    const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${item.supportName || ''} ${item.statusTag}`.toUpperCase();
                    if (!rowString.includes(searchText)) return false;
                }

                return true;
            });

            currentPage = 1;
            renderCurrentPage();
        }

        function renderCurrentPage() {
            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;

            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;

            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const pageData = filteredData.slice(startIndex, endIndex);

            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            if (pageData.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="shd-empty-cell">
                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
                                <i class="fa fa-folder-open-o" style="font-size: 40px; margin-bottom: 10px; opacity: 0.5; color: #64748b;"></i>
                                <span style="font-weight: 600; font-size: 14px; white-space: normal; text-align: center; color: #64748b;">
                                    Không tìm thấy dữ liệu yêu cầu phù hợp với bộ lọc.
                                </span>
                            </div>
                        </td>
                    </tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>#${item.id} • ${item.timeNguoiTao}</span>`;
                if (item.hasB2) badgesHtml += `<span class="sub-badge" style="color: #0369a1; border-color: #bae6fd; background: #f0f9ff; margin-left:5px;">BP.XN OK</span>`;
                if (item.hasGD) badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:5px;">GĐ OK</span>`;

                let supportHtml = item.supportName
                    ? `<div style="display: flex; align-items: center; gap: 6px;"><div class="support-avatar"><i class="fa fa-user-circle-o"></i></div><span style="font-weight: 700; color: #334155; font-size: 12px;">${item.supportName}</span></div>`
                    : `<span style="color: #cbd5e1; font-size: 11px; font-style: italic;">Chưa gán</span>`;

                const isCancelled = item.statusTag === "ĐÃ HỦY";
                let btnText = (item.idNguoiDuyet == null && !isCancelled) ? "Xử lý" : "Xem lại";
                let btnBg = (item.idNguoiDuyet != null || isCancelled) ? "#f1f5f9" : "@indigoPrimary";
                let btnColor = (item.idNguoiDuyet != null || isCancelled) ? "#64748b" : "#ffffff";

                html += `
                    <tr class="d-block d-md-table-row bg-white border border-md-0 rounded-4 rounded-md-0 mb-3 mb-md-0 p-3 p-md-0 shadow-sm shadow-md-none position-relative">
                        <td data-label="Nhân viên" style="padding: 15px 20px;">
                            <div class="mobile-val-wrap">
                                <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                                <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: @indigoPrimary;">MS: ${item.soNhanVien}</span></div>
                            </div>
                        </td>
                        <td data-label="Dịch vụ SHD" style="padding: 15px 20px;">
                            <div class="mobile-val-wrap">
                                <div style="font-weight: 800; color: #1e293b; font-size: 14px;">${item.tenForm}</div>
                                <div style="font-size: 10px; color: #94a3b8; font-weight: 700; display: flex; align-items: center; gap: 2px; margin-top: 4px; justify-content: flex-end; flex-wrap: wrap;">${badgesHtml}</div>
                            </div>
                        </td>
                        <td data-label="Người hỗ trợ" style="padding: 15px 20px;"><div class="mobile-val-wrap">${supportHtml}</div></td>
                        <td data-label="Tiến trình" style="padding: 15px 20px;">
                            <div class="mobile-val-wrap" style="width: 100%; max-width: 150px; margin-left: auto;">
                                <div style="font-size: 9px; font-weight: 1000; color: ${item.pColor}; margin-bottom: 4px; display: flex; justify-content: space-between; width: 100%;">
                                    <span>${item.pText}</span> <span>${item.pWidth}</span>
                                </div>
                                <div style="width: 100%; height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden;">
                                    <div style="width: ${item.pWidth}; height: 100%; background: ${item.pColor}; border-radius: 10px; transition: 0.5s ease;"></div>
                                </div>
                            </div>
                        </td>
                        <td data-label="Trạng thái" style="padding: 15px 20px; text-align: center;">
                            <div class="mobile-val-wrap">
                                <span style="background:${item.bg}; color:${item.fg}; padding: 6px 12px; border-radius: 8px; font-size: 9px; font-weight: 1000; border: 1.5px solid ${item.fg}; min-width: 95px; text-transform: uppercase; display: inline-block; text-align: center;">
                                    ${item.statusTag}
                                </span>
                            </div>
                        </td>
                        <td style="padding: 15px 20px; text-align: right;">
                            <a href="/FormSHD/ChiTiet/${item.id}" style="text-decoration: none; padding: 10px 16px; border-radius: 10px; font-size: 11px; font-weight: 1000; display: inline-block; transition: 0.2s; background: ${btnBg}; color: ${btnColor}; width: 100%; text-align: center; box-sizing: border-box;">
                                Chi tiết <i class="fa fa-arrow-right" style="margin-left: 5px;"></i>
                            </a>
                        </td>
                    </tr>`;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = ""; if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && (i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1)) {
                    if (i === 3 || i === totalPages - 2) {
                        const dot = document.createElement("span");
                        dot.innerText = "..."; dot.style.padding = "8px"; dot.style.color = "#64748b"; dot.style.fontWeight = "700";
                        container.appendChild(dot);
                    }
                    continue;
                }

                const btn = document.createElement("button");
                btn.innerText = i; btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    renderCurrentPage();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}