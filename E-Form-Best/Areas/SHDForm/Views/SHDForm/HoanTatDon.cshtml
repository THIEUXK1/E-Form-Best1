@using System.Security.Claims

@{
    ViewData["Title"] = "Kho Lưu Trữ Đơn SHD";
    Layout = "~/Areas/SHDForm/Views/Shared/_Layout.cshtml";

    var currentUserRole = User.FindFirst(ClaimTypes.Role)?.Value
                        ?? User.FindFirst("UserRole")?.Value ?? "User";
}

<style>
    /* Badge phong cách Glassmorphism */
    .sub-badge {
        font-size: 9px; padding: 2px 8px; border-radius: 6px; font-weight: 800;
        display: inline-flex; align-items: center; gap: 4px; border: 1.5px solid; margin-top: 3px;
    }
    .support-avatar {
        width: 28px; height: 28px; background: #ecfeff; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: #0891b2; border: 1px solid #cffafe;
    }
    .stat-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(226, 232, 240, 0.8);
    }
    .stat-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05), 0 10px 10px -5px rgba(0,0,0,0.04) !important;
        border-color: #3b82f6;
    }

    /* Modal hiệu ứng hiện đại */
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.4); z-index: 9998; backdrop-filter: blur(8px); transition: 0.3s; }
    .type-filter-modal { 
        display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); 
        background: white; width: 480px; max-width: 95%; border-radius: 24px; 
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3); z-index: 9999; padding: 30px; overflow: hidden;
    }
    .type-checkbox-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 20px; margin-bottom: 25px; max-height: 400px; overflow-y: auto; padding-right: 8px; }
    .type-item-label { 
        display: flex; align-items: center; gap: 12px; padding: 14px 18px; 
        background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; 
        cursor: pointer; transition: 0.2s; font-size: 14px; font-weight: 700; color: #334155; 
    }
    .type-item-label:hover { background: #f1f5f9; border-color: #3b82f6; color: #1e40af; }
    .type-checkbox { width: 20px; height: 20px; accent-color: #1e40af; cursor: pointer; }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #f1f5f9; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

    /* Phân trang */
    .page-btn {
        padding: 10px 18px; border-radius: 12px; border: 1.5px solid #e2e8f0; background: white; color: #64748b; font-weight: 800; font-size: 13px; cursor: pointer; transition: 0.3s;
    }
    .page-btn.active {
        background: #1e40af; color: white; border-color: #1e40af; box-shadow: 0 10px 15px -3px rgba(30, 64, 175, 0.3);
    }
</style>

<div style="background: #f8fafc; min-height: 100vh; padding: 30px; font-family: 'Plus Jakarta Sans', sans-serif; color: #1e293b;">
    <div style="max-width: 1600px; margin: 0 auto;">

        @* --- TOP HEADER --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px;">
            <div>
                <h2 style="margin: 0; color: #1e40af; font-weight: 1000; font-size: 28px; display: flex; align-items: center; gap: 15px; letter-spacing: -0.5px;">
                    <span style="background: linear-gradient(135deg, #1e40af, #3b82f6); color: white; width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(30, 64, 175, 0.2);">
                        <i class="fa fa-ship"></i>
                    </span>
                    KHO LƯU TRỮ ĐƠN SHD
                </h2>
                <p style="margin: 5px 0 0 63px; color: #64748b; font-weight: 600; font-size: 14px;">Quản lý hồ sơ Xuất Nhập Khẩu kỹ thuật số</p>
            </div>

            <div style="display: flex; gap: 15px; align-items: center;">
                <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 18px; border-radius: 16px; border: 1.5px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
                    <span style="font-size: 12px; font-weight: 800; color: #94a3b8; text-transform: uppercase;">Dòng:</span>
                    <select id="pageSizeSelect" onchange="changePageSize()" style="border: none; outline: none; font-weight: 800; color: #1e40af; cursor: pointer; background: transparent; font-size: 15px;">
                        <option value="10">10</option>
                        <option value="20" selected>20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>

                <div style="position: relative;">
                    <i class="fa fa-search" style="position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 15px;"></i>
                    <input type="text" id="searchInput" onkeyup="applyAllFilters()" placeholder="Tìm tên, mã thẻ, bộ phận..."
                           style="padding: 12px 20px 12px 48px; border-radius: 16px; border: 1.5px solid #e2e8f0; font-size: 14px; width: 320px; outline: none; font-weight: 700; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);"
                           onfocus="this.style.borderColor='#3b82f6'; this.style.boxShadow='0 0 0 4px rgba(59, 130, 246, 0.1)'"
                           onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'">
                </div>
                
                <button onclick="openTypeFilterModal()" style="padding: 12px 20px; background: white; border: 1.5px solid #e2e8f0; border-radius: 16px; color: #475569; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);" onmouseover="this.style.borderColor='#3b82f6'; this.style.color='#1e40af'" onmouseout="this.style.borderColor='#e2e8f0'; this.style.color='#475569'">
                    <i class="fa fa-filter"></i> Phân loại đơn
                </button>

                <div style="font-size: 12px; background: linear-gradient(135deg, #0891b2, #06b6d4); padding: 10px 18px; border-radius: 12px; font-weight: 900; color: #ffffff; text-transform: uppercase; box-shadow: 0 4px 12px rgba(8, 145, 178, 0.2);">
                    @currentUserRole
                </div>
            </div>
        </div>

        @* --- STATS GRID --- *@
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 35px;">
            <div onclick="filterByStatus('')" class="stat-card" style="background: white; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #64748b; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">TỔNG LƯU TRỮ</div>
                <div id="stat-total" style="font-size: 30px; font-weight: 1000; color: #1e293b;">0</div>
            </div>
            <div onclick="filterByStatus('CHỜ QL')" class="stat-card" style="background: #fffbeb; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #b45309; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">CHỜ QL DUYỆT</div>
                <div id="stat-ql" style="font-size: 30px; font-weight: 1000; color: #b45309;">0</div>
            </div>
            <div onclick="filterByStatus('BƯỚC 2')" class="stat-card" style="background: #f5f3ff; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #6b21a8; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">BP XÁC NHẬN</div>
                <div id="stat-b2" style="font-size: 30px; font-weight: 1000; color: #6b21a8;">0</div>
            </div>
            <div onclick="filterByStatus('GIÁM ĐỐC')" class="stat-card" style="background: #fdf4ff; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #86198f; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">GIÁM ĐỐC</div>
                <div id="stat-gd" style="font-size: 30px; font-weight: 1000; color: #86198f;">0</div>
            </div>
            <div onclick="filterByStatus('CHỜ SHD')" class="stat-card" style="background: #f0f9ff; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #0369a1; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">CHỜ SHD XỬ LÝ</div>
                <div id="stat-shd" style="font-size: 30px; font-weight: 1000; color: #0369a1;">0</div>
            </div>
            <div onclick="filterByStatus('HOÀN TẤT')" class="stat-card" style="background: #f0fdf4; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #15803d; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">ĐÃ HOÀN TẤT</div>
                <div id="stat-hoanTat" style="font-size: 30px; font-weight: 1000; color: #15803d;">0</div>
            </div>
            <div onclick="filterByStatus('ĐÃ HỦY')" class="stat-card" style="background: #fef2f2; padding: 22px; border-radius: 24px; cursor: pointer; text-align: center;">
                <div style="font-size: 11px; font-weight: 900; color: #b91c1c; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 1px;">ĐƠN ĐÃ HỦY</div>
                <div id="stat-huy" style="font-size: 30px; font-weight: 1000; color: #b91c1c;">0</div>
            </div>
        </div>

        @* --- DATA TABLE --- *@
        <div style="background: white; border-radius: 28px; border: 1px solid rgba(226, 232, 240, 0.8); overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.03);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8fafc; border-bottom: 2px solid #f1f5f9;">
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Thông tin nhân viên</th>
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Dịch vụ SHD</th>
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Người hỗ trợ</th>
                        <th style="padding: 20px 25px; text-align: left; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; width: 180px;">Tiến độ duyệt</th>
                        <th style="padding: 20px 25px; text-align: center; color: #64748b; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">Trạng thái</th>
                        <th style="padding: 20px 25px; text-align: right;"></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr>
                        <td colspan="6" style="padding: 80px; text-align: center; color: #94a3b8;">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 15px;">
                                <i class="fa fa-circle-notch fa-spin" style="font-size: 40px; color: #3b82f6;"></i>
                                <p style="font-weight: 700; font-size: 16px;">Đang đồng bộ dữ liệu từ kho SHD...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @* --- FOOTER / PAGINATION --- *@
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 25px 0; margin-top: 10px;">
            <div id="paginationButtons" style="display: flex; gap: 10px; flex-wrap: wrap;"></div>
            <div style="text-align: right;">
                <div style="color: #64748b; font-size: 14px; font-weight: 700;">
                    Trang <span id="currentPageNum" style="color: #1e40af; font-weight: 900;">1</span> / <span id="totalPagesNum" style="font-weight: 900;">1</span>
                </div>
                <div style="color: #94a3b8; font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-top: 6px;">
                    Hiển thị <span id="totalVisibleCount" style="color: #1e293b;">0</span> / <span id="stat-total-inner">0</span> hồ sơ
                </div>
            </div>
        </div>
    </div>
</div>

@* --- MODAL FILTER SHD --- *@
<div id="modalOverlay" class="modal-overlay" onclick="closeTypeFilterModal()"></div>
<div id="typeFilterModal" class="type-filter-modal">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 20px;">
        <h3 style="margin: 0; color: #0f172a; font-size: 20px; font-weight: 900; display: flex; align-items: center; gap: 12px;">
            <i class="fa fa-layer-group" style="color: #1e40af;"></i> DANH MỤC PHIẾU SHD
        </h3>
        <button onclick="closeTypeFilterModal()" style="background: #f1f5f9; border: none; width: 36px; height: 36px; border-radius: 50%; font-size: 18px; color: #64748b; cursor: pointer; display: flex; align-items: center; justify-content: center;">&times;</button>
    </div>
    
    <div class="type-checkbox-grid">
        <label class="type-item-label">
            <input type="checkbox" class="type-checkbox" value="SHD_XeCongTac_1" onchange="updateToggleBtnText()"> 
            <span><i class="fa fa-car" style="width: 20px;"></i> Đăng ký xe công tác SHD</span>
        </label>
    </div>

    <div style="display: flex; justify-content: space-between; gap: 12px; margin-top: 10px;">
        <button id="btnToggleSelectAll" type="button" onclick="toggleSelectAll()" style="padding: 14px; background: #f8fafc; color: #475569; border: 1.5px solid #e2e8f0; border-radius: 16px; font-weight: 800; cursor: pointer; flex: 1; transition: 0.2s;">Chọn tất cả</button>
        <button onclick="saveAndApplyTypeFilters()" style="padding: 14px; background: linear-gradient(135deg, #1e40af, #3b82f6); color: white; border: none; border-radius: 16px; font-weight: 800; cursor: pointer; flex: 2; transition: 0.2s; box-shadow: 0 8px 15px rgba(30, 64, 175, 0.2);">
            <i class="fa fa-check-circle"></i> Áp dụng bộ lọc
        </button>
    </div>
</div>

@section Scripts {
    <script>
        let masterData = [];     
        let filteredData = [];   
        let currentPage = 1;
        let rowsPerPage = 20;
        const STORAGE_KEY = 'ShdSelectedFormTypes';

        document.addEventListener("DOMContentLoaded", async () => {
            await loadData();
        });

        async function loadData() {
            try {
                const response = await fetch('/FormSHD/GetHoanTatDonData');
                if (!response.ok) throw new Error("Network response was not ok");
                
                masterData = await response.json();
                console.log("Dữ liệu gốc từ Server:", masterData);
                
                updateStatistics(masterData);
                loadSavedTypeFilters(); 
            } catch (error) {
                console.error("Lỗi:", error);
                document.getElementById('tableBody').innerHTML = `<tr><td colspan="6" style="padding: 80px; text-align: center;"><div style="color: #ef4444; font-weight: 800;"><i class="fa fa-exclamation-triangle" style="font-size: 32px; margin-bottom: 15px;"></i><br>Không thể kết nối máy chủ SHD.</div></td></tr>`;
            }
        }

        function updateStatistics(data) {
            document.getElementById("stat-total").innerText = data.length;
            document.getElementById("stat-total-inner").innerText = data.length;
            document.getElementById("stat-ql").innerText = data.filter(x => x.statusTag === "CHỜ QL").length;
            document.getElementById("stat-b2").innerText = data.filter(x => x.statusTag === "BƯỚC 2").length;
            document.getElementById("stat-gd").innerText = data.filter(x => x.statusTag === "GIÁM ĐỐC").length;
            document.getElementById("stat-shd").innerText = data.filter(x => x.statusTag === "CHỜ SHD").length;
            document.getElementById("stat-hoanTat").innerText = data.filter(x => x.statusTag === "HOÀN TẤT").length;
            document.getElementById("stat-huy").innerText = data.filter(x => x.statusTag === "ĐÃ HỦY").length;
        }

        function openTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'block';
            document.getElementById('typeFilterModal').style.display = 'block';
        }

        function closeTypeFilterModal() {
            document.getElementById('modalOverlay').style.display = 'none';
            document.getElementById('typeFilterModal').style.display = 'none';
        }

        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !isAllChecked);
            updateToggleBtnText();
        }

        function updateToggleBtnText() {
            const checkboxes = document.querySelectorAll('.type-checkbox');
            const isAllChecked = Array.from(checkboxes).every(cb => cb.checked);
            const btn = document.getElementById("btnToggleSelectAll");
            if (btn) btn.innerText = isAllChecked ? "Bỏ chọn tất cả" : "Chọn tất cả";
        }

        function loadSavedTypeFilters() {
            let saved = localStorage.getItem(STORAGE_KEY);
            let checkboxes = document.querySelectorAll('.type-checkbox');
            
            if (saved) {
                let selectedArray = JSON.parse(saved);
                checkboxes.forEach(cb => cb.checked = selectedArray.includes(cb.value));
            } else {
                // Mặc định chọn tất cả
                checkboxes.forEach(cb => cb.checked = true);
            }
            updateToggleBtnText();
            applyAllFilters();
        }

        function saveAndApplyTypeFilters() {
            let selectedArray = [];
            document.querySelectorAll('.type-checkbox:checked').forEach(cb => selectedArray.push(cb.value));
            localStorage.setItem(STORAGE_KEY, JSON.stringify(selectedArray));
            closeTypeFilterModal();
            applyAllFilters();
        }

        function filterByStatus(s) {
            document.getElementById("searchInput").value = s;
            applyAllFilters();
            window.scrollTo({ top: 200, behavior: 'smooth' });
        }

        function changePageSize() {
            rowsPerPage = parseInt(document.getElementById("pageSizeSelect").value);
            applyAllFilters();
        }

        // ==========================================
        // LOGIC LỌC ĐÃ ĐƯỢC SỬA LỖI (FIXED)
        // ==========================================
        function applyAllFilters() {
            const searchText = document.getElementById("searchInput").value.toUpperCase().trim();
            const savedTypesStr = localStorage.getItem(STORAGE_KEY);
            const allowedTypes = savedTypesStr ? JSON.parse(savedTypesStr) : [];
            
            const totalCheckboxes = document.querySelectorAll('.type-checkbox').length;
            const selectedCount = allowedTypes.length;

            // FIX: Chỉ khi TẤT CẢ các ô được tích thì mới coi là ShowAll. 
            // Nếu có ít nhất 1 ô bị bỏ tích, ta sẽ thực hiện lọc nghiêm ngặt theo mảng allowedTypes.
            const isAllChecked = (selectedCount === totalCheckboxes);

            filteredData = masterData.filter(item => {
                // 1. Lọc theo Search (Tên, Mã thẻ, Bộ phận...)
                const rowString = `${item.tenNguoiNv} ${item.boPhan} ${item.soNhanVien} ${item.tenForm} ${item.id} ${item.supportName || ''} ${item.statusTag}`.toUpperCase();
                const matchText = searchText === "" || rowString.includes(searchText);

                // 2. Lọc theo Phân loại đơn (ID Form)
                let matchType = true;
                if (!isAllChecked) {
                    // Nếu dữ liệu có idForm, ta tiến hành so sánh nghiêm ngặt
                    if (item.idForm) {
                        const currentId = item.idForm.toString().trim();
                        matchType = allowedTypes.includes(currentId);
                    } else {
                        // Nếu item không có idForm (trường hợp DB trả về null), mặc định hiện để tránh mất đơn
                        matchType = true; 
                    }
                }

                return matchText && matchType;
            });

            console.log("Số lượng đơn sau khi lọc:", filteredData.length);
            currentPage = 1; 
            renderCurrentPage();
        }

        function renderCurrentPage() {
            const totalItems = filteredData.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage) || 1;
            document.getElementById("totalVisibleCount").innerText = totalItems;
            document.getElementById("currentPageNum").innerText = currentPage;
            document.getElementById("totalPagesNum").innerText = totalPages;
            const startIndex = (currentPage - 1) * rowsPerPage;
            const pageData = filteredData.slice(startIndex, startIndex + rowsPerPage);
            renderTable(pageData);
            renderPaginationButtons(totalPages);
        }

        function renderTable(pageData) {
            const tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";
            if (pageData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" style="padding: 100px; text-align: center; color: #94a3b8;"><i class="fa fa-inbox" style="font-size: 50px; opacity: 0.2; margin-bottom: 15px;"></i><p style="font-weight: 700;">Không tìm thấy kết quả nào. Hãy kiểm tra lại từ khóa hoặc danh mục được chọn.</p></td></tr>`;
                return;
            }

            let html = "";
            pageData.forEach(item => {
                let badgesHtml = `<span>#${item.id} • <i class="fa fa-calendar-check"></i> ${item.timeNguoiTao}</span>`;
                if (item.hasB2) badgesHtml += `<span class="sub-badge" style="color: #6b21a8; border-color: #ddd6fe; background: #f5f3ff; margin-left:8px;"><i class="fa fa-users"></i> B2(${item.b2DoneCount}/${item.b2TotalCount})</span>`;
                if (item.hasGD) badgesHtml += `<span class="sub-badge" style="color: #86198f; border-color: #f5d0fe; background: #fdf4ff; margin-left:8px;"><i class="fa fa-shield-halved"></i> GĐ(${item.gdDoneCount}/${item.gdTotalCount})</span>`;

                let supportHtml = item.supportName 
                    ? `<div style="display: flex; align-items: center; gap: 8px;"><div class="support-avatar"><i class="fa fa-user-tie"></i></div><span style="font-weight: 700; color: #334155; font-size: 13px;">${item.supportName}</span></div>` 
                    : `<span style="color: #cbd5e1; font-size: 11px; font-style: italic;">Chờ chỉ định</span>`;

                html += `
                    <tr style="border-bottom: 1px solid #f8fafc; transition: 0.3s;" onmouseover="this.style.background='#f0f9ff'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 15px 25px;">
                            <div style="font-weight: 1000; color: #0f172a; font-size: 14px;">${item.tenNguoiNv}</div>
                            <div style="font-size: 11px; color: #64748b; font-weight: 800;">${item.boPhan} • <span style="color: #1e40af;">MS: ${item.soNhanVien}</span></div>
                        </td>
                        <td style="padding: 15px 25px;">
                            <div style="font-weight: 800; color: #1e293b; font-size: 13px;">${item.tenForm}</div>
                            <div style="font-size: 10px; color: #94a3b8; font-weight: 700; display: flex; flex-wrap: wrap; align-items: center; margin-top:4px;">
                                ${badgesHtml}
                            </div>
                        </td>
                        <td style="padding: 15px 25px;">${supportHtml}</td>
                        <td style="padding: 15px 25px;">
                            <div style="font-size: 9px; font-weight: 1000; color: ${item.pColor}; margin-bottom: 4px; display: flex; justify-content: space-between;">
                                <span>${item.pText}</span> <span>${item.pWidth}</span>
                            </div>
                            <div style="width: 100%; height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden;">
                                <div style="width: ${item.pWidth}; height: 100%; background: ${item.pColor}; border-radius: 10px; transition: 0.8s ease;"></div>
                            </div>
                        </td>
                        <td style="padding: 15px 25px; text-align: center;">
                            <span style="background:${item.bg}; color:${item.fg}; padding: 3px 8px; border-radius: 6px; font-size: 9px; font-weight: 1000; border: 1.5px solid ${item.fg}; display: inline-block; min-width: 80px; text-transform: uppercase; letter-spacing: 0.3px; white-space: nowrap;">
                                ${item.statusTag}
                            </span>
                        </td>
                        <td style="padding: 15px 25px; text-align: right;">
                            <a href="/FormSHD/ChiTiet/${item.id}" style="text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 11px; font-weight: 900; background: linear-gradient(135deg, #1e40af, #3b82f6); color: white; display: inline-flex; align-items: center; gap: 6px; transition: 0.3s; box-shadow: 0 4px 10px rgba(30, 64, 175, 0.12);">
                                XEM <i class="fa fa-chevron-right" style="font-size: 9px;"></i>
                            </a>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderPaginationButtons(totalPages) {
            const container = document.getElementById("paginationButtons");
            container.innerHTML = "";
            if (totalPages <= 1) return;
            const maxVisible = 5;
            let start = Math.max(1, currentPage - 2);
            let end = Math.min(totalPages, start + maxVisible - 1);
            if (end - start < maxVisible - 1) start = Math.max(1, end - maxVisible + 1);
            for (let i = start; i <= end; i++) {
                const btn = document.createElement("button");
                btn.innerText = i;
                btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                btn.onclick = () => {
                    currentPage = i;
                    renderCurrentPage();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
                container.appendChild(btn);
            }
        }
    </script>
}